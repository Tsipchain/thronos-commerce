<!DOCTYPE html>
<html lang="<%= lang %>">
  <head>
    <meta charset="UTF-8" />
    <title><%= t('orders.headerTitle') %> – <%= config.storeName %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css" />
    <style>
      :root {
        --primary-color: <%= config.primaryColor %>;
        --accent-color: <%= config.accentColor %>;
        --font-family: <%= config.fontFamily %>;
      }
      .orders-table { width: 100%; border-collapse: collapse; font-size: 0.86rem; }
      .orders-table th, .orders-table td { text-align: left; padding: 9px 12px; border-bottom: 1px solid #e5e7eb; vertical-align: top; }
      .orders-table th { background: #f8fafc; font-weight: 600; white-space: nowrap; }
      .status-badge { display:inline-block; padding:2px 8px; border-radius:999px; font-size:.74rem; font-weight:700; }
      .payment-PENDING_COD{background:#fff7ed;color:#9a3412}.payment-PENDING_STRIPE{background:#eff6ff;color:#1d4ed8}.payment-PAID{background:#ecfdf5;color:#047857}.payment-CANCELLED{background:#fef2f2;color:#b91c1c}
      .fulfillment-cod_pending,.fulfillment-pending_payment,.fulfillment-ready_to_ship{background:#fff7ed;color:#9a3412}
      .fulfillment-shipped{background:#eff6ff;color:#1d4ed8}
      .fulfillment-delivered{background:#ecfdf5;color:#047857}
      .fulfillment-cancelled{background:#fef2f2;color:#b91c1c}
      details.order-row { border:1px solid #e5e7eb;border-radius:10px;background:#fff; margin-bottom:12px; }
      details.order-row summary { cursor:pointer; list-style:none; padding:12px 14px; display:flex; gap:10px; flex-wrap:wrap; align-items:center; }
      details.order-row summary::-webkit-details-marker { display:none; }
      .muted { color:#64748b; font-size:.82rem; }
      .needs-action { border-left:4px solid #f59e0b; }
      .order-form { display:grid; gap:8px; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); margin-top:10px; }
      .order-form input,.order-form select { width:100%; }
      .flash { padding:10px 12px;border-radius:8px;margin-bottom:12px;font-size:.9rem; }
      .flash.ok { background:#ecfdf5;border:1px solid #bbf7d0;color:#166534; }
      .flash.err { background:#fef2f2;border:1px solid #fecaca;color:#991b1b; }
      .kpi { display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px; }
      .kpi-card { background:#fff7ed;border:1px solid #fed7aa;border-radius:10px;padding:10px 14px; }
      .kpi-card strong { font-size:1.1rem; }
    </style>
  </head>
  <body>
    <header>
      <h1><%= t('orders.headerTitle') %></h1>
      <p class="subtitle">
        <%= t('orders.store') %>: <strong><%= tenant.id %></strong>
        &nbsp;·&nbsp;<%= t('orders.package') %>: <strong><%= tenant.supportTier %></strong>
        &nbsp;·&nbsp;<a href="<%= withTenantLink('/admin') %>" style="font-size:0.85rem"><%= t('orders.settingsLink') %></a>
      </p>
    </header>

    <main class="admin-layout">
      <% if (message) { %><div class="flash ok"><%= message %></div><% } %>
      <% if (error) { %><div class="flash err"><%= error %></div><% } %>

      <section class="admin-block">
        <div class="kpi">
          <div class="kpi-card">Unresolved orders: <strong><%= unresolvedCount || 0 %></strong></div>
          <div class="kpi-card">Latest listed: <strong><%= orders.length %></strong></div>
        </div>
        <p class="helper">Orders requiring action are highlighted until tracking/fulfillment is updated.</p>

        <% if (!orders.length) { %>
          <p class="muted">No orders yet.</p>
        <% } %>

        <% orders.forEach(function(order) { 
             const needsAction = !order.hasTracking || ['cod_pending','pending_payment','ready_to_ship'].includes(order.fulfillmentStatus);
        %>
          <details class="order-row <%= needsAction ? 'needs-action' : '' %>">
            <summary>
              <code><%= order.id %></code>
              <span><strong><%= order.customerName || '-' %></strong> · <%= Number(order.total || 0).toFixed(2) %> €</span>
              <span class="status-badge payment-<%= order.paymentStatus || 'PENDING_COD' %>"><%= order.paymentStatus || 'PENDING_COD' %></span>
              <span class="status-badge fulfillment-<%= order.fulfillmentStatus %>"><%= order.fulfillmentStatus %></span>
              <% if (needsAction) { %><span class="status-badge fulfillment-ready_to_ship">needs action</span><% } %>
            </summary>
            <div style="padding:0 14px 14px;">
              <div class="muted">
                Payment: <strong><%= order.paymentMethodLabel || order.paymentMethodId || '-' %></strong> ·
                Shipping: <strong><%= order.shippingMethodLabel || order.shippingMethodId || '-' %></strong> ·
                Tracking: <strong><%= order.trackingNumber || 'not set' %></strong>
              </div>

              <form method="POST" action="<%= withTenantLink('/admin/orders/tracking') %>" class="order-form">
                <input type="hidden" name="orderId" value="<%= order.id %>" />
                <label>Password
                  <input type="password" name="password" required />
                </label>
                <label>Tracking number
                  <input type="text" name="trackingNumber" value="<%= order.trackingNumber || '' %>" placeholder="e.g. GR123456" />
                </label>
                <label>Carrier
                  <select name="trackingCarrier">
                    <option value="" <%= !order.trackingCarrier ? 'selected' : '' %>>—</option>
                    <option value="acs" <%= order.trackingCarrier === 'acs' ? 'selected' : '' %>>ACS</option>
                    <option value="elta" <%= order.trackingCarrier === 'elta' ? 'selected' : '' %>>ELTA</option>
                    <option value="geniki" <%= order.trackingCarrier === 'geniki' ? 'selected' : '' %>>Geniki Taxydromiki</option>
                    <option value="dhl" <%= order.trackingCarrier === 'dhl' ? 'selected' : '' %>>DHL</option>
                  </select>
                </label>
                <label>Tracking URL (optional)
                  <input type="url" name="trackingUrl" value="<%= order.trackingUrl || '' %>" placeholder="https://..." />
                </label>
                <label>Fulfillment status
                  <select name="fulfillmentStatus">
                    <% ['pending_payment','cod_pending','ready_to_ship','shipped','delivered','cancelled'].forEach(function(st){ %>
                      <option value="<%= st %>" <%= order.fulfillmentStatus === st ? 'selected' : '' %>><%= st %></option>
                    <% }) %>
                  </select>
                </label>
                <div style="display:flex;align-items:flex-end;">
                  <button class="button" type="submit">Update fulfillment</button>
                </div>
              </form>
              <% if (order.trackingUrl) { %>
                <p class="muted" style="margin-top:8px;">Tracking link: <a href="<%= order.trackingUrl %>" target="_blank" rel="noopener"><%= order.trackingUrl %></a></p>
              <% } %>
            </div>
          </details>
        <% }) %>
      </section>
    </main>
  </body>
</html>
