<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Orders – <%= config.storeName %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header><div class="logo-title"><a href="<%= withTenantLink('/') %>" style="text-decoration:none;color:inherit;"><h1><%= config.storeName %></h1></a></div></header>
  <% if (isPreviewMode) { %>
  <div style="padding:8px 16px;background:#fff7ed;border-bottom:1px solid #fed7aa;color:#9a3412;font-size:.85rem;">
    <strong>Preview Mode</strong> – this store is not live yet. Tenant: <strong><%= tenantId %></strong>
  </div>
  <% } %>
  <button type="button" id="quick-back-btn" style="position:fixed;left:12px;bottom:18px;z-index:1200;border:none;border-radius:999px;padding:10px 14px;background:#0f172a;color:#fff;font-weight:700;cursor:pointer;box-shadow:0 10px 24px rgba(2,6,23,.28);">← Back</button>
  <main style="max-width:900px;margin:30px auto;padding:0 16px;">
    <h2>My Orders</h2>
    <p><a href="<%= withTenantLink('/account') %>">My Account</a> · <a href="<%= withTenantLink('/logout') %>">Logout</a></p>
    <% if (!orders.length) { %>
      <p>No orders yet.</p>
    <% } else { %>
      <table style="width:100%;border-collapse:collapse;">
        <thead>
          <tr>
            <th style="text-align:left;border-bottom:1px solid #ddd;padding:8px;">Order</th>
            <th style="text-align:left;border-bottom:1px solid #ddd;padding:8px;">Date</th>
            <th style="text-align:left;border-bottom:1px solid #ddd;padding:8px;">Total</th>
            <th style="text-align:left;border-bottom:1px solid #ddd;padding:8px;">Digital</th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach(function(order){ %>
            <tr>
              <td style="padding:8px;border-bottom:1px solid #eee;"><%= order.id %><br/><small><%= order.productName %></small></td>
              <td style="padding:8px;border-bottom:1px solid #eee;"><%= new Date(order.createdAt).toLocaleString() %></td>
              <td style="padding:8px;border-bottom:1px solid #eee;"><%= Number(order.total || 0).toFixed(2) %> €</td>
              <td style="padding:8px;border-bottom:1px solid #eee;"><a href="<%= withTenantLink('/content/' + order.id) %>">Open</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </main>
  <script>
    (function() {
      const key = 'thrc_nav_last_url';
      const homeUrl = '<%= withTenantLink("/") %>';
      const currentUrl = window.location.pathname + window.location.search + window.location.hash;
      try { sessionStorage.setItem(key, currentUrl); } catch (err) {}
      document.getElementById('quick-back-btn').addEventListener('click', function() {
        if (window.history.length > 1 && document.referrer && document.referrer.indexOf(window.location.origin) === 0) return window.history.back();
        try {
          const fallback = sessionStorage.getItem(key) || '';
          if (fallback && fallback !== currentUrl) return window.location.href = fallback;
        } catch (err) {}
        window.location.href = homeUrl;
      });
    })();
  </script>
</body>
</html>
