<!DOCTYPE html>
<html lang="<%= lang %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= lang === 'el' ? 'Παρακολούθηση Παραγγελίας' : 'Track Order' %> – <%= config.storeName %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header>
      <div class="logo-title">
        <a href="<%= withTenantLink('/') %>" style="text-decoration:none;color:inherit;"><h1><%= config.storeName %></h1></a>
      </div>
    </header>
    <main style="max-width:760px;margin:32px auto;padding:0 16px;">
      <h2><%= lang === 'el' ? 'Παρακολούθηση Παραγγελίας' : 'Track Order' %></h2>
      <% if (error) { %>
        <div style="margin-bottom:12px;padding:10px 12px;border:1px solid #fecaca;background:#fef2f2;color:#991b1b;border-radius:8px;"><%= error %></div>
      <% } %>
      <form method="POST" action="<%= withTenantLink('/track') %>" style="display:grid;grid-template-columns:1fr 1fr auto;gap:10px;align-items:end;margin-bottom:20px;">
        <label>Order ID
          <input type="text" name="orderId" required />
        </label>
        <label>Email
          <input type="email" name="email" required />
        </label>
        <button type="submit"><%= lang === 'el' ? 'Έλεγχος' : 'Check' %></button>
      </form>

      <% if (order) { %>
        <section style="border:1px solid #e5e7eb;background:#fff;border-radius:10px;padding:14px;">
          <p><strong>Order:</strong> <%= order.id %></p>
          <p><strong><%= lang === 'el' ? 'Κατάσταση fulfillment' : 'Fulfillment status' %>:</strong> <%= order.fulfillmentStatus %></p>
          <p><strong><%= lang === 'el' ? 'Tracking #' : 'Tracking #' %>:</strong> <%= order.trackingNumber || '-' %></p>
          <p><strong><%= lang === 'el' ? 'Courier' : 'Carrier' %>:</strong> <%= order.trackingCarrier || '-' %></p>
          <% if (order.trackingUrl) { %>
            <p><a href="<%= order.trackingUrl %>" target="_blank" rel="noopener"><%= lang === 'el' ? 'Άνοιγμα tracking link' : 'Open tracking link' %></a></p>
          <% } %>
        </section>
      <% } %>
    </main>
  </body>
</html>
