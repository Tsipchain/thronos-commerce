<!DOCTYPE html>
<html lang="<%= lang %>">
  <head>
    <meta charset="UTF-8" />
    <title><%= t('checkout.pageTitle') %> – <%= config.storeName %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="<%= withTenantLink('/favicon.ico', { v: (config.favicon && config.favicon.updatedAt) || '' }) %>" />
    <link rel="stylesheet" href="/styles.css" />
    <style>
      :root {
        --primary-color: <%= config.primaryColor %>;
        --accent-color:  <%= config.accentColor %>;
        --font-family:   <%= config.fontFamily %>;
        --button-radius: <%= (config.theme && config.theme.buttonRadius) || '4px' %>;
      }
      .checkout-layout {
        display: grid;
        grid-template-columns: 1fr 360px;
        gap: 32px;
        max-width: 960px;
        margin: 0 auto;
        padding: 24px 16px 48px;
        align-items: start;
      }
      @media (max-width: 700px) {
        .checkout-layout { grid-template-columns: 1fr; }
        .checkout-summary { order: -1; }
      }
      .checkout-form-section h2 { margin-top: 0; font-size: 1.2rem; }
      .form-row {
        display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;
      }
      .form-row.full { grid-template-columns: 1fr; }
      .form-row label { display: flex; flex-direction: column; gap: 4px; font-size: .88rem; }
      .form-row input, .form-row select, .form-row textarea {
        padding: 9px 11px; border: 1px solid #d1d5db; border-radius: 5px;
        font-size: .9rem; font-family: inherit; box-sizing: border-box; width: 100%;
      }
      .form-row textarea { resize: vertical; }
      .quick-back-btn { position: fixed; left: 12px; bottom: 18px; z-index: 1200; border:none; border-radius:999px; padding:10px 14px; background:#0f172a; color:#fff; font-weight:700; cursor:pointer; box-shadow:0 10px 24px rgba(2,6,23,.28); }

      /* ── Order summary card ── */
      .checkout-summary {
        background: #f9fafb; border: 1px solid #e5e7eb;
        border-radius: 12px; padding: 20px;
        position: sticky; top: 16px;
      }
      .checkout-summary h3 { margin: 0 0 14px; font-size: 1rem; }
      #summary-items { list-style: none; padding: 0; margin: 0 0 14px; }
      #summary-items li {
        display: flex; justify-content: space-between;
        padding: 6px 0; border-bottom: 1px solid #e5e7eb;
        font-size: .86rem;
      }
      #summary-items li:last-child { border: none; }
      .summary-line {
        display: flex; justify-content: space-between;
        font-size: .86rem; margin: 4px 0;
      }
      .summary-line.total {
        font-size: 1rem; font-weight: 700; margin-top: 10px;
        border-top: 2px solid #e5e7eb; padding-top: 10px;
      }
      #empty-cart-msg {
        text-align: center; padding: 40px 0; color: #aaa; font-style: italic;
      }
      .btn-place-order {
        width: 100%; padding: 13px; margin-top: 18px;
        background: var(--primary-color, #4f46e5); color: #fff;
        border: none; border-radius: var(--button-radius, 4px);
        font-size: 1rem; font-weight: 700; cursor: pointer;
      }
      .btn-place-order:hover { opacity: .88; }
      .btn-place-order:disabled { opacity: .45; cursor: not-allowed; }
      .back-link {
        display: inline-block; margin-bottom: 18px;
        font-size: .86rem; color: var(--primary-color, #4f46e5);
      }
      .auth-links {
        display: flex; gap: 12px; margin: 8px 0 18px;
        font-size: .85rem;
      }
      .auth-note {
        margin: 0 0 14px;
        padding: 10px 12px;
        border-radius: 8px;
        font-size: .84rem;
      }
      .auth-note.info {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #1e3a8a;
      }
      .auth-note.warn {
        background: #fff7ed;
        border: 1px solid #fed7aa;
        color: #9a3412;
      }
      .store-header {
        position: sticky;
        top: 0;
        z-index: 1300;
        border-bottom: none !important;
        box-shadow:none !important;
        background: linear-gradient(135deg, rgba(15,23,42,.18), rgba(31,41,55,.16));
        backdrop-filter: blur(3px);
        transition: background .28s ease, box-shadow .28s ease, padding .22s ease;
      }
      .store-header.is-scrolled {
        background: linear-gradient(135deg, rgba(15,23,42,.97), rgba(31,41,55,.96));
        box-shadow: 0 8px 22px rgba(2,6,23,.3) !important;
      }
      .store-header.premium {
        background: #0b0d12 !important;
        border-bottom: 2px solid rgba(196,144,46,.32) !important;
        box-shadow: 0 2px 24px rgba(0,0,0,.55), 0 0 0 1px rgba(196,144,46,.06) inset !important;
      }
      .store-header.premium::before {
        content: '';
        display: block;
        height: 2px;
        background: linear-gradient(90deg, transparent 0%, #c4902e 30%, #dba83c 60%, transparent 100%);
        opacity: .7;
      }
      .checkout-nav {
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:12px;
        flex-wrap:wrap;
        padding: 8px 16px 12px;
      }
      .checkout-nav-links { display:flex; gap:8px; flex-wrap:wrap; }
      .checkout-nav-links a {
        text-decoration:none;
        color: var(--menu-text, #fff);
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.18);
        border-radius: 999px;
        padding: 4px 10px;
        font-size: .82rem;
      }
      .checkout-nav-links a:hover {
        background: rgba(255,255,255,.2);
      }
      .store-footer { margin-top:26px; padding:22px 16px 28px; color: var(--footer-text-color, #6b7280); font-size:.9rem; border-top:1px solid #e5e7eb; text-align:center; position:relative; }
      .store-footer .social-links { display:flex; gap:10px; justify-content:center; align-items:center; flex-wrap:wrap; margin-top:8px; }
      .store-footer .social-links a { text-decoration:none; font-size:1.05rem; }
      .store-footer .meta-line { margin-top:6px; }
      .store-footer .thronos-sign { position:absolute; right:10px; bottom:8px; font-size:.72rem; opacity:.85; text-decoration:none; color:inherit; }
    </style>
  </head>
  <body class="<%= config.theme && config.theme.presetId === 'eukolakis_classic_diy' ? 'eukolakis-classic' : '' %>">
    <header class="store-header <%= config.theme && config.theme.presetId === 'eukolakis_classic_diy' ? 'premium' : '' %>">
      <div class="logo-title">
        <% if (config.logoPath) { %>
          <img src="<%= config.logoPath %>" alt="<%= config.storeName %>" class="logo" />
        <% } %>
        <a href="<%= withTenantLink('/') %>" style="text-decoration:none;color:inherit;"><h1><%= config.storeName %></h1></a>
      </div>
      <div class="checkout-nav">
        <div class="checkout-nav-links">
          <a href="<%= withTenantLink('/') %>"><%= lang === 'el' ? 'Αρχική' : 'Home' %></a>
          <a href="<%= withTenantLink('/checkout') %>"><%= lang === 'el' ? 'Ολοκλήρωση' : 'Checkout' %></a>
          <% if (user) { %>
          <a href="<%= withTenantLink('/account') %>"><%= lang === 'el' ? 'Λογαριασμός' : 'Account' %></a>
          <% } else { %>
          <a href="<%= withTenantLink('/login') %>">Login</a>
          <% } %>
        </div>
      </div>
      <% if (isPreviewMode) { %>
      <div style="padding:8px 16px;background:#fff7ed;border-bottom:1px solid #fed7aa;color:#9a3412;font-size:.85rem;">
        <strong>Preview Mode</strong> – this store is not live yet. Tenant: <strong><%= tenantId %></strong>
      </div>
      <% } %>
    </header>
    <button type="button" id="quick-back-btn" class="quick-back-btn"><%= lang === 'el' ? '← Επιστροφή' : '← Back' %></button>

    <div id="empty-cart-msg" style="display:none;">
      <p><%= t('checkout.cartEmptyMsg') %></p>
      <a href="<%= withTenantLink('/') %>" class="button"><%= t('checkout.backToStore') %></a>
    </div>

    <div class="checkout-layout" id="checkout-layout" style="display:none;">

      <%# ── Left: Form ── %>
      <section class="checkout-form-section">
        <a href="<%= withTenantLink('/') %>" class="back-link">← <%= t('checkout.backToStore') %></a>
        <div class="auth-links">
          <% if (!user) { %>
            <a href="<%= withTenantLink('/login') %>">Login</a>
            <a href="<%= withTenantLink('/signup') %>">Signup</a>
          <% } else { %>
            <a href="<%= withTenantLink('/account') %>">My Account</a>
            <a href="<%= withTenantLink('/my-orders') %>">My Orders</a>
            <a href="<%= withTenantLink('/logout') %>">Logout</a>
          <% } %>
        </div>
        <h2><%= t('checkout.pageTitle') %></h2>
        <% if (user) { %>
          <p class="auth-note info">Συνδεδεμένος ως <strong><%= user.email %></strong>. Το email συμπληρώθηκε αυτόματα.</p>
        <% } else { %>
          <p class="auth-note warn">Κάνε εγγραφή για να έχεις πρόσβαση στα DIY videos.</p>
        <% } %>

        <form id="checkout-form" method="POST" action="<%= withTenantLink('/checkout') %>">
          <input type="hidden" name="cartJson" id="cart-json-input" value="" />

          <div class="form-row">
            <label>
              <%= t('checkout.fullName') %> *
              <input type="text" name="name" required />
            </label>
            <label>
              <%= t('checkout.email') %> *
              <input type="email" name="email" required value="<%= user ? user.email : '' %>" <%= user ? 'readonly' : '' %> />
            </label>
          </div>

          <div class="form-row">
            <label>
              <%= t('checkout.phone') %> *
              <input type="tel" name="phone" required placeholder="π.χ. 6912345678" />
            </label>
            <label>
              <%= t('checkout.tk') %>
              <input type="text" name="tk" placeholder="π.χ. 15123" maxlength="10" />
            </label>
          </div>

          <div class="form-row full">
            <label>
              <%= t('checkout.address') %> *
              <input type="text" name="address" required placeholder="<%= t('checkout.addressPlaceholder') %>" />
            </label>
          </div>

          <div class="form-row">
            <label>
              <%= t('checkout.doorbell') %>
              <input type="text" name="doorbell" placeholder="<%= t('checkout.doorbellPlaceholder') %>" />
            </label>
            <label>
              <%= t('checkout.city') %>
              <input type="text" name="city" placeholder="<%= t('checkout.cityPlaceholder') %>" />
            </label>
          </div>

          <div class="form-row">
            <label>
              <%= t('checkout.shippingMethod') %> *
              <select name="shippingMethodId" id="sel-shipping" required onchange="recalc()">
                <% (config.shippingOptions || []).forEach(function(opt) { %>
                  <option value="<%= opt.id %>" data-base="<%= Number(opt.base)||0 %>" data-codfee="<%= Number(opt.codFee)||0 %>" data-allowed="<%= Array.isArray(opt.allowedPaymentMethods) ? opt.allowedPaymentMethods.join(',') : '' %>">
                    <%= opt.label %><% if (opt.base > 0) { %> (+<%= Number(opt.base).toFixed(2) %> €)<% } %>
                  </option>
                <% }); %>
              </select>
            </label>
            <label>
              <%= t('checkout.paymentMethod') %> *
              <select name="paymentMethodId" id="sel-payment" required onchange="recalc()">
                <% (config.paymentOptions || []).forEach(function(opt) { %>
                  <option value="<%= opt.id %>"
                          data-surcharge="<%= Number(opt.gatewaySurchargePercent)||0 %>"
                          data-iscod="<%= opt.id === 'COD' ? '1' : '0' %>"
                          data-type="<%= opt.type || '' %>">
                    <%= opt.label %>
                  </option>
                <% }); %>
              </select>
            </label>
            <label>
              <%= lang === 'el' ? 'Κουπόνι' : 'Coupon' %>
              <input type="text" name="couponCode" id="coupon-code" placeholder="WELCOME10" />
            </label>
          </div>

          <%# Stripe badge (shown when stripe payment selected) %>
          <div id="stripe-badge" style="display:none;background:#f5f3ff;border:1px solid #ddd6fe;border-radius:8px;padding:10px 14px;margin-bottom:12px;font-size:.84rem;color:#5b21b6;">
            🔒 <%= t('checkout.stripeSecure') %>
          </div>

          <div class="form-row full">
            <label>
              <%= t('checkout.web3Wallet') %>
              <input type="text" name="wallet" placeholder="0x…" />
            </label>
          </div>

          <div class="form-row full">
            <label>
              <%= t('checkout.notes') %>
              <textarea name="notes" rows="3" placeholder="<%= t('checkout.notesPlaceholder') %>"></textarea>
            </label>
          </div>

          <button class="btn-place-order" type="submit" id="btn-submit" disabled>
            <span id="btn-submit-text"><%= t('checkout.submit') %></span>
          </button>
        </form>
      </section>

      <%# ── Right: Order summary ── %>
      <aside class="checkout-summary">
        <h3><%= t('checkout.orderSummary') %></h3>
        <ul id="summary-items"></ul>
        <div class="summary-line">
          <span><%= t('checkout.subtotal') %></span>
          <span id="sum-subtotal">–</span>
        </div>
        <div class="summary-line" id="sum-qtydisc-row" style="display:none;">
          <span><%= lang === 'el' ? 'Έκπτωση ποσότητας' : 'Quantity discount' %></span>
          <span id="sum-qtydisc">–</span>
        </div>
        <div class="summary-line" id="sum-coupon-row" style="display:none;">
          <span><%= lang === 'el' ? 'Έκπτωση κουπονιού' : 'Coupon discount' %></span>
          <span id="sum-coupon">–</span>
        </div>
        <div class="summary-line">
          <span><%= t('checkout.shipping') %></span>
          <span id="sum-shipping">–</span>
        </div>
        <div class="summary-line" id="sum-cod-row" style="display:none;">
          <span><%= t('checkout.codFee') %></span>
          <span id="sum-cod">–</span>
        </div>
        <div class="summary-line" id="sum-gw-row" style="display:none;">
          <span><%= t('checkout.gatewayFee') %></span>
          <span id="sum-gateway">–</span>
        </div>
        <div class="summary-line total">
          <span><%= t('checkout.total') %></span>
          <span id="sum-total">–</span>
        </div>
      </aside>
    </div>

    <script>
      const CART_SCOPE = '<%= (tenant && tenant.id) ? tenant.id : "default" %>';
      const CART_KEY = 'thrc_cart:' + CART_SCOPE;
      const CART_SESSION_KEY = 'thrc_cart_session:' + CART_SCOPE;
      const cartJsonInput = document.getElementById('cart-json-input');
      const cartSnapshotApi = '<%= withTenantLink("/api/checkout/cart-snapshot") %>';

      // ── Load & validate cart ──────────────────────────────────────
      function readCartSnapshot() {
        try {
          const local = JSON.parse(localStorage.getItem(CART_KEY) || 'null');
          if (Array.isArray(local)) return local;
        } catch(e) {}
        try {
          const session = JSON.parse(sessionStorage.getItem(CART_SESSION_KEY) || 'null');
          if (Array.isArray(session)) return session;
        } catch(e) {}
        return [];
      }
      function normalizeCartForCheckout(snapshot) {
        if (!Array.isArray(snapshot)) return [];
        return snapshot
          .filter(function(item){ return item && item.id; })
          .map(function(item){
            return {
              id: String(item.id || '').trim(),
              qty: Math.max(1, Number(item.qty) || 1),
              variantId: item.variantId ? String(item.variantId).trim() : '',
              isKitSummary: !!item.isKitSummary,
              selectedOptions: Array.isArray(item.selectedOptions) ? item.selectedOptions : []
            };
          })
          .filter(function(item){ return item.id; });
      }
      function syncCartPayload(snapshot) {
        const safeSnapshot = normalizeCartForCheckout(snapshot);
        if (cartJsonInput) cartJsonInput.value = JSON.stringify(safeSnapshot);
      }
      function syncCartSnapshotToServer(snapshot) {
        const safeSnapshot = normalizeCartForCheckout(snapshot);
        if (!safeSnapshot.length) return;
        try {
          fetch(cartSnapshotApi, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            keepalive: true,
            body: JSON.stringify({ items: safeSnapshot })
          }).catch(function(){});
        } catch (_) {}
      }
      let cart = readCartSnapshot();

      if (!cart.length) {
        document.getElementById('empty-cart-msg').style.display = '';
      } else {
        document.getElementById('checkout-layout').style.display = 'grid';
        document.getElementById('btn-submit').disabled = false;
        renderSummaryItems();
        recalc();
      }
      syncCartPayload(cart);
      syncCartSnapshotToServer(cart);

      function renderSummaryItems() {
        const el = document.getElementById('summary-items');
        el.innerHTML = cart.map(function(item) {
          const safeName = (item.name || '?').replace(/</g,'&lt;');
          const opts = item.optionSummary ? '<br><small style=\"color:#6b7280;\">' + String(item.optionSummary).replace(/</g,'&lt;') + '</small>' : '';
          return '<li><span>' + safeName + opts + ' &times;' + (item.qty || 1) + '</span>' +
            '<span>' + ((item.price || 0) * (item.qty || 1)).toFixed(2) + ' &euro;</span></li>';
        }).join('');
      }

      const STRIPE_SUBMIT_TEXT  = '<%= t("checkout.submitStripe") %>';
      const DEFAULT_SUBMIT_TEXT = '<%= t("checkout.submit") %>';

      // ── Live price calculation ────────────────────────────────────
      function syncAllowedPaymentOptions() {
        const shipSel = document.getElementById('sel-shipping');
        const paySel = document.getElementById('sel-payment');
        if (!shipSel || !paySel) return;
        const shipOpt = shipSel.options[shipSel.selectedIndex];
        const allowedRaw = shipOpt ? String(shipOpt.dataset.allowed || '').trim() : '';
        const allowed = allowedRaw
          ? allowedRaw.split(',').map(function(v) { return String(v || '').trim().toUpperCase(); }).filter(Boolean)
          : [];
        const allowedSet = new Set(allowed);
        let firstEnabledValue = '';
        Array.from(paySel.options).forEach(function(opt) {
          const optId = String(opt.value || '').trim().toUpperCase();
          const enabled = !allowedSet.size || allowedSet.has(optId);
          opt.hidden = !enabled;
          opt.disabled = !enabled;
          if (enabled && !firstEnabledValue) firstEnabledValue = opt.value;
        });
        const selected = paySel.options[paySel.selectedIndex];
        if ((!selected || selected.disabled) && firstEnabledValue) paySel.value = firstEnabledValue;
      }

      function recalc() {
        syncAllowedPaymentOptions();
        const subtotalRaw = cart.reduce(function(s, i) { return s + (i.price || 0) * (i.qty || 1); }, 0);
        const qtyDiscount = cart.reduce(function(s, i) {
          const qty = Number(i.qty) || 1;
          const line = (Number(i.price) || 0) * qty;
          const rate = qty >= 10 ? 0.10 : (qty >= 5 ? 0.05 : 0);
          return s + line * rate;
        }, 0);
        const subtotal = Math.max(0, subtotalRaw - qtyDiscount);

        const shipSel  = document.getElementById('sel-shipping');
        const paySel   = document.getElementById('sel-payment');
        const shipOpt  = shipSel && shipSel.options[shipSel.selectedIndex];
        const payOpt   = paySel  && paySel.options[paySel.selectedIndex];

        const shippingCost = shipOpt ? parseFloat(shipOpt.dataset.base  || 0) : 0;
        const codFee       = (payOpt && payOpt.dataset.iscod === '1')
                             ? parseFloat(shipOpt ? shipOpt.dataset.codfee || 0 : 0) : 0;
        const surcharge    = payOpt  ? parseFloat(payOpt.dataset.surcharge || 0) : 0;
        const couponEl = document.getElementById('coupon-code');
        const couponCode = (couponEl && couponEl.value || '').trim().toUpperCase();
        const couponDiscount = couponCode === 'WELCOME10' ? subtotal * 0.10 : 0;
        const subtotalAfterCoupon = Math.max(0, subtotal - couponDiscount);
        const gatewayFee   = subtotalAfterCoupon * surcharge;
        const total        = subtotalAfterCoupon + shippingCost + codFee + gatewayFee;

        document.getElementById('sum-subtotal').textContent = subtotalAfterCoupon.toFixed(2)      + ' €';
        document.getElementById('sum-shipping').textContent = shippingCost.toFixed(2)  + ' €';
        document.getElementById('sum-total').textContent    = total.toFixed(2)         + ' €';

        const codRow = document.getElementById('sum-cod-row');
        const gwRow  = document.getElementById('sum-gw-row');
        codRow.style.display = codFee > 0     ? '' : 'none';
        gwRow.style.display  = gatewayFee > 0 ? '' : 'none';
        document.getElementById('sum-cod').textContent     = codFee.toFixed(2)     + ' €';
        document.getElementById('sum-gateway').textContent = gatewayFee.toFixed(2) + ' €';
        const qtyRow = document.getElementById('sum-qtydisc-row');
        const qtyVal = document.getElementById('sum-qtydisc');
        if (qtyRow && qtyVal) {
          qtyRow.style.display = qtyDiscount > 0 ? '' : 'none';
          qtyVal.textContent = '-' + qtyDiscount.toFixed(2) + ' €';
        }
        const couponRow = document.getElementById('sum-coupon-row');
        const couponVal = document.getElementById('sum-coupon');
        if (couponRow && couponVal) {
          couponRow.style.display = couponDiscount > 0 ? '' : 'none';
          couponVal.textContent = '-' + couponDiscount.toFixed(2) + ' €';
        }

        // ── Stripe indicator ──────────────────────────────────────
        const isStripe  = payOpt && payOpt.dataset.type === 'stripe';
        const badge     = document.getElementById('stripe-badge');
        const btnText   = document.getElementById('btn-submit-text');
        if (badge)   badge.style.display   = isStripe ? '' : 'none';
        if (btnText) btnText.textContent    = isStripe ? STRIPE_SUBMIT_TEXT : DEFAULT_SUBMIT_TEXT;
      }

      // ── On submit: inject cart JSON ───────────────────────────────
      let checkoutSubmitting = false;
      document.getElementById('checkout-form').addEventListener('submit', function(e) {
        if (checkoutSubmitting) { e.preventDefault(); return; }
        const latestCart = readCartSnapshot();
        const submitSnapshot = Array.isArray(latestCart) && latestCart.length
          ? latestCart
          : (Array.isArray(cart) && cart.length ? cart : []);
        if (!submitSnapshot.length) { e.preventDefault(); return; }
        cart = submitSnapshot;
        syncCartPayload(submitSnapshot);
        syncCartSnapshotToServer(submitSnapshot);
        checkoutSubmitting = true;
        const submitBtn = document.getElementById('btn-submit');
        if (submitBtn) submitBtn.disabled = true;
      });
      window.addEventListener('pageshow', function() {
        const refreshedCart = readCartSnapshot();
        if (Array.isArray(refreshedCart) && refreshedCart.length) {
          cart = refreshedCart;
          syncCartPayload(refreshedCart);
          syncCartSnapshotToServer(refreshedCart);
        }
      });
      const couponInput = document.getElementById('coupon-code');
      if (couponInput) couponInput.addEventListener('input', recalc);
      (function() {
        const key = 'thrc_nav_last_url';
        const homeUrl = '<%= withTenantLink("/") %>';
        const currentUrl = window.location.pathname + window.location.search + window.location.hash;
        try { if (currentUrl.indexOf('/admin') !== 0) sessionStorage.setItem(key, currentUrl); } catch (err) {}
        const backBtn = document.getElementById('quick-back-btn');
        if (!backBtn) return;
        backBtn.addEventListener('click', function() {
          const ref = document.referrer || '';
          let hasStoreReferrer = false;
          try {
            if (ref) {
              const refUrl = new URL(ref);
              hasStoreReferrer = refUrl.origin === window.location.origin && !/^\/admin(?:\/|$)/.test(refUrl.pathname);
            }
          } catch (err) {}
          if (window.history.length > 1 && hasStoreReferrer) return window.history.back();
          try {
            const fallback = sessionStorage.getItem(key) || '';
            if (fallback && fallback !== currentUrl) return window.location.href = fallback;
          } catch (err) {}
          window.location.href = homeUrl;
        });
      })();
      (function bindCheckoutHeaderScrollState() {
        const headerEl = document.querySelector('.store-header');
        if (!headerEl) return;
        const sync = function() {
          if (window.scrollY > 8) headerEl.classList.add('is-scrolled');
          else headerEl.classList.remove('is-scrolled');
        };
        sync();
        window.addEventListener('scroll', sync, { passive: true });
      })();
    </script>
    <footer class="store-footer" style="--footer-text-color:<%= (config.theme && config.theme.footerTextColor) || '#6b7280' %>;">
      <% if (config.footer && (config.footer.facebookUrl || config.footer.instagramUrl || config.footer.tiktokUrl)) { %>
      <div class="social-links">
        <% if (config.footer.facebookUrl) { %><a href="<%= config.footer.facebookUrl %>" target="_blank" rel="noopener noreferrer" aria-label="Facebook">📘</a><% } %>
        <% if (config.footer.instagramUrl) { %><a href="<%= config.footer.instagramUrl %>" target="_blank" rel="noopener noreferrer" aria-label="Instagram">📸</a><% } %>
        <% if (config.footer.tiktokUrl) { %><a href="<%= config.footer.tiktokUrl %>" target="_blank" rel="noopener noreferrer" aria-label="TikTok">🎵</a><% } %>
      </div>
      <% } %>
      <div class="meta-line"><strong><%= config.storeName %></strong> · All rights reserved Thronos Team 2026</div>
      <% if (config.footer && config.footer.contactEmail) { %><div class="meta-line">Email: <a href="mailto:<%= config.footer.contactEmail %>"><%= config.footer.contactEmail %></a></div><% } %>
      <% if (config.footer && config.footer.pickupAddress) { %><div class="meta-line"><%= lang === 'el' ? 'Παραλαβή από' : 'Pickup at' %>: <%= config.footer.pickupAddress %></div><% } %>
      <% if (tenant && tenant.allowPoweredBy === true && (!config.footer || config.footer.poweredByEnabled !== false)) { %>
      <a class="thronos-sign" href="<%= (config.footer && config.footer.poweredByUrl) || 'https://thronoscommerce.thronoschain.org/' %>" target="_blank" rel="noopener noreferrer"><%= (config.footer && config.footer.poweredByText) || 'Powered by Thronos Commerce ↗' %></a>
      <% } %>
    </footer>
  </body>
</html>
