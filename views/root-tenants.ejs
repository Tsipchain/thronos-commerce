<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Root Tenants | Thronos</title>
  <link rel="stylesheet" href="/styles.css" />
  <style>
    :root { --accent:#5b6af5; }
    body { font-family:system-ui,-apple-system,sans-serif; background:#f4f6fb; color:#1a1a2e; margin:0; }
    .page-layout { max-width:1100px; margin:28px auto; padding:0 20px 60px; }
    .flash { padding:12px 18px; border-radius:6px; margin-bottom:20px; font-size:.9rem; }
    .flash.success { background:#d4edda; border:1px solid #b8dfc4; color:#155724; }
    .flash.error   { background:#f8d7da; border:1px solid #f1b0b7; color:#721c24; }
    .page-title { font-size:1.3rem; font-weight:700; margin:0 0 24px; }
    .card { background:#fff; border-radius:10px; padding:24px 28px; box-shadow:0 2px 12px rgba(0,0,0,.07); margin-bottom:22px; }
    .card h2 { margin:0 0 4px; font-size:1.02rem; font-weight:700; }
    .card .helper { font-size:.82rem; color:#666; margin:0 0 18px; }

    /* Tenants table */
    .tenants-table { width:100%; border-collapse:collapse; font-size:.84rem; }
    .tenants-table th, .tenants-table td { padding:9px 10px; text-align:left; border-bottom:1px solid #eee; }
    .tenants-table th { background:#f0f2fa; font-weight:600; white-space:nowrap; }
    .tenants-table tr:hover td { background:#fafbff; }
    .tier-badge { display:inline-block; padding:2px 8px; border-radius:20px; font-size:.73rem; font-weight:600; white-space:nowrap; }
    .tier-SELF_SERVICE     { background:#e3f0ff; color:#1a56db; }
    .tier-MANAGEMENT_START { background:#fef3c7; color:#92400e; }
    .tier-FULL_OPS_START   { background:#d1fae5; color:#065f46; }
    .tier-DIGITAL_STARTER  { background:#fce7f3; color:#9d174d; }
    .tier-DIGITAL_PRO      { background:#ede9fe; color:#5b21b6; }
    .active-yes { color:#065f46; font-weight:600; }
    .active-no  { color:#9f1239; font-weight:600; }

    /* Forms */
    .form-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:12px; margin-bottom:16px; }
    .form-grid .full { grid-column:1/-1; }
    .form-grid label { display:flex; flex-direction:column; gap:5px; font-size:.84rem; font-weight:500; }
    .form-grid input, .form-grid select { padding:7px 10px; border:1px solid #d1d5db; border-radius:6px; font-size:.88rem; background:#fff; }
    .form-grid input:focus, .form-grid select:focus { outline:none; border-color:var(--accent); box-shadow:0 0 0 3px rgba(91,106,245,.12); }
    .form-grid .hint { font-size:.76rem; color:#888; margin-top:2px; }
    .form-actions { display:flex; gap:10px; flex-wrap:wrap; align-items:center; }
    .btn { display:inline-block; padding:8px 20px; border-radius:6px; font-size:.88rem; font-weight:600; cursor:pointer; border:none; transition:opacity .15s; }
    .btn:hover { opacity:.87; }
    .btn-primary { background:var(--accent); color:#fff; }
    .btn-warning { background:#f59e0b; color:#fff; }
    .btn-danger  { background:#ef4444; color:#fff; }

    details { margin-top:10px; }
    details summary { cursor:pointer; font-weight:600; font-size:.92rem; color:var(--accent); list-style:none; padding:4px 0; }
    details summary::-webkit-details-marker { display:none; }
    details summary::before { content:'▶ '; font-size:.7rem; }
    details[open] summary::before { content:'▼ '; font-size:.7rem; }
    details .detail-body { padding:16px 0 4px; }

    .root-pass-note { font-size:.78rem; color:#888; border-top:1px dashed #ddd; margin-top:20px; padding-top:14px; }
  </style>
</head>
<body>
  <%- include('_root-nav', { page: 'tenants', openTicketCount: openTicketCount || 0, unresolvedFinanceCount: unresolvedFinanceCount || 0 }) %>

  <div class="page-layout">
    <% if (message) { %><div class="flash success"><%= message %></div><% } %>
    <% if (error) { %><div class="flash error"><%= error %></div><% } %>

    <h1 class="page-title">Tenants</h1>

    <%# ══ TENANTS TABLE ══ %>
    <div class="card">
      <h2>Tenants (<%= tenants.length %>)</h2>
      <p class="helper">Όλα τα καταστήματα που είναι εγγεγραμμένα στην πλατφόρμα.</p>

      <% if (tenants.length === 0) { %>
        <p style="color:#888;font-style:italic;">Δεν υπάρχουν tenants ακόμα.</p>
      <% } else { %>
      <div style="overflow-x:auto;">
        <table class="tenants-table">
          <thead>
            <tr>
              <th>ID</th><th>Domain</th><th>Domain status</th><th>Canonical</th>
              <th>Πακέτο</th><th>Referral</th><th>Ενεργό</th><th>Δημιουργία</th>
              <th>Συνδρομή</th><th>Preview URLs</th><th>Allowed themes</th>
            </tr>
          </thead>
          <tbody>
            <% tenants.forEach(function(t) { %>
            <tr>
              <td><code><%= t.id %></code></td>
              <td><%= t.domain || '–' %></td>
              <td><code><%= t.domainStatus || 'pending_dns' %></code></td>
              <td><code><%= t.canonicalToWww ? 'www' : 'off' %></code></td>
              <td><span class="tier-badge tier-<%= t.supportTier %>"><%= t.supportTier %></span></td>
              <td style="font-size:.8rem;">
                <% if (t.referral && t.referral.code) { %>
                  <code style="background:#f0f2fa;padding:1px 5px;border-radius:3px;"><%= t.referral.code %></code>
                  <span style="color:#888;"> <%= (t.referral.percent * 100).toFixed(0) %>%</span>
                <% } else { %><span style="color:#ccc;">–</span><% } %>
              </td>
              <td>
                <% if (t.active) { %><span class="active-yes">✓ Ναι</span>
                <% } else { %><span class="active-no">✗ Όχι</span><% } %>
              </td>
              <td style="white-space:nowrap;font-size:.8rem;color:#666;">
                <% if (t.createdAt) { %><%= new Date(t.createdAt).toLocaleDateString('el-GR') %><% } else { %>–<% } %>
              </td>
              <td>
                <% const sub = getSubscriptionInfo(t); %>
                <% if (sub && sub.expiryStr) { %>
                  <span style="font-size:.73rem;padding:2px 8px;border-radius:12px;font-weight:600;background:<%= sub.isExpired ? '#fee2e2' : sub.isExpiringSoon ? '#fef3c7' : '#d1fae5' %>;color:<%= sub.isExpired ? '#991b1b' : sub.isExpiringSoon ? '#92400e' : '#065f46' %>;">
                    <%= sub.isExpired ? '⚠ Ληγμένη' : sub.daysLeft + ' μέρες' %>
                  </span>
                  <span style="font-size:.7rem;color:#9ca3af;display:block;margin-top:2px;"><%= sub.expiryStr %></span>
                <% } else { %><span style="color:#ccc;font-size:.8rem;">–</span><% } %>
              </td>
              <td style="font-size:.75rem;">
                <div><a href="/t/<%= t.id %>" target="_blank">Store Preview</a></div>
                <div><a href="/t/<%= t.id %>/admin/login" target="_blank">Admin Preview</a></div>
              </td>
              <td style="font-size:.75rem;">
                <code><%= Array.isArray(t.allowedThemeKeys) ? t.allowedThemeKeys.join(', ') : 'core_default' %></code>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>


    <%# ══ CREATE TENANT ══ %>
    <div class="card">
      <h2>Δημιουργία νέου tenant</h2>
      <p class="helper">Δημιουργήστε νέο κατάστημα. Τα αρχεία config/products/categories θα δημιουργηθούν από το template.</p>

      <form method="POST" action="/root/tenants/create">
        <div class="form-grid">
          <label>
            Tenant ID *
            <input type="text" name="id" placeholder="π.χ. myshop" required pattern="[a-zA-Z0-9_-]+" />
            <span class="hint">Μοναδικό αναγνωριστικό (a-z, 0-9, -, _)</span>
          </label>
          <label>
            Domain
            <input type="text" name="domain" placeholder="π.χ. myshop.gr" />
          </label>
          <label>
            Primary domain
            <input type="text" name="primaryDomain" placeholder="π.χ. myshop.gr" />
          </label>
          <label>
            Domain aliases
            <input type="text" name="domains" placeholder="myshop.gr,www.myshop.gr" />
            <span class="hint">Comma-separated, χωρίς το primary domain</span>
          </label>
          <label>
            Preview subdomain
            <input type="text" name="previewSubdomain" placeholder="π.χ. myshop" />
          </label>
          <label>
            Domain status
            <select name="domainStatus">
              <option value="pending_dns" selected>pending_dns</option>
              <option value="ssl_validating">ssl_validating</option>
              <option value="active">active</option>
              <option value="failed">failed</option>
            </select>
          </label>
          <label>
            Canonical → www
            <select name="canonicalToWww">
              <option value="">Όχι (off)</option>
              <option value="true">Ναι (www redirect)</option>
            </select>
          </label>
          <label>
            Πακέτο υποστήριξης
            <select name="supportTier">
              <% (SUPPORT_TIERS || []).forEach(function(t) { %><option value="<%= t %>"><%= t %></option><% }) %>
            </select>
          </label>
          <label>
            Template
            <select name="templateId">
              <option value="demo">demo (default)</option>
            </select>
          </label>
          <label>
            Referral code
            <input type="text" name="refCode" placeholder="π.χ. partner-giannis" />
          </label>
          <label>
            Referral %
            <input type="number" name="refPercent" value="10" min="1" max="50" step="1" />
          </label>
          <label>
            Allowed theme keys
            <input type="text" name="allowedThemeKeys" placeholder="core_default" />
            <span class="hint">Comma-separated. Άδειο = μόνο core_default</span>
          </label>
          <label>
            Admin κωδικός *
            <input type="text" name="adminPasswordPlain" required autocomplete="new-password" placeholder="Αρχικός κωδικός admin" />
          </label>
          <label>
            Root κωδικός *
            <input type="password" name="rootPassword" required />
          </label>
        </div>
        <div class="form-actions">
          <button class="btn btn-primary" type="submit">Δημιουργία tenant</button>
        </div>
      </form>
    </div>


    <%# ══ UPDATE TENANT ══ %>
    <div class="card">
      <h2>Ενημέρωση tenant</h2>
      <p class="helper">Αλλαγή domain, πακέτου, κατάστασης, συνδρομής. Για referral config → <a href="/root/finance">Finance page</a>.</p>

      <% if (tenants.length === 0) { %>
        <p style="color:#888;font-style:italic;">Δεν υπάρχουν tenants.</p>
      <% } else { %>
      <form method="POST" action="/root/tenants/update" id="update-form">
        <div class="form-grid">
          <label>
            Tenant
            <select name="tenantId" id="update-tenant-select" onchange="prefillUpdate(this)">
              <% tenants.forEach(function(t) { %>
                <option value="<%= t.id %>"
                  data-domain="<%= t.domain || '' %>"
                  data-primary-domain="<%= t.primaryDomain || '' %>"
                  data-domains="<%= Array.isArray(t.domains) ? t.domains.join(',') : '' %>"
                  data-preview-subdomain="<%= t.previewSubdomain || t.id || '' %>"
                  data-domain-status="<%= t.domainStatus || 'pending_dns' %>"
                  data-canonical-to-www="<%= t.canonicalToWww ? 'true' : 'false' %>"
                  data-allowed-theme-keys="<%= Array.isArray(t.allowedThemeKeys) ? t.allowedThemeKeys.join(',') : '' %>"
                  data-tier="<%= t.supportTier %>"
                  data-active="<%= t.active ? 'true' : 'false' %>"
                  data-allow-powered-by="<%= t.allowPoweredBy ? 'true' : 'false' %>">
                  <%= t.id %>
                </option>
              <% }) %>
            </select>
          </label>

          <label>
            Domain
            <input type="text" name="domain" id="update-domain" placeholder="π.χ. myshop.gr" />
          </label>
          <label>
            Primary domain
            <input type="text" name="primaryDomain" id="update-primary-domain" />
          </label>
          <label>
            Domain aliases (comma)
            <input type="text" name="domains" id="update-domains" />
            <span class="hint">Αφαιρεί duplicates, lowercase, αφαιρεί primary από aliases.</span>
          </label>
          <label>
            Preview subdomain
            <input type="text" name="previewSubdomain" id="update-preview-subdomain" />
          </label>
          <label class="full">
            Allowed theme keys (comma)
            <input type="text" name="allowedThemeKeys" id="update-allowed-theme-keys" />
          </label>
          <label>
            Domain status
            <select name="domainStatus" id="update-domain-status">
              <option value="pending_dns">pending_dns</option>
              <option value="ssl_validating">ssl_validating</option>
              <option value="active">active</option>
              <option value="failed">failed</option>
            </select>
          </label>
          <label style="align-self:end;">
            <input type="hidden" name="canonicalToWww" value="0" />
            <input type="checkbox" id="update-canonical-to-www" name="canonicalToWww" value="1" />
            Canonical → www
          </label>
          <label>
            Πακέτο
            <select name="supportTier" id="update-tier">
              <% (SUPPORT_TIERS || []).forEach(function(t) { %><option value="<%= t %>"><%= t %></option><% }) %>
            </select>
          </label>
          <label>
            Κατάσταση
            <select name="active" id="update-active">
              <option value="true">Ενεργό</option>
              <option value="false">Ανενεργό</option>
            </select>
          </label>
          <label style="align-self:end;">
            <input type="hidden" name="allowPoweredBy" value="0" />
            <input type="checkbox" id="update-allow-powered-by" name="allowPoweredBy" value="1" />
            Powered by footer
          </label>
          <label>
            Λήξη συνδρομής
            <input type="date" name="subscriptionExpiry" id="update-subexpiry" />
          </label>
          <label>
            Root κωδικός *
            <input type="password" name="rootPassword" required />
          </label>
        </div>
        <div class="form-actions">
          <button class="btn btn-warning" type="submit">Ενημέρωση</button>
        </div>
      </form>
      <% } %>
    </div>


    <%# ══ RESET ADMIN PASSWORD ══ %>
    <div class="card">
      <h2>Επαναφορά κωδικού admin</h2>
      <p class="helper">Νέος bcrypt hash κωδικός για τον admin ενός tenant.</p>

      <% if (tenants.length === 0) { %>
        <p style="color:#888;font-style:italic;">Δεν υπάρχουν tenants.</p>
      <% } else { %>
      <form method="POST" action="/root/tenants/reset-admin-password">
        <div class="form-grid">
          <label>
            Tenant
            <select name="tenantId">
              <% tenants.forEach(function(t) { %><option value="<%= t.id %>"><%= t.id %></option><% }) %>
            </select>
          </label>
          <label>
            Νέος κωδικός admin *
            <input type="text" name="newPassword" required autocomplete="new-password" placeholder="Νέος κωδικός" />
          </label>
          <label class="full">
            Root κωδικός *
            <input type="password" name="rootPassword" required />
          </label>
        </div>
        <div class="form-actions">
          <button class="btn btn-danger" type="submit">Επαναφορά κωδικού</button>
        </div>
      </form>
      <% } %>
    </div>


    <%# ══ GATEWAY SURCHARGE ══ %>
    <div class="card">
      <h2>Gateway Surcharge</h2>
      <p class="helper">Ρύθμιση προσαύξησης gateway (%) ανά τρόπο πληρωμής για κάθε κατάστημα.</p>

      <% if (tenants.length === 0) { %>
        <p style="color:#888;font-style:italic;">Δεν υπάρχουν tenants.</p>
      <% } else { %>
      <form method="POST" action="/root/tenants/payment-config" id="surcharge-form">
        <div class="form-grid">
          <label>
            Tenant
            <select name="tenantId" id="surcharge-tenant-select" onchange="renderSurchargeFields(this.value)">
              <% tenants.forEach(function(t) { %><option value="<%= t.id %>"><%= t.id %></option><% }) %>
            </select>
          </label>
        </div>
        <div id="surcharge-fields" style="margin:12px 0 16px;"></div>
        <div class="form-grid">
          <label class="full">
            Root κωδικός *
            <input type="password" name="rootPassword" required />
          </label>
        </div>
        <div class="form-actions">
          <button class="btn btn-primary" type="submit">Αποθήκευση surcharges</button>
        </div>
      </form>
      <% } %>
    </div>

    <p class="root-pass-note">
      <strong>Ασφάλεια:</strong> Root password → env <code>THRONOS_ROOT_ADMIN_PASSWORD</code>. Μην κοινοποιείτε αυτό το URL.
    </p>
  </div>

  <script>
    const tenantPaymentConfigs = <%- JSON.stringify(tenantPaymentConfigs) %>;

    function renderSurchargeFields(tenantId) {
      const container = document.getElementById('surcharge-fields');
      const opts = tenantPaymentConfigs[tenantId] || [];
      if (opts.length === 0) {
        container.innerHTML = '<p style="color:#aaa;font-style:italic;font-size:.84rem;">Δεν υπάρχουν payment options για αυτό το tenant.</p>';
        return;
      }
      let html = '<table style="border-collapse:collapse;font-size:.85rem;width:100%;">' +
        '<thead><tr>' +
        '<th style="text-align:left;padding:6px 10px;background:#f0f2fa;">ID</th>' +
        '<th style="text-align:left;padding:6px 10px;background:#f0f2fa;">Label</th>' +
        '<th style="text-align:left;padding:6px 10px;background:#f0f2fa;">Surcharge %</th>' +
        '</tr></thead><tbody>';
      opts.forEach(function(opt, i) {
        html += '<tr><td style="padding:6px 10px;"><code>' + opt.id + '</code></td>' +
          '<td style="padding:6px 10px;">' + (opt.label || '–') + '</td>' +
          '<td style="padding:6px 10px;"><input type="number" name="surcharge_' + i + '" ' +
          'value="' + (opt.gatewaySurchargePercent || 0) + '" min="0" step="0.001" ' +
          'style="width:90px;padding:5px 8px;border:1px solid #d1d5db;border-radius:4px;" /></td></tr>';
      });
      html += '</tbody></table>';
      container.innerHTML = html;
    }
    const surchargeSelect = document.getElementById('surcharge-tenant-select');
    if (surchargeSelect) renderSurchargeFields(surchargeSelect.value);

    const tenantData = {
      <% tenants.forEach(function(t, i) { %>
        "<%= t.id %>": {
          domain: "<%- (t.domain || '').replace(/"/g, '\\"') %>",
          primaryDomain: "<%- (t.primaryDomain || '').replace(/"/g, '\\"') %>",
          domains: "<%- (Array.isArray(t.domains) ? t.domains.join(',') : '').replace(/"/g, '\\"') %>",
          previewSubdomain: "<%- (t.previewSubdomain || t.id || '').replace(/"/g, '\\"') %>",
          domainStatus: "<%- (t.domainStatus || 'pending_dns').replace(/"/g, '\\"') %>",
          canonicalToWww: <%= t.canonicalToWww ? 'true' : 'false' %>,
          allowedThemeKeys: "<%- (Array.isArray(t.allowedThemeKeys) ? t.allowedThemeKeys.join(',') : '').replace(/"/g, '\\"') %>",
          tier: "<%= t.supportTier %>",
          active: <%= t.active ? 'true' : 'false' %>,
          allowPoweredBy: <%= t.allowPoweredBy ? 'true' : 'false' %>
        }<%= i < tenants.length - 1 ? ',' : '' %>
      <% }) %>
    };

    function prefillUpdate(select) {
      const d = tenantData[select.value];
      if (!d) return;
      document.getElementById('update-domain').value = d.domain;
      const el = (id) => document.getElementById(id);
      if (el('update-primary-domain')) el('update-primary-domain').value = d.primaryDomain || '';
      if (el('update-domains')) el('update-domains').value = d.domains || '';
      if (el('update-preview-subdomain')) el('update-preview-subdomain').value = d.previewSubdomain || '';
      if (el('update-allowed-theme-keys')) el('update-allowed-theme-keys').value = d.allowedThemeKeys || '';
      const ds = el('update-domain-status');
      if (ds) { for (let i = 0; i < ds.options.length; i++) { if (ds.options[i].value === (d.domainStatus || 'pending_dns')) { ds.selectedIndex = i; break; } } }
      if (el('update-canonical-to-www')) el('update-canonical-to-www').checked = !!d.canonicalToWww;
      const ts = el('update-tier');
      if (ts) { for (let i = 0; i < ts.options.length; i++) { if (ts.options[i].value === d.tier) { ts.selectedIndex = i; break; } } }
      const as = el('update-active');
      if (as) { for (let i = 0; i < as.options.length; i++) { if ((as.options[i].value === 'true') === d.active) { as.selectedIndex = i; break; } } }
      if (el('update-allow-powered-by')) el('update-allow-powered-by').checked = !!d.allowPoweredBy;
    }
    const sel = document.getElementById('update-tenant-select');
    if (sel) prefillUpdate(sel);
  </script>
</body>
</html>
