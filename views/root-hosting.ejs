<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Root Hosting Panel</title>
  <link rel="stylesheet" href="/styles.css" />
  <style>
    .tenant-card { border:1px solid #e5e7eb; border-radius:10px; margin:0 0 14px; overflow:hidden; }
    .tenant-card summary {
      cursor:pointer; padding:12px 16px; background:#f8fafc; list-style:none;
      display:flex; align-items:center; gap:10px; flex-wrap:wrap;
    }
    .tenant-card summary::-webkit-details-marker { display:none; }
    .tenant-card summary .arrow { font-size:.8rem; color:#94a3b8; margin-left:auto; }
    .tenant-card[open] summary { border-bottom:1px solid #e5e7eb; background:#f1f5f9; }
    .chip { display:inline-block; padding:2px 9px; border-radius:999px; font-size:.72rem; font-weight:700; }
    .chip.ok   { background:#dcfce7; color:#15803d; }
    .chip.warn { background:#fef9c3; color:#a16207; }
    .chip.pend { background:#e0e7ef; color:#475569; }
    .chip.err  { background:#fee2e2; color:#991b1b; }
    .chip.info { background:#e0f2fe; color:#0369a1; }
    .tab-bar { display:flex; gap:0; border-bottom:2px solid #e5e7eb; margin:12px 16px 0; flex-wrap:wrap; }
    .tab-btn {
      padding:7px 14px; font-size:.8rem; font-weight:600; color:#64748b;
      border:none; background:none; cursor:pointer; border-bottom:2px solid transparent;
      margin-bottom:-2px; border-radius:6px 6px 0 0;
    }
    .tab-btn.active { color:#0f172a; border-bottom-color:#2563eb; background:#eff6ff; }
    .tab-btn:hover:not(.active) { background:#f1f5f9; }
    .tab-panel { display:none; padding:16px; }
    .tab-panel.active { display:block; }
    .form-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:10px; }
    .form-grid label { display:flex; flex-direction:column; gap:4px; font-size:.82rem; color:#374151; font-weight:600; }
    .form-grid label select, .form-grid label input[type=text],
    .form-grid label input[type=password] {
      padding:5px 8px; border:1px solid #d1d5db; border-radius:6px; font-size:.83rem; color:#111;
    }
    .form-grid .full { grid-column:1/-1; }
    .pw-row { display:flex; align-items:center; gap:8px; }
    .pw-row label { font-size:.8rem; font-weight:600; color:#374151; }
    .pw-row input { padding:5px 8px; border:1px solid #d1d5db; border-radius:6px; font-size:.83rem; width:140px; }
    .save-row { display:flex; align-items:center; gap:8px; margin-top:12px; flex-wrap:wrap; }
    .btn-save { background:#2563eb; color:#fff; border:none; border-radius:6px; padding:6px 18px; font-size:.82rem; font-weight:600; cursor:pointer; }
    .btn-recheck { background:#0ea5e9; color:#fff; border:none; border-radius:6px; padding:6px 16px; font-size:.82rem; font-weight:600; cursor:pointer; }
    .status-row { display:flex; align-items:baseline; gap:10px; margin:6px 0; font-size:.85rem; }
    .status-label { color:#64748b; min-width:140px; font-size:.78rem; text-transform:uppercase; letter-spacing:.04em; }
    .dns-result-box { background:#f8fafc; border:1px solid #e2e8f0; border-radius:6px; padding:10px 14px; margin:10px 0; font-size:.8rem; }
    .dns-ok   { color:#15803d; font-weight:700; }
    .dns-fail { color:#dc2626; font-weight:700; }
    .warn-box { background:#fffbeb; border:1px solid #fde68a; border-radius:6px; padding:8px 12px; font-size:.8rem; color:#78350f; margin:8px 0; }
    .info-box { background:#eff6ff; border:1px solid #bfdbfe; border-radius:6px; padding:8px 12px; font-size:.8rem; color:#1e40af; margin:8px 0; }
    .muted { color:#94a3b8; font-size:.76rem; }
  </style>
</head>
<body>
  <%- include('_root-nav', { page: 'hosting', openTicketCount: typeof openTicketCount !== 'undefined' ? openTicketCount : 0, unresolvedFinanceCount: typeof unresolvedFinanceCount !== 'undefined' ? unresolvedFinanceCount : 0 }) %>
  <main class="admin-layout">
    <% const safeRows = Array.isArray(rows) ? rows : []; %>
    <% if (message) { %><div class="flash ok"><%= message %></div><% } %>
    <% if (error) { %><div class="flash err"><%= error %></div><% } %>
    <% if (typeof vaUrlMissing !== 'undefined' && vaUrlMissing) { %>
    <div class="warn-box"><strong>⚠ THRONOS_ASSISTANT_URL</strong> not set — tenants with VA enabled will fail chat requests.</div>
    <% } %>

    <section class="admin-block">
      <h2>Overview</h2>
      <p>Tenants: <strong><%= safeRows.length %></strong> &nbsp;·&nbsp; Unresolved issues: <strong><%= Number(unresolvedCount || 0) %></strong></p>
      <p class="muted">Tabs per tenant save independently. DNS Recheck runs live DNS queries and auto-promotes domain status when CNAME + TXT pass.</p>
    </section>

    <% safeRows.forEach(function(row, ri) { %>
    <%
      const ds = row.domainStatus || 'pending_dns';
      const ss = row.sslStatus || 'pending';
      const dsChip = ds === 'active' ? 'ok' : (ds === 'ssl_validating' ? 'warn' : ds.startsWith('pending') ? 'pend' : 'err');
      const ssChip = ss === 'active' ? 'ok' : ss === 'pending' ? 'pend' : 'err';
    %>
    <details class="tenant-card" id="tc-<%= row.tenantId %>">
      <summary>
        <strong><%= row.tenantId %></strong>
        <span class="muted"><%= row.primaryDomain || '(platform only)' %></span>
        <span class="chip <%= dsChip %>">domain: <%= ds %></span>
        <span class="chip <%= ssChip %>">ssl: <%= ss %></span>
        <% if (row.issueFlag) { %><span class="chip err">⚠ issue</span><% } %>
        <% if (row.vaEnabled && !row.vaBackendAvailable) { %><span class="chip warn">VA: no backend URL</span><% } %>
        <span class="arrow">▼</span>
      </summary>

      <div class="tab-bar" id="tabs-<%= ri %>">
        <button class="tab-btn active" data-tab="<%= ri %>-dns" onclick="switchTab(this,'<%= ri %>')">DNS &amp; Domain</button>
        <button class="tab-btn" data-tab="<%= ri %>-ssl" onclick="switchTab(this,'<%= ri %>')">SSL</button>
        <button class="tab-btn" data-tab="<%= ri %>-footer" onclick="switchTab(this,'<%= ri %>')">Footer</button>
        <button class="tab-btn" data-tab="<%= ri %>-assistant" onclick="switchTab(this,'<%= ri %>')">Assistant</button>
        <button class="tab-btn" data-tab="<%= ri %>-mail" onclick="switchTab(this,'<%= ri %>')">Mail</button>
        <button class="tab-btn" data-tab="<%= ri %>-web3" onclick="switchTab(this,'<%= ri %>')">Web3</button>
        <button class="tab-btn" data-tab="<%= ri %>-advanced" onclick="switchTab(this,'<%= ri %>')">Advanced</button>
      </div>

      <%# ── DNS & Domain tab ── %>
      <div class="tab-panel active" id="<%= ri %>-dns">
        <p class="muted">
          Preview host: <code><%= row.previewHost || '—' %></code>
          &nbsp;·&nbsp; Canonical www: <%= row.canonicalToWww ? 'on' : 'off' %>
          &nbsp;·&nbsp; Type: <span class="chip info"><%= row.domainType %></span>
        </p>
        <div class="status-row"><span class="status-label">Primary domain</span><code><%= row.primaryDomain || '—' %></code></div>
        <div class="status-row"><span class="status-label">Aliases</span><code><%= Array.isArray(row.aliases) && row.aliases.length ? row.aliases.join(', ') : '—' %></code></div>

        <% let dnsResult = null; try { dnsResult = row.dnsCheckResult ? JSON.parse(row.dnsCheckResult) : null; } catch(e){} %>
        <% if (dnsResult) { %>
        <div class="dns-result-box">
          <strong>Last DNS check</strong> <span class="muted"><%= row.lastCheckedAt || '—' %></span><br/>
          <%
            var _cname = dnsResult.cname || {};
            var _txt   = dnsResult.txt   || {};
            var _cnameEffective = _cname.effectiveOk !== undefined ? _cname.effectiveOk : _cname.ok;
          %>
          CNAME <span class="<%= _cnameEffective ? 'dns-ok' : 'dns-fail' %>"><%= _cnameEffective ? '✓' : '✗' %></span>
          <% if (_cname.cnames) { %><span class="muted">→ <%= _cname.cnames.join(', ') %></span><% } %>
          <% if (_cname.type === 'apex-a') { %><span class="chip warn" style="font-size:.7rem;">Cloudflare apex-A</span><% } %>
          <% if (_cname.note) { %><span class="muted">(<%= _cname.note.slice(0,80) %>)</span><% } %>
          <span class="muted">[<%= _cname.resolver || '?' %>]</span>
          &nbsp;&nbsp;
          TXT <span class="<%= _txt.ok ? 'dns-ok' : 'dns-fail' %>"><%= _txt.ok ? '✓' : '✗' %></span>
          <% if (_txt.source) { %><span class="muted">via <%= _txt.source %></span><% } %>
          <span class="muted">[<%= _txt.resolver || '?' %>]</span>
          <% if (_txt.ok && _txt.source === 'legacy_subdomain') { %>
          <span class="chip warn" style="font-size:.7rem;">legacy TXT — migrate to root</span>
          <% } %>
          <% if (!_txt.ok) { %>
          <div class="warn-box" style="margin-top:6px;">
            Add root TXT: <code><%= row.primaryDomain %></code> → <code>thronos-verify=<%= row.tenantId %></code><br/>
            <span class="muted">(legacy: <code>_thronos-verify.<%= row.primaryDomain %></code> → <code>thronos-verify=<%= row.tenantId %></code> also accepted)</span>
          </div>
          <% } %>
          <% if (Array.isArray(dnsResult.aliases) && dnsResult.aliases.length) { %>
          <div style="margin-top:8px;"><strong>Aliases:</strong>
            <% dnsResult.aliases.forEach(function(a){ %>
            <div style="margin:3px 0;font-size:.8rem;">
              <code><%= a.domain %></code>: <span class="<%= a.ok ? 'dns-ok' : 'dns-fail' %>"><%= a.ok ? '✓' : '✗' %></span>
              <% if (a.cnames) { %><span class="muted">→ <%= a.cnames.join(', ') %></span><% } %>
              <% if (a.note) { %><span class="muted">(<%= a.note %>)</span><% } %>
            </div>
            <% }) %>
          </div>
          <% } %>
          <% if (dnsResult.smoke && Object.keys(dnsResult.smoke).length) { %>
          <div style="margin-top:8px;"><strong>HTTP smoke:</strong>
            <% Object.entries(dnsResult.smoke).forEach(function(e){ var d=e[0], s=e[1]; %>
            <div style="margin:3px 0;font-size:.8rem;">
              <code><%= d %></code>: <span class="<%= s.ok ? 'dns-ok' : 'dns-fail' %>"><%= s.ok ? '✓' : '✗' %></span>
              <% if (s.statusCode) { %><span class="muted"><%= s.proto %> <%= s.statusCode %></span><% } %>
              <% if (s.note) { %><span class="muted">(<%= s.note.slice(0,80) %>)</span><% } %>
            </div>
            <% }) %>
          </div>
          <% } %>

          <% if (dnsResult.requiredRecords) { %>
          <details style="margin-top:12px;"><summary style="cursor:pointer;font-weight:600;font-size:.85rem;">Required Records (Show)</summary>
            <div style="margin-top:8px;padding:10px;background:#f9fafb;border-radius:6px;">
              <div style="margin:8px 0;"><strong>Apex:</strong> <code><%= dnsResult.requiredRecords.apex.type %></code> → <code><%= dnsResult.requiredRecords.apex.target %></code></div>
              <div style="margin:8px 0;"><strong>TXT:</strong> <code><%= dnsResult.requiredRecords.txt.location %></code> → <code><%= dnsResult.requiredRecords.txt.value %></code></div>
              <% if (dnsResult.requiredRecords.aliases && dnsResult.requiredRecords.aliases.length) { %>
              <div style="margin:8px 0;"><strong>Aliases:</strong>
                <% dnsResult.requiredRecords.aliases.forEach(function(a){ %>
                <div style="margin:3px 0;font-size:.8rem;"><code><%= a.domain %></code> → <code><%= a.target %></code></div>
                <% }) %>
              </div>
              <% } %>
            </div>
          </details>
          <% } %>

          <% if (dnsResult.detectedRecords) { %>
          <details style="margin-top:8px;"><summary style="cursor:pointer;font-weight:600;font-size:.85rem;">Detected Records (Show)</summary>
            <div style="margin-top:8px;padding:10px;background:#f9fafb;border-radius:6px;">
              <div style="margin:8px 0;"><strong>Apex:</strong>
                <% if (dnsResult.detectedRecords.apex) { %>
                  <code><%= dnsResult.detectedRecords.apex.type %></code>
                  <% if (dnsResult.detectedRecords.apex.targets) { %><code><%= dnsResult.detectedRecords.apex.targets.join(', ') %></code><% } %>
                  <% if (dnsResult.detectedRecords.apex.addresses) { %><code><%= dnsResult.detectedRecords.apex.addresses.join(', ') %></code><% } %>
                  <span class="<%= dnsResult.detectedRecords.apex.verified ? 'dns-ok' : 'dns-fail' %>"><%= dnsResult.detectedRecords.apex.verified ? '✓' : '✗' %></span>
                  <% if (dnsResult.detectedRecords.apex.note) { %><span class="muted"><%= dnsResult.detectedRecords.apex.note %></span><% } %>
                <% } %>
              </div>
              <div style="margin:8px 0;"><strong>TXT:</strong>
                <% if (dnsResult.detectedRecords.txt) { %>
                  location: <code><%= dnsResult.detectedRecords.txt.location %></code>
                  <% if (dnsResult.detectedRecords.txt.value) { %><code><%= dnsResult.detectedRecords.txt.value %></code><% } %>
                  <span class="<%= dnsResult.detectedRecords.txt.verified ? 'dns-ok' : 'dns-fail' %>"><%= dnsResult.detectedRecords.txt.verified ? '✓' : '✗' %></span>
                  <% if (dnsResult.detectedRecords.txt.note) { %><span class="muted"><%= dnsResult.detectedRecords.txt.note %></span><% } %>
                <% } %>
              </div>
            </div>
          </details>
          <% } %>
        </div>
        <% } else { %>
        <div class="info-box">No DNS check result yet. Click Recheck below.</div>
        <% } %>
        <% if (row.lastCheckError) { %><div class="warn-box">Last error: <%= row.lastCheckError %></div><% } %>

        <div style="margin:12px 0;"><strong>Cloudflare Configuration</strong></div>
        <form method="POST" action="/root/hosting/cloudflare" style="display:flex;gap:8px;flex-wrap:wrap;margin:8px 0;">
          <input type="hidden" name="tenantId" value="<%= row.tenantId %>" />
          <input type="text" name="cfApiToken" placeholder="Cloudflare API Token" style="padding:5px 8px;border:1px solid #d1d5db;border-radius:6px;font-size:.82rem;flex:1;min-width:160px;" />
          <input type="text" name="cfZoneId" placeholder="Zone ID" style="padding:5px 8px;border:1px solid #d1d5db;border-radius:6px;font-size:.82rem;width:120px;" />
          <button type="submit" class="btn-save">Configure</button>
        </form>

        <div style="margin:12px 0;"><strong>Railway Deployment</strong></div>
        <form method="POST" action="/root/hosting/railway" style="display:flex;gap:8px;flex-wrap:wrap;margin:8px 0;">
          <input type="hidden" name="tenantId" value="<%= row.tenantId %>" />
          <input type="text" name="railwayDeploymentId" placeholder="Deployment ID" style="padding:5px 8px;border:1px solid #d1d5db;border-radius:6px;font-size:.82rem;width:140px;" />
          <input type="url" name="railwayUrl" placeholder="https://..." style="padding:5px 8px;border:1px solid #d1d5db;border-radius:6px;font-size:.82rem;flex:1;min-width:200px;" />
          <button type="submit" class="btn-save">Register</button>
        </form>

        <form method="POST" action="/root/hosting/recheck" style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin:10px 0;">
          <input type="hidden" name="tenantId" value="<%= row.tenantId %>" />
          <div class="pw-row"><label>Root pw:</label><input type="password" name="rootPassword" required /></div>
          <button type="submit" class="btn-recheck">⟳ DNS Recheck (primary + aliases)</button>
        </form>

        <form method="POST" action="/root/hosting/update">
          <input type="hidden" name="tenantId" value="<%= row.tenantId %>" />
          <input type="hidden" name="section" value="dns" />
          <div class="form-grid">
            <label>Domain status
              <select name="domainStatus">
                <% ['pending_dns','ssl_validating','active','failed'].forEach(function(st){ %>
                  <option value="<%= st %>" <%= row.domainStatus === st ? 'selected' : '' %>><%= st %></option>
                <% }) %>
              </select>
            </label>
            <label>DNS verified at <input type="text" name="dnsVerifiedAt" value="<%= row.dnsVerifiedAt || '' %>" placeholder="ISO datetime" /></label>
          </div>
          <div class="save-row">
            <div class="pw-row"><label>Root pw:</label><input type="password" name="rootPassword" required /></div>
            <button type="submit" class="btn-save">Save DNS status</button>
          </div>
        </form>
      </div>

      <%# ── SSL tab ── %>
      <div class="tab-panel" id="<%= ri %>-ssl">
        <form method="POST" action="/root/hosting/update">
          <input type="hidden" name="tenantId" value="<%= row.tenantId %>" />
          <input type="hidden" name="section" value="ssl" />
          <div class="form-grid">
            <label>SSL status
              <select name="sslStatus">
                <% ['pending','validating','active','failed'].forEach(function(st){ %>
                  <option value="<%= st %>" <%= (row.sslStatus || 'pending') === st ? 'selected' : '' %>><%= st %></option>
                <% }) %>
              </select>
            </label>
            <label>SSL provider <input type="text" name="sslProvider" value="<%= row.sslProvider || '' %>" placeholder="Railway, Let's Encrypt…" /></label>
            <label>Valid until <input type="text" name="sslValidUntil" value="<%= row.sslValidUntil || '' %>" placeholder="YYYY-MM-DD" /></label>
          </div>
          <div class="save-row">
            <div class="pw-row"><label>Root pw:</label><input type="password" name="rootPassword" required /></div>
            <button type="submit" class="btn-save">Save SSL</button>
          </div>
        </form>
      </div>

      <%# ── Footer tab ── %>
      <div class="tab-panel" id="<%= ri %>-footer">
        <p class="muted" style="margin-bottom:10px;">Controls the "Powered by" attribution link in the storefront footer.</p>
        <form method="POST" action="/root/hosting/update">
          <input type="hidden" name="tenantId" value="<%= row.tenantId %>" />
          <input type="hidden" name="section" value="footer" />
          <div class="form-grid">
            <label>Powered by mode
              <select name="poweredByMode">
                <option value="disabled"  <%= (row.poweredByMode || 'disabled') === 'disabled'  ? 'selected' : '' %>>disabled — never show</option>
                <option value="always"    <%= row.poweredByMode === 'always'    ? 'selected' : '' %>>always — always show</option>
                <option value="free_only" <%= row.poweredByMode === 'free_only' ? 'selected' : '' %>>free_only — only non-paid tenants</option>
              </select>
            </label>
            <label>Label override <input type="text" name="poweredByLabel" value="<%= row.poweredByLabel || '' %>" placeholder="Powered by Thronos Chain" /></label>
            <label>Href override <input type="text" name="poweredByHref" value="<%= row.poweredByHref || '' %>" placeholder="https://thronoschain.org" /></label>
          </div>
          <div class="save-row">
            <div class="pw-row"><label>Root pw:</label><input type="password" name="rootPassword" required /></div>
            <button type="submit" class="btn-save">Save Footer</button>
          </div>
        </form>
      </div>

      <%# ── Assistant tab ── %>
      <div class="tab-panel" id="<%= ri %>-assistant">
        <div class="status-row"><span class="status-label">VA widget</span> <span class="chip <%= row.vaEnabled ? 'ok' : 'pend' %>"><%= row.vaEnabled ? 'enabled' : 'disabled' %></span></div>
        <div class="status-row"><span class="status-label">VA mode</span> <code><%= row.vaMode || 'disabled' %></code></div>
        <div class="status-row"><span class="status-label">Backend URL</span> <span class="chip <%= row.vaBackendAvailable ? 'ok' : 'err' %>"><%= row.vaBackendAvailable ? 'configured' : 'MISSING' %></span></div>
        <% if (row.vaWarning) { %><div class="warn-box">⚠ <%= row.vaWarning %></div><% } %>
        <% if (!row.vaEnabled) { %><p class="muted">Widget disabled — tenant enables via Admin → Assistant.</p><% } %>
        <% if (row.vaEnabled && ['customer','both'].includes(row.vaMode) && row.vaBackendAvailable) { %>
        <div class="info-box">✓ VA widget is live and backend is configured.</div>
        <% } %>
        <p class="muted" style="margin-top:12px;">Backend URL is the global env var THRONOS_ASSISTANT_URL / ASSISTANT_API_URL. No per-tenant URL needed.</p>

        <div style="margin:12px 0;"><strong>Backend Health Check</strong></div>
        <button class="btn-recheck" onclick="checkAssistantHealth(<%= ri %>)">🏥 Check Health</button>
        <div id="health-<%= ri %>" style="margin:8px 0;"></div>
      </div>

      <%# ── Mail tab ── %>
      <div class="tab-panel" id="<%= ri %>-mail">
        <p class="muted" style="margin-bottom:10px;">Configure mail hosting and email delivery settings.</p>
        <form method="POST" action="/root/hosting/update">
          <input type="hidden" name="tenantId" value="<%= row.tenantId %>" />
          <input type="hidden" name="section" value="mail" />
          <div class="form-grid">
            <label>Mail provider
              <select name="mailProvider">
                <option value="">— Not configured —</option>
                <option value="sendgrid">SendGrid</option>
                <option value="mailgun">Mailgun</option>
                <option value="ses">Amazon SES</option>
                <option value="smtp">Custom SMTP</option>
              </select>
            </label>
            <label>MX records <input type="text" name="mxRecords" placeholder="Comma-separated MX records" /></label>
            <label>SPF record <input type="text" name="spfRecord" placeholder="v=spf1 ..." /></label>
            <label>DKIM records <input type="text" name="dkimRecords" placeholder="Comma-separated DKIM keys" /></label>
            <label>DMARC record <input type="text" name="dmarcRecord" placeholder="v=DMARC1 ..." /></label>
          </div>
          <div class="save-row">
            <div class="pw-row"><label>Root pw:</label><input type="password" name="rootPassword" required /></div>
            <button type="submit" class="btn-save">Save Mail Config</button>
          </div>
        </form>
      </div>

      <%# ── Web3 tab ── %>
      <div class="tab-panel" id="<%= ri %>-web3">
        <p class="muted" style="margin-bottom:10px;">Enable Web3 integration and IPFS configuration for decentralized hosting.</p>
        <form method="POST" action="/root/hosting/update">
          <input type="hidden" name="tenantId" value="<%= row.tenantId %>" />
          <input type="hidden" name="section" value="web3" />
          <div class="form-grid">
            <label style="flex-direction:row;align-items:center;padding-top:22px;gap:8px;">
              <input type="checkbox" name="web3Enabled" value="1" />
              Enable Web3 integration
            </label>
            <label>Web3 host <input type="text" name="web3Host" placeholder="web3.example.com" /></label>
            <label>IPFS gateway <input type="url" name="ipfsGateway" placeholder="https://gateway.pinata.cloud" /></label>
            <label>DNSLink TXT <input type="text" name="dnslinkTxt" placeholder="_dnslink=..." /></label>
          </div>
          <div class="save-row">
            <div class="pw-row"><label>Root pw:</label><input type="password" name="rootPassword" required /></div>
            <button type="submit" class="btn-save">Save Web3 Config</button>
          </div>
        </form>
      </div>

      <%# ── Advanced tab ── %>
      <div class="tab-panel" id="<%= ri %>-advanced">
        <div class="status-row"><span class="status-label">Branding</span>
          logo <span class="chip <%= row.logoConfigured ? 'ok' : 'warn' %>"><%= row.logoConfigured ? 'ok' : 'missing' %></span>
          favicon <span class="chip <%= row.faviconConfigured ? 'ok' : 'pend' %>"><%= row.faviconConfigured ? 'ok' : 'not set' %></span>
        </div>
        <div class="status-row"><span class="status-label">Intro</span>
          <span class="chip <%= row.introConfigured ? 'ok' : 'pend' %>"><%= row.introConfigured ? 'enabled' : 'off' %></span>
          asset <span class="chip <%= row.introAssetConfigured ? 'ok' : 'pend' %>"><%= row.introAssetConfigured ? 'set' : 'none' %></span>
        </div>
        <div class="status-row"><span class="status-label">Storage</span> <%= Number.isFinite(row.storageUsageMb) ? row.storageUsageMb + ' MB' : 'N/A' %></div>
        <form method="POST" action="/root/hosting/update" style="margin-top:12px;">
          <input type="hidden" name="tenantId" value="<%= row.tenantId %>" />
          <input type="hidden" name="section" value="advanced" />
          <div class="form-grid">
            <label>Backup status
              <select name="backupStatus">
                <% ['unknown','healthy','warning','failed'].forEach(function(st){ %>
                  <option value="<%= st %>" <%= (row.backupStatus || 'unknown') === st ? 'selected' : '' %>><%= st %></option>
                <% }) %>
              </select>
            </label>
            <label style="flex-direction:row;align-items:center;padding-top:22px;gap:8px;">
              <input type="checkbox" name="issueFlag" value="1" <%= row.issueFlag ? 'checked' : '' %> />
              Issue flag
            </label>
            <label class="full">Tenant note <input type="text" name="tenantNotes" value="<%= row.tenantNotes || '' %>" /></label>
            <label class="full">Internal note <input type="text" name="internalNotes" value="<%= row.internalNotes || '' %>" /></label>
          </div>
          <div class="save-row">
            <div class="pw-row"><label>Root pw:</label><input type="password" name="rootPassword" required /></div>
            <button type="submit" class="btn-save">Save Advanced</button>
          </div>
        </form>
      </div>
    </details>
    <% }) %>
  </main>
  <script>
  function switchTab(btn, ri) {
    var tabId = btn.getAttribute('data-tab');
    document.getElementById('tabs-' + ri).querySelectorAll('.tab-btn').forEach(function(b){ b.classList.remove('active'); });
    btn.classList.add('active');
    btn.closest('details').querySelectorAll('.tab-panel').forEach(function(p){ p.classList.remove('active'); });
    var panel = document.getElementById(tabId);
    if (panel) panel.classList.add('active');
  }
  (function(){
    var h = location.hash;
    if (h && h.startsWith('#tc-')) {
      var el = document.querySelector('details' + h);
      if (el) { el.open = true; el.scrollIntoView({ behavior:'smooth', block:'start' }); }
    }
  })();

  async function checkAssistantHealth(ri) {
    var resultDiv = document.getElementById('health-' + ri);
    resultDiv.innerHTML = '<p class="muted" style="font-style:italic;">Checking...</p>';
    try {
      var response = await fetch('/root/hosting/assistant-health', { method: 'POST' });
      var data = await response.json();
      var html = '';
      if (data.ok) {
        html = '<div class="info-box" style="background:#dcfce7;border-color:#86efac;"><strong style="color:#15803d;">✓ Healthy</strong><br/>' +
               'Status: ' + (data.status || '?') + '<br/>' +
               (data.responseTime ? 'Response time: ' + data.responseTime + 'ms<br/>' : '') +
               'Message: ' + (data.message || '') + '</div>';
      } else {
        html = '<div class="warn-box"><strong style="color:#991b1b;">✗ Unhealthy</strong><br/>' +
               'Status: ' + (data.status || '?') + '<br/>' +
               'Message: ' + (data.message || 'Unknown error') + '</div>';
      }
      resultDiv.innerHTML = html;
    } catch (err) {
      resultDiv.innerHTML = '<div class="warn-box"><strong>Error:</strong> ' + err.message + '</div>';
    }
  }
  </script>
</body>
</html>
