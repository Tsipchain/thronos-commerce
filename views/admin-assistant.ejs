<!DOCTYPE html>
<html lang="<%= locals.lang || 'el' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Βοηθός &mdash; <%= locals.tenant && locals.tenant.id ? locals.tenant.id : 'Admin' %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f5; color: #222; }

    /* ---- layout ---- */
    .aa-wrap { display: flex; min-height: 100vh; }
    .aa-sidebar { width: 240px; background: #1a1a2e; color: #cdd; flex-shrink: 0; padding: 24px 0; }
    .aa-sidebar h2 { font-size: 14px; text-transform: uppercase; letter-spacing: .1em; color: #88a; padding: 0 20px 16px; }
    .aa-sidebar a { display: flex; align-items: center; gap: 10px; padding: 10px 20px; color: #aab; text-decoration: none; font-size: 14px; transition: background .15s; }
    .aa-sidebar a:hover, .aa-sidebar a.active { background: #2a2a4e; color: #fff; }
    .aa-main { flex: 1; display: flex; flex-direction: column; max-height: 100vh; overflow: hidden; }

    /* ---- top bar ---- */
    .aa-topbar { background: #fff; border-bottom: 1px solid #e5e5e5; padding: 14px 24px; display: flex; align-items: center; justify-content: space-between; }
    .aa-topbar h1 { font-size: 18px; font-weight: 600; }
    .aa-topbar .section-badge { font-size: 12px; background: #e8f0fe; color: #1a73e8; padding: 3px 10px; border-radius: 12px; }

    /* ---- tabs ---- */
    .aa-tabs { display: flex; background: #fff; border-bottom: 1px solid #e5e5e5; padding: 0 24px; }
    .aa-tab { padding: 12px 18px; font-size: 14px; cursor: pointer; border-bottom: 2px solid transparent; color: #666; user-select: none; }
    .aa-tab.active { border-bottom-color: #1a73e8; color: #1a73e8; font-weight: 600; }

    /* ---- chat area ---- */
    .aa-content { flex: 1; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 16px; }
    .aa-content.hidden { display: none; }

    .msg { display: flex; gap: 12px; max-width: 780px; }
    .msg.user { align-self: flex-end; flex-direction: row-reverse; }
    .msg-avatar { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; }
    .msg.user .msg-avatar { background: #1a73e8; color: #fff; }
    .msg.bot .msg-avatar { background: #e8f0fe; color: #1a73e8; }
    .msg-bubble { background: #fff; border: 1px solid #e5e5e5; border-radius: 12px; padding: 12px 16px; font-size: 14px; line-height: 1.6; }
    .msg.user .msg-bubble { background: #1a73e8; color: #fff; border-color: transparent; }
    .msg-time { font-size: 11px; color: #999; margin-top: 4px; }

    /* ---- proposals ---- */
    .proposal-card { background: #fff; border: 1px solid #e5e5e5; border-radius: 10px; margin-top: 12px; overflow: hidden; }
    .proposal-header { background: #f8f9fa; padding: 10px 14px; font-size: 13px; font-weight: 600; color: #444; border-bottom: 1px solid #e5e5e5; display: flex; align-items: center; gap: 8px; }
    .proposal-header .badge { font-size: 11px; padding: 2px 8px; border-radius: 10px; }
    .badge-safe { background: #e6f4ea; color: #1e7e34; }
    .badge-sensitive { background: #fff3cd; color: #856404; }
    .proposal-body { padding: 12px 14px; }
    .patch-row { display: flex; gap: 8px; align-items: flex-start; margin-bottom: 8px; font-size: 13px; }
    .patch-row code { background: #f1f3f4; border-radius: 4px; padding: 2px 6px; font-size: 12px; }
    .patch-desc { color: #555; }
    .patch-diff { display: flex; gap: 8px; font-size: 12px; }
    .patch-old { color: #d93025; }
    .patch-new { color: #1e7e34; }
    .proposal-actions { padding: 12px 14px; display: flex; gap: 10px; align-items: center; border-top: 1px solid #f0f0f0; }
    .btn { padding: 8px 18px; border-radius: 6px; border: none; cursor: pointer; font-size: 14px; font-weight: 500; transition: opacity .15s; }
    .btn:disabled { opacity: .5; cursor: not-allowed; }
    .btn-primary { background: #1a73e8; color: #fff; }
    .btn-primary:hover:not(:disabled) { background: #1557b0; }
    .btn-danger { background: #d93025; color: #fff; }
    .btn-danger:hover:not(:disabled) { background: #b52d21; }
    .btn-ghost { background: transparent; color: #666; border: 1px solid #ddd; }
    .btn-ghost:hover:not(:disabled) { background: #f5f5f5; }
    .pw-field { border: 1px solid #ddd; border-radius: 6px; padding: 7px 12px; font-size: 14px; width: 200px; }

    /* ---- input bar ---- */
    .aa-inputbar { background: #fff; border-top: 1px solid #e5e5e5; padding: 16px 24px; display: flex; gap: 12px; align-items: flex-end; }
    .aa-input { flex: 1; border: 1px solid #ddd; border-radius: 10px; padding: 10px 14px; font-size: 14px; resize: none; font-family: inherit; min-height: 44px; max-height: 120px; outline: none; }
    .aa-input:focus { border-color: #1a73e8; }
    .aa-send { width: 44px; height: 44px; border-radius: 50%; background: #1a73e8; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #fff; flex-shrink: 0; }
    .aa-send:disabled { background: #ccc; cursor: not-allowed; }
    .section-select { border: 1px solid #ddd; border-radius: 6px; padding: 6px 10px; font-size: 13px; color: #444; }

    /* ---- audit log ---- */
    .audit-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .audit-table th { text-align: left; padding: 8px 12px; background: #f8f9fa; border-bottom: 2px solid #e5e5e5; font-weight: 600; color: #555; }
    .audit-table td { padding: 8px 12px; border-bottom: 1px solid #f0f0f0; vertical-align: top; }
    .audit-table tr:hover td { background: #f9f9f9; }
    .action-chat { color: #1a73e8; }
    .action-approve { color: #1e7e34; }
    .action-reject { color: #d93025; }

    /* ---- empty state ---- */
    .aa-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; color: #999; padding: 60px 20px; text-align: center; }
    .aa-empty .icon { font-size: 48px; }

    /* ---- status bar ---- */
    .aa-status { font-size: 13px; color: #888; padding: 4px 0 0; }
    .aa-status.error { color: #d93025; }
    .typing-dots::after { content: '...'; animation: dots 1.2s infinite; }
    @keyframes dots { 0%,20% { content: '.'; } 40%,60% { content: '..'; } 80%,100% { content: '...'; } }
  </style>
</head>
<body>
<div class="aa-wrap">

  <!-- Sidebar -->
  <nav class="aa-sidebar">
    <h2><%= locals.tenant && locals.tenant.id ? locals.tenant.id : 'Admin' %></h2>
    <a href="<%= withTenantLink('/admin') %>">&#9632; Dashboard</a>
    <a href="<%= withTenantLink('/admin') + '#tab-branding' %>">🎨 Branding</a>
    <a href="<%= withTenantLink('/admin') + '#tab-homepage' %>">🏠 Homepage</a>
    <a href="<%= withTenantLink('/admin/orders') %>">📦 Orders</a>
    <a href="<%= withTenantLink('/admin/payments') %>">💳 Payments</a>
    <a href="<%= withTenantLink('/admin') + '#tab-notifications' %>">🔔 Notifications</a>
    <a href="<%= withTenantLink('/admin') + '#tab-assistant' %>">🤖 Storefront Config</a>
    <a href="<%= withTenantLink('/admin/assistant-panel') %>" class="active">✨ AI Admin Panel</a>
    <a href="<%= withTenantLink('/admin/logout') %>" style="margin-top:auto;color:#f88;">&#x2192; Logout</a>
  </nav>

  <!-- Main -->
  <div class="aa-main">

    <!-- Top bar -->
    <div class="aa-topbar">
      <h1>Tenant Admin Assistant Panel</h1>
      <span class="section-badge" id="sectionBadge">Chat</span>
    </div>

    <!-- Tabs -->
    <div class="aa-tabs">
      <div class="aa-tab active" data-tab="chat">💬 Chat</div>
      <div class="aa-tab" data-tab="audit">📜 Audit Log</div>
    </div>

    <!-- Chat content -->
    <div class="aa-content" id="chatContent">
      <div class="aa-empty" id="emptyState">
        <div class="icon">✨</div>
        <div><strong>Βοηθός</strong> — AI βοηθός του καταστήματός σας</div>
        <div>Ρωτήστε για αλλαγές branding, ρυθμίσεις βοηθού, συστάσεις αρχικής σελίδας, και άλλα.</div>
      </div>
    </div>

    <!-- Audit log content -->
    <div class="aa-content hidden" id="auditContent">
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <h3 style="font-size:15px;">Audit Log</h3>
        <button class="btn btn-ghost" onclick="loadAuditLog()">&#x21bb; Refresh</button>
      </div>
      <div id="auditBody"><em style="color:#999;">Loading...</em></div>
    </div>

    <!-- Input bar (chat only) -->
    <div class="aa-inputbar" id="inputBar">
      <select class="section-select" id="sectionSelect">
        <option value="">General</option>
        <option value="branding">Branding</option>
        <option value="homepage">Homepage</option>
        <option value="products">Products</option>
        <option value="payments">Payments</option>
        <option value="notifications">Notifications</option>
        <option value="assistant">Assistant</option>
      </select>
      <textarea class="aa-input" id="msgInput" rows="1" placeholder="Ask the assistant... (Shift+Enter for newline)" maxlength="2000"></textarea>
      <button class="aa-send" id="sendBtn" title="Send">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
    <div class="aa-status" id="statusBar" style="padding:4px 24px 12px;"></div>

  </div>
</div>

<script>
(function () {
  'use strict';

  // Tenant-scoped API endpoints injected server-side (never hard-coded).
  const URL_CHAT      = '<%= withTenantLink("/admin/assistant-panel/chat") %>';
  const URL_APPROVE   = '<%= withTenantLink("/admin/assistant-panel/approve") %>';
  const URL_AUDIT_LOG = '<%= withTenantLink("/admin/assistant-panel/audit-log") %>';

  const chatContent  = document.getElementById('chatContent');
  const auditContent = document.getElementById('auditContent');
  const inputBar     = document.getElementById('inputBar');
  const statusBar    = document.getElementById('statusBar');
  const msgInput     = document.getElementById('msgInput');
  const sendBtn      = document.getElementById('sendBtn');
  const emptyState   = document.getElementById('emptyState');
  const sectionSel   = document.getElementById('sectionSelect');
  const sectionBadge = document.getElementById('sectionBadge');

  let history = []; // [{role, content}]
  let sending  = false;

  // ------------------------------------------------------------------ //
  // Tabs                                                                 //
  // ------------------------------------------------------------------ //
  document.querySelectorAll('.aa-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.aa-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const name = tab.dataset.tab;
      chatContent.classList.toggle('hidden', name !== 'chat');
      auditContent.classList.toggle('hidden', name !== 'audit');
      inputBar.style.display = name === 'chat' ? '' : 'none';
      statusBar.style.display = name === 'chat' ? '' : 'none';
      if (name === 'audit') loadAuditLog();
    });
  });

  sectionSel.addEventListener('change', () => {
    sectionBadge.textContent = sectionSel.options[sectionSel.selectedIndex].text;
  });

  // ------------------------------------------------------------------ //
  // Chat                                                                 //
  // ------------------------------------------------------------------ //
  function ts() {
    return new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  }

  function appendMessage(role, text) {
    if (emptyState) emptyState.remove();
    const div = document.createElement('div');
    div.className = `msg ${role}`;
    div.innerHTML = `
      <div class="msg-avatar">${role === 'user' ? 'A' : '✨'}</div>
      <div>
        <div class="msg-bubble">${escHtml(text).replace(/\n/g, '<br>')}</div>
        <div class="msg-time">${ts()}</div>
      </div>`;
    chatContent.appendChild(div);
    chatContent.scrollTop = chatContent.scrollHeight;
    return div;
  }

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function appendProposals(proposals) {
    if (!proposals || !proposals.length) return;
    if (emptyState) emptyState.remove();

    const card = document.createElement('div');
    card.className = 'proposal-card';

    const hasSensitive = proposals.some(p => p.requires_password);
    card.innerHTML = `
      <div class="proposal-header">
        📝 Proposed changes
        <span class="badge ${hasSensitive ? 'badge-sensitive' : 'badge-safe'}">
          ${hasSensitive ? 'Requires password' : 'Safe'}
        </span>
      </div>
      <div class="proposal-body">
        ${proposals.map(p => `
          <div class="patch-row">
            <code>${escHtml(p.field_path)}</code>
            <div>
              <div class="patch-desc">${escHtml(p.description)}</div>
              <div class="patch-diff">
                <span class="patch-old">− ${escHtml(String(p.current_value ?? ''))}</span>
                <span class="patch-new">+ ${escHtml(String(p.proposed_value ?? ''))}</span>
              </div>
            </div>
          </div>`).join('')}
      </div>
      <div class="proposal-actions">
        ${hasSensitive ? '<input type="password" class="pw-field" placeholder="Κωδικός διαχειριστή" id="pw_' + Date.now() + '">' : ''}
        <button class="btn btn-primary" data-approve="1">✓ Approve</button>
        <button class="btn btn-ghost" data-reject="1">✕ Reject</button>
        <span class="aa-status" style="margin-left:8px;"></span>
      </div>`;

    const approveBtn = card.querySelector('[data-approve]');
    const rejectBtn  = card.querySelector('[data-reject]');
    const pwInput    = card.querySelector('.pw-field');
    const patchStatus = card.querySelector('.proposal-actions .aa-status');

    approveBtn.addEventListener('click', async () => {
      approveBtn.disabled = true;
      rejectBtn.disabled  = true;
      patchStatus.textContent = 'Υποβολή...';
      try {
        const body = { patches: proposals };
        if (pwInput) body.password = pwInput.value;
        const r = await fetch(URL_APPROVE, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify(body),
        });
        const d = await r.json();
        if (r.ok && d.ok) {
          patchStatus.textContent = '✓ Applied: ' + d.applied.join(', ');
          patchStatus.style.color = '#1e7e34';
          approveBtn.style.display = 'none';
          rejectBtn.style.display  = 'none';
        } else {
          patchStatus.textContent = d.error || 'Error';
          patchStatus.style.color = '#d93025';
          approveBtn.disabled = false;
          rejectBtn.disabled  = false;
        }
      } catch {
        patchStatus.textContent = 'Network error';
        patchStatus.style.color = '#d93025';
        approveBtn.disabled = false;
        rejectBtn.disabled  = false;
      }
    });

    rejectBtn.addEventListener('click', () => {
      patchStatus.textContent = 'Rejected.';
      approveBtn.style.display = 'none';
      rejectBtn.style.display  = 'none';
    });

    chatContent.appendChild(card);
    chatContent.scrollTop = chatContent.scrollHeight;
  }

  async function sendMessage() {
    const text = msgInput.value.trim();
    if (!text || sending) return;
    sending = true;
    sendBtn.disabled = true;
    msgInput.value = '';
    statusBar.textContent = '';
    statusBar.className = 'aa-status';

    appendMessage('user', text);
    const typingDiv = appendMessage('bot', '⋯');
    typingDiv.querySelector('.msg-bubble').innerHTML = '<span class="typing-dots"></span>';

    history.push({ role: 'user', content: text });

    try {
      const r = await fetch(URL_CHAT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({
          message: text,
          section: sectionSel.value || null,
          conversationHistory: history.slice(-10),
        }),
      });
      const d = await r.json();
      typingDiv.remove();

      if (!r.ok) {
        appendMessage('bot', d.error || 'Error: ' + r.status);
        history.pop();
      } else {
        appendMessage('bot', d.response || '');
        history.push({ role: 'assistant', content: d.response || '' });
        if (d.proposed_patches && d.proposed_patches.length) {
          appendProposals(d.proposed_patches);
        }
      }
    } catch {
      typingDiv.remove();
      statusBar.textContent = 'Network error — please retry.';
      statusBar.className = 'aa-status error';
      history.pop();
    } finally {
      sending = false;
      sendBtn.disabled = false;
      msgInput.focus();
    }
  }

  sendBtn.addEventListener('click', sendMessage);
  msgInput.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  });
  msgInput.addEventListener('input', () => {
    msgInput.style.height = 'auto';
    msgInput.style.height = Math.min(msgInput.scrollHeight, 120) + 'px';
  });

  // ------------------------------------------------------------------ //
  // Audit log                                                            //
  // ------------------------------------------------------------------ //
  async function loadAuditLog() {
    document.getElementById('auditBody').innerHTML = '<em style="color:#999;">Loading...</em>';
    try {
      const r = await fetch(URL_AUDIT_LOG + '?limit=100', { credentials: 'same-origin' });
      const d = await r.json();
      const entries = d.entries || [];
      if (!entries.length) {
        document.getElementById('auditBody').innerHTML = '<em style="color:#999;">No entries yet.</em>';
        return;
      }
      const rows = entries.map(e => `
        <tr>
          <td>${escHtml(e.timestamp ? e.timestamp.replace('T',' ').slice(0,19) : '')}</td>
          <td class="action-${escHtml(e.action || '')}">${escHtml(e.action || '')}</td>
          <td>${escHtml(e.message || (e.patches ? e.patches.map(p=>p.field_path).join(', ') : ''))}</td>
          <td>${escHtml(e.intent || e.section || '')}</td>
        </tr>`).join('');
      document.getElementById('auditBody').innerHTML = `
        <table class="audit-table">
          <thead><tr><th>Time</th><th>Action</th><th>Detail</th><th>Context</th></tr></thead>
          <tbody>${rows}</tbody>
        </table>`;
    } catch {
      document.getElementById('auditBody').innerHTML = '<em style="color:#d93025;">Failed to load audit log.</em>';
    }
  }

  msgInput.focus();
})();
</script>
</body>
</html>
