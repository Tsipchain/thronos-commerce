<!DOCTYPE html>
<html lang="<%= lang %>">
  <head>
    <meta charset="UTF-8" />
    <title><%= config.storeName %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.ico" />
    <link rel="stylesheet" href="/styles.css" />
    <style>
      :root {
        --primary-color: <%= config.primaryColor %>;
        --accent-color: <%= config.accentColor %>;
        --font-family: <%= config.fontFamily %>;
        --menu-bg: <%= (config.theme && config.theme.menuBg) || '#111' %>;
        --menu-text: <%= (config.theme && config.theme.menuText) || '#fff' %>;
        --menu-active-bg: <%= (config.theme && config.theme.menuActiveBg) || '#f06292' %>;
        --menu-active-text: <%= (config.theme && config.theme.menuActiveText) || '#fff' %>;
        --button-radius: <%= (config.theme && config.theme.buttonRadius) || '4px' %>;
      }
      .lang-switcher { padding: 8px 16px; background: rgba(0,0,0,.06); font-size: 0.8rem; display:flex; align-items:center; gap:8px; }
      .lang-switcher select { padding: 4px 8px; border:1px solid #d1d5db; border-radius:6px; background:#fff; }

      /* ── Product grid ── */
      .product-list {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        padding: 20px 0;
      }
      @media (max-width: 900px) { .product-list { grid-template-columns: repeat(2, 1fr); } }
      @media (max-width: 560px) { .product-list { grid-template-columns: 1fr; } }

      .product-card {
        border: 1px solid #e8e8e8; border-radius: 8px;
        overflow: hidden; background: #fff;
        display: flex; flex-direction: column;
        transition: box-shadow .2s;
      }
      .product-card:hover { box-shadow: 0 4px 18px rgba(0,0,0,.1); }
      .product-card .product-thumb {
        width: 100%; aspect-ratio: 1; overflow: hidden; background: #f5f5f5;
      }
      .product-card .product-thumb img {
        width: 100%; height: 100%; object-fit: cover; display: block;
      }
      .product-card-body { padding: 14px 16px; flex: 1; display: flex; flex-direction: column; }
      .product-card h2 { font-size: 0.95rem; margin: 0 0 6px; }
      .product-card p  { font-size: 0.82rem; color: #555; margin: 0 0 8px; flex: 1;
                         display: -webkit-box; -webkit-line-clamp: 3;
                         -webkit-box-orient: vertical; overflow: hidden; }
      .product-card .price { font-size: 1.1rem; font-weight: 700; color: var(--primary-color); margin: 0 0 12px; }
      .product-card .button { align-self: flex-start; font-size: 0.85rem; padding: 7px 16px; }
      .product-card .card-actions { display: flex; gap: 8px; flex-wrap: wrap; margin-top: auto; }
      .btn-cart {
        padding: 7px 14px; font-size: 0.82rem; font-weight: 600; border: none; cursor: pointer;
        border-radius: var(--button-radius, 4px); background: var(--primary-color);
        color: #fff; transition: opacity .15s;
      }
      .btn-cart:hover { opacity: .85; }
      .btn-cart:disabled { opacity: .45; cursor: not-allowed; }
      .featured-badge {
        position: absolute; top: 8px; left: 8px;
        background: #f59e0b; color: #fff; font-size: 0.68rem; font-weight: 700;
        padding: 2px 8px; border-radius: 20px; letter-spacing: .04em; pointer-events: none;
      }
      .product-thumb { position: relative; }
      .featured-section { margin-bottom: 32px; }
      .featured-section h2 {
        font-size: 1.1rem; font-weight: 700; margin: 0 0 14px;
        color: var(--primary-color); display: flex; align-items: center; gap: 8px;
      }
      .stock-pill {
        font-size: 0.72rem; padding: 1px 7px; border-radius: 20px; margin-left: 4px;
        font-weight: 600;
      }
      .stock-pill.ok  { background: #d1fae5; color: #065f46; }
      .stock-pill.low { background: #fef3c7; color: #92400e; }
      .stock-pill.out { background: #fee2e2; color: #991b1b; }
      .cat-logo { width:22px;height:22px;object-fit:cover;border-radius:50%;vertical-align:middle;margin-right:6px; }
      .category-cards { display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin:14px 0 8px; }
      .category-card { border:1px solid #e5e7eb;border-radius:10px;padding:8px;text-decoration:none;color:inherit;text-align:center;background:#fff; }
      .category-card img { width:100%;height:60px;object-fit:cover;border-radius:8px;margin-bottom:6px; }
      .logo-title.centered { width:100%; justify-content:center; text-align:center; }
      .hero.strong { background:linear-gradient(130deg,#111827,#1f2937); color:#fff; border-radius:12px; padding:24px; }
      .category-card.only-image div { display:none; }
      body.cursor-tool { cursor: crosshair; }
      .hero .hero-title { margin: 0 0 8px; font-size: clamp(1.2rem, 2.2vw, 1.9rem); }
      .hero .hero-actions { margin-top: 12px; display:flex; gap:10px; flex-wrap:wrap; }
      .hero .hero-actions a { text-decoration:none; }
      .category-card.featured { border-color: var(--accent-color); box-shadow: 0 8px 20px rgba(0,0,0,.08); }
      .category-card small { display:block; color:#6b7280; margin-top:3px; font-size:.74rem; }
      .store-header.premium { background: linear-gradient(135deg,#0f172a,#1f2937); border-bottom: 1px solid rgba(255,255,255,.08); }
      .branding-mode-logo_only .store-name-wrap, .branding-mode-name_only .logo-frame { display:none; }
      .logo-frame { display:inline-flex; align-items:center; justify-content:center; }
      .logo-frame.logo-frame-dark { background: rgba(15,23,42,.88); }
      .logo-frame.logo-frame-clean { background: rgba(255,255,255,.9); border: 1px solid rgba(15,23,42,.1); }
      .logo-frame.logo-frame-floating { background: rgba(255,255,255,.08); backdrop-filter: blur(3px); }
      .logo-frame img { display:block; max-width: 240px; }
      .logo-image.cover { object-fit: cover; }
      .logo-image.contain { object-fit: contain; }
      .logo-image.clean_badge { object-fit: contain; filter: contrast(1.05) saturate(1.05); }
      .logo-image.transparent_blend { object-fit: contain; mix-blend-mode: screen; opacity: .95; }
      .pill-nav { display:flex; gap:8px; flex-wrap:wrap; margin-top:10px; }
      .pill-nav a { text-decoration:none; padding:6px 12px; border-radius:999px; background:rgba(255,255,255,.12); color:#fff; font-size:.85rem; }
      .pill-nav a.active { background:#f59e0b; color:#111827; font-weight:700; }
      .pill-nav .pill-item { display:inline-flex; align-items:center; gap:6px; }
      .pill-nav .pill-item img { width:20px; height:20px; border-radius:999px; object-fit:cover; }
      .home-secondary { border:1px solid #e5e7eb; border-radius:12px; padding:14px; background:#fff; }
      .store-footer { margin-top:26px; padding:18px 0; color:#6b7280; font-size:.85rem; border-top:1px solid #e5e7eb; }
      .featured-primary-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:16px; }
      .featured-kit-card { background:#fff; border:1px solid #e5e7eb; border-radius:14px; overflow:hidden; transition:transform .18s ease, box-shadow .18s ease; }
      .featured-kit-card:hover { transform: translateY(-2px); box-shadow: 0 12px 26px rgba(0,0,0,.12); }
      .featured-kit-card img { width:100%; height:220px; object-fit:cover; display:block; }
      .featured-kit-card .body { padding:12px 14px; }
      .kit-badge { display:inline-block; font-size:.72rem; font-weight:700; background:#0f766e; color:#fff; border-radius:999px; padding:3px 9px; margin-bottom:8px; }
      .kit-clickable { cursor: pointer; }
      .kit-wizard-backdrop { position: fixed; inset: 0; background: rgba(15,23,42,.58); z-index: 1200; display: none; padding: 24px; }
      .kit-wizard-backdrop.open { display: block; }
      .kit-wizard-modal { max-width: 920px; width: 100%; margin: 0 auto; background: #fff; border-radius: 14px; box-shadow: 0 22px 52px rgba(0,0,0,.35); max-height: calc(100vh - 48px); overflow: auto; }
      .kit-wizard-head { padding: 14px 16px; border-bottom: 1px solid #e5e7eb; display:flex; justify-content:space-between; gap:10px; align-items:center; }
      .kit-wizard-body { display:grid; grid-template-columns: 1.2fr .9fr; gap: 14px; padding: 14px 16px; }
      .kit-choice-grid { display:grid; gap:10px; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
      .kit-choice { border:1px solid #d1d5db; border-radius:10px; padding:10px; display:flex; gap:10px; cursor:pointer; align-items:flex-start; }
      .kit-choice.selected { border-color: #0f766e; box-shadow: 0 0 0 2px rgba(15,118,110,.12); }
      .kit-choice img { width:56px; height:56px; object-fit:cover; border-radius:8px; }
      .kit-preview { border:1px solid #e5e7eb; border-radius:10px; padding:8px; min-height:140px; background:#f8fafc; }
      .kit-preview img { width:100%; max-height:220px; object-fit:contain; border-radius:8px; background:#fff; }
      .kit-summary-line { font-size:.84rem; color:#334155; margin:4px 0; }
      .kit-wizard-foot { border-top:1px solid #e5e7eb; padding:12px 16px; display:flex; justify-content:space-between; gap:10px; align-items:center; flex-wrap:wrap; }
      .kit-total { font-weight:800; font-size:1.05rem; color:#0f172a; }
      .kit-progress { font-size:.82rem; color:#475569; font-weight:600; }
      @media (max-width: 760px) { .featured-primary-grid { grid-template-columns:1fr; } }
      @media (max-width: 640px) {
        .category-cards { display:flex; overflow-x:auto; gap:10px; padding-bottom:4px; }
        .category-card { min-width: 150px; }
        .kit-wizard-backdrop { padding: 0; }
        .kit-wizard-modal { border-radius: 0; max-height: 100vh; height: 100vh; }
        .kit-wizard-body { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <% const theme = config.theme || {}; %>
    <% const brandingMode = theme.brandingMode || 'logo_name'; %>
    <% const logoBgMode = theme.logoBgMode || 'auto'; %>
    <% const logoFrameClass = logoBgMode === 'dark_badge' ? 'logo-frame-dark' : (logoBgMode === 'light_badge' ? 'logo-frame-clean' : (logoBgMode === 'none' ? '' : 'logo-frame-floating')); %>
    <header class="store-header <%= tenant.id === 'eukolakis' ? 'premium' : '' %> branding-mode-<%= brandingMode %>">
      <div class="logo-title <%= theme.headerLayout === 'centered' ? 'centered' : '' %>">
        <% if (config.logoPath && brandingMode !== 'name_only') { %>
          <span class="logo-frame <%= logoFrameClass %>" style="padding:<%= Number(theme.logoPadding || 6) %>px;border-radius:<%= Number(theme.logoRadius || 10) %>px;box-shadow:<%= theme.logoShadow === 'floating' ? '0 12px 24px rgba(0,0,0,.25)' : (theme.logoShadow === 'none' ? 'none' : '0 3px 10px rgba(0,0,0,.12)') %>;">
            <img src="<%= config.logoPath %>" alt="<%= config.storeName %>" class="logo logo-image <%= theme.logoDisplayMode || 'contain' %>" style="max-height:<%= Number(theme.logoMaxHeight || 52) %>px;" />
          </span>
        <% } %>
        <% if (brandingMode !== 'logo_only') { %>
        <div class="store-name-wrap">
          <h1><%= config.storeName %></h1>
          <% if (config.web3Domain) { %>
            <p class="subtitle"><%= t('storefront.web3Domain') %>: <%= config.web3Domain %></p>
          <% } %>
        </div>
        <% } %>
      </div>
      <button class="menu-toggle" id="menu-toggle" type="button"><%= t('storefront.menuToggle') %></button>
      <nav class="main-nav" id="main-nav">
        <ul>
          <li class="<%= !activeCategory ? 'active' : '' %>">
            <a href="<%= withTenantLink('/', lang !== 'el' ? { lang } : {}) %>"><%= t('storefront.allProducts') %></a>
          </li>
          <% if (!theme.categoryMenuStyle || theme.categoryMenuStyle === 'text') { %>
            <% categories.forEach(function(cat) { %>
              <li class="<%= activeCategory === cat.slug ? 'active' : '' %>">
                <a href="<%= withTenantLink('/', Object.assign({ category: cat.slug }, lang !== 'el' ? { lang } : {})) %>">
                  <% if (cat.image) { %><img src="<%= cat.image %>" alt="<%= cat.name %>" class="cat-logo" /><% } %><%= cat.name %>
                </a>
              </li>
            <% }); %>
          <% } %>
          <% if (!user) { %>
            <li><a href="<%= withTenantLink('/login', lang !== 'el' ? { lang } : {}) %>">Login</a></li>
            <li><a href="<%= withTenantLink('/signup', lang !== 'el' ? { lang } : {}) %>">Signup</a></li>
          <% } else { %>
            <li><a href="<%= withTenantLink('/account', lang !== 'el' ? { lang } : {}) %>">My Account</a></li>
            <li><a href="<%= withTenantLink('/my-orders', lang !== 'el' ? { lang } : {}) %>">My Orders</a></li>
            <li><a href="<%= withTenantLink('/logout', lang !== 'el' ? { lang } : {}) %>">Logout</a></li>
          <% } %>
        </ul>
      </nav>
      <% const navCategories = categories.filter(function(c){ return c.showInMainNav !== false; }).sort(function(a,b){ return (Number(a.navOrder) || 999) - (Number(b.navOrder) || 999); }); %>
      <% if (tenant.id === 'eukolakis') { %>
      <div class="pill-nav">
        <% const navHomepage = config.homepage || {}; %>
        <% navCategories.forEach(function(cat){ %>
          <a class="pill-item <%= activeCategory === cat.slug ? 'active' : '' %>" href="<%= withTenantLink('/', Object.assign({ category: cat.slug }, lang !== 'el' ? { lang } : {})) %>">
            <% if (cat.image) { %><img src="<%= cat.image %>" alt="<%= cat.name %>" /><% } %>
            <span><%= cat.name %></span>
          </a>
        <% }) %>
        <% const subscriptionCategory = categories.find(function(c){ return c.slug === 'subscriptions'; }); %>
        <% if (subscriptionCategory) { %>
          <a class="pill-item <%= activeCategory === subscriptionCategory.slug ? 'active' : '' %>" href="<%= withTenantLink('/', Object.assign({ category: subscriptionCategory.slug }, lang !== 'el' ? { lang } : {})) %>"><span><%= subscriptionCategory.name %></span></a>
        <% } else if (navHomepage.showSubscriptionsCard) { %>
          <a class="pill-item" href="<%= withTenantLink('/content', lang !== 'el' ? { lang } : {}) %>"><span><%= lang === 'el' ? 'Συνδρομές / Videos' : 'Subscriptions / Videos' %></span></a>
        <% } %>
      </div>
      <% } %>
    </header>

    <% if (isPreviewMode) { %>
    <div style="padding:8px 16px;background:#fff7ed;border-bottom:1px solid #fed7aa;color:#9a3412;font-size:.85rem;">
      <strong>Preview Mode</strong> – this store is not live yet. Tenant: <strong><%= tenantId %></strong>
    </div>
    <% } %>

    <div class="lang-switcher">
      <label for="lang-switch"><%= t('storefront.langLabel') %>:</label>
      <select id="lang-switch" onchange="window.location.href=this.value">
        <% (contentLangs || ['el','en']).forEach(function(l) { %>
          <% const optionUrl = withTenantLink('/', Object.assign(activeCategory ? { category: activeCategory } : {}, { lang: l })); %>
          <option value="<%= optionUrl %>" <%= lang === l ? 'selected' : '' %>><%= l === 'el' ? 'Ελληνικά' : 'English' %></option>
        <% }) %>
      </select>
    </div>

    <main>
      <% const homepage = config.homepage || {}; %>
      <% const hpFeaturedPrimary = Array.isArray(homepage.featuredPrimary) ? homepage.featuredPrimary : (Array.isArray(homepage.featuredIds) ? homepage.featuredIds.slice(0,2) : []); %>
      <% const featuredHomeProducts = (allProducts || products).filter(function(p){ return hpFeaturedPrimary.includes(p.id); }).slice(0, 2); %>
      <% const featuredSecondary = (allProducts || products).find(function(p){ return p.id === homepage.featuredSecondaryId; }); %>
      <% const secondaryCard = homepage.secondaryCard || {}; %>
      <% if (tenant.id === 'eukolakis' && !activeCategory) { %>
      <section class="category-cards">
        <% navCategories.forEach(function(cat) { %>
          <a class="category-card <%= cat.featured ? 'featured' : '' %>" href="<%= withTenantLink('/', Object.assign({ category: cat.slug }, lang !== 'el' ? { lang } : {})) %>">
            <% if (cat.image) { %><img src="<%= cat.image %>" alt="<%= cat.name %>" /><% } %>
            <div><%= cat.name %></div>
          </a>
        <% }) %>
        <% const hasSubscriptionsCategory = navCategories.some(function(c){ return c.slug === 'subscriptions'; }); %>
        <% if ((homepage.showSubscriptionsCard || false) && !hasSubscriptionsCategory) { %>
          <a class="category-card" href="<%= withTenantLink('/content', lang !== 'el' ? { lang } : {}) %>">
            <div style="height:60px;display:flex;align-items:center;justify-content:center;background:#111827;color:#fff;border-radius:8px;">▶</div>
            <div><%= lang === 'el' ? 'Eukolaki Συνδρομές' : 'Eukolaki Subscriptions' %></div>
          </a>
        <% } %>
      </section>
      <% } else { %>
      <section class="category-cards">
        <% categories.forEach(function(cat) { %>
          <a class="category-card <%= (config.theme && config.theme.categoryMenuStyle === 'image') ? 'only-image' : '' %> <%= cat.featured ? 'featured' : '' %>" href="<%= withTenantLink('/', Object.assign({ category: cat.slug }, lang !== 'el' ? { lang } : {})) %>">
            <% if (cat.image && (!config.theme || config.theme.categoryMenuStyle !== 'text')) { %><img src="<%= cat.image %>" alt="<%= cat.name %>" /><% } %>
            <div><%= cat.name %> <% if (cat.featured) { %>⭐<% } %></div>
            <% if (cat.shortDescription && config.theme && config.theme.categoryMenuStyle !== 'image') { %><small><%= cat.shortDescription %></small><% } %>
          </a>
        <% }) %>
      </section>
      <% } %>
      <% if (!config.theme || config.theme.bannerVisible !== false) { %>
      <section class="hero <%= config.theme && config.theme.heroStyle === 'strong' ? 'strong' : '' %>">
        <% if (homepage.heroImage && tenant.id === 'eukolakis') { %>
          <div style="margin-bottom:14px;"><img src="<%= homepage.heroImage %>" alt="<%= config.storeName %>" style="width:100%;max-height:220px;object-fit:cover;border-radius:10px;" /></div>
        <% } %>
        <% if (tenant.id === 'eukolakis') { %>
          <h2 class="hero-title"><%= config.heroTitle || (lang === 'el' ? 'DIY λύσεις για ρολά, πόρτες και ανταλλακτικά' : 'DIY solutions for shutters, doors and spare parts') %></h2>
          <p style="margin:0;color:inherit;opacity:.92;"><%= config.heroSubtitle || (lang === 'el' ? 'Επαγγελματικό αποτέλεσμα με kits, ανταλλακτικά και καθοδήγηση βήμα-βήμα.' : 'Professional results with kits, spare parts and step-by-step guidance.') %></p>
        <% } %>
        <p><%= config.heroText %></p>
        <% if (tenant.id === 'eukolakis') { %>
          <div class="hero-actions">
            <a class="button" href="<%= withTenantLink('/', Object.assign({ category: 'diy-rolla' }, lang !== 'el' ? { lang } : {})) %>"><%= lang === 'el' ? 'Δείτε DIY Kits' : 'Explore DIY Kits' %></a>
            <a class="button" style="background:#111827;" href="<%= withTenantLink('/', Object.assign({ category: 'spare-parts' }, lang !== 'el' ? { lang } : {})) %>"><%= lang === 'el' ? 'Ανταλλακτικά / Εργαλεία' : 'Spare Parts / Tools' %></a>
          </div>
        <% } %>
      </section>
      <% } %>

      <% if (tenant.id === 'eukolakis' && !activeCategory && featuredHomeProducts.length) { %>
      <section class="featured-section">
        <h2>🧰 <%= lang === 'el' ? 'Κύρια DIY Kits' : 'Primary DIY Kits' %></h2>
        <div class="featured-primary-grid">
          <% featuredHomeProducts.forEach(function (product) { %>
            <article class="featured-kit-card">
              <% if (product.imageUrl) { %><img src="<%= product.imageUrl %>" alt="<%= product.name %>" /><% } %>
              <div class="body">
                <% if (product.type === 'KIT') { %><span class="kit-badge">KIT</span><% } %>
                <h3 style="margin:0 0 8px;"><%= product.name %></h3>
                <p style="margin:0 0 10px;color:#4b5563;"><%= product.description || '' %></p>
                <a class="button" href="<%= withTenantLink('/product/' + product.id, lang !== 'el' ? { lang } : {}) %>" <%= tenant.id === 'eukolakis' && product.type === 'KIT' ? ('data-kit-launch="' + product.id + '"') : '' %>><%= lang === 'el' ? 'Δες το kit' : 'View kit' %></a>
              </div>
            </article>
          <% }) %>
        </div>
      </section>
      <% if (secondaryCard.title || secondaryCard.text) { %>
      <section class="hero" style="padding:16px;background:#fff;border:1px solid #e5e7eb;border-radius:10px;">
        <h3 style="margin-top:0;"><%= resolveField(secondaryCard.title, lang) || secondaryCard.title %></h3>
        <p style="margin-bottom:8px;"><%= resolveField(secondaryCard.text, lang) || secondaryCard.text %></p>
        <% if (secondaryCard.link) { %><a class="button" href="<%= secondaryCard.link %>"><%= lang === 'el' ? 'Δείτε περισσότερα' : 'Learn more' %></a><% } %>
      </section>
      <% } %>
      <% } %>

      <% if (!(tenant.id === 'eukolakis' && !activeCategory)) { %>
      <%# ── Featured products ── %>
      <% const featuredProducts = products.filter(function(p){ return p.featured; }); %>
      <% if (featuredProducts.length > 0) { %>
      <section class="featured-section">
        <h2>⭐ <%= t('storefront.featuredTitle') %></h2>
        <div class="product-list">
          <% featuredProducts.forEach(function (product) { %>
            <%- include('_product-card', { product, lang, t, config, tenantId: tenant.id }) %>
          <% }); %>
        </div>
      </section>
      <% } %>

      <section class="product-list">
        <% if (products.length === 0) { %>
          <p><%= t('storefront.noProducts') %></p>
        <% } %>

        <% products.forEach(function (product) { %>
          <%- include('_product-card', { product, lang, t, config, tenantId: tenant.id }) %>
        <% }); %>
      </section>
      <% } %>

      <% if (tenant.id === 'eukolakis' && !activeCategory && featuredSecondary) { %>
      <section class="home-secondary">
        <h3 style="margin-top:0;"><%= featuredSecondary.name %></h3>
        <p><%= featuredSecondary.description || '' %></p>
        <a class="button" href="<%= withTenantLink('/product/' + featuredSecondary.id, lang !== 'el' ? { lang } : {}) %>"><%= lang === 'el' ? 'Δείτε προϊόν' : 'View product' %></a>
      </section>
      <% } %>
    </main>
    <% if (tenant.id === 'eukolakis') { %>
    <div id="kit-wizard-backdrop" class="kit-wizard-backdrop" aria-hidden="true">
      <div class="kit-wizard-modal" role="dialog" aria-modal="true" aria-label="<%= lang === 'el' ? 'Οδηγός kit' : 'Kit wizard' %>">
        <div class="kit-wizard-head">
          <div>
            <strong id="kit-wizard-title"></strong>
            <div id="kit-wizard-progress" class="kit-progress"></div>
          </div>
          <button type="button" id="kit-wizard-close" class="btn-cart" style="background:#1f2937;">✕</button>
        </div>
        <div class="kit-wizard-body">
          <div>
            <h3 id="kit-group-title" style="margin:0 0 8px;"></h3>
            <p id="kit-group-required" class="helper" style="margin:0 0 8px;"></p>
            <div id="kit-choice-grid" class="kit-choice-grid"></div>
            <div id="kit-summary" style="display:none;"></div>
          </div>
          <div>
            <div class="kit-preview" id="kit-preview"></div>
            <p style="margin:10px 0 0;font-size:.84rem;"><a id="kit-full-link" href="#"><%= lang === 'el' ? 'View full page' : 'View full page' %></a></p>
          </div>
        </div>
        <div class="kit-wizard-foot">
          <div class="kit-total" id="kit-total"></div>
          <div style="display:flex;gap:8px;align-items:center;">
            <button type="button" id="kit-back" class="btn-cart" style="background:#334155;"><%= lang === 'el' ? 'Πίσω' : 'Back' %></button>
            <button type="button" id="kit-next" class="btn-cart"><%= lang === 'el' ? 'Επόμενο' : 'Next' %></button>
          </div>
        </div>
      </div>
    </div>
    <script id="kit-products-json" type="application/json"><%- JSON.stringify((allProducts || products).filter(function(p){ return p && p.type === 'KIT'; })).replace(/</g, '\\u003c') %></script>
    <% } %>
    <footer class="store-footer">
      <strong><%= config.storeName %></strong> · DIY Kits · Spare Parts · Tools
    </footer>

    <%# ── Floating draggable cart (shared partial) ── %>
    <%- include('_cart') %>

    <script>
      // ── Menu toggle ────────────────────────────────────────────────
      const menuToggle = document.getElementById("menu-toggle");
      const mainNav = document.getElementById("main-nav");
      if (menuToggle && mainNav) {
        menuToggle.addEventListener("click", () => {
          mainNav.classList.toggle("open");
        });
      }
      const isEukolakis = <%= tenant.id === 'eukolakis' ? 'true' : 'false' %>;
      if (isEukolakis && <%= config.theme && config.theme.cursorEffect ? 'true' : 'false' %> && window.matchMedia('(pointer:fine)').matches) {
        const cursorImage = <%- JSON.stringify((config.theme && config.theme.cursorImage) || '') %>;
        if (cursorImage) {
          document.body.style.cursor = 'url("' + cursorImage.replace(/"/g, '\\"') + '") 8 8, crosshair';
        } else {
          document.body.classList.add('cursor-tool');
        }
      }

      if (isEukolakis) {
        const kitDataEl = document.getElementById('kit-products-json');
        const wizard = document.getElementById('kit-wizard-backdrop');
        if (!kitDataEl || !wizard) {
          // no-op
        } else {
        const kitProducts = JSON.parse(kitDataEl.textContent || '[]');
        const kitById = Object.fromEntries(kitProducts.map(function(p){ return [p.id, p]; }));
        const state = { product: null, step: 0, selections: {} };
        const titleEl = document.getElementById('kit-wizard-title');
        const progressEl = document.getElementById('kit-wizard-progress');
        const groupTitleEl = document.getElementById('kit-group-title');
        const groupReqEl = document.getElementById('kit-group-required');
        const choiceGrid = document.getElementById('kit-choice-grid');
        const previewEl = document.getElementById('kit-preview');
        const totalEl = document.getElementById('kit-total');
        const summaryEl = document.getElementById('kit-summary');
        const fullLinkEl = document.getElementById('kit-full-link');
        const btnBack = document.getElementById('kit-back');
        const btnNext = document.getElementById('kit-next');
        function esc(v) {
          return String(v || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
        }

        function selectedEntries() {
          const out = [];
          (state.product.kitOptions || []).forEach(function(g){
            const sel = state.selections[g.id] || [];
            sel.forEach(function(cid){
              const c = (g.choices || []).find(function(ch){ return ch.id === cid; });
              if (c) out.push({ groupId: g.id, groupLabel: g.label, choiceId: c.id, choiceLabel: c.label, priceDelta: Number(c.priceDelta)||0 });
            });
          });
          return out;
        }
        function totalPrice() {
          const delta = selectedEntries().reduce(function(s,o){ return s + (Number(o.priceDelta)||0); }, 0);
          return (Number(state.product.price)||0) + delta;
        }
        function renderPreview(group) {
          const sel = state.selections[group.id] || [];
          const imgs = sel.map(function(cid){ return (group.choices||[]).find(function(c){ return c.id === cid; }); }).filter(Boolean).filter(function(c){ return c.image; });
          if (!imgs.length) { previewEl.innerHTML = '<p style="margin:0;color:#64748b;font-size:.84rem;"><%= lang === 'el' ? 'Επιλέξτε επιλογή για προεπισκόπηση.' : 'Select an option to preview.' %></p>'; return; }
          previewEl.innerHTML = imgs.map(function(c){ return '<div style="margin-bottom:8px;"><img src=\"' + esc(c.image) + '\" alt=\"\" /><p style=\"margin:4px 0 0;font-size:.82rem;\">' + esc(c.label) + '</p></div>'; }).join('');
        }
        function renderSummary() {
          const entries = selectedEntries();
          summaryEl.innerHTML = entries.length ? entries.map(function(e){ return '<p class=\"kit-summary-line\">' + esc(e.groupLabel) + ': <strong>' + esc(e.choiceLabel) + '</strong> (' + (e.priceDelta>=0?'+':'') + e.priceDelta.toFixed(2) + '€)</p>'; }).join('') : '<p class="kit-summary-line"><%= lang === 'el' ? 'Δεν υπάρχουν επιλογές.' : 'No selected options.' %></p>';
        }
        function groupDone(group) {
          const sel = state.selections[group.id] || [];
          return !group.required || sel.length > 0;
        }
        function renderStep() {
          const groups = state.product.kitOptions || [];
          const summaryStep = state.step >= groups.length;
          titleEl.textContent = state.product.name || 'KIT';
          progressEl.textContent = summaryStep ? ('<%= lang === 'el' ? 'Σύνοψη' : 'Summary' %>') : ((state.step + 1) + '/' + groups.length);
          totalEl.textContent = '<%= lang === 'el' ? 'Σύνολο' : 'Total' %>: ' + totalPrice().toFixed(2) + '€';
          fullLinkEl.href = '<%= withTenantLink('/product/', lang !== 'el' ? { lang } : {}) %>' + state.product.id;
          btnBack.disabled = state.step === 0;
          btnNext.textContent = summaryStep ? '<%= lang === 'el' ? 'Προσθήκη στο καλάθι' : 'Add to cart' %>' : '<%= lang === 'el' ? 'Επόμενο' : 'Next' %>';
          choiceGrid.innerHTML = '';
          summaryEl.style.display = summaryStep ? 'block' : 'none';
          if (summaryStep) {
            groupTitleEl.textContent = '<%= lang === 'el' ? 'Σύνοψη επιλογών' : 'Option summary' %>';
            groupReqEl.textContent = '';
            previewEl.innerHTML = '';
            renderSummary();
            return;
          }
          const group = groups[state.step];
          groupTitleEl.textContent = group.label || group.id;
          groupReqEl.textContent = group.required ? '<%= lang === 'el' ? 'Υποχρεωτική επιλογή' : 'Required selection' %>' : '<%= lang === 'el' ? 'Προαιρετική επιλογή' : 'Optional selection' %>';
          (group.choices || []).forEach(function(choice){
            const sel = state.selections[group.id] || [];
            const checked = sel.includes(choice.id);
            const card = document.createElement('button');
            card.type = 'button';
            card.className = 'kit-choice' + (checked ? ' selected' : '');
            card.innerHTML = (choice.image ? ('<img src="' + esc(choice.image) + '" alt="">') : '<div style="width:56px;height:56px;border-radius:8px;background:#e5e7eb;"></div>') +
              '<div style="text-align:left;"><strong>' + esc(choice.label || choice.id) + '</strong><div style="font-size:.82rem;color:#0f766e;">' + ((Number(choice.priceDelta)||0)>=0?'+':'') + (Number(choice.priceDelta)||0).toFixed(2) + '€</div>' +
              (choice.description ? ('<div style="font-size:.78rem;color:#64748b;margin-top:2px;">' + esc(choice.description) + '</div>') : '') + '</div>';
            card.addEventListener('click', function(){
              state.selections[group.id] = state.selections[group.id] || [];
              if (group.inputType === 'checkbox') {
                if (state.selections[group.id].includes(choice.id)) state.selections[group.id] = state.selections[group.id].filter(function(v){ return v !== choice.id; });
                else state.selections[group.id].push(choice.id);
              } else {
                state.selections[group.id] = [choice.id];
              }
              renderStep();
            });
            choiceGrid.appendChild(card);
          });
          renderPreview(group);
        }
        function openWizard(productId) {
          const p = kitById[productId];
          if (!p || p.type !== 'KIT') return;
          state.product = p;
          state.step = 0;
          state.selections = {};
          wizard.classList.add('open');
          wizard.setAttribute('aria-hidden', 'false');
          renderStep();
        }
        function closeWizard() {
          wizard.classList.remove('open');
          wizard.setAttribute('aria-hidden', 'true');
        }
        document.querySelectorAll('[data-kit-launch]').forEach(function(el){
          el.addEventListener('click', function(e){
            if (e.metaKey || e.ctrlKey || e.shiftKey || e.button === 1) return;
            e.preventDefault();
            openWizard(el.getAttribute('data-kit-launch'));
          });
        });
        document.querySelectorAll('.kit-clickable').forEach(function(card){
          card.addEventListener('click', function(e){
            if (e.target.closest('a,button,input,textarea,select,label')) return;
            openWizard(card.getAttribute('data-kit-product-id'));
          });
        });
        document.getElementById('kit-wizard-close').addEventListener('click', closeWizard);
        wizard.addEventListener('click', function(e){ if (e.target === wizard) closeWizard(); });
        document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && wizard.classList.contains('open')) closeWizard(); });
        btnBack.addEventListener('click', function(){ if (state.step > 0) { state.step -= 1; renderStep(); } });
        btnNext.addEventListener('click', function(){
          const groups = state.product.kitOptions || [];
          if (state.step < groups.length) {
            const g = groups[state.step];
            if (!groupDone(g)) { alert('<%= lang === 'el' ? 'Η επιλογή είναι υποχρεωτική για να συνεχίσετε.' : 'Please complete required selection.' %>'); return; }
            state.step += 1;
            renderStep();
            return;
          }
          const selected = selectedEntries();
          const finalPrice = totalPrice();
          const optionSummary = selected.map(function(o){ return o.groupLabel + ': ' + o.choiceLabel; }).join(' | ');
          const cartKey = state.product.id + '::' + selected.map(function(o){ return o.groupId + '=' + o.choiceId; }).sort().join('&');
          if (window.thrcAddToCart) {
            window.thrcAddToCart({
              id: state.product.id,
              name: state.product.name,
              price: finalPrice,
              imageUrl: state.product.imageUrl || '',
              selectedOptions: selected,
              optionSummary: optionSummary || undefined,
              finalUnitPrice: finalPrice,
              cartKey: cartKey
            });
          }
          closeWizard();
        });
        }
      }
    </script>
  </body>
</html>
