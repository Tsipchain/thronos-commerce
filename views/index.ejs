<!DOCTYPE html>
<html lang="<%= lang %>">
  <head>
    <meta charset="UTF-8" />
    <title><%= config.storeName %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.ico" />
    <link rel="stylesheet" href="/styles.css" />
    <style>
      :root {
        --primary-color: <%= config.primaryColor %>;
        --accent-color: <%= config.accentColor %>;
        --font-family: <%= config.fontFamily %>;
        --menu-bg: <%= (config.theme && config.theme.menuBg) || '#111' %>;
        --menu-text: <%= (config.theme && config.theme.menuText) || '#fff' %>;
        --menu-active-bg: <%= (config.theme && config.theme.menuActiveBg) || '#f06292' %>;
        --menu-active-text: <%= (config.theme && config.theme.menuActiveText) || '#fff' %>;
        --button-radius: <%= (config.theme && config.theme.buttonRadius) || '4px' %>;
      }
      .lang-switcher { padding: 8px 16px; background: rgba(0,0,0,.06); font-size: 0.8rem; display:flex; align-items:center; gap:8px; }
      .lang-switcher select { padding: 4px 8px; border:1px solid #d1d5db; border-radius:6px; background:#fff; }

      /* ── Product grid ── */
      .product-list {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        padding: 20px 0;
      }
      @media (max-width: 900px) { .product-list { grid-template-columns: repeat(2, 1fr); } }
      @media (max-width: 560px) { .product-list { grid-template-columns: 1fr; } }

      .product-card {
        border: 1px solid #e8e8e8; border-radius: 8px;
        overflow: hidden; background: #fff;
        display: flex; flex-direction: column;
        transition: box-shadow .2s;
      }
      .product-card:hover { box-shadow: 0 4px 18px rgba(0,0,0,.1); }
      .product-card .product-thumb {
        width: 100%; aspect-ratio: 1; overflow: hidden; background: #f5f5f5;
      }
      .product-card .product-thumb img {
        width: 100%; height: 100%; object-fit: cover; display: block;
      }
      .product-card-body { padding: 14px 16px; flex: 1; display: flex; flex-direction: column; }
      .product-card h2 { font-size: 0.95rem; margin: 0 0 6px; }
      .product-card p  { font-size: 0.82rem; color: #555; margin: 0 0 8px; flex: 1;
                         display: -webkit-box; -webkit-line-clamp: 3;
                         -webkit-box-orient: vertical; overflow: hidden; }
      .product-card .price { font-size: 1.1rem; font-weight: 700; color: var(--primary-color); margin: 0 0 12px; }
      .product-card .button { align-self: flex-start; font-size: 0.85rem; padding: 7px 16px; }
      .product-card .card-actions { display: flex; gap: 8px; flex-wrap: wrap; margin-top: auto; }
      .btn-cart {
        padding: 7px 14px; font-size: 0.82rem; font-weight: 600; border: none; cursor: pointer;
        border-radius: var(--button-radius, 4px); background: var(--primary-color);
        color: #fff; transition: opacity .15s;
      }
      .btn-cart:hover { opacity: .85; }
      .btn-cart:disabled { opacity: .45; cursor: not-allowed; }
      .featured-badge {
        position: absolute; top: 8px; left: 8px;
        background: #f59e0b; color: #fff; font-size: 0.68rem; font-weight: 700;
        padding: 2px 8px; border-radius: 20px; letter-spacing: .04em; pointer-events: none;
      }
      .product-thumb { position: relative; }
      .featured-section { margin-bottom: 32px; }
      .featured-section h2 {
        font-size: 1.1rem; font-weight: 700; margin: 0 0 14px;
        color: var(--primary-color); display: flex; align-items: center; gap: 8px;
      }
      .stock-pill {
        font-size: 0.72rem; padding: 1px 7px; border-radius: 20px; margin-left: 4px;
        font-weight: 600;
      }
      .stock-pill.ok  { background: #d1fae5; color: #065f46; }
      .stock-pill.low { background: #fef3c7; color: #92400e; }
      .stock-pill.out { background: #fee2e2; color: #991b1b; }
      .cat-logo { width:22px;height:22px;object-fit:cover;border-radius:50%;vertical-align:middle;margin-right:6px; }
      .category-cards { display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin:14px 0 8px; }
      .category-card { border:1px solid #e5e7eb;border-radius:10px;padding:8px;text-decoration:none;color:inherit;text-align:center;background:#fff; }
      .category-card img { width:100%;height:60px;object-fit:cover;border-radius:8px;margin-bottom:6px; }
      .logo-title.centered { width:100%; justify-content:center; text-align:center; }
      .hero.strong { background:linear-gradient(130deg,#111827,#1f2937); color:#fff; border-radius:12px; padding:24px; }
      .category-card.only-image div { display:none; }
      body.cursor-tool { cursor: crosshair; }
      .hero .hero-title { margin: 0 0 8px; font-size: clamp(1.2rem, 2.2vw, 1.9rem); }
      .hero .hero-actions { margin-top: 12px; display:flex; gap:10px; flex-wrap:wrap; }
      .hero .hero-actions a { text-decoration:none; }
      .category-card.featured { border-color: var(--accent-color); box-shadow: 0 8px 20px rgba(0,0,0,.08); }
      .category-card small { display:block; color:#6b7280; margin-top:3px; font-size:.74rem; }
      .store-header.premium { background: linear-gradient(135deg,#0f172a,#1f2937); border-bottom: 1px solid rgba(255,255,255,.08); }
      .branding-mode-logo_only .store-name-wrap, .branding-mode-name_only .logo-frame { display:none; }
      .logo-frame { display:inline-flex; align-items:center; justify-content:center; }
      .logo-frame.logo-frame-dark { background: rgba(15,23,42,.88); }
      .logo-frame.logo-frame-clean { background: rgba(255,255,255,.9); border: 1px solid rgba(15,23,42,.1); }
      .logo-frame.logo-frame-floating { background: rgba(255,255,255,.08); backdrop-filter: blur(3px); }
      .logo-frame img { display:block; max-width: 240px; }
      .logo-image.cover { object-fit: cover; }
      .logo-image.contain { object-fit: contain; }
      .logo-image.clean_badge { object-fit: contain; filter: contrast(1.05) saturate(1.05); }
      .logo-image.transparent_blend { object-fit: contain; mix-blend-mode: screen; opacity: .95; }
      @media (max-width: 640px) {
        .category-cards { display:flex; overflow-x:auto; gap:10px; padding-bottom:4px; }
        .category-card { min-width: 150px; }
      }
    </style>
  </head>
  <body>
    <% const theme = config.theme || {}; %>
    <% const brandingMode = theme.brandingMode || 'logo_name'; %>
    <% const logoBgMode = theme.logoBgMode || 'auto'; %>
    <% const logoFrameClass = logoBgMode === 'dark_badge' ? 'logo-frame-dark' : (logoBgMode === 'light_badge' ? 'logo-frame-clean' : (logoBgMode === 'none' ? '' : 'logo-frame-floating')); %>
    <header class="store-header <%= tenant.id === 'eukolakis' ? 'premium' : '' %> branding-mode-<%= brandingMode %>">
      <div class="logo-title <%= theme.headerLayout === 'centered' ? 'centered' : '' %>">
        <% if (config.logoPath && brandingMode !== 'name_only') { %>
          <span class="logo-frame <%= logoFrameClass %>" style="padding:<%= Number(theme.logoPadding || 6) %>px;border-radius:<%= Number(theme.logoRadius || 10) %>px;box-shadow:<%= theme.logoShadow === 'floating' ? '0 12px 24px rgba(0,0,0,.25)' : (theme.logoShadow === 'none' ? 'none' : '0 3px 10px rgba(0,0,0,.12)') %>;">
            <img src="<%= config.logoPath %>" alt="<%= config.storeName %>" class="logo logo-image <%= theme.logoDisplayMode || 'contain' %>" style="max-height:<%= Number(theme.logoMaxHeight || 52) %>px;" />
          </span>
        <% } %>
        <% if (brandingMode !== 'logo_only') { %>
        <div class="store-name-wrap">
          <h1><%= config.storeName %></h1>
          <% if (config.web3Domain) { %>
            <p class="subtitle"><%= t('storefront.web3Domain') %>: <%= config.web3Domain %></p>
          <% } %>
        </div>
        <% } %>
      </div>
      <button class="menu-toggle" id="menu-toggle" type="button"><%= t('storefront.menuToggle') %></button>
      <nav class="main-nav" id="main-nav">
        <ul>
          <li class="<%= !activeCategory ? 'active' : '' %>">
            <a href="<%= withTenantLink('/', lang !== 'el' ? { lang } : {}) %>"><%= t('storefront.allProducts') %></a>
          </li>
          <% if (!theme.categoryMenuStyle || theme.categoryMenuStyle === 'text') { %>
            <% categories.forEach(function(cat) { %>
              <li class="<%= activeCategory === cat.slug ? 'active' : '' %>">
                <a href="<%= withTenantLink('/', Object.assign({ category: cat.slug }, lang !== 'el' ? { lang } : {})) %>">
                  <% if (cat.image) { %><img src="<%= cat.image %>" alt="<%= cat.name %>" class="cat-logo" /><% } %><%= cat.name %>
                </a>
              </li>
            <% }); %>
          <% } %>
          <% if (!user) { %>
            <li><a href="<%= withTenantLink('/login', lang !== 'el' ? { lang } : {}) %>">Login</a></li>
            <li><a href="<%= withTenantLink('/signup', lang !== 'el' ? { lang } : {}) %>">Signup</a></li>
          <% } else { %>
            <li><a href="<%= withTenantLink('/account', lang !== 'el' ? { lang } : {}) %>">My Account</a></li>
            <li><a href="<%= withTenantLink('/my-orders', lang !== 'el' ? { lang } : {}) %>">My Orders</a></li>
            <li><a href="<%= withTenantLink('/logout', lang !== 'el' ? { lang } : {}) %>">Logout</a></li>
          <% } %>
        </ul>
      </nav>
    </header>

    <% if (isPreviewMode) { %>
    <div style="padding:8px 16px;background:#fff7ed;border-bottom:1px solid #fed7aa;color:#9a3412;font-size:.85rem;">
      <strong>Preview Mode</strong> – this store is not live yet. Tenant: <strong><%= tenantId %></strong>
    </div>
    <% } %>

    <div class="lang-switcher">
      <label for="lang-switch"><%= t('storefront.langLabel') %>:</label>
      <select id="lang-switch" onchange="window.location.href=this.value">
        <% (contentLangs || ['el','en']).forEach(function(l) { %>
          <% const optionUrl = withTenantLink('/', Object.assign(activeCategory ? { category: activeCategory } : {}, { lang: l })); %>
          <option value="<%= optionUrl %>" <%= lang === l ? 'selected' : '' %>><%= l === 'el' ? 'Ελληνικά' : 'English' %></option>
        <% }) %>
      </select>
    </div>

    <main>
      <section class="category-cards">
        <% categories.forEach(function(cat) { %>
          <a class="category-card <%= (config.theme && config.theme.categoryMenuStyle === 'image') ? 'only-image' : '' %> <%= cat.featured ? 'featured' : '' %>" href="<%= withTenantLink('/', Object.assign({ category: cat.slug }, lang !== 'el' ? { lang } : {})) %>">
            <% if (cat.image && (!config.theme || config.theme.categoryMenuStyle !== 'text')) { %><img src="<%= cat.image %>" alt="<%= cat.name %>" /><% } %>
            <div><%= cat.name %> <% if (cat.featured) { %>⭐<% } %></div>
            <% if (cat.shortDescription && config.theme && config.theme.categoryMenuStyle !== 'image') { %><small><%= cat.shortDescription %></small><% } %>
          </a>
        <% }) %>
      </section>
      <% if (!config.theme || config.theme.bannerVisible !== false) { %>
      <section class="hero <%= config.theme && config.theme.heroStyle === 'strong' ? 'strong' : '' %>">
        <% if (tenant.id === 'eukolakis') { %>
          <h2 class="hero-title"><%= lang === 'el' ? 'DIY λύσεις για ρολά, πόρτες και ανταλλακτικά' : 'DIY solutions for shutters, doors and spare parts' %></h2>
          <p style="margin:0;color:inherit;opacity:.92;"><%= lang === 'el' ? 'Επαγγελματικό αποτέλεσμα με kits, ανταλλακτικά και καθοδήγηση βήμα-βήμα.' : 'Professional results with kits, spare parts and step-by-step guidance.' %></p>
        <% } %>
        <p><%= config.heroText %></p>
        <% if (tenant.id === 'eukolakis') { %>
          <div class="hero-actions">
            <a class="button" href="<%= withTenantLink('/', Object.assign({ category: 'diy-rolla' }, lang !== 'el' ? { lang } : {})) %>"><%= lang === 'el' ? 'Δείτε DIY Kits' : 'Explore DIY Kits' %></a>
            <a class="button" style="background:#111827;" href="<%= withTenantLink('/', Object.assign({ category: 'spare-parts' }, lang !== 'el' ? { lang } : {})) %>"><%= lang === 'el' ? 'Ανταλλακτικά / Εργαλεία' : 'Spare Parts / Tools' %></a>
          </div>
        <% } %>
      </section>
      <% } %>

      <%# ── Featured products ── %>
      <% const featuredProducts = products.filter(function(p){ return p.featured; }); %>
      <% if (featuredProducts.length > 0) { %>
      <section class="featured-section">
        <h2>⭐ <%= t('storefront.featuredTitle') %></h2>
        <div class="product-list">
          <% featuredProducts.forEach(function (product) { %>
            <%- include('_product-card', { product, lang, t, config }) %>
          <% }); %>
        </div>
      </section>
      <% } %>

      <section class="product-list">
        <% if (products.length === 0) { %>
          <p><%= t('storefront.noProducts') %></p>
        <% } %>

        <% products.forEach(function (product) { %>
          <%- include('_product-card', { product, lang, t, config }) %>
        <% }); %>
      </section>
    </main>

    <%# ── Floating draggable cart (shared partial) ── %>
    <%- include('_cart') %>

    <script>
      // ── Menu toggle ────────────────────────────────────────────────
      const menuToggle = document.getElementById("menu-toggle");
      const mainNav = document.getElementById("main-nav");
      if (menuToggle && mainNav) {
        menuToggle.addEventListener("click", () => {
          mainNav.classList.toggle("open");
        });
      }
      if (<%= tenant.id === 'eukolakis' && config.theme && config.theme.cursorEffect ? 'true' : 'false' %> && window.matchMedia('(pointer:fine)').matches) {
        document.body.classList.add('cursor-tool');
      }
    </script>
  </body>
</html>
