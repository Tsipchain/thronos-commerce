    <%# ── Floating draggable cart (shared partial) ── %>
    <%- include('_cart') %>
    <div id="exposure-overlay" class="exposure-overlay" aria-hidden="true"></div>

    <script>
      // ── Menu toggle ────────────────────────────────────────────────
      const menuToggle = document.getElementById("menu-toggle");
      const mainNav = document.getElementById("main-nav");
      if (menuToggle && mainNav) {
        menuToggle.addEventListener("click", () => {
          mainNav.classList.toggle("open");
        });
      }
      const isEukolakis = <%= tenant.id === 'eukolakis' ? 'true' : 'false' %>;
      const isDesktopDevice = <%= device === 'desktop' ? 'true' : 'false' %>;
      const productPreOpenEffect = <%- safeJson((config.theme && config.theme.productPreOpenEffect) || 'none') %>;
      if (isEukolakis && isDesktopDevice && <%= config.theme && config.theme.cursorEffect ? 'true' : 'false' %>) {
        const cursorImage = <%- JSON.stringify((config.theme && config.theme.cursorImage) || '') %>;
        const cursorTargets = 'a,button,input,select,textarea,label,[role="button"],.button,.btn-cart';
        const isDevHost = /localhost|127\.0\.0\.1/.test(window.location.hostname);
        const applyCrosshair = function() {
          document.body.classList.add('cursor-tool');
          document.documentElement.style.cursor = 'crosshair';
          document.body.style.cursor = 'crosshair';
          document.querySelectorAll(cursorTargets).forEach(function(el){
            el.style.cursor = 'crosshair';
          });
        };
        if (cursorImage && (/^\//).test(cursorImage)) {
          const testImg = new Image();
          testImg.onload = function() {
            const safeCursor = cursorImage.replace(/"/g, '\\"');
            const cursorRule = 'url("' + safeCursor + '") 16 16, auto';
            document.documentElement.style.cursor = cursorRule;
            document.body.style.cursor = cursorRule;
            document.querySelectorAll(cursorTargets).forEach(function(el){
              el.style.cursor = cursorRule;
            });
          };
          testImg.onerror = function() {
            if (isDevHost) console.warn('[cursor] preload failed, falling back to crosshair:', cursorImage);
            applyCrosshair();
          };
          testImg.src = cursorImage;
        } else applyCrosshair();
      }

      if (isEukolakis) {
        const KIT_T = {
          previewPrompt: <%- safeJson(lang === 'el' ? 'Επιλέξτε επιλογή για προεπισκόπηση.' : 'Select an option to preview.') %>,
          noSelections: <%- safeJson(lang === 'el' ? 'Δεν υπάρχουν επιλογές.' : 'No selected options.') %>,
          summary: <%- safeJson(lang === 'el' ? 'Σύνοψη' : 'Summary') %>,
          total: <%- safeJson(lang === 'el' ? 'Σύνολο' : 'Total') %>,
          addToCart: <%- safeJson(lang === 'el' ? 'Προσθήκη στο καλάθι' : 'Add to cart') %>,
          next: <%- safeJson(lang === 'el' ? 'Συνέχεια' : 'Continue') %>,
          optionSummary: <%- safeJson(lang === 'el' ? 'Σύνοψη επιλογών' : 'Option summary') %>,
          addSelected: <%- safeJson(lang === 'el' ? 'Προσθήκη επιλεγμένων στο καλάθι' : 'Add selected to cart') %>,
          required: <%- safeJson(lang === 'el' ? 'Υποχρεωτική επιλογή' : 'Required selection') %>,
          optional: <%- safeJson(lang === 'el' ? 'Προαιρετική επιλογή' : 'Optional selection') %>,
          variant: <%- safeJson(lang === 'el' ? 'Παραλλαγή' : 'Variant') %>,
          requiredAlert: <%- safeJson(lang === 'el' ? 'Η επιλογή είναι υποχρεωτική για να συνεχίσετε.' : 'Please complete required selection.') %>
        };
        const KIT_PRODUCT_BASE_URL = <%- safeJson(withTenantLink('/product/', lang !== 'el' ? { lang } : {})) %>;
        const kitDataEl = document.getElementById('kit-products-json');
        const catalogDataEl = document.getElementById('catalog-products-json');
        const wizard = document.getElementById('kit-wizard-backdrop');
        if (!kitDataEl || !catalogDataEl || !wizard) {
          // no-op
        } else {
        const kitProducts = JSON.parse(kitDataEl.textContent || '[]');
        const catalogProducts = JSON.parse(catalogDataEl.textContent || '[]');
        const catalogById = Object.fromEntries(catalogProducts.map(function(p){ return [p.id, p]; }));
        const kitById = Object.fromEntries(kitProducts.map(function(p){ return [p.id, p]; }));
        const state = { product: null, step: 0, selections: {}, selectedVariants: {} };
        const titleEl = document.getElementById('kit-wizard-title');
        const progressEl = document.getElementById('kit-wizard-progress');
        const groupTitleEl = document.getElementById('kit-group-title');
        const groupReqEl = document.getElementById('kit-group-required');
        const choiceGrid = document.getElementById('kit-choice-grid');
        const previewEl = document.getElementById('kit-preview');
        const totalEl = document.getElementById('kit-total');
        const summaryEl = document.getElementById('kit-summary');
        const addLinkedWrapEl = document.getElementById('kit-add-linked-wrap');
        const addLinkedEl = document.getElementById('kit-add-linked-parts');
        const fullLinkEl = document.getElementById('kit-full-link');
        const btnBack = document.getElementById('kit-back');
        const btnNext = document.getElementById('kit-next');
        function esc(v) {
          return String(v || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
        }

        function getSelectionArray(group) {
          const raw = state.selections[group.id];
          if (group.inputType === 'checkbox') return Array.isArray(raw) ? raw : [];
          return raw ? [raw] : [];
        }
        function selectedEntries() {
          const out = [];
          (state.product.kitOptions || []).forEach(function(g){
            const sel = getSelectionArray(g);
            sel.forEach(function(cid){
              const c = (g.choices || []).find(function(ch){ return ch.id === cid; });
              if (!c) return;
              const variantKey = g.id + '::' + c.id;
              const variantId = (c.linkedVariantId || state.selectedVariants[variantKey] || '');
              const variants = Array.isArray(c.linkedVariants) ? c.linkedVariants : [];
              const variant = variants.find(function(v){ return v.id === variantId; });
              const priceDelta = variant && variant.price !== undefined && !Number.isNaN(Number(variant.price))
                ? Number(variant.price)
                : (Number(c.priceDelta) || 0);
              out.push({
                groupId: g.id,
                groupLabel: g.label,
                choiceId: c.id,
                choiceLabel: c.label,
                priceDelta: priceDelta,
                linkedProductId: c.linkedProductId || '',
                selectedVariantId: variant ? variant.id : '',
                selectedVariantLabel: variant ? variant.label : ''
              });
            });
          });
          return out;
        }
        function totalPrice() {
          const delta = selectedEntries().reduce(function(s,o){ return s + (Number(o.priceDelta)||0); }, 0);
          if (state.product.kitPayMode === 'parts_only') return delta;
          return (Number(state.product.price)||0) + delta;
        }
        function renderPreview(group) {
          const sel = getSelectionArray(group);
          const imgs = sel.map(function(cid){
            const c = (group.choices||[]).find(function(choice){ return choice.id === cid; });
            if (!c) return null;
            const variantKey = group.id + '::' + c.id;
            const variantId = (c.linkedVariantId || state.selectedVariants[variantKey] || '');
            const variant = (Array.isArray(c.linkedVariants) ? c.linkedVariants : []).find(function(v){ return v.id === variantId; });
            return {
              label: c.label,
              image: (variant && variant.imageUrl) || c.image || c.linkedImageUrl || '',
              price: variant && variant.price !== undefined && !Number.isNaN(Number(variant.price)) ? Number(variant.price) : (Number(c.priceDelta) || 0),
              variantLabel: variant ? variant.label : ''
            };
          }).filter(Boolean).filter(function(c){ return c.image; });
          if (!imgs.length) { previewEl.innerHTML = '<p style="margin:0;color:#64748b;font-size:.84rem;">' + esc(KIT_T.previewPrompt) + '</p>'; return; }
          previewEl.innerHTML = imgs.map(function(c){
            return '<div style="margin-bottom:8px;"><img src=\"' + esc(c.image) + '\" alt=\"\" /><p style=\"margin:4px 0 0;font-size:.82rem;\"><strong>' + esc(c.label) + '</strong>' +
              (c.variantLabel ? (' · ' + esc(c.variantLabel)) : '') + ' — ' + c.price.toFixed(2) + '€</p></div>';
          }).join('');
        }
        function renderSummary() {
          const entries = selectedEntries();
          summaryEl.innerHTML = entries.length ? entries.map(function(e){
            return '<p class=\"kit-summary-line\">' + esc(e.groupLabel) + ': <strong>' + esc(e.choiceLabel) + '</strong>' +
              (e.selectedVariantLabel ? (' · ' + esc(e.selectedVariantLabel)) : '') +
              ' (' + (e.priceDelta>=0?'+':'') + e.priceDelta.toFixed(2) + '€)</p>';
          }).join('') : '<p class="kit-summary-line">' + esc(KIT_T.noSelections) + '</p>';
        }
        function groupDone(group) {
          const sel = getSelectionArray(group);
          return !group.required || sel.length > 0;
        }
        function renderStep() {
          const groups = state.product.kitOptions || [];
          const summaryStep = state.step >= groups.length;
          titleEl.textContent = state.product.name || 'KIT';
          progressEl.textContent = summaryStep ? KIT_T.summary : ((state.step + 1) + '/' + groups.length);
          totalEl.textContent = KIT_T.total + ': ' + totalPrice().toFixed(2) + '€';
          fullLinkEl.href = KIT_PRODUCT_BASE_URL + state.product.id;
          btnBack.disabled = state.step === 0;
          btnNext.textContent = summaryStep ? KIT_T.addSelected : KIT_T.next;
          choiceGrid.innerHTML = '';
          summaryEl.style.display = summaryStep ? 'block' : 'none';
          addLinkedWrapEl.style.display = summaryStep && state.product.kitPayMode !== 'parts_only' ? 'inline-flex' : 'none';
          if (summaryStep) {
            groupTitleEl.textContent = KIT_T.optionSummary;
            groupReqEl.textContent = '';
            previewEl.innerHTML = '';
            renderSummary();
            return;
          }
          const group = groups[state.step];
          groupTitleEl.textContent = group.label || group.id;
          groupReqEl.textContent = group.required ? KIT_T.required : KIT_T.optional;
          (group.choices || []).forEach(function(choice){
            const sel = getSelectionArray(group);
            const checked = sel.includes(choice.id);
            const card = document.createElement('button');
            card.type = 'button';
            card.className = 'kit-choice' + (checked ? ' selected' : '');
            const variantKey = group.id + '::' + choice.id;
            const fixedVariantId = choice.linkedVariantId || '';
            const variantId = fixedVariantId || state.selectedVariants[variantKey] || '';
            const choiceVariants = Array.isArray(choice.linkedVariants) ? choice.linkedVariants : [];
            const selectedVariant = choiceVariants.find(function(v){ return v.id === variantId; });
            const choiceImage = (selectedVariant && selectedVariant.imageUrl) || choice.image || choice.linkedImageUrl || '';
            const choicePrice = selectedVariant && selectedVariant.price !== undefined && !Number.isNaN(Number(selectedVariant.price))
              ? Number(selectedVariant.price)
              : (Number(choice.priceDelta)||0);
            const checkboxHtml = group.inputType === 'checkbox'
              ? '<input type="checkbox" ' + (checked ? 'checked' : '') + ' tabindex="-1" aria-hidden="true" style="margin-right:6px;pointer-events:none;" />'
              : '';
            const variantSelectHtml = checked && choiceVariants.length && !fixedVariantId
              ? ('<div style="margin-top:6px;"><label style="display:block;font-size:.72rem;color:#475569;margin-bottom:3px;">' + esc(KIT_T.variant) + '</label>' +
                  '<select class="kit-variant-select" data-group-id="' + esc(group.id) + '" data-choice-id="' + esc(choice.id) + '" style="width:100%;padding:5px;border:1px solid #cbd5e1;border-radius:7px;">' +
                  choiceVariants.map(function(v){
                    const vPrice = !Number.isNaN(Number(v.price)) ? Number(v.price).toFixed(2) : (Number(choice.priceDelta)||0).toFixed(2);
                    return '<option value="' + esc(v.id) + '"' + (v.id === variantId ? ' selected' : '') + '>' + esc(v.label || v.id) + ' (' + vPrice + '€)</option>';
                  }).join('') +
                  '</select></div>')
              : '';
            card.innerHTML = (choiceImage ? ('<img class="kit-choice-thumb" src="' + esc(choiceImage) + '" alt="">') : '<div class="kit-choice-thumb placeholder">🖼️</div>') +
              '<div style="text-align:left;">' + checkboxHtml + '<strong>' + esc(choice.label || choice.id) + '</strong>' +
              '<div style="font-size:.82rem;color:#0f766e;">' + choicePrice.toFixed(2) + '€</div>' +
              (choice.description ? ('<div style="font-size:.78rem;color:#64748b;margin-top:2px;">' + esc(choice.description) + '</div>') : '') +
              variantSelectHtml + '</div>';
            card.addEventListener('click', function(){
              if (group.inputType === 'checkbox') {
                state.selections[group.id] = Array.isArray(state.selections[group.id]) ? state.selections[group.id] : [];
                if (state.selections[group.id].includes(choice.id)) state.selections[group.id] = state.selections[group.id].filter(function(v){ return v !== choice.id; });
                else state.selections[group.id].push(choice.id);
              } else {
                state.selections[group.id] = choice.id;
              }
              const nowSelected = getSelectionArray(group).includes(choice.id);
              if (!nowSelected) {
                delete state.selectedVariants[variantKey];
              } else if (fixedVariantId) {
                state.selectedVariants[variantKey] = fixedVariantId;
              } else if (choiceVariants.length && !state.selectedVariants[variantKey]) {
                state.selectedVariants[variantKey] = choiceVariants[0].id;
              }
              renderStep();
            });
            choiceGrid.appendChild(card);
          });
          choiceGrid.querySelectorAll('.kit-variant-select').forEach(function(selectEl){
            selectEl.addEventListener('change', function(e){
              const key = (e.target.getAttribute('data-group-id') || '') + '::' + (e.target.getAttribute('data-choice-id') || '');
              state.selectedVariants[key] = e.target.value || '';
              renderStep();
            });
          });
          renderPreview(group);
        }
        function openWizard(productId) {
          const p = kitById[productId];
          if (!p || p.type !== 'KIT') return;
          state.product = p;
          state.step = 0;
          state.selections = {};
          state.selectedVariants = {};
          wizard.classList.add('open');
          wizard.setAttribute('aria-hidden', 'false');
          renderStep();
        }
        function closeWizard() {
          wizard.classList.remove('open');
          wizard.setAttribute('aria-hidden', 'true');
        }
        document.querySelectorAll('[data-kit-launch]').forEach(function(el){
          el.addEventListener('click', function(e){
            if (e.metaKey || e.ctrlKey || e.shiftKey || e.button === 1) return;
            e.preventDefault();
            openWizard(el.getAttribute('data-kit-launch'));
          });
        });
        document.querySelectorAll('.kit-clickable').forEach(function(card){
          card.addEventListener('click', function(e){
            if (e.target.closest('a,button,input,textarea,select,label')) return;
            openWizard(card.getAttribute('data-kit-product-id'));
          });
        });
        document.getElementById('kit-wizard-close').addEventListener('click', closeWizard);
        wizard.addEventListener('click', function(e){ if (e.target === wizard) closeWizard(); });
        document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && wizard.classList.contains('open')) closeWizard(); });
        window.openKitWizard = openWizard;
        btnBack.addEventListener('click', function(){ if (state.step > 0) { state.step -= 1; renderStep(); } });
        btnNext.addEventListener('click', function(){
          const groups = state.product.kitOptions || [];
          if (state.step < groups.length) {
            const g = groups[state.step];
            if (!groupDone(g)) { alert(KIT_T.requiredAlert); return; }
            state.step += 1;
            renderStep();
            return;
          }
          const selected = selectedEntries();
          const finalPrice = totalPrice();
          const optionSummary = selected.map(function(o){
            return o.groupLabel + ': ' + o.choiceLabel + (o.selectedVariantLabel ? (' [' + o.selectedVariantLabel + ']') : '');
          }).join(' | ');
          const cartKey = state.product.id + '::' + selected.map(function(o){
            return o.groupId + '=' + o.choiceId + (o.selectedVariantId ? (':' + o.selectedVariantId) : '');
          }).sort().join('&');
          if (window.thrcAddToCart) {
            if (state.product.kitPayMode === 'parts_only') {
              selected.filter(function(o){ return !!o.linkedProductId; }).forEach(function(opt){
                const linked = catalogById[opt.linkedProductId];
                if (linked) {
                  const variant = opt.selectedVariantId && Array.isArray(linked.variants)
                    ? linked.variants.find(function(v){ return v.id === opt.selectedVariantId; })
                    : null;
                  window.thrcAddToCart({
                    id: linked.id,
                    name: variant ? (linked.name + ' - ' + (variant.label || variant.id)) : linked.name,
                    price: variant && variant.price !== undefined && !Number.isNaN(Number(variant.price)) ? Number(variant.price) : (Number(linked.price) || 0),
                    imageUrl: (variant && variant.imageUrl) || linked.imageUrl || '',
                    variantId: variant ? variant.id : undefined,
                    variantLabel: variant ? (variant.label || variant.id) : undefined,
                    cartKey: linked.id + '::from-kit:' + state.product.id + ':' + opt.groupId + (opt.selectedVariantId ? (':' + opt.selectedVariantId) : '')
                  });
                }
              });
              window.thrcAddToCart({
                id: state.product.id,
                name: (state.product.name || 'KIT') + ' (summary)',
                price: 0,
                imageUrl: state.product.imageUrl || '',
                selectedOptions: selected,
                optionSummary: optionSummary || undefined,
                finalUnitPrice: 0,
                cartKey: cartKey + '::summary',
                isKitSummary: true
              });
            } else {
              window.thrcAddToCart({
                id: state.product.id,
                name: state.product.name,
                price: finalPrice,
                imageUrl: state.product.imageUrl || '',
                selectedOptions: selected,
                optionSummary: optionSummary || undefined,
                finalUnitPrice: finalPrice,
                cartKey: cartKey
              });
            }
            if (state.product.kitPayMode !== 'parts_only' && addLinkedEl && addLinkedEl.checked) {
              selected.filter(function(o){ return !!o.linkedProductId; }).forEach(function(opt){
                const linked = catalogById[opt.linkedProductId];
                if (linked) {
                  window.thrcAddToCart({
                    id: linked.id,
                    name: linked.name,
                    price: Number(linked.price) || 0,
                    imageUrl: linked.imageUrl || ''
                  });
                }
              });
            }
          }
          closeWizard();
        });
        const wizardParam = new URLSearchParams(window.location.search).get('wizard');
        if (wizardParam && kitById[wizardParam]) {
          openWizard(wizardParam);
        }
        }
      }
      if (productPreOpenEffect === 'exposure') {
        const exposureOverlay = document.getElementById('exposure-overlay');
        const openWithExposure = function(href) {
          if (!href || !exposureOverlay) return window.location.href = href;
          exposureOverlay.classList.add('open');
          setTimeout(function(){ window.location.href = href; }, 260);
        };
        document.querySelectorAll('.product-card[data-product-open-url]').forEach(function(card){
          card.addEventListener('click', function(e){
            if (e.target.closest('a,button,input,textarea,select,label,[role="button"]')) return;
            const href = card.getAttribute('data-product-open-url');
            openWithExposure(href);
          });
        });
        document.querySelectorAll('a[data-exposure-link]').forEach(function(link) {
          link.addEventListener('click', function(e){
            if (e.metaKey || e.ctrlKey || e.shiftKey || e.button === 1) return;
            e.preventDefault();
            openWithExposure(link.getAttribute('href'));
          });
        });
      }
    </script>
  </body>
</html>
