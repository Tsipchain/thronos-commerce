    <%# ── Floating draggable cart (shared partial) ── %>
    <%- include('_cart') %>
    <div id="exposure-overlay" class="exposure-overlay" aria-hidden="true"></div>

    <script>
      // Defensive footer de-duplication (in case upstream/theme injections replicate footer blocks).
      (function ensureSingleFooterBlock() {
        const footers = Array.from(document.querySelectorAll('footer.store-footer'));
        if (footers.length > 1) {
          footers.slice(1).forEach(function(footerEl){ footerEl.remove(); });
        }
        const firstFooter = footers[0];
        if (!firstFooter) return;
        const seenMetaLines = new Set();
        Array.from(firstFooter.querySelectorAll('.meta-line')).forEach(function(lineEl){
          const key = String(lineEl.textContent || '').trim().replace(/\s+/g, ' ');
          if (!key) return;
          if (seenMetaLines.has(key)) {
            lineEl.remove();
            return;
          }
          seenMetaLines.add(key);
        });
      })();
      // ── Menu toggle ────────────────────────────────────────────────
      const menuToggle = document.getElementById("menu-toggle");
      const mainNav = document.getElementById("main-nav");
      if (menuToggle && mainNav) {
        menuToggle.addEventListener("click", () => {
          mainNav.classList.toggle("open");
        });
      }
      const isEukolakis = <%= tenant.id === 'eukolakis' ? 'true' : 'false' %>;
      const isDesktopDevice = <%= device === 'desktop' ? 'true' : 'false' %>;
      const productPreOpenEffect = <%- safeJson((config.theme && config.theme.productPreOpenEffect) || 'none') %>;
      if (isEukolakis && isDesktopDevice && <%= config.theme && config.theme.cursorEffect ? 'true' : 'false' %>) {
        const cursorImage = <%- JSON.stringify((config.theme && config.theme.cursorImage) || '') %>;
        const cursorTargets = 'a,button,input,select,textarea,label,[role="button"],.button,.btn-cart';
        const isDevHost = /localhost|127\.0\.0\.1/.test(window.location.hostname);
        const applyCursorRule = function(cursorRule) {
          let styleEl = document.getElementById('thrc-cursor-style');
          if (!styleEl) {
            styleEl = document.createElement('style');
            styleEl.id = 'thrc-cursor-style';
            document.head.appendChild(styleEl);
          }
          styleEl.textContent = 'html,body,a,button,input,select,textarea,label,[role=\"button\"],.button,.btn-cart{cursor:' + cursorRule + ' !important;}';
        };
        const applyCrosshair = function() {
          document.body.classList.add('cursor-tool');
          applyCursorRule('crosshair');
        };
        if (cursorImage && (/^\//).test(cursorImage)) {
          const testImg = new Image();
          testImg.onload = function() {
            const safeCursor = cursorImage.replace(/"/g, '\\"');
            const cursorRule = 'url("' + safeCursor + '") 16 16, auto';
            applyCursorRule(cursorRule);
          };
          testImg.onerror = function() {
