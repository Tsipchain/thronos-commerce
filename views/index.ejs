        if (!headerEl) return;
        const onScroll = function() {
          headerEl.classList.toggle('is-scrolled', window.scrollY > 16);
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      })();
      (function() {
        const hero = document.querySelector('.hero.has-parallax');
        if (!hero) return;
        hero.addEventListener('mousemove', function(e) {
          const rect = hero.getBoundingClientRect();
          const x = ((e.clientX - rect.left) / Math.max(1, rect.width)) * 100;
          const y = ((e.clientY - rect.top) / Math.max(1, rect.height)) * 100;
          hero.style.setProperty('--hero-glow-x', x.toFixed(2) + '%');
          hero.style.setProperty('--hero-glow-y', y.toFixed(2) + '%');
        });
      })();
      (function() {
        const filtersRoot = document.getElementById('spare-filters');
        const grid = document.getElementById('product-list-grid');
        if (!filtersRoot || !grid) return;
        const searchEl = document.getElementById('spare-filter-search');
        const tagEl = document.getElementById('spare-filter-tag');
        const priceEl = document.getElementById('spare-filter-price');
        const priceValueEl = document.getElementById('spare-filter-price-value');
        const resetBtn = document.getElementById('spare-filter-reset');
        const emptyResetBtn = document.getElementById('spare-filter-empty-reset');
        const resultEl = document.getElementById('spare-filter-results');
        const emptyStateEl = document.getElementById('spare-filter-empty');
        const cards = Array.from(grid.querySelectorAll('.product-card'));
        const renderResultText = function(count) {
          if (!resultEl) return;
          resultEl.textContent = count + ' ' + <%- safeJson(lang === 'el' ? 'προϊόντα βρέθηκαν' : 'products found') %>;
        };
        const updateFilters = function() {
          const q = (searchEl && searchEl.value || '').trim().toLowerCase();
          const tag = (tagEl && tagEl.value || '').trim().toLowerCase();
          const maxPrice = Number(priceEl && priceEl.value || 0);
          if (priceValueEl) priceValueEl.textContent = maxPrice.toFixed(0);
          let visibleCount = 0;
          cards.forEach(function(card) {
            const nameText = (card.querySelector('h2') && card.querySelector('h2').textContent || '').toLowerCase();
            const sku = String(card.getAttribute('data-product-sku') || '').toLowerCase();
            const tags = String(card.getAttribute('data-product-tags') || '').toLowerCase();
            const price = Number(card.getAttribute('data-product-price') || 0);
            const okQuery = !q || nameText.includes(q) || sku.includes(q);
            const okTag = !tag || tags.split(',').includes(tag);
            const okPrice = !maxPrice || price <= maxPrice;
            const visible = okQuery && okTag && okPrice;
            if (visible) visibleCount += 1;
            card.classList.toggle('filter-hidden', !visible);
          });
          renderResultText(visibleCount);
          if (emptyStateEl) emptyStateEl.style.display = visibleCount === 0 ? 'block' : 'none';
        };
        [searchEl, tagEl, priceEl].forEach(function(el){ if (el) el.addEventListener('input', updateFilters); });
        const resetFilters = function() {
          if (searchEl) searchEl.value = '';
          if (tagEl) tagEl.value = '';
          if (priceEl) priceEl.value = priceEl.max || priceEl.value;
          updateFilters();
        };
        if (resetBtn) resetBtn.addEventListener('click', resetFilters);
        if (emptyResetBtn) emptyResetBtn.addEventListener('click', resetFilters);
        updateFilters();
      })();
      (function() {
        const grid = document.getElementById('kit-choice-grid');
        if (!grid) return;
        const pulse = function() {
          grid.classList.remove('fade-step', 'ready');
          void grid.offsetWidth;
          grid.classList.add('fade-step');
          requestAnimationFrame(function(){ grid.classList.add('ready'); });
        };
        pulse();
        const observer = new MutationObserver(pulse);
        observer.observe(grid, { childList: true, subtree: true });
      })();
      (function() {
        const key = 'thrc_nav_last_url';
        const homeUrl = <%- safeJson(withTenantLink('/', lang !== 'el' ? { lang } : {})) %>;
        const currentUrl = window.location.pathname + window.location.search + window.location.hash;
        try {
          const prev = sessionStorage.getItem(key);
          if (prev !== currentUrl) sessionStorage.setItem(key, currentUrl);
        } catch (err) {}
        const backBtn = document.getElementById('quick-back-btn');
        if (!backBtn) return;
        backBtn.addEventListener('click', function() {
          const ref = document.referrer || '';
          let hasStoreReferrer = false;
          try {
            if (ref) {
              const refUrl = new URL(ref);
              hasStoreReferrer = refUrl.origin === window.location.origin && !/^\/admin(?:\/|$)/.test(refUrl.pathname);
            }
          } catch (err) {}
          if (window.history.length > 1 && hasStoreReferrer) return window.history.back();
          try {
            const fallback = sessionStorage.getItem(key) || '';
            if (fallback && fallback !== currentUrl) return window.location.href = fallback;
          } catch (err) {}
          window.location.href = homeUrl;
        });
      })();
      /* ── Eukolaki industrial color mode toggle ── */
      (function() {
        var body = document.getElementById('eko-body');
        if (!body || !body.classList.contains('eukolakis-classic')) return;
        var STORAGE_KEY = 'eko_color_mode';
        var saved;
        try { saved = localStorage.getItem(STORAGE_KEY); } catch(_) {}
        var serverDefault = <%- JSON.stringify((config.theme && config.theme.colorMode) || 'dark') %>;
        var current = saved || serverDefault;
        function applyMode(mode) {
          if (mode === 'light') { body.classList.add('eko-light'); }
          else { body.classList.remove('eko-light'); }
          try { localStorage.setItem(STORAGE_KEY, mode); } catch(_) {}
          if (btn) btn.textContent = mode === 'light'
            ? (<%- JSON.stringify(lang) %> === 'el' ? '🌙 Σκοτεινό' : '🌙 Dark')
            : (<%- JSON.stringify(lang) %> === 'el' ? '☀️ Φωτεινό' : '☀️ Light');
        }
        var btn = document.createElement('button');
        btn.className = 'eko-mode-btn';
        btn.type = 'button';
        document.body.appendChild(btn);
        applyMode(current);
        btn.addEventListener('click', function() {
          current = body.classList.contains('eko-light') ? 'dark' : 'light';
          applyMode(current);
        });
      })();
    </script>
  </body>
</html>
