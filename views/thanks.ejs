<!DOCTYPE html>
<html lang="<%= lang %>">
  <head>
    <meta charset="UTF-8" />
    <title><%= t('thankyou.pageTitle') %> – <%= config.storeName %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css" />
    <style>
      :root {
        --primary-color: <%= config.primaryColor %>;
        --accent-color: <%= config.accentColor %>;
        --font-family: <%= config.fontFamily %>;
        --menu-bg: <%= (config.theme && config.theme.menuBg) || '#111' %>;
        --menu-text: <%= (config.theme && config.theme.menuText) || '#fff' %>;
        --menu-active-bg: <%= (config.theme && config.theme.menuActiveBg) || '#f06292' %>;
        --menu-active-text: <%= (config.theme && config.theme.menuActiveText) || '#fff' %>;
        --button-radius: <%= (config.theme && config.theme.buttonRadius) || '4px' %>;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="logo-title">
        <% if (config.logoPath) { %>
          <img src="<%= config.logoPath %>" alt="<%= config.storeName %>" class="logo" />
        <% } %>
        <h1><%= config.storeName %></h1>
      </div>
      <div style="padding:8px 16px;font-size:.85rem;display:flex;gap:12px;flex-wrap:wrap;">
        <% if (!user) { %>
          <a href="<%= withTenantLink('/login') %>">Login</a>
          <a href="<%= withTenantLink('/signup') %>">Signup</a>
        <% } else { %>
          <a href="<%= withTenantLink('/account') %>">My Account</a>
          <a href="<%= withTenantLink('/my-orders') %>">My Orders</a>
          <a href="<%= withTenantLink('/logout') %>">Logout</a>
        <% } %>
      </div>
    </header>

    <main>
      <%
        const safeOrder = (typeof order !== 'undefined' && order) ? order : { id: '-', subtotal: 0, shippingCost: 0, codFee: 0, gatewayFee: 0, total: 0 };
      %>
      <section class="thank-you">
        <h2><%= t('thankyou.title') %></h2>
        <p><%= t('thankyou.orderId') %>: <strong><%= safeOrder.id %></strong></p>
        <p><%= t('thankyou.product') %>: <strong><%= safeOrder.productName || '-' %></strong></p>
        <p><%= t('thankyou.shipping') %>: <strong><%= safeOrder.shippingMethodLabel || '-' %></strong></p>
        <p><%= t('thankyou.payment') %>: <strong><%= safeOrder.paymentMethodLabel || '-' %></strong></p>
        <hr />
        <p><%= t('thankyou.subtotal') %>: <strong><%= order.subtotal.toFixed(2) %> €</strong></p>
        <p><%= t('thankyou.shippingCost') %>: <strong><%= order.shippingCost.toFixed(2) %> €</strong></p>
        <p><%= t('thankyou.codFee') %>: <strong><%= order.codFee.toFixed(2) %> €</strong></p>
        <p><%= t('thankyou.gatewayFee') %>: <strong><%= order.gatewayFee.toFixed(2) %> €</strong></p>
        <p><%= t('thankyou.total') %>: <strong><%= order.total.toFixed(2) %> €</strong></p>
        <% if (order.trackingNumber) { %>
          <p><%= lang === 'el' ? 'Tracking #' : 'Tracking #' %>: <strong><%= order.trackingNumber %></strong></p>
          <% if (order.trackingUrl) { %>
            <p><a href="<%= order.trackingUrl %>" target="_blank" rel="noopener"><%= lang === 'el' ? 'Άνοιγμα tracking link' : 'Open tracking link' %></a></p>
          <% } %>
        <% } else { %>
          <p><a href="<%= withTenantLink('/track') %>"><%= lang === 'el' ? 'Παρακολούθηση παραγγελίας' : 'Track your order' %></a></p>
        <% } %>

        <% if (safeOrder.wallet) { %>
          <p><%= t('thankyou.wallet') %>: <code><%= safeOrder.wallet %></code></p>
        <% } %>

        <p class="hash">
          <%= t('thankyou.proofHash') %>:<br />
          <code><%= proofHash %></code>
        </p>

        <% if (locals.contentUrl) { %>
        <div style="margin-top:24px;padding:20px;background:#f0fdf4;border:2px solid #22c55e;border-radius:10px;text-align:center;">
          <p style="margin:0 0 6px;font-size:1.05rem;font-weight:700;color:#15803d;">🔐 <%= t('content.accessReady') %></p>
          <p style="margin:0 0 14px;font-size:.88rem;color:#166534;"><%= t('content.accessSub') %></p>
          <a href="<%= contentUrl %>"
             style="display:inline-block;background:#16a34a;color:#fff;padding:11px 28px;border-radius:var(--button-radius,4px);text-decoration:none;font-weight:700;font-size:.95rem;">
            📄🎬 <%= t('content.accessBtn') %>
          </a>
          <p style="margin:10px 0 0;font-size:.75rem;color:#6b7280;"><%= t('content.saveLink') %></p>
        </div>
        <% } %>
        <% const trackHref = withTenantLink('/track'); %>
        <p style="margin-top:12px;">
          <a href="<%= trackHref %>">🔎 <%= lang === 'el' ? 'Παρακολούθηση παραγγελίας' : 'Track order' %></a>
          <% if (safeOrder.trackingToken) { %>
            <br /><small style="color:#6b7280;"><%= lang === 'el' ? 'Tracking token' : 'Tracking token' %>: <code><%= safeOrder.trackingToken %></code></small>
          <% } %>
        </p>
        <% if (!user) { %>
          <div style="margin-top:16px;padding:12px;border:1px solid #bfdbfe;background:#eff6ff;border-radius:10px;">
            <strong><%= lang === 'el' ? 'Θέλεις καλύτερη παρακολούθηση παραγγελιών;' : 'Want easier future tracking?' %></strong>
            <p style="margin:6px 0 0;font-size:.9rem;">
              <%= lang === 'el' ? 'Κάνε εγγραφή για να βλέπεις μελλοντικά όλες τις παραγγελίες/tracking σε ένα σημείο και για μελλοντική πρόσβαση σε συνδρομές ή videos αν ενεργοποιηθούν.' : 'Create an account so future orders/tracking are in one place and to be ready for future subscription/video access.' %>
            </p>
            <p style="margin:8px 0 0;"><a href="<%= withTenantLink('/signup') %>">✅ <%= lang === 'el' ? 'Δημιουργία λογαριασμού' : 'Create account' %></a></p>
          </div>
        <% } %>
      </section>
    </main>
    <button type="button" id="quick-back-btn" style="position:fixed;left:12px;bottom:18px;z-index:1200;border:none;border-radius:999px;padding:10px 14px;background:#0f172a;color:#fff;font-weight:700;cursor:pointer;box-shadow:0 10px 24px rgba(2,6,23,.28);"><%= lang === 'el' ? '← Επιστροφή' : '← Back' %></button>
    <% if (locals.clearCart) { %>
    <script>
      // Clear cart after successful order
      try { localStorage.removeItem('thrc_cart'); } catch(e) {}
      try { sessionStorage.removeItem('thrc_cart_session'); } catch(e) {}
    </script>
    <% } %>
    <script>
      (function() {
        const key = 'thrc_nav_last_url';
        const homeUrl = '<%= withTenantLink("/") %>';
        const currentUrl = window.location.pathname + window.location.search + window.location.hash;
        try { sessionStorage.setItem(key, currentUrl); } catch (err) {}
        const btn = document.getElementById('quick-back-btn');
        if (!btn) return;
        btn.addEventListener('click', function() {
          if (window.history.length > 1 && document.referrer && document.referrer.indexOf(window.location.origin) === 0) return window.history.back();
          try {
            const fallback = sessionStorage.getItem(key) || '';
            if (fallback && fallback !== currentUrl) return window.location.href = fallback;
          } catch (err) {}
          window.location.href = homeUrl;
        });
      })();
    </script>
  </body>
</html>
