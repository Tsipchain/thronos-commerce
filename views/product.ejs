<!DOCTYPE html>
<html lang="<%= lang %>">
  <head>
    <meta charset="UTF-8" />
    <title><%= product.name %> – <%= config.storeName %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="<%= withTenantLink('/favicon.ico', { v: (config.favicon && config.favicon.updatedAt) || '' }) %>" />
    <link rel="stylesheet" href="/styles.css" />
    <% if (product.seoTitle) { %><meta name="og:title" content="<%= product.seoTitle %>" /><% } %>
    <% if (product.seoDescription) { %><meta name="description" content="<%= product.seoDescription %>" /><% } %>
    <style>
      :root {
        --primary-color: <%= config.primaryColor %>;
        --accent-color:  <%= config.accentColor %>;
        --font-family:   <%= config.fontFamily %>;
        --menu-bg:         <%= (config.theme && config.theme.menuBg)         || '#111' %>;
        --menu-text:       <%= (config.theme && config.theme.menuText)       || '#fff' %>;
        --menu-active-bg:  <%= (config.theme && config.theme.menuActiveBg)   || '#f06292' %>;
        --menu-active-text:<%= (config.theme && config.theme.menuActiveText) || '#fff' %>;
        --button-radius:   <%= (config.theme && config.theme.buttonRadius)   || '4px' %>;
      }

      /* ── Hero image ───────────────────────────────────────────────── */
      .product-hero-image {
        overflow: hidden; border-radius: 10px; cursor: zoom-in;
        display: inline-block; max-width: 100%;
      }
      .product-hero-image img {
        display: block; max-width: 100%; max-height: 420px;
        object-fit: contain; border-radius: 10px;
        transition: transform .3s ease, opacity .15s;
      }
      .product-hero-image:hover img { transform: scale(1.08); }

      /* ── Lightbox ─────────────────────────────────────────────────── */
      #lightbox {
        display: none; position: fixed; inset: 0; z-index: 1100;
        background: rgba(0,0,0,.85); align-items: center; justify-content: center;
      }
      #lightbox.open { display: flex; }
      #lightbox img {
        max-width: 92vw; max-height: 88vh; object-fit: contain;
        border-radius: 8px; box-shadow: 0 8px 40px rgba(0,0,0,.5);
      }
      #lightbox-close {
        position: absolute; top: 20px; right: 28px;
        color: #fff; font-size: 2.2rem; cursor: pointer; line-height: 1;
        background: none; border: none; padding: 0;
      }

      /* ── Thumbnails ───────────────────────────────────────────────── */
      .gallery-thumbs { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 10px; }
      .gallery-thumbs img {
        width: 72px; height: 72px; object-fit: cover; border-radius: 4px;
        cursor: pointer; border: 2px solid transparent; transition: border-color .15s;
      }
      .gallery-thumbs img:hover, .gallery-thumbs img.active { border-color: var(--accent-color); }

      /* ── Stock badge ──────────────────────────────────────────────── */
      .stock-badge {
        display: inline-block; padding: 3px 10px; border-radius: 20px;
        font-size: .8rem; font-weight: 600; margin: 4px 0 12px;
      }
      .stock-badge.ok  { background: #d1fae5; color: #065f46; }
      .stock-badge.low { background: #fef3c7; color: #92400e; }
      .stock-badge.out { background: #fee2e2; color: #991b1b; }

      /* ── Add to Cart button ───────────────────────────────────────── */
      .btn-add-cart {
        display: inline-flex; align-items: center; gap: 8px;
        background: var(--primary-color, #4f46e5); color: #fff;
        border: none; border-radius: var(--button-radius, 4px);
        padding: 12px 26px; font-size: 1rem; font-weight: 600;
        cursor: pointer; margin-top: 10px;
        transition: opacity .15s, transform .1s;
      }
      .btn-add-cart:hover:not(:disabled) { opacity: .88; }
      .btn-add-cart:active:not(:disabled) { transform: scale(.96); }
      .btn-add-cart:disabled { opacity: .45; cursor: not-allowed; }

      /* ── Specs table ──────────────────────────────────────────────── */
      .specs-table {
        width: 100%; border-collapse: collapse; margin: 18px 0;
        font-size: .88rem;
      }
      .specs-table th, .specs-table td {
        padding: 7px 12px; border: 1px solid #e5e7eb; text-align: left;
      }
      .specs-table th {
        background: #f9fafb; width: 38%; font-weight: 600; color: #374151;
      }

      /* ── Variant selector ────────────────────────────────────────── */
      .variant-selector { margin: 14px 0 4px; }
      .variant-selector > p { font-size: .88rem; font-weight: 600; color: #374151; margin: 0 0 8px; }
      .variant-pills { display: flex; flex-wrap: wrap; gap: 8px; }
      .variant-pill {
        padding: 7px 18px; border-radius: 20px; border: 2px solid #e5e7eb;
        background: #fff; cursor: pointer; font-size: .88rem; font-weight: 500;
        transition: border-color .15s, background .15s, color .15s;
        line-height: 1.3;
      }
      .variant-pill:hover:not(:disabled) { border-color: var(--primary-color, #4f46e5); }
      .variant-pill.selected {
        border-color: var(--primary-color, #4f46e5);
        background: var(--primary-color, #4f46e5); color: #fff;
      }
      .variant-pill:disabled { opacity: .4; cursor: not-allowed; }
      .kit-config { margin-top: 22px; padding: 16px; border: 1px solid #e5e7eb; border-radius: 10px; background: #fafafa; }
      .kit-layout { display:grid; grid-template-columns: 1.5fr 1fr; gap: 14px; }
      .kit-group { margin-bottom: 16px; }
      .kit-group h4 { margin: 0 0 8px; font-size: .95rem; }
      .kit-choices { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 8px; }
      .kit-choice { border: 1px solid #d1d5db; border-radius: 8px; padding: 8px; background: #fff; }
      .kit-choice.active { border-color: var(--accent-color); box-shadow: 0 0 0 2px rgba(16,185,129,.15); }
      .kit-preview-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(120px,1fr)); gap: 8px; margin-top: 12px; }
      .kit-preview-item { background:#fff;border:1px solid #e5e7eb;border-radius:8px;padding:8px;text-align:center;font-size:.78rem; }
      .kit-preview-item img { width:100%;height:80px;object-fit:cover;border-radius:6px; }
      .final-price-box { position: sticky; bottom: 10px; background:#111827;color:#fff;padding:12px;border-radius:10px;margin-top:12px;display:flex;justify-content:space-between;align-items:center; }
      .quick-back-btn { position: fixed; left: 12px; bottom: 18px; z-index: 1200; border:none; border-radius:999px; padding:10px 14px; background:#0f172a; color:#fff; font-weight:700; cursor:pointer; box-shadow:0 10px 24px rgba(2,6,23,.28); }
      @media (max-width: 900px) { .kit-layout { grid-template-columns: 1fr; } }
      /* ── Header structure (shared) ── */
      .header-main-row { display:flex; align-items:center; gap:12px; }
      .header-nav-row  { display:flex; align-items:center; gap:12px; margin-top:0; }
      .header-auth-actions { margin-left:auto; display:flex; gap:8px; align-items:center; }
      .branding-mode-logo_only .store-name-wrap, .branding-mode-name_only .logo-frame { display:none; }
      .store-header.premium { background: linear-gradient(135deg,#0f172a,#1f2937); border-bottom: 1px solid rgba(255,255,255,.08); }

      /* ══════════════════════════════════════════════════════════════════
         EUKOLAKIS INDUSTRIAL THEME — product page
         ══════════════════════════════════════════════════════════════════ */
      body.eukolakis-classic {
        --eko-bg:           #0b0d12;
        --eko-surface:      #141820;
        --eko-surface-2:    #1c2030;
        --eko-border:       rgba(100,110,140,.28);
        --eko-border-hover: rgba(184,137,42,.55);
        --eko-accent:       #c4902e;
        --eko-accent-light: #dba83c;
        --eko-text:         #d0d5e0;
        --eko-text-muted:   #64707f;
        --eko-text-strong:  #edf0f6;
        background: var(--eko-bg);
        color: var(--eko-text);
      }

      /* ── Header: dark industrial bar ── */
      body.eukolakis-classic .store-header {
        background: #0b0d12 !important;
        border-bottom: 2px solid rgba(196,144,46,.32) !important;
        box-shadow: 0 2px 24px rgba(0,0,0,.55) !important;
        padding: 0 !important;
      }
      body.eukolakis-classic .store-header::before {
        content: ''; display: block; height: 2px;
        background: linear-gradient(90deg, transparent 0%, var(--eko-accent) 30%, var(--eko-accent-light) 60%, transparent 100%);
        opacity: .7;
      }
      body.eukolakis-classic .header-main-row {
        justify-content: space-between !important;
        align-items: center !important;
        padding: 12px 20px;
        min-height: 72px;
        max-width: 1180px;
        margin: 0 auto;
        width: 100%;
        box-sizing: border-box;
        flex-wrap: nowrap;
      }
      body.eukolakis-classic .logo-title.classic-branding {
        width: auto !important;
        justify-content: flex-start !important;
        text-align: left !important;
        align-items: center;
        gap: 12px;
        flex-shrink: 0;
      }
      body.eukolakis-classic .logo-frame {
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
        padding: 0 !important;
      }
      body.eukolakis-classic .logo-image-dynamic {
        max-width: 300px;
        filter: brightness(1.08) !important;
        width: auto;
      }
      body.eukolakis-classic .store-name-wrap h1 {
        font-size: 1.05rem !important;
        font-weight: 800;
        letter-spacing: .04em;
        text-transform: uppercase;
        color: var(--eko-text-strong);
        margin: 0;
      }
      body.eukolakis-classic .header-auth-actions {
        margin-left: auto !important;
        gap: 8px;
        flex-shrink: 0;
      }
      body.eukolakis-classic .header-auth-actions a.button {
        font-size: .8rem !important;
        padding: 7px 15px !important;
        border-radius: 7px !important;
        font-weight: 700 !important;
        text-decoration: none !important;
        line-height: 1 !important;
      }
      body.eukolakis-classic .header-auth-actions a.button:first-child {
        background: var(--eko-accent) !important;
        border-color: var(--eko-accent) !important;
        color: #fff !important;
      }
      body.eukolakis-classic .header-auth-actions a.button:last-child {
        background: transparent !important;
        border: 1px solid var(--eko-border) !important;
        color: var(--eko-text) !important;
      }
      body.eukolakis-classic .header-auth-actions a.button:last-child:hover {
        border-color: var(--eko-border-hover) !important;
        color: var(--eko-accent) !important;
      }

      /* ── Nav tab row ── */
      body.eukolakis-classic .header-nav-row {
        padding: 0 !important;
        border-top: 1px solid rgba(196,144,46,.12);
        background: rgba(0,0,0,.38);
      }
      body.eukolakis-classic .header-nav-row .main-nav {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 20px;
        display: block;
      }
      body.eukolakis-classic .header-nav-row .main-nav ul {
        display: flex; gap: 0; list-style: none; margin: 0; padding: 0;
        overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none;
      }
      body.eukolakis-classic .header-nav-row .main-nav ul::-webkit-scrollbar { display: none; }
      body.eukolakis-classic .header-nav-row .main-nav ul li a {
        display: flex; align-items: center;
        padding: 0 22px; height: 44px;
        color: var(--eko-text-muted);
        text-decoration: none; font-size: .82rem; font-weight: 600;
        letter-spacing: .02em; white-space: nowrap; text-transform: uppercase;
        border-bottom: 2px solid transparent;
        transition: color .14s, border-color .14s, background .14s;
      }
      body.eukolakis-classic .header-nav-row .main-nav ul li a:hover {
        color: var(--eko-accent);
        background: rgba(196,144,46,.06);
      }

      /* ── Preview banner ── */
      body.eukolakis-classic .preview-banner {
        background: rgba(196,144,46,.12) !important;
        border-bottom: 1px solid rgba(196,144,46,.25) !important;
        color: var(--eko-accent) !important;
        font-size: .8rem;
        padding: 6px 20px !important;
      }

      /* ── Main content area ── */
      body.eukolakis-classic main {
        background: var(--eko-bg);
        max-width: 1180px;
        margin: 0 auto;
        min-height: 60vh;
        padding: 20px 18px 48px;
      }
      body.eukolakis-classic .product-detail h2 { color: var(--eko-text-strong) !important; }
      body.eukolakis-classic .product-detail p  { color: var(--eko-text) !important; }
      body.eukolakis-classic p.price            { color: var(--eko-accent) !important; }
      body.eukolakis-classic .product-detail .price { color: var(--eko-accent) !important; }
      body.eukolakis-classic .variant-selector p { color: var(--eko-text) !important; }
      body.eukolakis-classic .kit-group h4 { color: var(--eko-text-strong) !important; }
      body.eukolakis-classic .kit-config p { color: var(--eko-text-muted) !important; }
      body.eukolakis-classic .specs-table th,
      body.eukolakis-classic .specs-table td {
        border-color: var(--eko-border);
        color: var(--eko-text);
        background: var(--eko-surface);
      }
      body.eukolakis-classic .specs-table th { color: var(--eko-accent); background: rgba(196,144,46,.08); }
      body.eukolakis-classic .btn-add-cart {
        background: var(--eko-accent);
        color: #0b0d12;
        font-weight: 700;
      }
      body.eukolakis-classic .btn-add-cart:hover:not(:disabled) { opacity: .88; }
      body.eukolakis-classic .variant-pill {
        border-color: var(--eko-border);
        background: var(--eko-surface);
        color: var(--eko-text);
      }
      body.eukolakis-classic .variant-pill:hover:not(:disabled) { border-color: var(--eko-accent); }
      body.eukolakis-classic .variant-pill.selected {
        border-color: var(--eko-accent);
        background: var(--eko-accent);
        color: #0b0d12;
      }
      body.eukolakis-classic .review-card { border-bottom-color: var(--eko-border); }
      body.eukolakis-classic .review-gate {
        background: var(--eko-surface);
        border: 1px solid var(--eko-border);
      }
      body.eukolakis-classic .review-gate input,
      body.eukolakis-classic .review-gate textarea,
      body.eukolakis-classic .review-gate select {
        background: var(--eko-bg);
        border-color: var(--eko-border);
        color: var(--eko-text);
      }
      body.eukolakis-classic .kit-config {
        background: var(--eko-surface);
        border-color: var(--eko-border);
      }
      body.eukolakis-classic .kit-choice {
        background: var(--eko-bg);
        border-color: var(--eko-border);
        color: var(--eko-text);
      }
      body.eukolakis-classic .final-price-box {
        background: var(--eko-surface);
        border: 1px solid var(--eko-border);
      }
      body.eukolakis-classic .quick-back-btn {
        background: var(--eko-surface);
        border: 1px solid var(--eko-border);
        color: var(--eko-accent);
      }
      body.eukolakis-classic .eko-back-link {
        color: var(--eko-accent) !important;
      }
      .logo-frame { display:inline-flex; align-items:center; justify-content:center; }
      .logo-frame.logo-frame-dark { background: rgba(15,23,42,.88); }
      .logo-frame.logo-frame-clean { background: rgba(255,255,255,.9); border: 1px solid rgba(15,23,42,.1); }
      .logo-frame.logo-frame-floating { background: rgba(255,255,255,.08); backdrop-filter: blur(3px); }
      .logo-image.cover { object-fit: cover; }
      .logo-image.contain { object-fit: contain; }
      .logo-image.clean_badge { object-fit: contain; filter: contrast(1.05) saturate(1.05); }
      .logo-image.transparent_blend { object-fit: contain; mix-blend-mode: screen; opacity: .95; }

      /* ── Reviews ──────────────────────────────────────────────────── */
      .reviews-section { margin-top: 36px; }
      .review-card {
        border-bottom: 1px solid #eee; padding: 12px 0;
      }
      .review-card .rv-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
      .rv-stars { color: #f59e0b; }
      .rv-date  { color: #aaa; font-size: .78rem; }
      .rv-comment { font-size: .88rem; margin: 4px 0 0; }
      .review-gate {
        background: #f9fafb; border-radius: 8px; padding: 18px 20px; margin-top: 16px;
      }
      .review-gate input, .review-gate textarea, .review-gate select {
        width: 100%; margin-top: 4px; padding: 7px 10px;
        border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box;
      }
      .review-gate label { display: block; margin-bottom: 10px; font-size: .9rem; }
    </style>
    <%
      const _offers = [];
      if (Array.isArray(product.variants) && product.variants.length) {
        product.variants.forEach(function(v) {
          _offers.push({
            "@type": "Offer",
            "name": v.label,
            "price": (Number(v.price) || 0).toFixed(2),
            "priceCurrency": "EUR",
            "availability": (v.stock === 0) ? "https://schema.org/OutOfStock" : "https://schema.org/InStock"
          });
        });
      } else {
        _offers.push({
          "@type": "Offer",
          "price": (Number(product.price) || 0).toFixed(2),
          "priceCurrency": "EUR",
          "availability": (product.stock === 0) ? "https://schema.org/OutOfStock" : "https://schema.org/InStock"
        });
      }
      const _ldJson = {
        "@context": "https://schema.org/",
        "@type": "Product",
        "name": product.name,
        "description": product.description || product.seoDescription || '',
        "sku": product.sku || '',
        "image": product.imageUrl || '',
        "brand": { "@type": "Brand", "name": config.storeName },
        "offers": _offers.length === 1 ? _offers[0] : _offers
      };
    %>
    <script type="application/ld+json"><%- JSON.stringify(_ldJson, null, 2) %></script>
  </head>
  <body class="<%= (config.theme && config.theme.presetId === 'eukolakis_classic_diy') ? 'eukolakis-classic' : '' %>">
    <% const theme = config.theme || {}; %>
    <% const isEukolakisClassic = tenant.id === 'eukolakis' && theme.presetId === 'eukolakis_classic_diy'; %>
    <% const brandingMode = theme.brandingMode || 'logo_name'; %>
    <% const logoBgMode = theme.logoBgMode || 'auto'; %>
    <% const logoFrameClass = logoBgMode === 'dark_badge' ? 'logo-frame-dark' : (logoBgMode === 'light_badge' ? 'logo-frame-clean' : (logoBgMode === 'none' ? '' : 'logo-frame-floating')); %>
    <% const logoMaxHeight = Math.max(56, Math.min(120, Number(theme.logoMaxHeight || (isEukolakisClassic ? 96 : 64)))); %>
    <% const hideStoreNameForClassicBanner = isEukolakisClassic && brandingMode === 'logo_name' && !!config.logoPath; %>
    <% const navCategories = Array.isArray(categories) ? categories.filter(function(c){ return c.showInMainNav !== false; }).sort(function(a,b){ return (Number(a.navOrder)||999)-(Number(b.navOrder)||999); }) : []; %>
    <header class="store-header <%= tenant.id === 'eukolakis' ? 'premium' : '' %> branding-mode-<%= brandingMode %>">
      <div class="header-main-row">
        <div class="logo-title <%= theme.headerLayout === 'centered' ? 'centered' : '' %> <%= isEukolakisClassic ? 'classic-branding' : '' %>">
          <% if (config.logoPath && brandingMode !== 'name_only') { %>
            <span class="logo-frame <%= logoFrameClass %>" style="padding:<%= Number(theme.logoPadding||6) %>px;border-radius:<%= Number(theme.logoRadius||10) %>px;">
              <img src="<%= config.logoPath %>" alt="<%= config.storeName %>" class="logo logo-image logo-image-dynamic <%= theme.logoDisplayMode || 'contain' %>" style="max-height:<%= logoMaxHeight %>px;" />
            </span>
          <% } %>
          <% if (brandingMode !== 'logo_only' && !hideStoreNameForClassicBanner) { %>
          <div class="store-name-wrap">
            <a href="<%= withTenantLink('/', lang !== 'el' ? { lang } : {}) %>" style="text-decoration:none;color:inherit;"><h1><%= config.storeName %></h1></a>
          </div>
          <% } %>
        </div>
        <% if (isEukolakisClassic) { %>
        <div class="header-auth-actions">
          <% if (!user) { %>
            <a class="button" href="<%= withTenantLink('/login', lang !== 'el' ? { lang } : {}) %>"><%= lang === 'el' ? 'Σύνδεση' : 'Login' %></a>
            <a class="button" href="<%= withTenantLink('/signup', lang !== 'el' ? { lang } : {}) %>"><%= lang === 'el' ? 'Εγγραφή' : 'Signup' %></a>
          <% } else { %>
            <a class="button" href="<%= withTenantLink('/account', lang !== 'el' ? { lang } : {}) %>"><%= lang === 'el' ? 'Ο Λογαριασμός μου' : 'My Account' %></a>
            <a class="button" href="<%= withTenantLink('/logout', lang !== 'el' ? { lang } : {}) %>"><%= lang === 'el' ? 'Αποσύνδεση' : 'Logout' %></a>
          <% } %>
        </div>
        <% } else { %>
        <div style="font-size:.85rem;display:flex;gap:12px;flex-wrap:wrap;padding:0 8px;">
          <% if (!user) { %>
            <a href="<%= withTenantLink('/login', lang !== 'el' ? { lang } : {}) %>">Login</a>
            <a href="<%= withTenantLink('/signup', lang !== 'el' ? { lang } : {}) %>">Signup</a>
          <% } else { %>
            <a href="<%= withTenantLink('/account', lang !== 'el' ? { lang } : {}) %>">My Account</a>
            <a href="<%= withTenantLink('/my-orders', lang !== 'el' ? { lang } : {}) %>">My Orders</a>
            <a href="<%= withTenantLink('/logout', lang !== 'el' ? { lang } : {}) %>">Logout</a>
          <% } %>
        </div>
        <% } %>
      </div>
      <% if (isPreviewMode) { %>
      <div class="preview-banner" style="padding:8px 16px;background:#fff7ed;border-bottom:1px solid #fed7aa;color:#9a3412;font-size:.85rem;">
        <strong>Preview Mode</strong> – this store is not live yet. Tenant: <strong><%= tenantId %></strong>
      </div>
      <% } %>
      <% if (isEukolakisClassic && navCategories.length) { %>
      <div class="header-nav-row">
        <nav class="main-nav open">
          <ul>
            <% navCategories.forEach(function(cat) { %>
              <li><a href="<%= withTenantLink('/', Object.assign({ category: cat.slug }, lang !== 'el' ? { lang } : {})) %>"><%= cat.name %></a></li>
            <% }) %>
          </ul>
        </nav>
      </div>
      <% } %>
    </header>

    <main>
      <a href="<%= withTenantLink('/', lang !== 'el' ? { lang } : {}) %>" class="<%= isEukolakisClassic ? 'eko-back-link' : '' %>" style="display:inline-flex;align-items:center;gap:6px;font-size:.86rem;color:var(--primary-color,#4f46e5);text-decoration:none;margin-bottom:14px;opacity:.85;">
        ← <%= t('checkout.backToStore') %>
      </a>
      <button type="button" id="quick-back-btn" class="quick-back-btn"><%= lang === 'el' ? '← Επιστροφή' : '← Back' %></button>
      <article class="product-detail">

        <%# ── Hero image + lightbox trigger ── %>
        <% const allImgs = [product.imageUrl].concat(Array.isArray(product.gallery) ? product.gallery : []).filter(Boolean); %>
        <% if (allImgs.length) { %>
          <div class="product-hero-image" onclick="openLightbox('<%= allImgs[0] %>')" id="hero-wrap">
            <img src="<%= allImgs[0] %>" alt="<%= product.name %>" id="hero-img" />
          </div>
          <% if (allImgs.length > 1) { %>
          <div class="gallery-thumbs">
            <% allImgs.forEach(function(url, gi) { %>
              <img src="<%= url %>" alt="" loading="lazy" class="<%= gi === 0 ? 'active' : '' %>"
                   onclick="swapHero(this, '<%= url %>')" />
            <% }) %>
          </div>
          <% } %>
        <% } %>

        <%# ── Product info ── %>
        <h2><%= product.name %></h2>
        <% if (product.sku) { %><p style="color:#888;font-size:.82rem;margin:-6px 0 6px;">SKU: <%= product.sku %></p><% } %>

        <% if (product.stock !== undefined) { %>
          <p id="stock-badge" class="stock-badge <%= product.stock === 0 ? 'out' : product.stock < 3 ? 'low' : 'ok' %>">
            <% if (product.stock === 0) { %><%= t('checkout.stockOut') %>
            <% } else if (product.stock < 3) { %><%= t('checkout.stockLow') %> (<%= product.stock %>)
            <% } else { %><%= t('checkout.inStock') %><% } %>
          </p>
        <% } else { %>
          <p id="stock-badge" class="stock-badge ok" style="display:none;"></p>
        <% } %>

        <p class="price"><span id="product-price"><%= Number(product.price).toFixed(2) %></span> €</p>
        <p style="margin:4px 0 10px;font-size:.82rem;color:#64748b;">
          🚚 <%= product.deliveryEstimate || (lang === 'el' ? (product.stock === 0 ? 'Παράδοση 4-7 ημέρες' : 'Παράδοση 1-3 ημέρες') : (product.stock === 0 ? 'Delivery in 4-7 days' : 'Delivery in 1-3 days')) %>
        </p>

        <%# ── Variant selector ── %>
        <% if (Array.isArray(product.variants) && product.variants.length) { %>
          <div class="variant-selector">
            <p><%= t('product.variantsTitle') %>: <strong id="variant-label"><%= product.variants[0].label %></strong></p>
            <div class="variant-pills">
              <% product.variants.forEach(function(v, vi) { %>
                <button class="variant-pill <%= vi === 0 ? 'selected' : '' %>"
                        data-vid="<%= v.id %>"
                        <%= v.stock === 0 ? 'disabled' : '' %>
                        onclick="selectVariant(this)">
                  <%= v.label %>
                  <% if (Number(v.price) !== Number(product.price)) { %>
                    <span style="font-size:.76rem;opacity:.82;"> &ndash; <%= Number(v.price).toFixed(2) %> &euro;</span>
                  <% } %>
                </button>
              <% }) %>
            </div>
          </div>
        <% } %>

        <% if (product.description) { %>
          <p class="product-description"><%= product.description %></p>
        <% } %>

        <% if (product.type === 'KIT' && Array.isArray(product.kitOptions) && product.kitOptions.length) { %>
          <section class="kit-config">
            <h3 style="margin:0 0 6px;"><%= lang === 'el' ? 'Διαμόρφωσε το Kit σου' : 'Configure your kit' %></h3>
            <p style="margin:0 0 12px;font-size:.84rem;color:#6b7280;"><%= lang === 'el' ? 'Επέλεξε υποχρεωτικά και προαιρετικά μέρη. Η τελική τιμή ενημερώνεται άμεσα.' : 'Choose required and optional parts. Final price updates instantly.' %></p>
            <div class="kit-layout">
              <div>
                <% product.kitOptions.forEach(function(group){ %>
                  <div class="kit-group" data-kit-group="<%= group.id %>" data-required="<%= group.required ? '1':'0' %>" data-input-type="<%= group.inputType || 'radio' %>">
                    <h4><%= group.label %> <% if (group.required) { %><span style="color:#dc2626;">*</span><% } %></h4>
                    <div class="kit-choices">
                      <% (group.choices || []).forEach(function(choice){ %>
                        <label class="kit-choice">
                          <input type="<%= group.inputType === 'checkbox' ? 'checkbox':'radio' %>"
                                name="kit_<%= group.id %>"
                                value="<%= choice.id %>"
                                data-group-id="<%= group.id %>"
                                data-group-label="<%= group.label %>"
                                data-choice-label="<%= choice.label %>"
                                data-price-delta="<%= Number(choice.priceDelta) || 0 %>"
                                data-image="<%= choice.image || '' %>"
                                data-linked-product-id="<%= choice.linkedProductId || '' %>"
                                onchange="onKitSelectionChange()" />
                          <strong><%= choice.label %></strong>
                          <div style="font-size:.78rem;color:#6b7280;"><%= choice.description || '' %></div>
                          <div style="font-size:.78rem;color:#111827;font-weight:600;"><%= Number(choice.priceDelta || 0).toFixed(2) %> €</div>
                        </label>
                      <% }) %>
                    </div>
                  </div>
                <% }) %>
              </div>
              <div>
                <strong style="font-size:.85rem;">Selected parts preview</strong>
                <div id="kit-preview" class="kit-preview-grid"></div>
              </div>
              <div class="final-price-box">
                <span>Τελική τιμή kit</span>
                <strong><span id="kit-final-price"><%= Number(product.price).toFixed(2) %></span> €</strong>
              </div>
            </div>
          </section>
        <% } %>

        <%# ── Technical specs ── %>
        <% const specs = Array.isArray(product.specs) ? product.specs.filter(function(s){ return s.k && s.v; }) : []; %>
        <% if (specs.length) { %>
          <h3 style="margin-top:22px;margin-bottom:8px;font-size:1rem;"><%= t('product.specsTitle') %></h3>
          <table class="specs-table">
            <tbody>
              <% specs.forEach(function(s) { %>
                <tr><th><%= s.k %></th><td><%= s.v %></td></tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>

        <%# ── Digital content preview ── %>
        <% if (product.hasDigitalContent) { %>
          <input type="hidden" id="has-manual" value="<%= product.manualUrl ? '1' : '' %>" />
          <div id="content-preview" style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:16px 20px;margin:18px 0;<%= (product.manualUrl || product.videoUrl || product.contentDescription) ? '' : 'display:none' %>">
            <p style="margin:0 0 8px;font-weight:700;color:#15803d;font-size:.95rem;">🎁 <%= t('product.contentIncluded') %></p>
            <% if (product.contentDescription) { %>
              <p style="margin:0 0 8px;font-size:.86rem;color:#166534;"><%= product.contentDescription %></p>
            <% } %>
            <ul style="margin:0;padding-left:18px;font-size:.83rem;color:#166534;">
              <% if (product.manualUrl) { %><li>📄 <%= t('product.contentManual') %></li><% } %>
              <% if (product.videoUrl) { %><li>🎬 <%= t('product.contentVideo') %></li><% } %>
            </ul>
            <p style="margin:8px 0 0;font-size:.75rem;color:#6b7280;"><%= t('product.contentAfterPurchase') %></p>
          </div>
        <% } %>

        <%# ── Add to Cart button ── %>
        <button class="btn-add-cart" id="btn-add-cart"
                <%= product.stock === 0 ? 'disabled' : '' %>
                onclick="addThisToCart()">
          🛒 <%= t('storefront.addToCart') %>
        </button>

      </article>

      <%# ── Reviews section ── %>
      <section class="reviews-section">
        <h3><%= t('reviews.title') %></h3>
        <div id="reviews-list"></div>

        <div class="review-gate" id="review-gate">
          <p style="margin:0 0 12px;font-size:.88rem;color:#6b7280;"><%= t('reviews.verifiedNote') %></p>
          <label>
            Email αγοράς
            <input type="email" id="rv-email-check" placeholder="Το email που χρησιμοποιήσατε στην παραγγελία" />
          </label>
          <button class="button" type="button" id="rv-verify-btn" onclick="verifyPurchase()" style="margin-top:2px;">
            <%= t('reviews.verifyBtn') %>
          </button>
          <p id="rv-verify-msg" style="font-size:.83rem;margin-top:8px;"></p>
        </div>

        <div id="review-form-wrap" class="review-gate" style="display:none;">
          <h4 style="margin:0 0 14px;"><%= t('reviews.writeReview') %></h4>
          <p id="review-msg" style="font-size:.88rem;margin-bottom:10px;"></p>
          <input type="hidden" id="rv-verified-email" value="" />
          <label>
            <%= t('reviews.labelName') %>
            <input type="text" id="rv-name" />
          </label>
          <label>
            <%= t('reviews.labelRating') %>
            <select id="rv-rating">
              <option value="5">★★★★★</option>
              <option value="4">★★★★☆</option>
              <option value="3">★★★☆☆</option>
              <option value="2">★★☆☆☆</option>
              <option value="1">★☆☆☆☆</option>
            </select>
          </label>
          <label>
            <%= t('reviews.labelComment') %>
            <textarea id="rv-comment" rows="3" style="resize:vertical;"></textarea>
          </label>
          <button class="button" id="rv-submit" type="button" onclick="submitReview()"><%= t('reviews.submit') %></button>
        </div>
      </section>
    </main>

    <%# ── Lightbox overlay ── %>
    <div id="lightbox" onclick="closeLightbox()">
      <button id="lightbox-close" onclick="closeLightbox()" aria-label="Κλείσιμο">&times;</button>
      <img id="lightbox-img" src="" alt="" onclick="event.stopPropagation()" />
    </div>

    <%# ── Floating cart ── %>
    <%- include('_cart') %>

    <script>
      // ── Product data ──────────────────────────────────────────────
      const PRODUCT = {
        id:    '<%= product.id %>',
        name:  '<%- (product.name || '').replace(/'/g, "\\'") %>',
        price: <%= Number(product.price) || 0 %>,
        imageUrl: '<%- (product.imageUrl || '').replace(/'/g, "\\'") %>'
      };
      const VARIANTS = <%- JSON.stringify(Array.isArray(product.variants) ? product.variants : []) %>;
      const IS_KIT = <%= product.type === 'KIT' ? 'true' : 'false' %>;
      const KIT_OPTIONS = <%- JSON.stringify(Array.isArray(product.kitOptions) ? product.kitOptions : []) %>;
      const KIT_PAY_MODE = <%- JSON.stringify(product.kitPayMode || 'bundle') %>;
      const HAS_DIGITAL = <%= product.hasDigitalContent ? 'true' : 'false' %>;
      const IS_EUKOLAKIS_CLASSIC = <%= tenant.id === 'eukolakis' && config.theme && config.theme.presetId === 'eukolakis_classic_diy' ? 'true' : 'false' %>;
      const HOME_WIZARD_URL = '<%= withTenantLink('/', Object.assign({ wizard: product.id }, lang !== 'el' ? { lang } : {})) %>';
      const BASE_MANUAL  = '<%= product.manualUrl ? '1' : '' %>';
      const BASE_VIDEO   = '<%- (product.videoUrl || '').replace(/'/g, "\\'") %>';
      const BASE_DESC    = '<%- (product.contentDescription || '').replace(/'/g, "\\'").replace(/\n/g, ' ') %>';
      const STOCK_OUT    = '<%= t("checkout.stockOut") %>';
      const STOCK_LOW    = '<%= t("checkout.stockLow") %>';
      const IN_STOCK     = '<%= t("checkout.inStock") %>';

      let selectedVariant = VARIANTS.length ? VARIANTS[0] : null;
      let selectedKitOptions = [];

      if (IS_EUKOLAKIS_CLASSIC && IS_KIT) {
        window.location.replace(HOME_WIZARD_URL);
      }

      // ── Variant selection ─────────────────────────────────────────
      function selectVariant(btn) {
        document.querySelectorAll('.variant-pill').forEach(function(b) { b.classList.remove('selected'); });
        btn.classList.add('selected');
        const vid = btn.dataset.vid;
        const v   = VARIANTS.find(function(vv) { return vv.id === vid; });
        if (!v) return;
        selectedVariant = v;

        // Update label
        const lbl = document.getElementById('variant-label');
        if (lbl) lbl.textContent = v.label;

        // Update price
        const priceEl = document.getElementById('product-price');
        if (priceEl) priceEl.textContent = (Number(v.price) || PRODUCT.price).toFixed(2);

        // Update stock badge
        const stock = (v.stock !== undefined) ? Number(v.stock) : -1;
        updateStockBadge(stock);

        // Update add-to-cart disabled state
        const btnCart = document.getElementById('btn-add-cart');
        if (btnCart) btnCart.disabled = (Number(v.stock) === 0);

        // Update digital content preview
        if (HAS_DIGITAL) {
          updateContentPreview(
            v.videoUrl  || BASE_VIDEO,
            v.contentDescription || BASE_DESC,
            BASE_MANUAL
          );
        }
      }

      function updateStockBadge(stock) {
        const badge = document.getElementById('stock-badge');
        if (!badge) return;
        if (stock < 0) { badge.style.display = 'none'; return; }
        badge.style.display = '';
        if (stock === 0) {
          badge.className = 'stock-badge out';
          badge.textContent = STOCK_OUT;
        } else if (stock < 3) {
          badge.className = 'stock-badge low';
          badge.textContent = STOCK_LOW + ' (' + stock + ')';
        } else {
          badge.className = 'stock-badge ok';
          badge.textContent = IN_STOCK;
        }
      }

      function updateContentPreview(videoUrl, desc, hasManual) {
        const box = document.getElementById('content-preview');
        if (!box) return;
        const hasVideo = !!videoUrl;
        if (!hasManual && !hasVideo && !desc) { box.style.display = 'none'; return; }
        box.style.display = '';
        let html = '<p style="margin:0 0 8px;font-weight:700;color:#15803d;font-size:.95rem;">🎁 <%= t("product.contentIncluded") %></p>';
        if (desc) html += '<p style="margin:0 0 8px;font-size:.86rem;color:#166534;">' + desc.replace(/</g,'&lt;') + '</p>';
        html += '<ul style="margin:0;padding-left:18px;font-size:.83rem;color:#166534;">';
        if (hasManual) html += '<li>📄 <%= t("product.contentManual") %></li>';
        if (hasVideo)  html += '<li>🎬 <%= t("product.contentVideo") %></li>';
        html += '</ul>';
        html += '<p style="margin:8px 0 0;font-size:.75rem;color:#6b7280;"><%= t("product.contentAfterPurchase") %></p>';
        box.innerHTML = html;
      }

      // ── Add to Cart ───────────────────────────────────────────────
      function collectSelectedKitOptions() {
        const selected = [];
        document.querySelectorAll('[data-group-id]').forEach(function(el) {
          if (el.checked) {
            selected.push({
              groupId: el.dataset.groupId,
              groupLabel: el.dataset.groupLabel,
              choiceId: el.value,
              choiceLabel: el.dataset.choiceLabel,
              priceDelta: Number(el.dataset.priceDelta || 0),
              image: el.dataset.image || '',
              linkedProductId: el.dataset.linkedProductId || ''
            });
          }
        });
        return selected;
      }

      function kitMissingRequired() {
        if (!IS_KIT) return false;
        return KIT_OPTIONS.some(function(group) {
          if (!group.required) return false;
          return !selectedKitOptions.some(function(sel) { return sel.groupId === group.id; });
        });
      }

      function computeFinalPrice() {
        const base = KIT_PAY_MODE === 'parts_only' ? 0 : (selectedVariant ? (Number(selectedVariant.price) || PRODUCT.price) : PRODUCT.price);
        const delta = selectedKitOptions.reduce(function(s, o) { return s + (Number(o.priceDelta) || 0); }, 0);
        return base + delta;
      }

      function renderKitPreview() {
        if (!IS_KIT) return;
        const wrap = document.getElementById('kit-preview');
        if (!wrap) return;
        wrap.innerHTML = selectedKitOptions.map(function(opt) {
          const img = opt.image ? '<img src=\"' + opt.image + '\" alt=\"' + opt.choiceLabel.replace(/</g,'&lt;') + '\" />' : '';
          return '<div class=\"kit-preview-item\">' + img + '<div><strong>' + opt.choiceLabel.replace(/</g,'&lt;') + '</strong></div><div>' + opt.groupLabel.replace(/</g,'&lt;') + '</div></div>';
        }).join('') || '<div style=\"font-size:.8rem;color:#6b7280;\">Δεν έχουν επιλεγεί μέρη ακόμα.</div>';
        const fp = document.getElementById('kit-final-price');
        if (fp) fp.textContent = computeFinalPrice().toFixed(2);
      }

      function onKitSelectionChange() {
        selectedKitOptions = collectSelectedKitOptions();
        document.querySelectorAll('.kit-choice').forEach(function(c) { c.classList.remove('active'); });
        document.querySelectorAll('.kit-choice input:checked').forEach(function(el) {
          if (el && el.closest('.kit-choice')) el.closest('.kit-choice').classList.add('active');
        });
        renderKitPreview();
        const btnCart = document.getElementById('btn-add-cart');
        if (btnCart && IS_KIT) btnCart.disabled = kitMissingRequired();
        if (IS_KIT) {
          const priceEl = document.getElementById('product-price');
          if (priceEl) priceEl.textContent = computeFinalPrice().toFixed(2);
        }
      }

      function addThisToCart() {
        if (typeof window.thrcAddToCart !== 'function') return;
        selectedKitOptions = collectSelectedKitOptions();
        if (kitMissingRequired()) {
          alert('Παρακαλώ συμπλήρωσε όλα τα υποχρεωτικά πεδία kit.');
          return;
        }
        const finalPrice = computeFinalPrice();
        const optionSummary = selectedKitOptions.map(function(opt) { return opt.groupLabel + ': ' + opt.choiceLabel; }).join(' | ');
        const p = {
          id:       PRODUCT.id,
          name:     PRODUCT.name,
          price:    finalPrice,
          basePrice: selectedVariant ? (Number(selectedVariant.price) || PRODUCT.price) : PRODUCT.price,
          imageUrl: PRODUCT.imageUrl
        };
        if (selectedVariant) {
          p.variantId    = selectedVariant.id;
          p.variantLabel = selectedVariant.label;
        }
        if (IS_KIT) {
          if (KIT_PAY_MODE === 'parts_only') {
            selectedKitOptions.filter(function(opt){ return !!opt.linkedProductId; }).forEach(function(opt){
              window.thrcAddToCart({
                id: opt.linkedProductId,
                name: opt.choiceLabel,
                price: Number(opt.priceDelta || 0),
                imageUrl: opt.image || '',
                cartKey: opt.linkedProductId + '::from-kit:' + PRODUCT.id + ':' + opt.groupId
              });
            });
            window.thrcAddToCart({
              id: PRODUCT.id,
              name: PRODUCT.name + ' (summary)',
              price: 0,
              imageUrl: PRODUCT.imageUrl,
              selectedOptions: selectedKitOptions,
              optionSummary: optionSummary || undefined,
              finalUnitPrice: 0,
              cartKey: PRODUCT.id + '::' + selectedKitOptions.map(function(o){ return o.groupId + '=' + o.choiceId; }).sort().join('&') + '::summary',
              isKitSummary: true
            });
            return;
          }
          p.selectedOptions = selectedKitOptions;
          p.optionSummary = optionSummary;
          p.finalUnitPrice = finalPrice;
          p.cartKey = PRODUCT.id + '::' + selectedKitOptions.map(function(o){ return o.groupId + '=' + o.choiceId; }).sort().join('&');
        }
        window.thrcAddToCart(p);
      }

      // ── Gallery swap ──────────────────────────────────────────────
      function swapHero(thumb, url) {
        const hero = document.getElementById('hero-img');
        const wrap = document.getElementById('hero-wrap');
        if (hero) { hero.src = url; }
        if (wrap) { wrap.onclick = function() { openLightbox(url); }; }
        document.querySelectorAll('.gallery-thumbs img').forEach(function(t) { t.classList.remove('active'); });
        thumb.classList.add('active');
      }

      // ── Lightbox ──────────────────────────────────────────────────
      function openLightbox(url) {
        const lb = document.getElementById('lightbox');
        document.getElementById('lightbox-img').src = url;
        lb.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
      function closeLightbox() {
        document.getElementById('lightbox').classList.remove('open');
        document.body.style.overflow = '';
      }
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeLightbox();
      });
      if (IS_KIT) {
        selectedKitOptions = collectSelectedKitOptions();
        renderKitPreview();
        onKitSelectionChange();
      }

      // ── Reviews ───────────────────────────────────────────────────
      const PRODUCT_ID = '<%= product.id %>';
      const STARS = ['', '★☆☆☆☆', '★★☆☆☆', '★★★☆☆', '★★★★☆', '★★★★★'];

      function renderReviews(list) {
        const el = document.getElementById('reviews-list');
        if (!list.length) {
          el.innerHTML = '<p style="color:#aaa;font-style:italic;font-size:.86rem;"><%= t("reviews.noReviews") %></p>';
          return;
        }
        el.innerHTML = list.slice(-20).reverse().map(function(r) {
          const d = new Date(r.createdAt).toLocaleDateString('<%= lang %>');
          const verified = r.verified ? '<span style="color:#059669;font-size:.75rem;margin-left:6px;">✓ Επαληθευμένη αγορά</span>' : '';
          return '<div class="review-card">' +
            '<div class="rv-meta"><strong>' + (r.name || '').replace(/</g,'&lt;') + '</strong>' +
            verified +
            '<span class="rv-stars">' + (STARS[r.rating] || r.rating) + '</span>' +
            '<span class="rv-date">' + d + '</span></div>' +
            '<p class="rv-comment">' + (r.comment || '').replace(/</g,'&lt;') + '</p>' +
            '</div>';
        }).join('');
      }

      fetch('/api/products/' + PRODUCT_ID + '/reviews')
        .then(function(r) { return r.json(); }).then(renderReviews).catch(function(){});

      // ── Verified purchase gate ────────────────────────────────────
      function verifyPurchase() {
        const email = (document.getElementById('rv-email-check').value || '').trim();
        const msg   = document.getElementById('rv-verify-msg');
        if (!email) { msg.style.color = '#dc2626'; msg.textContent = 'Εισάγετε email.'; return; }
        msg.style.color = '#6b7280'; msg.textContent = 'Έλεγχος...';
        fetch('/api/products/' + PRODUCT_ID + '/can-review?email=' + encodeURIComponent(email))
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.canReview) {
              document.getElementById('rv-verified-email').value = email;
              document.getElementById('review-gate').style.display = 'none';
              document.getElementById('review-form-wrap').style.display = '';
            } else {
              msg.style.color = '#dc2626';
              msg.textContent = '<%= t("reviews.notVerified") %>';
            }
          })
          .catch(function() { msg.style.color='#dc2626'; msg.textContent='Σφάλμα ελέγχου.'; });
      }

      function submitReview() {
        const name    = (document.getElementById('rv-name').value    || '').trim();
        const comment = (document.getElementById('rv-comment').value || '').trim();
        const rating  = document.getElementById('rv-rating').value;
        const email   = document.getElementById('rv-verified-email').value;
        const msgEl   = document.getElementById('review-msg');
        msgEl.textContent = '';
        fetch('/api/products/' + PRODUCT_ID + '/reviews', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, rating, comment, email })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.ok) {
            msgEl.style.color = '#155724';
            msgEl.textContent = '<%= t("reviews.submitOk") %>';
            document.getElementById('rv-name').value = '';
            document.getElementById('rv-comment').value = '';
            fetch('/api/products/' + PRODUCT_ID + '/reviews')
              .then(function(r) { return r.json(); }).then(renderReviews);
          } else {
            msgEl.style.color = '#721c24';
            msgEl.textContent = data.error || '<%= t("reviews.submitErr") %>';
          }
        })
        .catch(function() { msgEl.style.color='#721c24'; msgEl.textContent='<%= t("reviews.submitErr") %>'; });
      }
      (function() {
        const key = 'thrc_nav_last_url';
        const homeUrl = '<%= withTenantLink("/", lang !== "el" ? { lang } : {}) %>';
        const currentUrl = window.location.pathname + window.location.search + window.location.hash;
        try {
          sessionStorage.setItem(key, currentUrl);
        } catch (err) {}
        const backBtn = document.getElementById('quick-back-btn');
        if (!backBtn) return;
        backBtn.addEventListener('click', function() {
          const ref = document.referrer || '';
          let hasStoreReferrer = false;
          try {
            if (ref) {
              const refUrl = new URL(ref);
              hasStoreReferrer = refUrl.origin === window.location.origin && !/^\/admin(?:\/|$)/.test(refUrl.pathname);
            }
          } catch (err) {}
          if (window.history.length > 1 && hasStoreReferrer) return window.history.back();
          try {
            const fallback = sessionStorage.getItem(key) || '';
            if (fallback && fallback !== currentUrl) return window.location.href = fallback;
          } catch (err) {}
          window.location.href = homeUrl;
        });
      })();
    </script>
  </body>
</html>
