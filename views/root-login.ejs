<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Root Login</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <main style="max-width:420px;margin:48px auto;padding:0 16px;">
    <h1>Root Admin Login</h1>
    <% if (error) { %><p style="color:#b91c1c;"><%= error %></p><% } %>
    <form method="POST" action="/root/login" style="display:grid;gap:10px;">
      <label>Password
        <input type="password" name="password" required />
      </label>
      <button class="button" type="submit">Login</button>
    </form>
  </main>
</body>
</html>
