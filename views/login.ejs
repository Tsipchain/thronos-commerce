<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login – <%= config.storeName %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header><div class="logo-title"><a href="/" style="text-decoration:none;color:inherit;"><h1><%= config.storeName %></h1></a></div></header>
  <main style="max-width:460px;margin:30px auto;padding:0 16px;">
    <h2>Login</h2>
    <% if (error) { %><p style="color:#b91c1c;"><%= error %></p><% } %>
    <form method="POST" action="/login" style="display:grid;gap:10px;">
      <label>Email <input type="email" name="email" required /></label>
      <label>Password <input type="password" name="password" required /></label>
      <button class="button" type="submit">Login</button>
    </form>
    <p style="margin-top:12px;font-size:.9rem;">No account? <a href="/signup">Signup</a></p>
  </main>
</body>
</html>
