<!DOCTYPE html>
<html lang="<%= lang %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= config.storeName %> · Intro</title>
    <link rel="icon" href="<%= withTenantLink('/favicon.ico', { v: (config.favicon && config.favicon.updatedAt) || '' }) %>" />
    <link rel="stylesheet" href="/styles.css" />
    <style>
      <% if (isEukolakisClassic) { %>
      :root {
        --eko-bg: #0b0d12; --eko-surface: #141820; --eko-surface-2: #1c2030;
        --eko-accent: #c4902e; --eko-accent-light: #dba83c;
        --eko-border: rgba(100,110,140,.28); --eko-text: #d0d5e0; --eko-text-muted: #64707f;
      }
      body {
        margin: 0;
        background: var(--eko-bg);
        background-image:
          repeating-linear-gradient(0deg,  rgba(196,144,46,.025) 0px, rgba(196,144,46,.025) 1px, transparent 1px, transparent 56px),
          repeating-linear-gradient(90deg, rgba(196,144,46,.025) 0px, rgba(196,144,46,.025) 1px, transparent 1px, transparent 56px);
        color: var(--eko-text);
        font-family: system-ui, sans-serif;
      }
      .intro-card {
        width: min(980px, 96vw);
        background: var(--eko-surface);
        border: 1px solid var(--eko-border);
        border-top: 2px solid var(--eko-accent);
        border-radius: 14px; padding: 20px;
        box-shadow: 0 32px 72px rgba(0,0,0,.65), 0 0 0 1px rgba(196,144,46,.08) inset;
      }
      .intro-card h2 { color: #edf0f6; letter-spacing: .04em; text-transform: uppercase; font-size: 1rem; }
      .intro-sound { border: 1px solid var(--eko-border); background: var(--eko-surface-2); color: var(--eko-text); border-radius: 8px; padding: 9px 12px; cursor: pointer; }
      .quick-back-btn { background: var(--eko-surface-2); border: 1px solid var(--eko-border); color: var(--eko-text); }
      <% } else { %>
      body { margin:0; background: radial-gradient(circle at 10% 10%, #111827, #020617 72%); color:#fff; font-family: system-ui, sans-serif; }
      .intro-card { width:min(980px,96vw); background:rgba(15,23,42,.9); border:1px solid rgba(148,163,184,.35); border-radius:16px; padding:18px; box-shadow:0 28px 58px rgba(0,0,0,.5); }
      .intro-sound { border:1px solid rgba(148,163,184,.45); background:#0b1220; color:#e2e8f0; border-radius:8px; padding:9px 12px; cursor:pointer; }
      .quick-back-btn { background:#0f172a; color:#fff; }
      <% } %>
      .intro-wrap { min-height:100vh; display:grid; place-items:center; padding:20px; }
      .intro-player { width:100%; border-radius:10px; overflow:hidden; background:#000; }
      .intro-player video { width:100%; max-height:72vh; display:block; object-fit:cover; }
      .intro-actions { margin-top:14px; display:flex; gap:10px; flex-wrap:wrap; justify-content:center; align-items:center; }
      .intro-enter { border:none; background:<%= isEukolakisClassic ? '#c4902e' : '#0ea5e9' %>; color:#fff; border-radius:8px; padding:10px 22px; font-weight:700; cursor:pointer; font-size:.95rem; letter-spacing:.01em; }
      .intro-enter:hover { filter:brightness(1.1); transform: translateY(-1px); }
      .intro-skip { color:#94a3b8; text-decoration:none; padding:6px 12px; font-size:.82rem; display:inline-block; margin-top:8px; }
      .quick-back-btn { position:fixed; left:12px; bottom:18px; z-index:1200; border:none; border-radius:999px; padding:10px 14px; font-weight:700; cursor:pointer; box-shadow:0 10px 24px rgba(2,6,23,.28); }
    </style>
  </head>
  <body>
    <button type="button" id="quick-back-btn" class="quick-back-btn"><%= lang === 'el' ? '← Επιστροφή' : '← Back' %></button>
    <div class="intro-wrap">
      <div class="intro-card">
        <h2 style="margin:0 0 10px;"><%= config.storeName %></h2>
        <% if (homepage.introVideoUrl) { %>
        <div class="intro-player">
          <video id="intro-video" controls playsinline preload="metadata" muted <%= homepage.introPosterUrl ? ('poster="' + homepage.introPosterUrl + '"') : '' %>>
            <source src="<%= homepage.introVideoUrl %>" type="video/mp4" />
          </video>
        </div>
        <div class="intro-actions">
          <button class="intro-sound" id="intro-sound-toggle" type="button"><%= lang === 'el' ? 'Αναπαραγωγή με ήχο' : 'Play with sound' %></button>
          <button class="intro-enter" id="intro-enter"><%= lang === 'el' ? 'Μπες στο κατάστημα' : 'Enter store' %></button>
        </div>
        <% } else { %>
        <div style="padding:40px 20px;text-align:center;">
          <% if (config.logoPath) { %>
            <img src="<%= config.logoPath %>" alt="<%= config.storeName %>" style="max-height:80px;max-width:240px;margin:0 auto 20px;display:block;object-fit:contain;" />
          <% } else { %>
            <div style="font-size:2.4rem;font-weight:800;letter-spacing:.04em;margin-bottom:20px;"><%= config.storeName %></div>
          <% } %>
          <p style="color:#94a3b8;margin:0 0 24px;font-size:.95rem;"><%= lang === 'el' ? 'Καλώς ορίσατε στο κατάστημά μας.' : 'Welcome to our store.' %></p>
          <button class="intro-enter" id="intro-enter" style="font-size:1.1rem;padding:14px 32px;"><%= lang === 'el' ? 'Μπες στο κατάστημα' : 'Enter store' %></button>
        </div>
        <% } %>
        <div style="text-align:center;"><a class="intro-skip" id="intro-skip" href="<%= skipHref %>"><%= lang === 'el' ? 'Παράλειψη intro' : 'Skip intro' %></a></div>
      </div>
    </div>
    <script>
      (function(){
        var nextHref = <%- JSON.stringify(skipHref).replace(/</g, '\\u003c') %>;
        var videoEl = document.getElementById('intro-video');
        var soundBtn = document.getElementById('intro-sound-toggle');
        function persistIntroSeen() {
          var days = 180;
          var expires = new Date(Date.now() + days * 24 * 60 * 60 * 1000).toUTCString();
          var cookieName = <%- JSON.stringify(introCookieName || 'intro_seen') %>;
          var storageKey = <%- JSON.stringify(introStorageKey || 'intro_seen') %>;
          var secureAttr = window.location.protocol === 'https:' ? '; Secure' : '';
          document.cookie = cookieName + '=1; expires=' + expires + '; path=/; SameSite=Lax' + secureAttr;
          try { localStorage.setItem(storageKey, '1'); } catch (_) {}
        }
        if (soundBtn && videoEl) {
          soundBtn.addEventListener('click', function() {
            videoEl.muted = !videoEl.muted;
            soundBtn.textContent = videoEl.muted
              ? <%- JSON.stringify(lang === 'el' ? 'Αναπαραγωγή με ήχο' : 'Play with sound').replace(/</g, '\\u003c') %>
              : <%- JSON.stringify(lang === 'el' ? 'Σίγαση' : 'Mute').replace(/</g, '\\u003c') %>;
            if (!videoEl.paused) return;
            videoEl.play().catch(function(){});
          });
        }
        document.getElementById('intro-enter').addEventListener('click', function() {
          persistIntroSeen();
          window.location.href = nextHref;
        });
        var skipEl = document.getElementById('intro-skip');
        if (skipEl) {
          skipEl.addEventListener('click', function() {
            persistIntroSeen();
          });
        }
        var backBtn = document.getElementById('quick-back-btn');
        if (backBtn) {
          backBtn.addEventListener('click', function() {
            if (window.history.length > 1 && document.referrer && document.referrer.indexOf(window.location.origin) === 0) return window.history.back();
            window.location.href = nextHref;
          });
        }
      })();
    </script>
  </body>
</html>
