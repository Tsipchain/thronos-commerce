        <label><span>Υπότιτλος hero (EL / EN)</span>
          <textarea name="heroSubtitle_el" rows="2" placeholder="Ελληνικά — σύντομη περιγραφή"><%= resolveField(rawConfig.heroSubtitle, 'el') %></textarea>
          <textarea name="heroSubtitle_en" rows="2" placeholder="English — short tagline"><%= resolveField(rawConfig.heroSubtitle, 'en') %></textarea>
          <small class="helper">Προαιρετικός υπότιτλος κάτω από τον τίτλο.</small>
        </label>
        <label><span>Εικόνα hero / banner</span>
          <input type="text" id="homepageHeroImage" name="homepageHeroImage" value="<%= (rawConfig.homepage && rawConfig.homepage.heroImage) || '' %>" placeholder="/tenants/<%= tenant.id %>/media/banner.png" />
          <% if (rawConfig.homepage && rawConfig.homepage.heroImage) { %>
          <div style="margin-top:6px;">
            <img id="homepage-hero-preview" src="<%= rawConfig.homepage.heroImage %>" alt="Hero preview" style="width:220px;height:80px;object-fit:cover;border-radius:8px;border:1px solid #d1d5db;" />
            <small style="display:block;font-size:.75rem;color:#64748b;margin-top:3px;">Τρέχουσα εικόνα hero</small>
          </div>
          <% } else { %>
          <img id="homepage-hero-preview" src="" alt="" style="display:none;margin-top:6px;width:220px;height:80px;object-fit:cover;border-radius:8px;border:1px solid #d1d5db;" />
          <% } %>
          <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:8px;">
            <input type="file" id="homepage-banner-file" accept="image/*" />
            <button type="button" class="btn-xs" id="homepage-banner-upload-btn">Ανέβασμα banner</button>
            <small id="homepage-banner-status" style="font-size:.78rem;color:#64748b;"></small>
          </div>
          <small class="helper">Συνιστώμενο μέγεθος: <strong>1600 × 600 px</strong>. Κρατήστε το κείμενο στο κέντρο (το mobile κόβει τα άκρα).</small>
        </label>
        <h3 class="settings-section-heading"><%= homepageLabels.featuredSectionTitle %></h3>
        <p class="helper"><%= homepageLabels.featuredSectionHelper %></p>

        <% const hpPrimary = (rawConfig.homepage && (rawConfig.homepage.featuredPrimary || rawConfig.homepage.featuredIds)) || []; %>
        <% const hpKitProducts = (rawProducts || []).filter(function(p){ return p.type === 'KIT'; }); %>
        <% const hpKitIds = hpKitProducts.map(function(p){ return p.id; }); %>
        <% const hpP1Missing = hpPrimary[0] && !hpKitIds.includes(hpPrimary[0]); %>
        <% const hpP2Missing = hpPrimary[1] && !hpKitIds.includes(hpPrimary[1]); %>
        <label><span><%= homepageLabels.featuredPrimary1 %> <small style="font-weight:400;color:#94a3b8;">(μεγάλο card αριστερά)</small></span>
          <select name="homepageFeaturedPrimary1" id="homepageFeaturedPrimary1">
            <option value=""><%= homepageLabels.featuredPickerEmpty %></option>
            <% hpKitProducts.forEach(function(p){ %>
              <option value="<%= p.id %>" <%= hpPrimary[0] === p.id ? 'selected' : '' %>><%= resolveField(p.name, 'el') || resolveField(p.name, 'en') || p.id %></option>
            <% }) %>
          </select>
          <% if (hpP1Missing) { %><small style="color:#b91c1c;font-weight:700;">Το επιλεγμένο προϊόν δεν υπάρχει πλέον — επιλέξτε νέο.</small><% } %>
        </label>
        <label><span><%= homepageLabels.featuredPrimary2 %> <small style="font-weight:400;color:#94a3b8;">(μεγάλο card δεξιά)</small></span>
          <select name="homepageFeaturedPrimary2" id="homepageFeaturedPrimary2">
            <option value=""><%= homepageLabels.featuredPickerEmpty %></option>
            <% hpKitProducts.forEach(function(p){ %>
              <option value="<%= p.id %>" <%= hpPrimary[1] === p.id ? 'selected' : '' %>><%= resolveField(p.name, 'el') || resolveField(p.name, 'en') || p.id %></option>
            <% }) %>
          </select>
          <% if (hpP2Missing) { %><small style="color:#b91c1c;font-weight:700;">Το επιλεγμένο προϊόν δεν υπάρχει πλέον — επιλέξτε νέο.</small><% } %>
          <% if (hpP1Missing || hpP2Missing) { %><button type="button" class="button" style="margin-top:8px;" onclick="window.location.hash='#tab-products'">Μεταβείτε στα Προϊόντα →</button><% } %>
        </label>
        <label><span><%= homepageLabels.featuredSecondaryLabel %> <small style="font-weight:400;color:#94a3b8;">(προαιρετικό)</small></span>
          <input type="text" name="homepageFeaturedSecondaryId" value="<%= (rawConfig.homepage && rawConfig.homepage.featuredSecondaryId) || '' %>" placeholder="<%= homepageLabels.featuredSecondaryPlaceholder %>" />
          <small class="helper"><%= homepageLabels.featuredSecondaryHelper %></small>
        </label>
        <label><span><%= homepageLabels.secondaryCardTitleLabel %> <small style="font-weight:400;color:#94a3b8;">(προαιρετικό override)</small></span>
          <input type="text" name="homepageSecondaryTitle_el" value="<%= resolveField(rawConfig.homepage && rawConfig.homepage.secondaryCard && rawConfig.homepage.secondaryCard.title, 'el') %>" placeholder="<%= homepageLabels.secondaryCardTitlePlaceholderEl %>" />
          <input type="text" name="homepageSecondaryTitle_en" value="<%= resolveField(rawConfig.homepage && rawConfig.homepage.secondaryCard && rawConfig.homepage.secondaryCard.title, 'en') %>" placeholder="<%= homepageLabels.secondaryCardTitlePlaceholderEn %>" />
          <small class="helper"><%= homepageLabels.secondaryCardTitleHelper %></small>
        </label>
        <label><span><%= homepageLabels.secondaryCardTextLabel %> <small style="font-weight:400;color:#94a3b8;">(προαιρετικό)</small></span>
          <input type="text" name="homepageSecondaryText_el" value="<%= resolveField(rawConfig.homepage && rawConfig.homepage.secondaryCard && rawConfig.homepage.secondaryCard.text, 'el') %>" placeholder="<%= homepageLabels.secondaryCardTextPlaceholderEl %>" />
          <input type="text" name="homepageSecondaryText_en" value="<%= resolveField(rawConfig.homepage && rawConfig.homepage.secondaryCard && rawConfig.homepage.secondaryCard.text, 'en') %>" placeholder="<%= homepageLabels.secondaryCardTextPlaceholderEn %>" />
        </label>
        <label><span><%= homepageLabels.secondaryCardLinkLabel %> <small style="font-weight:400;color:#94a3b8;">(προαιρετικό)</small></span>
          <input type="text" name="homepageSecondaryLink" value="<%= (rawConfig.homepage && rawConfig.homepage.secondaryCard && rawConfig.homepage.secondaryCard.link) || '' %>" placeholder="<%= homepageLabels.secondaryCardLinkPlaceholder %>" />
          <small class="helper"><%= homepageLabels.secondaryCardLinkHelper %></small>
        </label>
        <label><span>Εικόνα secondary card <small style="font-weight:400;color:#94a3b8;">(προαιρετικό)</small></span>
          <input type="text" name="homepageSecondaryImage" value="<%= (rawConfig.homepage && rawConfig.homepage.secondaryCard && rawConfig.homepage.secondaryCard.image) || '' %>" placeholder="/tenants/TENANT/media/secondary-card.jpg" />
          <small class="helper">Σχετική ή απόλυτη διαδρομή εικόνας για το secondary card της αρχικής σελίδας.</small>
        </label>

        <h3 class="settings-section-heading">Ενότητες Αρχικής Σελίδας</h3>
        <p class="helper">Επιλέξτε ποιες ενότητες εμφανίζονται και αλλάξτε τη σειρά τους.</p>

        <label class="checkbox-label">
          <input type="hidden" name="homepageShowSubscriptionsCard" value="0" />
          <input type="checkbox" name="homepageShowSubscriptionsCard" value="1" <%= (rawConfig.homepage && rawConfig.homepage.showSubscriptionsCard) ? 'checked' : '' %> />
          <span><%= homepageLabels.subscriptionsToggle %></span>
        </label>

        <%# Hidden raw block order input — managed by the drag UI below %>
        <label style="display:none;">
          <input type="text" id="homepageBlockOrderInput" name="homepageBlockOrder" value="<%= Array.isArray(rawConfig.homepage && rawConfig.homepage.blockOrder) ? rawConfig.homepage.blockOrder.join(',') : 'hero,kits,spare,subscriptions' %>" placeholder="hero,kits,spare,subscriptions" />
        </label>

        <h3 class="settings-section-heading">Intro / Teaser Σελίδα</h3>
        <% const _introEnabled = !!(rawConfig.homepage && rawConfig.homepage.introEnabled); %>
        <% const _introMode    = (rawConfig.homepage && rawConfig.homepage.introMode) || 'basic'; %>
        <% const _introVideo   = (rawConfig.homepage && rawConfig.homepage.introVideoUrl) || ''; %>
        <% const _introPoster  = (rawConfig.homepage && rawConfig.homepage.introPosterUrl) || ''; %>
        <% const _introTagline = (rawConfig.homepage && rawConfig.homepage.introTagline) || ''; %>
        <%# ── Status summary chip ── %>
        <div style="padding:10px 14px;border-radius:10px;margin-bottom:12px;background:<%= _introEnabled ? '#f0fdf4' : '#f8fafc' %>;border:1px solid <%= _introEnabled ? '#bbf7d0' : '#e2e8f0' %>;">
          <p style="margin:0;font-size:.84rem;font-weight:700;color:<%= _introEnabled ? '#15803d' : '#475569' %>;">
            <% if (_introEnabled) { %>✓ Intro ενεργό — εμφανίζεται στον επισκέπτη πριν μπει στο κατάστημα<% } else { %>○ Intro ανενεργό — παρακάμπτεται αυτόματα<% } %>
          </p>
          <% if (_introEnabled) { %>
          <p style="margin:4px 0 0;font-size:.78rem;color:#166534;">
            Τύπος: <strong><%= _introMode === 'video' ? 'Βίντεο' : _introMode === 'assembly' ? 'Montage (assembly)' : 'Απλό splash' %></strong>
            <% if (_introMode === 'video') { %>
              &nbsp;·&nbsp;
              <% if (_introVideo) { %>Video: <strong>ρυθμισμένο ✓</strong><% } else { %><em style="color:#ca8a04;">χωρίς video URL — θα εμφανιστεί montage</em><% } %>
            <% } %>
          </p>
          <% } %>
        </div>

        <%# ── Enable/disable ── %>
        <label class="checkbox-label">
          <input type="hidden" name="homepageIntroEnabled" value="0" />
          <input type="checkbox" name="homepageIntroEnabled" value="1" <%= _introEnabled ? 'checked' : '' %> />
          <span>Ενεργοποίηση intro σελίδας</span>
        </label>
        <small class="helper" style="display:block;margin:-4px 0 12px 28px;">Όταν ενεργό, ο νέος επισκέπτης βλέπει πρώτα την intro σελίδα — αφού την δει μία φορά, παρακάμπτεται αυτόματα (cookie 180 ημερών).</small>

        <%# ── Mode selector ── %>
        <label><span>Τύπος εισαγωγής</span>
          <select name="homepageIntroMode">
            <option value="basic"    <%= _introMode === 'basic'    ? 'selected' : '' %>>Απλό splash — logo + μήνυμα καλωσορίσματος</option>
            <option value="assembly" <%= _introMode === 'assembly' ? 'selected' : '' %>>Montage — τα στοιχεία ασσεμπλάρονται στην οθόνη</option>
            <option value="video"    <%= _introMode === 'video'    ? 'selected' : '' %>>Βίντεο — αναπαραγωγή βίντεο εισαγωγής</option>
          </select>
          <small class="helper">
            <strong>Απλό splash</strong>: logo + όνομα + μήνυμα.&nbsp;
            <strong>Montage</strong>: τα στοιχεία εμφανίζονται το ένα μετά το άλλο (premium εφέ).&nbsp;
            <strong>Βίντεο</strong>: παίζει βίντεο — αν δεν έχει οριστεί URL, εμφανίζεται αυτόματα montage.
          </small>
        </label>

        <%# ── Tagline (used by basic + assembly modes) ── %>
        <label><span>Υπότιτλος / tagline <small style="font-weight:400;color:#94a3b8;">(προαιρετικό)</small></span>
          <input type="text" name="homepageIntroTagline" value="<%= _introTagline %>"
                 placeholder="<%= lang === 'el' ? 'π.χ. Εξοπλισμός & ανταλλακτικά για επαγγελματίες' : 'e.g. Professional tools & parts' %>" />
          <small class="helper">Εμφανίζεται κάτω από το όνομα του καταστήματος στο splash ή το montage. Αφήστε κενό για το προεπιλεγμένο μήνυμα καλωσορίσματος.</small>
        </label>

        <%# ── Video fields — shown always, note when irrelevant ── %>
        <label><span>URL βίντεο εισαγωγής (.mp4) <small style="font-weight:400;color:#94a3b8;">(για τύπο Βίντεο)</small></span>
          <input type="text" name="homepageIntroVideoUrl" value="<%= _introVideo %>" placeholder="/tenants/<%= tenant.id %>/media/intro/intro.mp4" />
          <small class="helper">Ανεβάστε το βίντεο στην ενότητα <a href="#tab-upload">Media</a> και αντιγράψτε το path εδώ.</small>
        </label>
        <label><span>Εικόνα poster βίντεο <small style="font-weight:400;color:#94a3b8;">(εμφανίζεται πριν φορτωθεί το βίντεο)</small></span>
          <input type="text" name="homepageIntroPosterUrl" value="<%= _introPoster %>" placeholder="/tenants/<%= tenant.id %>/media/intro/poster.jpg" />
          <% if (_introPoster) { %>
          <div style="margin-top:6px;">
            <img src="<%= _introPoster %>" alt="Poster preview" style="height:72px;max-width:220px;object-fit:cover;border-radius:6px;border:1px solid #d1d5db;" onerror="this.style.display='none'" />
            <small style="display:block;font-size:.72rem;color:#64748b;margin-top:2px;">Τρέχον poster</small>
          </div>
          <% } %>
          <small class="helper">Ίδιο aspect ratio με το video (π.χ. 16:9).</small>
        </label>

        <%# ── Preview link ── %>
        <div style="margin:8px 0 16px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
          <a href="<%= withTenantLink('/intro') %>" target="_blank" style="display:inline-flex;align-items:center;gap:6px;font-size:.82rem;color:#0ea5e9;text-decoration:none;padding:7px 12px;border:1px solid rgba(14,165,233,.35);border-radius:7px;background:rgba(14,165,233,.06);">
            ▶ Προεπισκόπηση intro &nbsp;<small style="opacity:.7;">(νέα καρτέλα)</small>
          </a>
          <% if (!_introEnabled) { %>
          <small style="color:#64748b;font-size:.78rem;">Θα ανακατευθυνθείτε στην αρχική αν το intro δεν είναι ενεργό.</small>
          <% } %>
        </div>
        <h3 class="settings-section-heading" style="margin-top:20px;">Σειρά & Ορατότητα Ενοτήτων</h3>
        <p class="helper">Αλλάξτε σειρά με τα βέλη ↑↓ και απενεργοποιήστε ενότητες που δεν χρειάζεστε.<% if (config.theme && config.theme.presetId === 'eukolakis_classic_diy') { %> Το <strong>Εμφάνιση Hero</strong> ελέγχει το βιομηχανικό hero banner της αρχικής σελίδας.<% } %></p>
        <div id="homepage-block-builder" style="border:1px solid #dbe2ea;border-radius:8px;padding:10px;background:#f8fafc;margin-bottom:10px;">
          <div data-key="hero" class="hb-row" style="display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px dashed #d1d5db;"><span>Hero / Banner</span><span><button type="button" class="btn-xs hb-up">↑</button> <button type="button" class="btn-xs hb-down">↓</button></span></div>
          <div data-key="kits" class="hb-row" style="display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px dashed #d1d5db;"><span><%= homepageLabels.blockRowKits %></span><span><button type="button" class="btn-xs hb-up">↑</button> <button type="button" class="btn-xs hb-down">↓</button></span></div>
          <div data-key="spare" class="hb-row" style="display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px dashed #d1d5db;"><span><%= homepageLabels.blockRowSpare %></span><span><button type="button" class="btn-xs hb-up">↑</button> <button type="button" class="btn-xs hb-down">↓</button></span></div>
          <div data-key="subscriptions" class="hb-row" style="display:flex;justify-content:space-between;align-items:center;padding:6px 0;"><span><%= homepageLabels.blockRowSubscriptions %></span><span><button type="button" class="btn-xs hb-up">↑</button> <button type="button" class="btn-xs hb-down">↓</button></span></div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px;margin-bottom:12px;">
          <label class="checkbox-label"><input type="hidden" name="homepageBlockHero" value="0" /><input type="checkbox" name="homepageBlockHero" value="1" <%= (!rawConfig.homepage || !rawConfig.homepage.blockVisibility || rawConfig.homepage.blockVisibility.hero !== false) ? 'checked' : '' %> /><span>Εμφάνιση Hero</span></label>
          <label class="checkbox-label"><input type="hidden" name="homepageBlockKits" value="0" /><input type="checkbox" name="homepageBlockKits" value="1" <%= (!rawConfig.homepage || !rawConfig.homepage.blockVisibility || rawConfig.homepage.blockVisibility.kits !== false) ? 'checked' : '' %> /><span><%= homepageLabels.blockShowKits %></span></label>
          <label class="checkbox-label"><input type="hidden" name="homepageBlockSpare" value="0" /><input type="checkbox" name="homepageBlockSpare" value="1" <%= (!rawConfig.homepage || !rawConfig.homepage.blockVisibility || rawConfig.homepage.blockVisibility.spare !== false) ? 'checked' : '' %> /><span><%= homepageLabels.blockShowSpare %></span></label>
          <label class="checkbox-label"><input type="hidden" name="homepageBlockSubscriptions" value="0" /><input type="checkbox" name="homepageBlockSubscriptions" value="1" <%= (!rawConfig.homepage || !rawConfig.homepage.blockVisibility || rawConfig.homepage.blockVisibility.subscriptions !== false) ? 'checked' : '' %> /><span><%= homepageLabels.blockShowSubscriptions %></span></label>
        </div>
        <label><span><%= homepageLabels.blockKitsTitleLabel %> <small style="font-weight:400;color:#94a3b8;">(προαιρετικό override)</small></span>
          <input type="text" name="homepageKitsTitle" value="<%= (rawConfig.homepage && rawConfig.homepage.blockContent && rawConfig.homepage.blockContent.kitsTitle) || '' %>" placeholder="<%= homepageLabels.blockKitsTitlePlaceholder %>" />
          <small class="helper">Αφήστε κενό για τον προεπιλεγμένο τίτλο.</small>
        </label>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px;">
          <label><span>CTA κουμπί — κείμενο <small style="font-weight:400;color:#94a3b8;">(kits)</small></span>
            <input type="text" name="homepageKitsCtaLabel" value="<%= (rawConfig.homepage && rawConfig.homepage.blockContent && rawConfig.homepage.blockContent.kitsCtaLabel) || '' %>" placeholder="π.χ. Δείτε τα kits" />
          </label>
          <label><span>CTA κουμπί — σύνδεσμος <small style="font-weight:400;color:#94a3b8;">(kits)</small></span>
            <input type="text" name="homepageKitsCtaHref" value="<%= (rawConfig.homepage && rawConfig.homepage.blockContent && rawConfig.homepage.blockContent.kitsCtaHref) || '' %>" placeholder="/products?cat=kits" />
          </label>
        </div>
        <label><span><%= homepageLabels.blockSpareTitleLabel %> <small style="font-weight:400;color:#94a3b8;">(προαιρετικό override)</small></span>
          <input type="text" name="homepageSpareTitle" value="<%= (rawConfig.homepage && rawConfig.homepage.blockContent && rawConfig.homepage.blockContent.spareTitle) || '' %>" placeholder="<%= homepageLabels.blockSpareTitlePlaceholder %>" />
          <small class="helper">Αφήστε κενό για τον προεπιλεγμένο τίτλο.</small>
        </label>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px;">
          <label><span>CTA κουμπί — κείμενο <small style="font-weight:400;color:#94a3b8;">(ανταλλακτικά)</small></span>
            <input type="text" name="homepageSpareCtaLabel" value="<%= (rawConfig.homepage && rawConfig.homepage.blockContent && rawConfig.homepage.blockContent.spareCtaLabel) || '' %>" placeholder="π.χ. Ανταλλακτικά & εργαλεία" />
          </label>
          <label><span>CTA κουμπί — σύνδεσμος <small style="font-weight:400;color:#94a3b8;">(ανταλλακτικά)</small></span>
            <input type="text" name="homepageSpareCtaHref" value="<%= (rawConfig.homepage && rawConfig.homepage.blockContent && rawConfig.homepage.blockContent.spareCtaHref) || '' %>" placeholder="/products?cat=spare" />
          </label>
        </div>
        <label><span><%= homepageLabels.blockSubscriptionsTitleLabel %> <small style="font-weight:400;color:#94a3b8;">(προαιρετικό override)</small></span>
          <input type="text" name="homepageSubscriptionsTitle" value="<%= (rawConfig.homepage && rawConfig.homepage.blockContent && rawConfig.homepage.blockContent.subscriptionsTitle) || '' %>" placeholder="<%= homepageLabels.blockSubscriptionsTitlePlaceholder %>" />
          <small class="helper">Αφήστε κενό για τον προεπιλεγμένο τίτλο.</small>
        </label>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px;">
          <label><span>CTA κουμπί — κείμενο <small style="font-weight:400;color:#94a3b8;">(συνδρομές)</small></span>
            <input type="text" name="homepageSubscriptionsCtaLabel" value="<%= (rawConfig.homepage && rawConfig.homepage.blockContent && rawConfig.homepage.blockContent.subscriptionsCtaLabel) || '' %>" placeholder="π.χ. Δείτε τα πλάνα" />
          </label>
          <label><span>CTA κουμπί — σύνδεσμος <small style="font-weight:400;color:#94a3b8;">(συνδρομές)</small></span>
            <input type="text" name="homepageSubscriptionsCtaHref" value="<%= (rawConfig.homepage && rawConfig.homepage.blockContent && rawConfig.homepage.blockContent.subscriptionsCtaHref) || '' %>" placeholder="/products?cat=subscriptions" />
          </label>
        </div>
        <h3 class="settings-section-heading">Επικοινωνία & Social Media</h3>
        <p class="helper">Τα στοιχεία επικοινωνίας και τα social links εμφανίζονται στο footer του καταστήματος.</p>

        <label><span>Email επικοινωνίας</span>
          <input type="email" name="footerContactEmail" value="<%= (rawConfig.footer && rawConfig.footer.contactEmail) || '' %>" placeholder="info@katastima.gr" />
          <small class="helper">Εμφανίζεται στο footer ως σύνδεσμος επικοινωνίας.</small>
        </label>
        <label><span>Διεύθυνση παραλαβής / φυσικό κατάστημα</span>
          <input type="text" name="footerPickupAddress" value="<%= (rawConfig.footer && rawConfig.footer.pickupAddress) || '' %>" placeholder="π.χ. Αθήνα, Λεωφόρος Παπάγου 12" />
          <small class="helper">Αφήστε κενό αν δεν υπάρχει φυσικό κατάστημα παραλαβής.</small>
        </label>
        <label><span>Facebook URL</span>
          <input type="text" name="footerFacebookUrl" value="<%= (rawConfig.footer && rawConfig.footer.facebookUrl) || '' %>" placeholder="https://facebook.com/yourpage" />
        </label>
        <label><span>Instagram URL</span>
          <input type="text" name="footerInstagramUrl" value="<%= (rawConfig.footer && rawConfig.footer.instagramUrl) || '' %>" placeholder="https://instagram.com/yourhandle" />
        </label>
        <label><span>TikTok URL</span>
          <input type="text" name="footerTiktokUrl" value="<%= (rawConfig.footer && rawConfig.footer.tiktokUrl) || '' %>" placeholder="https://tiktok.com/@yourhandle" />
        </label>
        <p class="helper" style="margin-top:4px;">
          Το “Powered by” του footer ρυθμίζεται από το Root Admin στο
          <code>/root/tenants</code>.
        </p>
        <input type="password" name="password" placeholder="Κωδικός διαχειριστή" />
        <p class="helper" style="margin-top:-4px;">Προαιρετικό όσο το admin session είναι ενεργό (30 λεπτά).</p>
        <button type="submit" class="button">Αποθήκευση homepage</button>
      </form>


      <%# ══════════════════════════════════════════════════════════ %>
      <%#   TAB 2 – CATEGORIES                                      %>
      <%# ══════════════════════════════════════════════════════════ %>
      <section id="tab-categories" class="admin-block section-panel">
        <h2><%= t('admin.categoriesTitle') %></h2>
        <p class="helper"><%= t('admin.categoriesHelper') %></p>
        <form method="POST" action="<%= withTenantLink('/admin/settings') %>" class="admin-subform" style="margin-bottom:12px;">
          <h3 style="margin:0 0 8px;">Εμφάνιση κατηγοριών στο κατάστημα</h3>
          <label><span>Τρόπος εμφάνισης κάρτας «Ανταλλακτικά / Εργαλεία»</span>
            <select name="themeSpareToolsCardMode">
              <option value="prominent" <%= ((config.theme && config.theme.spareToolsCardMode) || 'prominent') === 'prominent' ? 'selected' : '' %>>Κεντρική / Μεγάλη κάρτα (προεπιλογή)</option>
              <option value="compact" <%= ((config.theme && config.theme.spareToolsCardMode) || '') === 'compact' ? 'selected' : '' %>>Συμπαγής / Μικρή κάρτα</option>
            </select>
          </label>
          <input type="password" name="password" placeholder="Κωδικός διαχειριστή" />
          <button type="submit" class="button">Αποθήκευση εμφάνισης</button>
        </form>
        <p class="cat-helper-row">Αντικατάσταση εικόνας: πατήστε «Ανέβασμα/Αλλαγή» και διαλέξτε αρχείο. Δεν χρειάζεται επικόλληση path.</p>
        <label style="display:inline-flex;align-items:center;gap:8px;font-size:.82rem;margin-bottom:10px;">
          Κωδικός επαναπιστοποίησης (μόνο αν ζητηθεί):
          <input id="category-reauth-password" type="password" placeholder="προαιρετικό" style="padding:6px 8px;border:1px solid #d1d5db;border-radius:6px;min-width:220px;" />
        </label>
        <div id="cat-upload-status" class="cat-upload-status"></div>

        <table class="admin-table">
          <thead>
            <tr>
              <th><%= t('admin.catColId') %></th>
              <th>Εικόνα</th>
              <th><%= t('admin.catColName') %></th>
              <th><%= t('admin.catColSlug') %></th>
              <th>Στο μενού</th>
              <th>Σειρά</th>
              <th><%= t('admin.catColParent') %></th>
              <th><%= t('admin.catColAction') %></th>
            </tr>
          </thead>
          <tbody>
            <% categories.forEach(function(cat){ %>
              <tr>
                <% const rawCat = rawCategories.find(rc=>rc.id===cat.id); %>
                <td><code><%= cat.id %></code></td>
                <td>
                  <% if (rawCat?.image) { %>
                    <div class="cat-image-wrap">
                      <img src="<%= rawCat.image %>" alt="<%= cat.name %>" class="cat-preview" />
                      <div class="cat-hover-actions">
                        <label class="cat-upload-btn" style="padding:4px 8px;font-size:.72rem;">
                          <input type="file" accept="image/*" onchange="uploadCategoryImage('<%= cat.id %>', this)" style="display:none;" />
                          Αλλαγή
                        </label>
                        <button type="button" class="cat-upload-btn cat-remove-btn" style="padding:4px 8px;font-size:.72rem;" onclick="removeCategoryImage('<%= cat.id %>')">Αφαίρεση</button>
                      </div>
                    </div>
                  <% } else { %><span style="color:#9ca3af;">—</span><% } %>
                </td>
                <td>
                  <div><strong>EL:</strong> <%= resolveField(rawCat?.name, 'el') || cat.name %></div>
                  <div style="color:#6b7280;"><strong>EN:</strong> <%= resolveField(rawCat?.name, 'en') || '—' %></div>
                  <div class="cat-meta">
                    <div><strong>EL desc:</strong> <%= resolveField(rawCat?.shortDescription, 'el') || '—' %></div>
                    <div><strong>EN desc:</strong> <%= resolveField(rawCat?.shortDescription, 'en') || '—' %></div>
                  </div>
                </td>
                <td><%= cat.slug %></td>
                <td><%= rawCat && rawCat.showInMainNav === false ? 'Όχι' : 'Ναι' %></td>
                <td><%= (rawCat && rawCat.navOrder !== undefined) ? rawCat.navOrder : '—' %></td>
                <td><%= cat.parentId ? cat.parentId : '–' %></td>
                <td>
                  <div class="cat-inline-actions">
                    <label class="cat-upload-btn">
                      <input type="file" accept="image/*" onchange="uploadCategoryImage('<%= cat.id %>', this)" style="display:none;" />
                      <%= rawCat?.image ? 'Αλλαγή εικόνας' : 'Ανέβασμα εικόνας' %>
                    </label>
                    <button type="button" class="cat-upload-btn cat-remove-btn" onclick="removeCategoryImage('<%= cat.id %>')" <%= rawCat?.image ? '' : 'disabled' %>>Αφαίρεση</button>
                  </div>
                  <form method="POST" action="<%= withTenantLink('/admin/categories/delete') %>" class="inline-form">
                    <input type="hidden" name="categoryId" value="<%= cat.id %>" />
                    <input type="password" name="password" placeholder="Κωδικός (μόνο αν ζητηθεί)"
                           <%= permissions.canEditCategories ? '' : 'disabled' %> />
                    <button type="submit" class="button danger"
                            <%= permissions.canEditCategories ? '' : 'disabled' %>><%= t('admin.catDelete') %></button>
                  </form>
                </td>
              </tr>
            <% }) %>
            <% if (categories.length === 0) { %>
              <tr><td colspan="8" style="color:#888;font-style:italic;"><%= t('admin.catNone') %></td></tr>
            <% } %>
          </tbody>
        </table>

        <% if (permissions.canEditCategories) { %>
        <form method="POST" action="<%= withTenantLink('/admin/import/categories') %>" enctype="multipart/form-data" class="admin-subform">
          <h3>Μαζικό import κατηγοριών (CSV)</h3>
          <p class="helper">
            Χρήσιμες στήλες: <code>id</code>, <code>name</code>, <code>slug</code>, <code>description</code>, <code>image</code>, <code>visible</code>, <code>showInMainNav</code>, <code>navOrder</code>.
            Μπορείτε επίσης να δώσετε <code>name_el/name_en</code> και <code>description_el/description_en</code>.
          </p>
          <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
            <input type="file" name="file" accept=".csv,text/csv" required />
            <input type="password" name="password" placeholder="Κωδικός διαχειριστή (μόνο αν ζητηθεί)" required />
            <button type="submit" class="button">Import categories</button>
            <a class="button" style="background:#334155;" href="<%= withTenantLink('/admin/import/categories-template.csv') %>">Sample CSV</a>
          </div>
          <small class="helper">Το import κάνει create/update με ασφαλή normalisation. Στο αποτέλεσμα θα δείτε πόσα έγιναν create/update/skipped και τυχόν προβλήματα ανά γραμμή.</small>
        </form>
        <% } %>

        <% if (permissions.canEditCategories) { %>
        <form method="POST" action="<%= withTenantLink('/admin/categories/add') %>" class="admin-subform">
          <h3><%= t('admin.catAddTitle') %></h3>
          <p class="helper"><%= t('admin.catAddHelper') %></p>
          <input type="text" name="id" placeholder="Κωδικός (π.χ. bags)" required />
          <input type="text" name="name_el" placeholder="Όνομα (Ελληνικά)" required />
          <input type="text" name="name_en" placeholder="Name (English)" />
          <input type="text" name="shortDescription_el" placeholder="Σύντομη περιγραφή (Ελληνικά)" />
          <input type="text" name="shortDescription_en" placeholder="Short description (English)" />
          <label class="checkbox-label"><input type="checkbox" name="showInMainNav" checked /><span>Εμφάνιση στο μενού πλοήγησης του καταστήματος</span></label>
          <input type="number" name="navOrder" placeholder="Σειρά στο μενού (π.χ. 1, 2, 3 — το 1 εμφανίζεται πρώτο)" />
          <label>
            <input type="text" name="slug" placeholder="Slug URL (π.χ. tsantes)" required />
            <small class="helper">Χρησιμοποιείται στη διεύθυνση URL: /products/tsantes. Χρησιμοποιείτε μόνο λατινικούς χαρακτήρες, αριθμούς και παύλες.</small>
          </label>
          <select name="parentId">
            <option value=""><%= t('admin.catNoParent') %></option>
            <% categories.forEach(function(cat){ %>
              <option value="<%= cat.id %>"><%= cat.name %> (<%= cat.id %>)</option>
            <% }) %>
          </select>
          <input type="password" name="password" placeholder="Κωδικός διαχειριστή (μόνο αν ζητηθεί)" required />
          <button type="submit" class="button"><%= t('admin.catAddBtn') %></button>
        </form>

        <form method="POST" action="<%= withTenantLink('/admin/categories/update') %>" class="admin-subform">
          <h3><%= t('admin.catUpdateTitle') %></h3>
          <select name="categoryId">
            <% categories.forEach(function(cat){ %>
              <option value="<%= cat.id %>"><%= cat.name %> (<%= cat.id %>)</option>
            <% }) %>
          </select>
          <input type="text" name="name_el" placeholder="Νέο όνομα (Ελληνικά)" required />
          <input type="text" name="name_en" placeholder="New name (English)" />
          <input type="text" name="shortDescription_el" placeholder="Σύντομη περιγραφή (Ελληνικά)" />
          <input type="text" name="shortDescription_en" placeholder="Short description (English)" />
          <label class="checkbox-label"><input type="checkbox" name="showInMainNav" checked /><span>Εμφάνιση στο μενού πλοήγησης του καταστήματος</span></label>
          <input type="number" name="navOrder" placeholder="Σειρά στο μενού (π.χ. 1, 2, 3 — το 1 εμφανίζεται πρώτο)" />
          <label>
            <input type="text" name="slug" placeholder="Νέο slug URL (π.χ. tsantes)" required />
            <small class="helper">Χρησιμοποιείται στη διεύθυνση URL: /products/tsantes. Χρησιμοποιείτε μόνο λατινικούς χαρακτήρες, αριθμούς και παύλες.</small>
          </label>
          <select name="parentId">
            <option value=""><%= t('admin.catNoParent') %></option>
            <% categories.forEach(function(cat){ %>
              <option value="<%= cat.id %>"><%= cat.name %> (<%= cat.id %>)</option>
            <% }) %>
          </select>
          <input type="password" name="password" placeholder="Κωδικός διαχειριστή (μόνο αν ζητηθεί)" required />
          <button type="submit" class="button"><%= t('admin.catUpdateBtn') %></button>
        </form>
        <% } else { %>
          <p class="helper"><%= t('admin.catManagedNote') %></p>
        <% } %>
      </section>

      <%# ══════════════════════════════════════════════════════════ %>
      <%#   TAB 3 – PRODUCTS (table + modal editor)                 %>
      <%# ══════════════════════════════════════════════════════════ %>
      <section id="tab-products" class="admin-block section-panel">
        <h2><%= t('admin.productsTitle') %></h2>
        <p class="helper">
          <%= t('admin.productsHelper') %>
          <% if (!permissions.canEditProducts) { %>
            <br><em><%= t('admin.productsManagedNote') %></em>
          <% } %>
        </p>

        <% if (permissions.canEditProducts) { %>
          <button class="button" id="btn-add-product" type="button"><%= t('admin.addProduct') %></button>
          <button class="button" id="btn-view-all-products" type="button" style="background:#1f2937;">All</button>
          <button class="button" id="btn-view-parts-products" type="button" style="background:#0f766e;">Spare parts</button>
          <details style="margin-top:10px;">
            <summary style="cursor:pointer;font-weight:700;">Quick add spare part</summary>
            <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px;margin-top:8px;">
              <input type="text" id="quick-part-id" placeholder="id (e.g. part-bolt-m8)" />
              <input type="text" id="quick-part-name" placeholder="Όνομα ανταλλακτικού" />
              <input type="number" id="quick-part-price" placeholder="Τιμή" min="0" step="0.01" />
              <input type="number" id="quick-part-stock" placeholder="Stock" min="0" step="1" />
              <input type="text" id="quick-part-image" placeholder="Image URL (auto από upload)" readonly />
              <div style="display:flex;gap:8px;">
                <label class="cat-upload-btn" style="cursor:pointer;">Upload<input type="file" id="quick-part-file" accept="image/*" style="display:none;" /></label>
                <button class="button" type="button" id="btn-quick-part-add">Add part</button>
              </div>
              <input type="password" id="quick-part-password" placeholder="Password (μόνο αν λήξει session)" style="display:none;" />
              <img id="quick-part-preview" alt="" style="display:none;width:58px;height:58px;object-fit:cover;border-radius:8px;border:1px solid #e5e7eb;" />
            </div>
          </details>
        <% } %>

        <table class="products-table" id="products-table">
          <thead>
            <tr>
              <th></th>
              <th><%= t('admin.colName') %></th>
              <th><%= t('admin.colPrice') %></th>
              <th><%= t('admin.colSku') %></th>
              <th><%= t('admin.colCategory') %></th>
              <% if (permissions.canEditProducts) { %><th><%= t('admin.colActions') %></th><% } %>
            </tr>
          </thead>
          <tbody id="products-tbody">
            <%# Rendered by JS below %>
          </tbody>
        </table>

        <%# Hidden form that submits the serialized JSON array to the backend %>
        <form id="products-save-form" method="POST" action="<%= withTenantLink('/admin/products') %>">
          <input type="hidden" name="productsJson" id="products-json-input" />
          <% if (permissions.canEditProducts) { %>
          <div class="save-row">
            <label style="flex:1 1 auto;font-size:0.86rem;">
              <%= t('admin.savePassLabel') %>
            </label>
            <input type="password" name="password" placeholder="<%= t('admin.adminPass') %>" />
            <button type="submit" class="button"><%= t('admin.saveAll') %></button>
          </div>
          <% } %>
        </form>
      </section>


      <%# ══════════════════════════════════════════════════════════ %>
      <%#   TAB 4 – IMAGE UPLOAD                                    %>
      <%# ══════════════════════════════════════════════════════════ %>
      <section id="tab-upload" class="admin-block section-panel">
        <h2><%= t('admin.imagesTitle') %></h2>
        <p class="helper"><%= t('admin.imagesHelper') %></p>
        <form id="upload-form" enctype="multipart/form-data">
          <input type="file" name="image" accept="image/*"
                 <%= permissions.canUploadMedia ? '' : 'disabled' %> required />
          <input type="password" name="password" placeholder="Κωδικός διαχειριστή (μόνο αν ζητηθεί)"
                 <%= permissions.canUploadMedia ? '' : 'disabled' %> />
          <button class="button" type="submit"
                  <%= permissions.canUploadMedia ? '' : 'disabled' %>><%= t('admin.uploadBtn') %></button>
        </form>
        <p id="upload-result"></p>
        <% if (!permissions.canUploadMedia) { %>
          <p class="helper"><%= t('admin.imagesManagedNote') %></p>
        <% } %>

        <%# ── Favicon ── %>
        <hr style="margin:28px 0 22px;border:none;border-top:1px solid #e5e7eb;" />
        <h3 style="margin-bottom:6px;"><%= t('admin.faviconTitle') %></h3>
        <p class="helper"><%= t('admin.faviconHelper') %></p>

        <% if (hasFavicon) { %>
          <div style="display:flex;align-items:center;gap:16px;margin-bottom:14px;">
            <% const faviconVersion = (rawConfig && rawConfig.favicon && rawConfig.favicon.updatedAt) || Date.now(); %>
            <img src="<%= withTenantLink('/favicon.ico', { v: faviconVersion }) %>" alt="favicon"
                 style="width:48px;height:48px;object-fit:contain;border:1px solid #e5e7eb;border-radius:6px;padding:4px;background:#f9fafb;" />
            <div>
              <p style="margin:0 0 6px;font-size:0.85rem;color:#374151;font-weight:500;">Τρέχον favicon</p>
              <form method="POST" action="<%= withTenantLink('/admin/favicon/delete') %>" style="display:inline;">
                <input type="hidden" name="password" id="fav-del-pw" value="" />
                <button class="button" type="button" style="font-size:0.8rem;padding:4px 10px;background:#fee2e2;color:#b91c1c;border:1px solid #fca5a5;"
                        onclick="deleteFavicon(this)"><%= t('admin.faviconDelete') %></button>
              </form>
            </div>
          </div>
        <% } else { %>
          <p style="color:#9ca3af;font-size:0.85rem;margin-bottom:14px;"><%= t('admin.faviconNone') %></p>
        <% } %>

        <form method="POST" action="<%= withTenantLink('/admin/favicon') %>" enctype="multipart/form-data" style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
          <input type="file" name="favicon" accept="image/png,image/jpeg,image/x-icon,image/vnd.microsoft.icon,image/svg+xml" required />
          <input type="password" name="password" placeholder="<%= t('admin.passwordPlaceholder') %>" required style="width:180px;" />
          <button class="button" type="submit"><%= t('admin.faviconUploadBtn') %></button>
        </form>
        <p style="font-size:0.78rem;color:#9ca3af;margin-top:6px;">PNG / ICO / SVG · max 512 KB</p>
      </section>

      <%# ══════════════════════════════════════════════════════════ %>
      <%#   TAB 5 – SHIPPING & PAYMENT                              %>
      <%# ══════════════════════════════════════════════════════════ %>
      <section id="tab-shipping" class="admin-block section-panel">
        <h2><%= t('admin.shippingTitle') %></h2>
        <p class="helper"><%= t('admin.shippingHelper') %></p>

        <% if (!permissions.canEditSettings) { %>
          <p class="helper"><%= t('admin.shippingManagedNote') %></p>
        <% } %>

        <form method="POST" action="<%= withTenantLink('/admin/shipping-payment') %>">

          <%# ── Shipping options ── %>
          <h3><%= t('admin.shippingOptionsTitle') %></h3>
          <% if ((config.shippingOptions || []).length === 0) { %>
            <p class="helper" style="color:#888;"><%= t('admin.shippingNone') %></p>
          <% } else { %>
          <table class="sp-table">
            <thead>
              <tr>
                <th><%= t('admin.shipColId') %></th>
                <th><%= t('admin.shipColLabel') %></th>
                <th><%= t('admin.shipColBase') %></th>
                <th><%= t('admin.shipColCodFee') %></th>
                <th><%= t('admin.shipColAllowed') %></th>
              </tr>
            </thead>
            <tbody>
              <% (config.shippingOptions || []).forEach(function(opt, i) { %>
              <tr>
                <td><span class="sp-badge"><%= opt.id %></span></td>
                <td>
                  <input type="text" name="ship_label_<%= i %>"
                         value="<%= opt.label || '' %>"
                         <%= permissions.canEditSettings ? 'required' : 'readonly' %> />
                </td>
                <td>
                  <input type="number" name="ship_base_<%= i %>"
                         value="<%= opt.base !== undefined ? opt.base : 0 %>"
                         min="0" step="0.01"
                         <%= permissions.canEditSettings ? '' : 'readonly' %> />
                </td>
                <td>
                  <input type="number" name="ship_codFee_<%= i %>"
                         value="<%= opt.codFee !== undefined ? opt.codFee : 0 %>"
                         min="0" step="0.01"
                         <%= permissions.canEditSettings ? '' : 'readonly' %> />
                </td>
                <td>
                  <% (opt.allowedPaymentMethods || []).forEach(function(pm) { %>
                    <span class="sp-badge"><%= pm %></span>
                  <% }) %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <% } %>
          <p class="helper" style="margin-top:6px;"><%= t('admin.shipCostHelper') %></p>

          <%# ── Payment options ── %>
          <h3><%= t('admin.paymentOptionsTitle') %></h3>
          <% if ((config.paymentOptions || []).length === 0) { %>
            <p class="helper" style="color:#888;"><%= t('admin.paymentNone') %></p>
          <% } else { %>
          <table class="sp-table">
            <thead>
              <tr>
                <th><%= t('admin.payColId') %></th>
                <th><%= t('admin.payColLabel') %></th>
                <th><%= t('admin.payColType') %></th>
              </tr>
            </thead>
            <tbody>
              <% (config.paymentOptions || []).forEach(function(opt, i) { %>
              <tr>
                <td><span class="sp-badge"><%= opt.id %></span></td>
                <td>
                  <input type="text" name="pay_label_<%= i %>"
                         value="<%= opt.label || '' %>"
                         <%= permissions.canEditSettings ? 'required' : 'readonly' %> />
                </td>
                <td><span class="sp-badge"><%= opt.type || '–' %></span></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <% } %>
          <% if (permissions.canEditSettings) { %>
          <div class="save-row">
            <label style="flex:1 1 auto;font-size:0.86rem;"><%= t('admin.adminPass') %>:</label>
            <input type="password" name="password" placeholder="<%= t('admin.adminPass') %>" />
            <button type="submit" class="button"><%= t('admin.shippingSave') %></button>
          </div>
          <% } %>

        </form>
      </section>

      <%# ══════════════════════════════════════════════════════════ %>
      <%#   TAB 7 – NOTIFICATIONS                                   %>
      <%# ══════════════════════════════════════════════════════════ %>
      <form id="tab-notifications" class="admin-block section-panel" method="POST" action="<%= withTenantLink('/admin/notifications') %>">
        <h2><%= t('admin.notificationsTitle') %></h2>
        <p class="helper">Ρύθμιση email ειδοποιήσεων για νέες παραγγελίες. Κάθε φορά που μπαίνει παραγγελία, ο διαχειριστής ειδοποιείται αυτόματα.</p>

        <h3 class="settings-section-heading">Email ειδοποιήσεων</h3>

        <label class="checkbox-label">
          <input type="checkbox" name="emailNotificationsEnabled"
                 <%= (config.notifications && config.notifications.enabled) ? 'checked' : '' %>
                 <%= permissions.canEditSettings ? '' : 'disabled' %> />
          <span>Ενεργοποίηση ειδοποιήσεων email παραγγελιών</span>
        </label>
        <small class="helper" style="display:block;margin:-4px 0 10px 28px;">Όταν ενεργό, ο merchant λαμβάνει email για κάθε νέα παραγγελία.</small>

        <label>
          <span>Email παραλήπτη (merchant)</span>
          <input type="email" name="notificationEmail"
                 value="<%= (config.notifications && config.notifications.notificationEmail) || (config.notificationEmails && config.notificationEmails[0]) || '' %>"
                 placeholder="owner@myshop.gr"
                 <%= permissions.canEditSettings ? '' : 'readonly' %> />
          <small class="helper">Το email του καταστηματάρχη που λαμβάνει ειδοποίηση για κάθε νέα παραγγελία.</small>
        </label>

        <label>
          <span>Reply-To email <small style="font-weight:400;color:#94a3b8;">(προαιρετικό)</small></span>
          <input type="email" name="replyToEmail"
                 value="<%= (config.notifications && config.notifications.replyToEmail) || '' %>"
                 placeholder="noreply@myshop.gr"
                 <%= permissions.canEditSettings ? '' : 'readonly' %> />
          <small class="helper">Αν ορίσετε αυτό, τα emails θα έχουν αυτό το Reply-To αντί του from address.</small>
        </label>

        <label>
          <span>Support email <small style="font-weight:400;color:#94a3b8;">(εμφανίζεται στον πελάτη)</small></span>
          <input type="email" name="supportEmail"
                 value="<%= (config.notifications && config.notifications.supportEmail) || '' %>"
                 placeholder="support@myshop.gr"
                 <%= permissions.canEditSettings ? '' : 'readonly' %> />
          <small class="helper">Εμφανίζεται στο email επιβεβαίωσης παραγγελίας ως επαφή υποστήριξης.</small>
        </label>

        <label class="checkbox-label">
          <input type="checkbox" name="notificationCcCustomer"
                 <%= config.notificationCcCustomer ? 'checked' : '' %>
                 <%= permissions.canEditSettings ? '' : 'disabled' %> />
          <span>Αποστολή επιβεβαίωσης παραγγελίας και στον πελάτη</span>
        </label>
        <small class="helper" style="display:block;margin:-4px 0 10px 28px;">Αν ενεργοποιηθεί, ο πελάτης λαμβάνει email επιβεβαίωσης μετά την παραγγελία του.</small>

        <label>
          <span>Εμφανιζόμενο όνομα αποστολέα</span>
          <input type="text" name="notificationFromName"
                 value="<%= config.notificationFromName || '' %>"
                 placeholder="π.χ. Eukolakis Store"
                 <%= permissions.canEditSettings ? '' : 'readonly' %> />
          <small class="helper">Φαίνεται ως «Από:» στα emails προς τον πελάτη και τον merchant.</small>
        </label>

        <details style="margin:10px 0 14px;">
          <summary style="cursor:pointer;font-weight:700;font-size:.88rem;">Webhook integration <small style="font-weight:400;color:#94a3b8;">(για προχωρημένους — προαιρετικό)</small></summary>
          <p class="helper" style="margin:8px 0;">Αν θέλετε να ειδοποιείται αυτόματα ένα εξωτερικό σύστημα (π.χ. ERP, Zapier, Make.com) για κάθε παραγγελία, ορίστε εδώ ένα Webhook URL.</p>
          <label>
            <span>Webhook URL</span>
            <input type="text" name="notificationWebhookUrl"
                   value="<%= config.notificationWebhookUrl || '' %>"
                   placeholder="https://hooks.zapier.com/hooks/catch/..."
                   <%= permissions.canEditSettings ? '' : 'readonly' %> />
            <small class="helper">Κάθε νέα παραγγελία στέλνει HTTP POST με JSON payload σε αυτό το URL.</small>
          </label>
          <label>
            <span>Webhook Secret <small style="font-weight:400;color:#94a3b8;">(προαιρετικό)</small></span>
            <input type="text" name="notificationWebhookSecret"
                   value="<%= config.notificationWebhookSecret || '' %>"
                   placeholder="mysecret123"
                   <%= permissions.canEditSettings ? '' : 'readonly' %> />
            <small class="helper">Μυστικό κλειδί για την επαλήθευση της αυθεντικότητας του webhook (X-Thronos-Signature header). Αφήστε κενό αν δεν χρειάζεται.</small>
          </label>
        </details>

        <% if (permissions.canEditSettings) { %>
        <div class="save-row">
          <label style="flex:1 1 auto;font-size:0.86rem;"><%= t('admin.adminPass') %>:</label>
          <input type="password" name="password" placeholder="<%= t('admin.adminPass') %>" />
          <button type="submit" class="button">Αποθήκευση ειδοποιήσεων</button>
        </div>
        <% } %>
      </form>


      <%# ══════════════════════════════════════════════════════════ %>
      <%#   TAB – VIRTUAL ASSISTANT                                 %>
      <%# ══════════════════════════════════════════════════════════ %>
      <% const _va = (rawConfig.assistant) || {}; %>
      <% const _vaEnabled = !!_va.vaEnabled; %>
      <% const _vaMode    = _va.vaMode    || 'disabled'; %>
      <% const _vaLang    = _va.vaLanguage || 'auto'; %>
      <% const _vaTone    = _va.vaTone    || 'friendly'; %>
      <form id="tab-assistant" class="admin-block section-panel" method="POST" action="<%= withTenantLink('/admin/assistant') %>">
        <h2>🤖 Εικονικός Βοηθός</h2>
        <p class="helper">Ρυθμίστε τον εικονικό βοηθό του καταστήματός σας. Ο βοηθός μπορεί να καθοδηγεί τους πελάτες σας και να σας δίνει εισηγήσεις για τη βελτίωση του καταστήματος — όταν εσείς δεν είστε παρόντες.</p>

        <%# ── Status chip ── %>
        <div style="padding:10px 14px;border-radius:10px;margin-bottom:18px;background:<%=
          _vaEnabled && _vaMode !== 'disabled' ? '#f0fdf4' : '#f8fafc'
        %>;border:1px solid <%=
          _vaEnabled && _vaMode !== 'disabled' ? '#bbf7d0' : '#e2e8f0'
        %>;">
          <p style="margin:0;font-size:.84rem;font-weight:700;color:<%=
            _vaEnabled && _vaMode !== 'disabled' ? '#15803d' : '#475569'
          %>;">
            <% if (_vaEnabled && _vaMode !== 'disabled') { %>
              ✓ Βοηθός ενεργός —
              <% if (_vaMode === 'customer')  { %>καθοδήγηση πελατών<% }
                else if (_vaMode === 'merchant') { %>εισηγήσεις για τον έμπορο<% }
                else { %>καθοδήγηση πελατών + εισηγήσεις εμπόρου<% } %>
            <% } else { %>
              ○ Βοηθός ανενεργός
            <% } %>
          </p>
        </div>

        <%# ── SECTION 1: Ενεργοποίηση ── %>
        <h3 class="settings-section-heading">Ενεργοποίηση</h3>

        <label class="checkbox-label">
          <input type="hidden" name="vaEnabled" value="0" />
          <input type="checkbox" name="vaEnabled" value="1" <%= _vaEnabled ? 'checked' : '' %> <%= permissions.canEditSettings ? '' : 'disabled' %> />
          <span>Ενεργοποίηση εικονικού βοηθού</span>
        </label>
        <small class="helper" style="display:block;margin:-4px 0 14px 28px;">Όταν ενεργός, ο βοηθός μπορεί να λαμβάνει και να απαντά σε ερωτήματα ανάλογα με τον τρόπο λειτουργίας που επιλέγετε παρακάτω.</small>

        <label><span>Τρόπος λειτουργίας</span>
          <select name="vaMode" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="disabled" <%= _vaMode === 'disabled'  ? 'selected' : '' %>>Ανενεργός — δεν απαντά σε τίποτα</option>
            <option value="customer" <%= _vaMode === 'customer'  ? 'selected' : '' %>>Μόνο πελάτες — βοηθά τους επισκέπτες του καταστήματος</option>
            <option value="merchant" <%= _vaMode === 'merchant'  ? 'selected' : '' %>>Μόνο έμπορος — εισηγήσεις και υπενθυμίσεις για εσάς</option>
            <option value="both"     <%= _vaMode === 'both'      ? 'selected' : '' %>>Και τα δύο — πελάτες και εισηγήσεις εμπόρου</option>
          </select>
          <small class="helper">
            <strong>Μόνο πελάτες</strong>: ο βοηθός απαντά σε ερωτήσεις πελατών (διαθεσιμότητα, οδηγίες, shipping κ.λπ.).
            <strong>Μόνο έμπορος</strong>: σας στέλνει εισηγήσεις για βελτίωση των προϊόντων, περιεχομένου ή εμφάνισης.
            <strong>Και τα δύο</strong>: συνδυασμός.
          </small>
        </label>

        <%# ── SECTION 2: Χαρακτήρας & Φωνή ── %>
        <h3 class="settings-section-heading">Χαρακτήρας & Φωνή Βοηθού</h3>
        <p class="helper" style="margin-bottom:12px;">Πείτε στον βοηθό πώς να μιλάει — τι γλώσσα να χρησιμοποιεί και τι ύφος να έχει.</p>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;">
          <label><span>Γλώσσα επικοινωνίας</span>
            <select name="vaLanguage" <%= permissions.canEditSettings ? '' : 'disabled' %>>
              <option value="el"   <%= _vaLang === 'el'   ? 'selected' : '' %>>Ελληνικά</option>
              <option value="en"   <%= _vaLang === 'en'   ? 'selected' : '' %>>English</option>
              <option value="auto" <%= _vaLang === 'auto' ? 'selected' : '' %>>Αυτόματα (ανάλογα με τον επισκέπτη)</option>
            </select>
          </label>
          <label><span>Ύφος επικοινωνίας</span>
            <select name="vaTone" <%= permissions.canEditSettings ? '' : 'disabled' %>>
              <option value="friendly"     <%= _vaTone === 'friendly'     ? 'selected' : '' %>>Φιλικό & προσιτό</option>
              <option value="professional" <%= _vaTone === 'professional' ? 'selected' : '' %>>Επαγγελματικό & επίσημο</option>
              <option value="technical"    <%= _vaTone === 'technical'    ? 'selected' : '' %>>Τεχνικό & αναλυτικό</option>
            </select>
          </label>
        </div>

        <label><span>Φωνή της μάρκας / τρόπος έκφρασης <small style="font-weight:400;color:#94a3b8;">(προαιρετικό)</small></span>
          <textarea name="vaBrandVoice" rows="2"
            placeholder="π.χ. Μιλάμε ως ειδικοί στα DIY Roll Kit — απλά, κατανοητά, με τεχνική ακρίβεια. Χρησιμοποιούμε πρώτο πληθυντικό πρόσωπο."
            <%= permissions.canEditSettings ? '' : 'readonly' %>><%= _va.vaBrandVoice || '' %></textarea>
          <small class="helper">Περιγράψτε πώς θέλετε ο βοηθός να εκφράζεται — σαν να εκπαιδεύετε έναν νέο υπάλληλο στο στυλ επικοινωνίας σας.</small>
        </label>

        <%# ── SECTION 3: Οδηγίες Καταστήματος ── %>
        <h3 class="settings-section-heading">Οδηγίες για το Κατάστημα & Προϊόντα</h3>
        <p class="helper" style="margin-bottom:12px;">Εξηγήστε στον βοηθό τι κάνει το κατάστημά σας και τι να τονίζει όταν μιλά με πελάτες.</p>

        <label><span>Τι κάνει το κατάστημά σας</span>
          <textarea name="vaStoreInstructions" rows="3"
            placeholder="π.χ. Πουλάμε εξοπλισμό και ανταλλακτικά για εγκατάσταση συρόμενων κουφωμάτων. Εξυπηρετούμε κυρίως επαγγελματίες τεχνίτες και αρχιτέκτονες στην Ελλάδα."
            <%= permissions.canEditSettings ? '' : 'readonly' %>><%= _va.vaStoreInstructions || '' %></textarea>
          <small class="helper">Αυτό βοηθά τον βοηθό να κατανοεί το αντικείμενο του καταστήματος και να απαντά σωστά σε ερωτήσεις πελατών.</small>
        </label>

        <label><span>Τι να τονίζει για τα προϊόντα <small style="font-weight:400;color:#94a3b8;">(προαιρετικό)</small></span>
          <textarea name="vaProductGuidance" rows="2"
            placeholder="π.χ. Τόνισε την ευκολία εγκατάστασης, την ποιότητα υλικών, και ότι τα DIY Roll Kit σχεδιάστηκαν για επαγγελματίες."
            <%= permissions.canEditSettings ? '' : 'readonly' %>><%= _va.vaProductGuidance || '' %></textarea>
          <small class="helper">Ειδικές οδηγίες για το τι να προτείνει και τι να τονίζει ο βοηθός όταν κάποιος ρωτά για τα προϊόντα.</small>
        </label>

        <%# ── SECTION 4: Εξυπηρέτηση Πελατών ── %>
        <h3 class="settings-section-heading">Εξυπηρέτηση Πελατών</h3>

        <label><span>Πώς να χειρίζεται ερωτήσεις πελατών <small style="font-weight:400;color:#94a3b8;">(προαιρετικό)</small></span>
          <textarea name="vaCustomerSupport" rows="2"
            placeholder="π.χ. Για ερωτήσεις shipping, παρέπεμψε στη σελίδα Αποστολές. Για παραγγελίες, παρέπεμψε στο info@katastima.gr. Μην δίνεις τιμές ανταγωνιστών."
            <%= permissions.canEditSettings ? '' : 'readonly' %>><%= _va.vaCustomerSupport || '' %></textarea>
          <small class="helper">Οδηγίες για το πώς να αντιμετωπίζει ο βοηθός συνηθισμένες ερωτήσεις: shipping, επιστροφές, παραγγελίες κ.λπ.</small>
        </label>

        <label><span>Τι να αποφεύγει ο βοηθός <small style="font-weight:400;color:#94a3b8;">(προαιρετικό)</small></span>
          <textarea name="vaAvoidTopics" rows="2"
            placeholder="π.χ. Μην αναφέρεις ανταγωνιστές. Μην δίνεις ακριβείς τιμές για custom κατασκευές. Μην υπόσχεσαι χρόνους παράδοσης που δεν είναι εγγυημένοι."
            <%= permissions.canEditSettings ? '' : 'readonly' %>><%= _va.vaAvoidTopics || '' %></textarea>
          <small class="helper">Θέματα, πληροφορίες ή υποσχέσεις που ο βοηθός δεν πρέπει ποτέ να αναφέρει.</small>
        </label>

        <%# ── SECTION 5: Στόχοι Εμπόρου ── %>
        <h3 class="settings-section-heading">Στόχοι & Προτεραιότητες Πωλήσεων</h3>

        <label><span>Τρέχοντες στόχοι ή προτεραιότητες <small style="font-weight:400;color:#94a3b8;">(προαιρετικό)</small></span>
          <textarea name="vaMerchantGoals" rows="2"
            placeholder="π.χ. Θέλουμε να αυξήσουμε τις πωλήσεις των DIY Roll Kit Premium τον επόμενο μήνα. Δευτερεύουσα προτεραιότητα τα ανταλλακτικά."
            <%= permissions.canEditSettings ? '' : 'readonly' %>><%= _va.vaMerchantGoals || '' %></textarea>
          <small class="helper">Πείτε στον βοηθό τι να προωθεί προτεραιακά — τρέχουσα καμπάνια, εποχιακά προϊόντα, slow movers κ.λπ.</small>
        </label>

        <%# ── SECTION 6: Επερχόμενα (placeholder, clearly labeled) ── %>
        <h3 class="settings-section-heading" style="margin-top:24px;">Επερχόμενες Λειτουργίες</h3>
        <div style="padding:14px 16px;border-radius:10px;background:#fefce8;border:1px solid #fde68a;color:#92400e;">
          <p style="margin:0 0 8px;font-size:.86rem;font-weight:700;">Σύντομα διαθέσιμα — ο βοηθός θα μπορεί να:</p>
          <ul style="margin:0;padding-left:18px;font-size:.83rem;line-height:1.7;">
            <li>Προτείνει βελτιώσεις στην αρχική σελίδα (εικόνες, τίτλοι, περιγραφές)</li>
            <li>Εντοπίζει προϊόντα χωρίς φωτογραφία ή περιγραφή</li>
            <li>Προτείνει FAQ και κείμενο υποστήριξης πελατών</li>
            <li>Δίνει αναφορές: τι ψάχνουν οι πελάτες που δεν βρίσκουν</li>
            <li>Σας ειδοποιεί αυτόματα για ζητήματα του καταστήματος</li>
          </ul>
          <p style="margin:10px 0 0;font-size:.78rem;color:#a16207;">Αυτές οι λειτουργίες θα ενεργοποιηθούν αυτόματα όταν η σύνδεση με τον βοηθό είναι έτοιμη — δεν απαιτούνται αλλαγές από εσάς.</p>
        </div>

        <%# ── Save row ── %>
        <% if (permissions.canEditSettings) { %>
        <div class="save-row" style="margin-top:20px;">
          <label style="flex:1 1 auto;font-size:0.86rem;"><%= t('admin.adminPass') %>:</label>
          <input type="password" name="password" placeholder="<%= t('admin.adminPass') %>" />
          <button type="submit" class="button">Αποθήκευση βοηθού</button>
        </div>
        <% } else { %>
        <p class="settings-info-note" style="margin-top:14px;">Το πακέτο σας δεν επιτρέπει αλλαγή ρυθμίσεων βοηθού. Επικοινωνήστε με την υποστήριξη για αναβάθμιση.</p>
        <% } %>
      </form>


      <%# ══════════════════════════════════════════════════════════ %>
      <%#   TAB 8 – INVENTORY                                       %>
      <%# ══════════════════════════════════════════════════════════ %>
      <section id="tab-inventory" class="admin-block section-panel">
        <h2><%= t('admin.inventoryTitle') %></h2>
        <p class="helper"><%= t('admin.inventoryHelper') %></p>

        <%# ── Stock table ── %>
        <h3><%= t('admin.inventoryStockTitle') %></h3>
        <table class="sp-table" id="inv-stock-table">
          <thead>
            <tr>
              <th><%= t('admin.invColProduct') %></th>
              <th><%= t('admin.invColSku') %></th>
              <th><%= t('admin.invColStock') %></th>
              <th><%= t('admin.invColStatus') %></th>
              <th><%= t('admin.invColViews') %></th>
              <th><%= t('admin.invColOrders') %></th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach(function(p) { %>
              <% const s = p.stock !== undefined ? p.stock : '–'; %>
              <% const sNum = typeof s === 'number' ? s : parseInt(s); %>
              <% const statusClass = s === '–' ? '' : sNum === 0 ? 'stock-out' : sNum < 3 ? 'stock-low' : 'stock-ok'; %>
              <tr>
                <td>
                  <% if (p.imageUrl) { %><img src="<%= p.imageUrl %>" style="width:28px;height:28px;object-fit:cover;border-radius:3px;vertical-align:middle;margin-right:6px;" /><% } %>
                  <%= p.name %>
                  <% if (p.featured) { %><span style="color:#f59e0b;font-size:.75rem;margin-left:4px;">⭐</span><% } %>
                </td>
                <td style="color:#888;font-size:.82rem;"><%= p.sku || '–' %></td>
                <td style="font-weight:600;"><%= s %></td>
                <td>
                  <% if (s !== '–') { %>
                    <% if (sNum === 0) { %>
                      <span class="sp-badge" style="background:#fee2e2;color:#991b1b;"><%= t('admin.invStatusOut') %></span>
                    <% } else if (sNum < 3) { %>
                      <span class="sp-badge" style="background:#fef3c7;color:#92400e;"><%= t('admin.invStatusLow') %></span>
                    <% } else { %>
                      <span class="sp-badge" style="background:#d1fae5;color:#065f46;"><%= t('admin.invStatusOk') %></span>
                    <% } %>
                  <% } else { %>–<% } %>
                </td>
                <td style="font-size:.85rem;"><%= analytics.pageViews[p.id] || 0 %></td>
                <td style="font-size:.85rem;font-weight:600;"><%= orderCounts[p.id] || 0 %></td>
              </tr>
            <% }) %>
            <% if (!products.length) { %>
              <tr><td colspan="6" style="color:#aaa;text-align:center;padding:20px;"><%= t('admin.noProductsYet') %></td></tr>
            <% } %>
          </tbody>
        </table>

        <%# ── Orders by product bar chart ── %>
        <% const chartProducts = products.filter(function(p){ return (orderCounts[p.id]||0) > 0; }); %>
        <% if (chartProducts.length > 0) { %>
        <h3 style="margin-top:24px;"><%= t('admin.chartOrdersTitle') %></h3>
        <% const maxOrders = Math.max.apply(null, chartProducts.map(function(p){ return orderCounts[p.id]||0; })); %>
        <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:20px;">
          <% chartProducts.sort(function(a,b){ return (orderCounts[b.id]||0)-(orderCounts[a.id]||0); }).forEach(function(p) { %>
            <div style="display:flex;align-items:center;gap:10px;font-size:.84rem;">
              <span style="width:160px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= p.name %></span>
              <div style="flex:1;background:#f0f2fa;border-radius:4px;overflow:hidden;height:18px;">
                <div style="width:<%= Math.round((orderCounts[p.id]||0)/maxOrders*100) %>%;background:var(--accent-color,#5b6af5);height:100%;border-radius:4px;"></div>
              </div>
              <span style="width:28px;text-align:right;font-weight:700;"><%= orderCounts[p.id]||0 %></span>
            </div>
          <% }); %>
        </div>
        <% } %>

        <%# ── Top cities ── %>
        <% const cityEntries = Object.entries(cityCounts).sort(function(a,b){ return b[1]-a[1]; }).slice(0,10); %>
        <% if (cityEntries.length > 0) { %>
        <h3 style="margin-top:24px;"><%= t('admin.chartCitiesTitle') %></h3>
        <% const maxCityOrders = cityEntries[0][1]; %>
        <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:20px;">
          <% cityEntries.forEach(function(entry) { %>
            <div style="display:flex;align-items:center;gap:10px;font-size:.84rem;">
              <span style="width:140px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">📍 <%= entry[0] %></span>
              <div style="flex:1;background:#f0f2fa;border-radius:4px;overflow:hidden;height:18px;">
                <div style="width:<%= Math.round(entry[1]/maxCityOrders*100) %>%;background:#10b981;height:100%;border-radius:4px;"></div>
              </div>
              <span style="width:28px;text-align:right;font-weight:700;"><%= entry[1] %></span>
            </div>
          <% }); %>
        </div>
        <% } %>

        <%# ── Manual stock adjustment ── %>
        <% if (permissions.canEditProducts) { %>
        <h3 style="margin-top:24px;"><%= t('admin.invAdjustTitle') %></h3>
        <form method="POST" action="<%= withTenantLink('/admin/stock/adjust') %>" class="admin-subform" style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;">
          <label style="flex:1;min-width:140px;">
            <%= t('admin.invAdjustProduct') %>
            <select name="productId" style="margin-top:4px;">
              <% products.forEach(function(p) { %>
                <option value="<%= p.id %>"><%= p.name %> (<%= p.stock !== undefined ? p.stock : '–' %>)</option>
              <% }) %>
            </select>
          </label>
          <label style="flex:0 0 90px;">
            <%= t('admin.invAdjustQty') %>
            <input type="number" name="newStock" min="0" step="1" value="0" style="margin-top:4px;" />
          </label>
          <label style="flex:1;min-width:140px;">
            <%= t('admin.invAdjustReason') %>
            <input type="text" name="reason" placeholder="π.χ. αναπλήρωση" style="margin-top:4px;" />
          </label>
          <label style="flex:0 0 160px;">
            <%= t('admin.adminPass') %>
            <input type="password" name="password" style="margin-top:4px;" />
          </label>
          <button class="button" type="submit" style="align-self:flex-end;"><%= t('admin.invAdjustBtn') %></button>
        </form>
        <% } %>

        <%# ── Stock movement log ── %>
        <h3 style="margin-top:24px;"><%= t('admin.invLogTitle') %></h3>
        <% if (stockLog.length === 0) { %>
          <p class="helper" style="color:#aaa;"><%= t('admin.invLogEmpty') %></p>
        <% } else { %>
        <table class="sp-table" style="font-size:.83rem;">
          <thead>
            <tr>
              <th><%= t('admin.invLogDate') %></th>
              <th><%= t('admin.invLogProduct') %></th>
              <th><%= t('admin.invLogDelta') %></th>
              <th><%= t('admin.invLogReason') %></th>
              <th><%= t('admin.invLogOrder') %></th>
            </tr>
          </thead>
          <tbody>
            <% stockLog.forEach(function(e) { %>
            <tr>
              <td style="white-space:nowrap;color:#666;"><%= new Date(e.createdAt).toLocaleDateString(lang) %></td>
              <td><%= e.productName || e.productId %></td>
              <td style="font-weight:700;color:<%= e.delta < 0 ? '#dc2626' : '#16a34a' %>">
                <%= e.delta > 0 ? '+' + e.delta : e.delta %>
              </td>
              <td><%= e.reason %></td>
              <td style="font-size:.78rem;color:#aaa;font-family:monospace;"><%= e.orderId || '–' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </section>


      <%# ══════════════════════════════════════════════════════════ %>
      <%#   TAB 9 – SUPPORT / TICKETS                               %>
      <%# ══════════════════════════════════════════════════════════ %>
      <section id="tab-support" class="admin-block section-panel">
        <h2>💬 <%= t('admin.supportTitle') %></h2>
        <p class="helper"><%= t('admin.supportHelper') %></p>

        <div style="margin:0 0 20px;padding:14px;border:1px solid #e5e7eb;border-radius:10px;background:#f8fafc;">
          <h3 style="margin:0 0 8px;">Backups & Export</h3>
          <% if (exportAccess) { %>
            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px;">
              <a class="button" href="<%= withTenantLink('/admin/export/products.json') %>">Export products.json</a>
              <a class="button" href="<%= withTenantLink('/admin/export/products.csv') %>" style="background:#1f2937;">Export products.csv</a>
              <a class="button" href="<%= withTenantLink('/admin/export/orders.csv') %>" style="background:#0f766e;">Export orders.csv</a>
              <a class="button" href="<%= withTenantLink('/admin/export/categories.json') %>" style="background:#334155;">Export categories.json</a>
              <a class="button" href="<%= withTenantLink('/admin/export/config.json') %>" style="background:#475569;">Export config.json</a>
            </div>
          <% } else { %>
            <p style="margin:0 0 10px;color:#92400e;">Export available on paid plans. Contact support / upgrade.</p>
          <% } %>
          <div style="max-height:210px;overflow:auto;border:1px solid #e5e7eb;background:#fff;border-radius:8px;padding:8px;">
            <% if (backups && backups.length) { %>
              <% backups.forEach(function(b) { %>
                <div style="display:flex;justify-content:space-between;gap:10px;align-items:center;padding:6px 0;border-bottom:1px solid #f1f5f9;">
                  <div style="font-size:.82rem;">
                    <strong><%= b.filename %></strong><br />
                    <span style="color:#64748b;"><%= b.type %> · <%= Math.max(1, Math.round(Number(b.size || 0) / 1024)) %>KB · <%= new Date(b.modifiedAt).toLocaleString('el-GR') %></span>
                  </div>
                  <div style="display:flex;gap:6px;">
                    <a class="button" style="padding:4px 10px;font-size:.75rem;" href="<%= withTenantLink('/admin/backups/' + b.filename) %>">Download</a>
                    <form method="POST" action="<%= withTenantLink('/admin/backups/restore') %>" onsubmit="return confirm('Restore backup <%= b.filename %>;')" style="display:flex;gap:6px;align-items:center;">
                      <input type="hidden" name="filename" value="<%= b.filename %>" />
                      <input type="password" name="password" placeholder="password" style="padding:4px 6px;font-size:.74rem;width:110px;" />
                      <button class="button" type="submit" style="padding:4px 8px;font-size:.75rem;background:#0f766e;">Restore</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <p style="margin:0;font-size:.82rem;color:#64748b;">No backups yet. Save products/categories/settings to generate backups.</p>
            <% } %>
          </div>
          <form method="POST" action="<%= withTenantLink('/admin/backups/create-now') %>" style="display:flex;gap:8px;align-items:center;margin-top:10px;flex-wrap:wrap;">
            <input type="password" name="password" placeholder="Admin password" style="padding:6px 8px;" />
            <button class="button" type="submit">Create backup now</button>
          </form>
          <form method="POST" action="<%= withTenantLink('/admin/import/products') %>" enctype="multipart/form-data" style="display:flex;gap:8px;align-items:center;margin-top:10px;flex-wrap:wrap;">
            <input type="file" name="file" accept=".csv,.xlsx" required />
            <select name="importMode" style="padding:6px 8px;">
              <option value="merge">Merge (safe)</option>
              <option value="replace">Replace all</option>
            </select>
            <input type="password" name="password" placeholder="Admin password" style="padding:6px 8px;" />
            <button class="button" type="submit" style="background:#0f766e;">Import products from Excel/CSV</button>
          </form>
          <p style="margin:6px 0 0;font-size:.78rem;color:#64748b;">Variant columns: variantId, variantLabel_el, variantLabel_en, variantSku, variantPrice, variantStock, variantImageUrl.</p>
          <form method="POST" action="<%= withTenantLink('/admin/import/variants') %>" enctype="multipart/form-data" style="display:flex;gap:8px;align-items:center;margin-top:8px;flex-wrap:wrap;">
            <input type="file" name="file" accept=".csv" required />
            <input type="password" name="password" placeholder="Admin password" style="padding:6px 8px;" />
            <button class="button" type="submit" style="background:#0f766e;">Import variants CSV</button>
          </form>
          <p style="margin:6px 0 0;font-size:.78rem;color:#64748b;">
            Columns: <strong>productId, variantName, variantSku, priceEUR, stock, imageUrl, videoUrl, videoDescription</strong>.
            <a href="<%= withTenantLink('/admin/import/variants-template.csv') %>">Download template</a>
          </p>
        </div>

        <%# ── Ticket list ── %>
        <% if (tickets && tickets.length) { %>
          <h3 style="font-size:.9rem;margin-bottom:10px;"><%= t('admin.supportHistory') %></h3>
          <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:28px;">
            <% tickets.forEach(function(tk) { %>
              <div style="border:1px solid #e5e7eb;border-radius:8px;padding:14px 16px;background:#fafafa;">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:6px;">
                  <strong style="font-size:.9rem;"><%= tk.subject %></strong>
                  <span style="font-size:.74rem;padding:2px 10px;border-radius:20px;font-weight:600;background:<%= tk.status === 'resolved' ? '#d1fae5' : tk.status === 'replied' ? '#dbeafe' : '#fef3c7' %>;color:<%= tk.status === 'resolved' ? '#065f46' : tk.status === 'replied' ? '#1e40af' : '#92400e' %>;">
                    <%= tk.status === 'resolved' ? '✓ Επιλύθηκε' : tk.status === 'replied' ? '💬 Απάντηση' : '⏳ Εκκρεμεί' %>
                  </span>
                </div>
                <p style="font-size:.82rem;color:#374151;margin:6px 0 4px;white-space:pre-wrap;"><%= tk.body %></p>
                <span style="font-size:.74rem;color:#9ca3af;"><%= new Date(tk.createdAt).toLocaleString('el-GR') %> · <%= tk.category %></span>
                <% if (tk.replies && tk.replies.length) { %>
                  <% tk.replies.forEach(function(r) { %>
                    <div style="margin-top:10px;padding:10px 12px;background:#eff6ff;border-left:3px solid #3b82f6;border-radius:4px;">
                      <strong style="font-size:.8rem;color:#1d4ed8;">Support</strong>
                      <p style="font-size:.82rem;margin:4px 0 0;white-space:pre-wrap;color:#1e3a8a;"><%= r.text %></p>
                      <span style="font-size:.72rem;color:#93c5fd;"><%= new Date(r.createdAt).toLocaleString('el-GR') %></span>
                    </div>
                  <% }) %>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } %>

        <%# ── New ticket form ── %>
        <h3 style="font-size:.9rem;margin-bottom:10px;"><%= t('admin.supportNewTicket') %></h3>
        <form method="POST" action="<%= withTenantLink('/admin/tickets/new') %>" style="display:flex;flex-direction:column;gap:12px;max-width:600px;">
          <label style="font-size:.86rem;display:flex;flex-direction:column;gap:4px;">
            <%= t('admin.supportCategory') %>
            <select name="category" style="padding:8px 10px;border:1px solid #d1d5db;border-radius:5px;font-size:.86rem;">
              <option value="product_change">🛍 Αλλαγή προϊόντων / περιεχομένου</option>
              <option value="design_change">🎨 Αλλαγή σχεδιασμού / theme</option>
              <option value="billing">💳 Τιμολόγηση / συνδρομή</option>
              <option value="technical">🔧 Τεχνικό πρόβλημα</option>
              <option value="general">💬 Γενική ερώτηση</option>
            </select>
          </label>
          <label style="font-size:.86rem;display:flex;flex-direction:column;gap:4px;">
            <%= t('admin.supportSubject') %>
            <input type="text" name="subject" required placeholder="π.χ. Θέλω να προσθέσω 3 νέα προϊόντα" style="padding:8px 10px;border:1px solid #d1d5db;border-radius:5px;font-size:.86rem;" />
          </label>
          <label style="font-size:.86rem;display:flex;flex-direction:column;gap:4px;">
            <%= t('admin.supportMessage') %>
            <textarea name="message" required rows="5" placeholder="Περιγράψτε αναλυτικά τι χρειάζεστε. Αν έχετε εικόνες, στείλτε τες και στο support@thronoschain.org." style="padding:8px 10px;border:1px solid #d1d5db;border-radius:5px;font-size:.86rem;resize:vertical;"></textarea>
          </label>
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
            <input type="password" name="password" placeholder="<%= t('admin.adminPass') %>" style="flex:0 0 180px;padding:8px 10px;border:1px solid #d1d5db;border-radius:5px;font-size:.86rem;" />
            <button type="submit" class="button" style="white-space:nowrap;">📨 <%= t('admin.supportSend') %></button>
          </div>
        </form>
        <p style="margin-top:14px;font-size:.78rem;color:#9ca3af;">
          Μπορείτε επίσης να επικοινωνήσετε απευθείας: <a href="mailto:support@thronoschain.org" style="color:#4338ca;">support@thronoschain.org</a>
        </p>
      </section>
      </div>
      </div>
    </main>


