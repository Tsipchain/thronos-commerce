        <label><span>Price</span><input id="kit-part-price" type="number" min="0" step="0.01" /></label>
        <label><span>Stock</span><input id="kit-part-stock" type="number" min="0" step="1" value="0" /></label>
        <label><span>Image</span><input id="kit-part-file" type="file" accept="image/png,image/webp,image/jpeg" /></label>
