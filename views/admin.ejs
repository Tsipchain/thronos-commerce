<!DOCTYPE html>
<html lang="<%= lang %>">
  <head>
    <meta charset="UTF-8" />
    <title><%= t('admin.tabTheme').split('&')[0].trim() %> – <%= config.storeName %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css" />
    <style>
      :root {
        --primary-color: <%= config.primaryColor %>;
        --accent-color: <%= config.accentColor %>;
        --font-family: <%= config.fontFamily %>;
        --menu-bg: <%= (config.theme && config.theme.menuBg) || '#111' %>;
        --menu-text: <%= (config.theme && config.theme.menuText) || '#fff' %>;
        --menu-active-bg: <%= (config.theme && config.theme.menuActiveBg) || '#f06292' %>;
        --menu-active-text: <%= (config.theme && config.theme.menuActiveText) || '#fff' %>;
        --button-radius: <%= (config.theme && config.theme.buttonRadius) || '4px' %>;
      }

      /* ── Full-Ops banner ── */
      .fullops-banner {
        background: #fff3cd;
        border: 1px solid #ffc107;
        border-radius: 6px;
        padding: 14px 18px;
        margin-bottom: 20px;
        font-size: 0.95rem;
        line-height: 1.5;
        color: #5a4200;
      }

      /* ── Products table & modal ── */
      .products-table { width: 100%; border-collapse: collapse; margin-bottom: 12px; }
      .products-table th, .products-table td {
        text-align: left; padding: 8px 10px;
        border-bottom: 1px solid #e0e0e0; font-size: 0.88rem;
      }
      .products-table th { background: #f5f5f5; font-weight: 600; }
      .products-table .thumb { width: 48px; height: 48px; object-fit: cover; border-radius: 4px; }
      .products-table .no-img { width: 48px; height: 48px; background: #eee; border-radius: 4px; display: inline-block; }
      .btn-sm { padding: 4px 10px; font-size: 0.8rem; border-radius: 4px; cursor: pointer;
                border: 1px solid #ccc; background: #fff; }
      .btn-sm.edit { border-color: var(--accent-color); color: var(--accent-color); }
      .btn-sm.del  { border-color: #e57373; color: #e57373; }
      .btn-sm:disabled { opacity: 0.4; cursor: not-allowed; }

      /* modal overlay */
      .modal-overlay {
        display: none; position: fixed; inset: 0;
        background: rgba(0,0,0,.45); z-index: 900;
        align-items: center; justify-content: center;
      }
      .modal-overlay.open { display: flex; }
      #kit-builder-modal.modal-overlay { background: rgba(2,6,23,.84); z-index: 1200; padding:16px; }
      #kit-builder-modal .modal { background:#ffffff; border:1px solid #93c5fd; color:#0f172a; box-shadow:0 18px 44px rgba(2,6,23,.52); width:min(980px,95vw); max-height:90vh; overflow:auto; padding:18px 20px; border-radius:12px; }
      #kit-builder-modal h3, #kit-builder-modal h4 { color:#0b1120; }
      #kit-builder-modal .helper { color:#1e293b; }
      #kit-builder-modal #kit-groups-list,
      #kit-builder-modal #kit-choices-list,
      #kit-builder-modal #kit-choice-search-results,
      #kit-builder-modal #kit-builder-preview { background:rgba(255,255,255,.9); color:#0f172a; }
      #kit-builder-modal #kit-builder-preview { display:flex; flex-wrap:wrap; gap:8px; align-items:flex-start; }
      #kit-builder-modal input, #kit-builder-modal select, #kit-builder-modal textarea {
        border:1px solid #cbd5e1; border-radius:8px; padding:7px 8px; font-size:.84rem;
      }
      #kit-builder-modal h4 { margin: 6px 0 8px; }
      body.device-mobile #kit-builder-modal .modal { width: 100%; max-height: 100vh; border-radius: 0; padding: 14px; }
      body.device-mobile .modal-actions { position: sticky; bottom: 0; background: #fff; padding-top: 10px; }
      .modal-box {
        background: #fff; border-radius: 8px; padding: 28px 28px 20px;
        width: min(520px, 95vw); max-height: 90vh; overflow-y: auto;
        box-shadow: 0 8px 32px rgba(0,0,0,.18);
      }
      .modal-box h3 { margin-top: 0; }
      .modal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
      .modal-grid .full { grid-column: 1 / -1; }
      .modal-grid label { display: flex; flex-direction: column; gap: 4px; font-size: 0.86rem; }
      .modal-grid input, .modal-grid textarea, .modal-grid select {
        padding: 6px 8px; border: 1px solid #ccc; border-radius: 4px; font-size: 0.9rem;
      }
      .modal-actions { display: flex; gap: 10px; margin-top: 16px; justify-content: flex-end; }

      /* helper text */
      .helper { font-size: 0.82rem; color: #666; margin: 0 0 12px; }

      /* password row for product save */
      .save-row { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-top: 10px; }
      .save-row input[type=password] { flex: 1 1 180px; }

      /* ── Shipping & Payment table ── */
      .sp-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
      .sp-table th, .sp-table td {
        padding: 8px 10px; text-align: left;
        border-bottom: 1px solid #e0e0e0; font-size: 0.87rem;
      }
      .sp-table th { background: #f5f5f5; font-weight: 600; white-space: nowrap; }
      .sp-table input[type=text],
      .sp-table input[type=number] {
        width: 100%; box-sizing: border-box;
        padding: 5px 7px; border: 1px solid #ccc; border-radius: 4px; font-size: 0.87rem;
      }
      .sp-table input:read-only { background: #f9f9f9; color: #888; cursor: not-allowed; }
      .sp-badge {
        display: inline-block; background: #e8f4fd; color: #1a73b8;
        border-radius: 3px; padding: 1px 6px; font-size: 0.76rem; font-family: monospace;
      }

      /* ── Color picker pairs ── */
      .color-field { display: flex; gap: 6px; align-items: center; }
      .color-field input[type=text]  { flex: 1; }
      .color-field input[type=color] {
        width: 36px; height: 34px; padding: 2px;
        border: 1px solid #ccc; border-radius: 4px; cursor: pointer; background: #fff;
        flex-shrink: 0;
      }
      .color-field input[type=color]:disabled { opacity: 0.4; cursor: not-allowed; }

      /* ── Logo upload inline ── */
      .logo-upload-row { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; margin-top: 4px; }
      .logo-upload-row input[type=file] { flex: 1 1 160px; font-size: 0.82rem; }
      .btn-xs { padding: 5px 12px; font-size: 0.8rem; background: #eee;
                border: 1px solid #ccc; border-radius: 4px; cursor: pointer; white-space: nowrap; }
      #logo-upload-status { font-size: 0.8rem; color: #555; margin-top: 4px; }
      .logo-preview-frame { display:inline-flex; align-items:center; justify-content:center; min-width:120px; min-height:60px; margin-top:6px; }
      .logo-preview-frame.is-dark { background:#111827; }
      .logo-preview-frame.is-light { background:#f8fafc; border:1px solid #e5e7eb; }
      .logo-preview-frame.is-auto { background:linear-gradient(135deg,#0f172a,#1f2937); }
      .logo-preview-frame img { max-width: 220px; object-fit: contain; }
      .branding-live-preview {
        margin-top: 8px; padding: 10px; border:1px solid #e2e8f0; border-radius:10px; background:#f8fafc;
      }
      .branding-live-preview .title { font-size:.78rem; color:#475569; margin-bottom:6px; font-weight:700; }

      /* ── Notifications section ── */
      .notif-section { margin-top: 22px; padding-top: 16px; border-top: 1px dashed #ddd; }
      .notif-section h3 { margin: 0 0 4px; }
      .checkbox-label { display: flex !important; flex-direction: row !important;
                        align-items: center; gap: 8px; cursor: pointer; }
      .checkbox-label input[type=checkbox] { width: auto; margin: 0; }
      .admin-shell { display:grid; grid-template-columns: 250px 1fr; gap:16px; }
      .admin-sidebar { border:1px solid #e5e7eb; border-radius:10px; padding:10px; background:#fff; position:sticky; top:10px; height:fit-content; }
      .admin-sidebar a { display:block; padding:8px 10px; border-radius:8px; text-decoration:none; color:#111827; font-size:.86rem; }
      .admin-sidebar a.active { background:#eef2ff; color:#3730a3; font-weight:700; }
      .section-panel { display:none; }
      .section-panel.active { display:block; }
      .settings-section-heading { font-size:.78rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#64748b; border-bottom:1px solid #e2e8f0; padding-bottom:6px; margin:22px 0 12px; }
      .settings-section-heading:first-child { margin-top:6px; }
      .settings-info-note { padding:8px 12px; background:#f0f9ff; border:1px solid #bae6fd; border-radius:8px; font-size:.82rem; color:#0369a1; margin:8px 0 14px; }
      .settings-divider { border:none; border-top:1px dashed #e2e8f0; margin:20px 0 16px; }
      .sidebar-toggle{display:none;margin-bottom:10px;}
      @media (max-width: 900px){ .admin-shell{grid-template-columns:1fr;} .sidebar-toggle{display:inline-block;} .admin-sidebar{display:none;} .admin-shell.show-sidebar .admin-sidebar{display:block;} }
      .cat-preview { width: 120px; height: 74px; object-fit: cover; border-radius: 8px; border: 1px solid #e5e7eb; background: #f8fafc; }
      .cat-upload-btn { display:inline-flex; align-items:center; justify-content:center; padding:6px 10px; border-radius:6px; border:1px solid #d1d5db; background:#fff; font-size:.78rem; cursor:pointer; font-weight:600; }
      .cat-remove-btn { background:#fff1f2; border-color:#fecdd3; color:#be123c; }
      .cat-inline-actions { display:flex; align-items:center; gap:6px; flex-wrap:wrap; }
      .cat-image-wrap { position: relative; display: inline-block; }
      .cat-hover-actions {
        position:absolute; inset:auto 6px 6px 6px; display:flex; gap:6px; opacity:0;
        transition:opacity .15s ease-in-out;
      }
      .cat-image-wrap:hover .cat-hover-actions { opacity:1; }
      .cat-helper-row { font-size:.76rem; color:#6b7280; margin-top:4px; }
      .cat-upload-status { font-size:.82rem; margin:10px 0 14px; padding:8px 10px; border-radius:8px; background:#f8fafc; border:1px solid #e2e8f0; color:#334155; display:none; }
      .cat-meta { font-size:.76rem; color:#6b7280; margin-top:4px; line-height:1.3; }
    </style>
  </head>
  <body class="device-<%= device || 'desktop' %> os-<%= os || 'other' %>">
    <header>
      <h1><%= t('admin.headerTitle') %></h1>
      <p class="subtitle">
        <%= t('admin.store') %>: <strong><%= tenant.id %></strong>
        &nbsp;·&nbsp;
        <%= t('admin.package') %>: <strong><%= tenant.supportTier %></strong>
        &nbsp;·&nbsp;
        <a href="<%= withTenantLink('/admin') %>" style="font-size:0.85rem"><%= t('admin.settingsLink') %></a>
        &nbsp;|&nbsp;
        <a href="<%= withTenantLink('/admin/orders') %>" style="font-size:0.85rem"><%= t('admin.ordersLink') %> <% if (typeof unresolvedOrdersCount === 'number' && unresolvedOrdersCount > 0) { %>(<%= unresolvedOrdersCount %> open)<% } %></a>
        &nbsp;|&nbsp;
        <a href="<%= withTenantLink('/') %>" target="_blank" rel="noopener" style="font-size:0.85rem"><%= t('admin.storefrontLink') %></a>
      </p>
      <div style="margin-top:8px;display:flex;gap:8px;flex-wrap:wrap;">
        <a href="<%= withTenantLink('/admin') %>" class="button" style="font-size:.82rem;">💾 Αποθήκευση αλλαγών</a>
        <a href="<%= withTenantLink('/') %>" target="_blank" rel="noopener" class="button" style="font-size:.82rem;background:#111827;display:inline-flex;align-items:center;gap:6px;">Προβολή Καταστήματος ↗</a>
        <% if (isPreviewMode) { %>
          <span style="font-size:.8rem;background:#fff7ed;border:1px solid #fed7aa;color:#9a3412;padding:6px 10px;border-radius:6px;">Preview tenant: <strong><%= tenant.id %></strong></span>
        <% } %>
      </div>
    </header>

    <main class="admin-layout">

      <%# ── Full-Ops banner ── %>
      <% if (tenant.supportTier === 'FULL_OPS_START') { %>
      <div class="fullops-banner">
        <strong><%= t('admin.fullOpsBanner') %></strong><br>
        <%= t('admin.fullOpsText') %>
      </div>
      <% } %>

      <%# ── Flash messages ── %>
      <% if (message) { %><p class="admin-msg success"><%= message %></p><% } %>
      <% if (error)   { %><p class="admin-msg error"><%= error %></p><% } %>

      <%# ── Subscription status widget ── %>
      <% if (subscription) { %>
      <div style="background:<%= subscription.isExpired ? '#fef2f2' : subscription.isExpiringSoon ? '#fffbeb' : '#f0fdf4' %>;border:1px solid <%= subscription.isExpired ? '#fca5a5' : subscription.isExpiringSoon ? '#fde68a' : '#bbf7d0' %>;border-radius:10px;padding:14px 18px;margin-bottom:18px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
        <div>
          <span style="font-weight:700;font-size:.9rem;color:<%= subscription.isExpired ? '#dc2626' : subscription.isExpiringSoon ? '#d97706' : '#15803d' %>;">
            <% if (subscription.isExpired) { %>⚠️ Η συνδρομή σας έχει λήξει
            <% } else if (subscription.isExpiringSoon) { %>⏳ Η συνδρομή λήγει σύντομα (<%= subscription.daysLeft %> μέρες)
            <% } else if (subscription.daysLeft !== null) { %>✓ Ενεργή συνδρομή — <%= subscription.daysLeft %> μέρες απομένουν
            <% } else { %>✓ Ενεργή συνδρομή (διαχειριζόμενη)<% } %>
          </span>
          <span style="display:block;font-size:.78rem;color:#6b7280;margin-top:2px;">
            Πακέτο: <strong><%= subscription.plan %></strong>
            <% if (subscription.expiryStr) { %> · Λήξη: <strong><%= subscription.expiryStr %></strong><% } %>
          </span>
        </div>
        <% if (subscription.isExpired || subscription.isExpiringSoon) { %>
        <div>
          <form method="POST" action="<%= withTenantLink('/admin/subscribe/renew') %>" style="display:inline-flex;gap:8px;align-items:center;">
            <input type="password" name="password" placeholder="Κωδικός admin" style="padding:6px 10px;border:1px solid #d1d5db;border-radius:5px;font-size:.82rem;" required />
            <button type="submit" style="padding:7px 16px;background:#4338ca;color:#fff;border:none;border-radius:5px;font-size:.82rem;font-weight:600;cursor:pointer;white-space:nowrap;">💳 Ανανέωση</button>
          </form>
        </div>
        <% } %>
      </div>
      <% } %>

      <button class="button sidebar-toggle" type="button" onclick="document.querySelector('.admin-shell').classList.toggle('show-sidebar')">☰ Μενού</button>
      <div class="admin-shell">
      <aside class="admin-sidebar">
        <a href="#tab-dashboard">📊 Dashboard</a>
        <a href="#tab-theme">🎨 Branding</a>
        <a href="#tab-homepage">🏠 Homepage</a>
        <a href="#tab-categories">🗂️ Categories</a>
        <a href="#tab-products">📦 Products</a>
        <a href="#tab-upload">🖼️ Media</a>
        <a href="<%= withTenantLink('/admin/orders') %>">🧾 Orders</a>
        <a href="<%= withTenantLink('/admin/payments') %>">💳 Payments</a>
        <a href="<%= withTenantLink('/admin/hosting') %>">🛰️ Hosting</a>
        <a href="#tab-notifications">🔔 Notifications</a>
        <a href="#tab-assistant">🤖 Βοηθός</a>
        <a href="<%= withTenantLink('/admin/assistant-panel') %>">🧠 Assistant Panel</a>
        <a href="#tab-support">⚙️ Advanced</a>
        <a href="<%= withTenantLink('/') %>">👁️ Preview Store</a>
      </aside>
      <div class="admin-main">
      <section id="tab-dashboard" class="admin-block section-panel">
        <h2>Dashboard</h2>
        <p class="helper">Καλώς ήρθατε! Επιλέξτε ενότητα από το sidebar για να κάνετε αλλαγές στο κατάστημά σας.</p>
        <div style="margin-top:12px;padding:10px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;">
          <strong>Payments status</strong>
          <p class="helper" style="margin:6px 0;">Stripe configured: <strong><%= config.stripePublishableKey ? 'yes' : 'no' %></strong> · PayPal configured: <strong><%= config.paypalEmail ? 'yes' : 'no' %></strong></p>
          <p class="helper" style="margin:6px 0;">COD available by default για να μην μπλοκάρει η ολοκλήρωση παραγγελίας.</p>
          <a class="button" href="<%= withTenantLink('/admin/payments') %>" style="text-decoration:none;">Open Payments Settings</a>
        </div>
        <div style="margin-top:12px;padding:10px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;">
          <strong>Coupons</strong>
          <p class="helper" style="margin:6px 0;">Δημιούργησε / ενημέρωσε κουπόνια για το tenant.</p>
          <form method="POST" action="<%= withTenantLink('/admin/coupons') %>" style="display:grid;grid-template-columns:1fr 120px 110px 120px;gap:8px;align-items:end;">
            <label style="margin:0;"><span class="helper">Code</span><input type="text" name="code" placeholder="WELCOME10" required /></label>
            <label style="margin:0;"><span class="helper">Type</span><select name="type"><option value="percent">Percent</option><option value="fixed">Fixed €</option></select></label>
            <label style="margin:0;"><span class="helper">Value</span><input type="number" min="0" step="0.01" name="value" required /></label>
            <label style="margin:0;"><span class="helper">Min subtotal</span><input type="number" min="0" step="0.01" name="minSubtotal" value="0" /></label>
            <label class="checkbox-label" style="grid-column:1/3;margin:0;"><input type="checkbox" name="active" value="1" checked /><span>Active</span></label>
            <label style="grid-column:3/5;margin:0;"><span class="helper">Admin password</span><input type="password" name="password" required /></label>
            <button class="button" type="submit" style="grid-column:1/5;">Save coupon</button>
          </form>
          <div class="helper" style="margin-top:8px;">
            <% if (Array.isArray(config.coupons) && config.coupons.length) { %>
              <% config.coupons.forEach(function(c){ %>
                <span style="display:inline-block;margin-right:8px;">• <strong><%= c.code %></strong> (<%= c.type === 'fixed' ? '€' : '%' %><%= c.value %>, min <%= Number(c.minSubtotal || 0).toFixed(2) %>, <%= c.active === false ? 'inactive' : 'active' %>)</span>
              <% }) %>
            <% } else { %>
              No tenant coupons yet (fallback WELCOME10 remains available when coupon list is empty).
            <% } %>
          </div>
        </div>
        <div style="margin-top:12px;padding:10px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;">
          <strong>Referral</strong>
          <% const ref = tenant.referral || null; %>
          <% if (ref && ref.code) { %>
            <p class="helper" style="margin:6px 0;">Code: <strong><%= ref.code %></strong> · Percent: <strong><%= Math.round(Number(ref.percent || 0) * 100) %>%</strong></p>
            <p class="helper" style="margin:6px 0;">Referral link: <code><%= withTenantLink('/?ref=' + encodeURIComponent(ref.code)) %></code></p>
          <% } else { %>
            <p class="helper" style="margin:6px 0;">Δεν έχει οριστεί referral code για αυτό το tenant από το root admin.</p>
          <% } %>
        </div>
        <div style="margin-top:12px;padding:10px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;">
          <strong>Finance summary (read-only)</strong>
          <% const fsum = financeSummary || { pendingSettlementEstimate: 0, pendingPlatformDues: 0, pendingReferralImpact: 0 }; %>
          <p class="helper" style="margin:6px 0;">Pending tenant payout estimate: <strong><%= Number(fsum.pendingSettlementEstimate || 0).toFixed(2) %> €</strong></p>
          <p class="helper" style="margin:6px 0;">Pending platform dues (COD): <strong><%= Number(fsum.pendingPlatformDues || 0).toFixed(2) %> €</strong></p>
          <p class="helper" style="margin:6px 0;">Pending referral impact: <strong><%= Number(fsum.pendingReferralImpact || 0).toFixed(2) %> €</strong></p>
          <p class="helper" style="margin:6px 0;">Root admin controls approvals/settlements from the root panel.</p>
        </div>
      </section>
      <div style="display:flex;justify-content:flex-end;margin:8px 0 14px;">
        <label style="font-size:.84rem;display:flex;align-items:center;gap:8px;">
          <strong><%= lang === 'el' ? 'Γλώσσα περιεχομένου' : 'Content language' %>:</strong>
          <select onchange="window.location.href=this.value" style="padding:5px 8px;border:1px solid #d1d5db;border-radius:6px;">
            <% (contentLangs || ['el','en']).forEach(function(cl) { %>
              <option value="<%= withTenantLink('/admin', { contentLang: cl, lang }) %>" <%= contentLang === cl ? 'selected' : '' %>><%= cl === 'el' ? 'Ελληνικά' : 'English' %></option>
            <% }) %>
          </select>
        </label>
      </div>


      <%# ══════════════════════════════════════════════════════════ %>
      <%#   TAB 1 – THEME / SETTINGS                                %>
      <%# ══════════════════════════════════════════════════════════ %>
      <% const isEukolakisClassic = config.theme && config.theme.presetId === 'eukolakis_classic_diy'; %>
      <% const isAistheticTenant = tenant && tenant.id === 'aisthetic'; %>
      <% const supportedGroups = (activeThemeMeta && Array.isArray(activeThemeMeta.supportedSettings)) ? activeThemeMeta.supportedSettings : []; %>
      <% const supportsColors = supportedGroups.includes('colors'); %>
      <% const supportsMenu = supportedGroups.includes('menu'); %>
      <% const supportsCursor = supportedGroups.includes('cursor'); %>
      <form id="tab-theme" class="admin-block section-panel js-settings-save-form" method="POST" action="<%= withTenantLink('/admin/settings') %>">
        <h2>Branding & Εμφάνιση</h2>
        <p class="helper"><%= t('admin.themeHelper') %></p>
        <p class="settings-info-note">Quick start για νέο merchant: <strong>1)</strong> ανέβασε logo, <strong>2)</strong> βάλε hero κείμενο/εικόνα στην Homepage, <strong>3)</strong> ανέβασε category εικόνες, <strong>4)</strong> πρόσθεσε πρώτα προϊόντα.</p>
        <% if (isAistheticTenant) { %>
        <div class="settings-info-note" style="background:#eefdf5;border-color:#bbf7d0;color:#166534;">
          <strong>Aisthetic Stores – First Session Checklist</strong><br />
          1) <a href="#tab-theme">Branding</a>: ανέβασε logo.<br />
          2) <a href="#tab-homepage">Homepage</a>: γράψε τίτλο/κείμενο και ανέβασε hero image.<br />
          3) <a href="#tab-categories">Categories</a>: ανέβασε εικόνα σε κάθε κατηγορία.<br />
          4) <a href="#tab-products">Products</a>: πρόσθεσε τα πρώτα προϊόντα και τιμές.
        </div>
        <% } %>
        <label><span>Ενεργό Theme</span>
          <select name="themePresetId" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <% (allowedThemes || []).forEach(function(themeMeta) { %>
              <option value="<%= themeMeta.key %>" <%= ((config.theme && config.theme.presetId) || 'core_default') === themeMeta.key ? 'selected' : '' %>>
                <%= themeMeta.label %> (<%= themeMeta.key %>)
              </option>
            <% }) %>
          </select>
          <small class="helper">Ο tenant μπορεί να επιλέξει μόνο themes που έχουν επιτραπεί από το Root Admin.</small>
        </label>
        <p class="settings-info-note">
          Active theme: <strong><%= (activeThemeMeta && activeThemeMeta.label) || ((config.theme && config.theme.presetId) || 'core_default') %></strong>.
          Υποστηριζόμενες ομάδες ρυθμίσεων: <code><%= (activeThemeMeta && activeThemeMeta.supportedSettings ? activeThemeMeta.supportedSettings.join(', ') : 'general') %></code>.
        </p>

        <h3 class="settings-section-heading">Ταυτότητα Καταστήματος</h3>

        <label><span><%= t('admin.storeName') %></span>
          <input type="text" name="storeName_el" value="<%= resolveField(rawConfig.storeName, 'el') %>" placeholder="Ελληνικά"
                 <%= permissions.canEditSettings ? '' : 'readonly' %> />
          <input type="text" name="storeName_en" value="<%= resolveField(rawConfig.storeName, 'en') %>" placeholder="English"
                 <%= permissions.canEditSettings ? '' : 'readonly' %> />
          <small class="helper">Το όνομα που βλέπει ο πελάτης στο storefront.</small>
        </label>

        <label><span>Κείμενο hero / Καλωσόρισμα</span>
          <textarea name="heroText_el" rows="2" placeholder="Ελληνικά"
                    <%= permissions.canEditSettings ? '' : 'readonly' %>><%= resolveField(rawConfig.heroText, 'el') %></textarea>
          <textarea name="heroText_en" rows="2" placeholder="English"
                    <%= permissions.canEditSettings ? '' : 'readonly' %>><%= resolveField(rawConfig.heroText, 'en') %></textarea>
          <small class="helper">Σύντομο μήνυμα κάτω από τον τίτλο στο hero banner. Για πιο πλούσιο hero (εικόνα + τίτλος), χρησιμοποιήστε την ενότητα <a href="#tab-homepage">Homepage → Hero Banner</a>.</small>
        </label>

        <label><span>Web3 Domain <small style="font-weight:400;color:#94a3b8;">(προαιρετικό)</small></span>
          <input type="text" name="web3Domain" value="<%= config.web3Domain %>"
                 placeholder="π.χ. mystore.thr" <%= permissions.canEditSettings ? '' : 'readonly' %> />
          <small class="helper">Αφήστε κενό αν δεν χρησιμοποιείτε Web3 domain. Εμφανίζεται δίπλα στο όνομα καταστήματος.</small>
        </label>

        <h3 class="settings-section-heading">Χρώματα & Τυπογραφία <% if (!supportsColors) { %><small style="color:#ca8a04;font-weight:600;">(περιορισμένη επίδραση στο τρέχον theme)</small><% } %></h3>
        <% if (config.theme && config.theme.presetId === 'eukolakis_classic_diy') { %>
        <p class="settings-info-note" style="background:#fefce8;border-color:#fde68a;color:#92400e;">Το θέμα <strong>Eukolakis Classic</strong> χρησιμοποιεί σταθερό βιομηχανικό header. Τα <strong>χρώματα μενού</strong> δεν εφαρμόζονται (βλ. παρακάτω). Το <strong>Primary & Accent color</strong> επηρεάζουν κουμπιά, links και δευτερεύοντα στοιχεία — εφαρμόζονται κανονικά.</p>
        <% } %>

        <label><span><%= t('admin.primaryColor') %></span>
          <div class="color-field">
            <input type="text" name="primaryColor" id="txt-primaryColor"
                   value="<%= config.primaryColor %>" placeholder="#222222"
                   <%= permissions.canEditSettings ? '' : 'readonly' %> />
            <input type="color" id="cp-primaryColor" value="<%= config.primaryColor || '#222222' %>"
                   title="Επιλογή χρώματος" <%= permissions.canEditSettings ? '' : 'disabled' %> />
          </div>
          <small class="helper">Κύριο χρώμα κεφαλίδας, μενού και call-to-action buttons.</small>
        </label>

        <label><span><%= t('admin.accentColor') %></span>
          <div class="color-field">
            <input type="text" name="accentColor" id="txt-accentColor"
                   value="<%= config.accentColor %>" placeholder="#00ff88"
                   <%= permissions.canEditSettings ? '' : 'readonly' %> />
            <input type="color" id="cp-accentColor" value="<%= config.accentColor || '#00ff88' %>"
                   title="Επιλογή χρώματος" <%= permissions.canEditSettings ? '' : 'disabled' %> />
          </div>
          <small class="helper">Δευτερεύον χρώμα για highlights, badges και ενεργές κατηγορίες.</small>
        </label>

        <label><span><%= t('admin.fontFamily') %></span>
          <select name="fontFamily" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
              <%= config.fontFamily.includes('system-ui') ? 'selected' : '' %>>System UI — προεπιλογή (γρήγορο φόρτωμα)</option>
            <option value="'Roboto', Arial, sans-serif"
              <%= config.fontFamily.includes('Roboto') ? 'selected' : '' %>>Roboto</option>
            <option value="'Segoe UI', system-ui, sans-serif"
              <%= config.fontFamily.includes('Segoe UI') && !config.fontFamily.includes('system-ui, -apple') ? 'selected' : '' %>>Segoe UI</option>
          </select>
        </label>

        <h3 class="settings-section-heading">Logo</h3>

        <% if (config.logoPath) { %>
        <div style="display:flex;align-items:center;gap:14px;padding:10px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;margin-bottom:12px;">
          <div style="background:#1e2130;border-radius:8px;padding:10px;min-width:74px;display:flex;align-items:center;justify-content:center;">
            <img src="<%= config.logoPath %>" alt="Current logo" style="max-height:46px;max-width:130px;object-fit:contain;" />
          </div>
          <div style="flex:1;min-width:0;">
            <p style="margin:0 0 2px;font-size:.8rem;font-weight:700;color:#374151;">Τρέχον logo</p>
            <code style="font-size:.72rem;color:#64748b;word-break:break-all;"><%= config.logoPath %></code>
          </div>
        </div>
        <% } else { %>
        <div style="padding:8px 12px;background:#fff7ed;border:1px solid #fed7aa;border-radius:8px;margin-bottom:12px;font-size:.82rem;color:#92400e;">
          Δεν έχει ανέβει logo ακόμα — χρησιμοποιήστε το upload παρακάτω.
        </div>
        <% } %>

        <label><span><%= t('admin.logoPath') %></span>
          <input type="text" name="logoPath" id="logoPath-input" value="<%= config.logoPath %>"
                 placeholder="/logo.svg" readonly />
          <small class="helper">Ενημερώνεται αυτόματα μετά το upload. Δεν χρειάζεται χειροκίνητη αλλαγή.</small>
        </label>
        <% if (permissions.canUploadMedia) { %>
        <div style="margin:-4px 0 14px;">
          <p class="helper" style="margin-bottom:5px;"><%= t('admin.uploadLogoHelper') %></p>
          <div class="logo-upload-row">
            <input type="file" id="logo-file" accept="image/*" />
            <input type="password" id="logo-pass" placeholder="Κωδικός (προαιρετικό)" style="width:160px;" />
            <button type="button" class="btn-xs" id="logo-upload-btn"><%= t('admin.uploadLogoBtn') %></button>
          </div>
          <p id="logo-upload-status"></p>
          <small class="helper">Αποδεκτές μορφές: PNG, SVG, JPG, WEBP. Συνιστάται τετράγωνο PNG με διαφανές φόντο.</small>
        </div>
        <% } %>
        <p class="settings-info-note">Το favicon (εικόνα στην καρτέλα browser) ανεβαίνει στην ενότητα <a href="#tab-upload">Media</a>.</p>

        <h3 class="settings-section-heading">Χρώματα Μενού Πλοήγησης <% if (!supportsMenu) { %><small style="color:#ca8a04;font-weight:600;">(preset-limited)</small><% } %></h3>
        <p class="helper" style="margin:0 0 8px;"><%= t('admin.menuColorsHelper') %></p>
        <% if (config.theme && config.theme.presetId === 'eukolakis_classic_diy') { %>
        <p class="settings-info-note" style="background:#fefce8;border-color:#fde68a;color:#92400e;margin-bottom:10px;">Το θέμα <strong>Eukolakis Classic</strong> χρησιμοποιεί σταθερό σκούρο header — αυτά τα χρώματα δεν εφαρμόζονται στο τρέχον θέμα.</p>
        <% } %>

        <label><span><%= t('admin.menuBg') %></span>
          <div class="color-field">
            <input type="text" name="themeMenuBg" id="txt-themeMenuBg"
                   value="<%= (config.theme && config.theme.menuBg) || '#111111' %>"
                   <%= (isEukolakisClassic || !permissions.canEditSettings) ? 'readonly' : '' %> />
            <input type="color" id="cp-themeMenuBg"
                   value="<%= (config.theme && config.theme.menuBg) || '#111111' %>"
                   title="Επιλογή χρώματος" <%= (isEukolakisClassic || !permissions.canEditSettings) ? 'disabled' : '' %> />
          </div>
        </label>

        <label><span><%= t('admin.menuText') %></span>
          <div class="color-field">
            <input type="text" name="themeMenuText" id="txt-themeMenuText"
                   value="<%= (config.theme && config.theme.menuText) || '#ffffff' %>"
                   <%= (isEukolakisClassic || !permissions.canEditSettings) ? 'readonly' : '' %> />
            <input type="color" id="cp-themeMenuText"
                   value="<%= (config.theme && config.theme.menuText) || '#ffffff' %>"
                   title="Επιλογή χρώματος" <%= (isEukolakisClassic || !permissions.canEditSettings) ? 'disabled' : '' %> />
          </div>
        </label>

        <label><span><%= t('admin.menuActiveBg') %></span>
          <div class="color-field">
            <input type="text" name="themeMenuActiveBg" id="txt-themeMenuActiveBg"
                   value="<%= (config.theme && config.theme.menuActiveBg) || '#f06292' %>"
                   <%= (isEukolakisClassic || !permissions.canEditSettings) ? 'readonly' : '' %> />
            <input type="color" id="cp-themeMenuActiveBg"
                   value="<%= (config.theme && config.theme.menuActiveBg) || '#f06292' %>"
                   title="Επιλογή χρώματος" <%= (isEukolakisClassic || !permissions.canEditSettings) ? 'disabled' : '' %> />
          </div>
        </label>

        <label><span><%= t('admin.menuActiveText') %></span>
          <div class="color-field">
            <input type="text" name="themeMenuActiveText" id="txt-themeMenuActiveText"
                   value="<%= (config.theme && config.theme.menuActiveText) || '#ffffff' %>"
                   <%= (isEukolakisClassic || !permissions.canEditSettings) ? 'readonly' : '' %> />
            <input type="color" id="cp-themeMenuActiveText"
                   value="<%= (config.theme && config.theme.menuActiveText) || '#ffffff' %>"
                   title="Επιλογή χρώματος" <%= (isEukolakisClassic || !permissions.canEditSettings) ? 'disabled' : '' %> />
          </div>
        </label>

        <label><span>Στρογγυλότητα κουμπιών <small style="font-weight:400;color:#94a3b8;">(corner radius)</small></span>
          <input type="text" name="themeButtonRadius"
                 value="<%= (config.theme && config.theme.buttonRadius) || '4px' %>"
                 placeholder="4px" <%= permissions.canEditSettings ? '' : 'readonly' %> />
          <small class="helper">Τιμές: <code>0px</code> = γωνιώδη, <code>4px</code> = ήπιo, <code>999px</code> = πλήρως στρογγυλά.</small>
        </label>

        <hr class="settings-divider" />
        <details style="margin:0 0 14px;">
          <summary style="cursor:pointer;font-weight:700;display:flex;align-items:center;gap:6px;">Εμφάνιση, layout & προχωρημένα <small style="font-weight:400;color:#94a3b8;">(κλικ για ανάπτυξη/σύμπτυξη)</small></summary>
          <p class="helper">Ρυθμίσεις εμφάνισης λογότυπου και διάταξης header. Αλλάξτε μόνο αν θέλετε να προσαρμόσετε την εμφάνιση του logo στο header.</p>
        <label><span>Διάταξη Header</span>
          <select name="themeHeaderLayout" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="default" <%= ((config.theme && config.theme.headerLayout) || 'default') === 'default' ? 'selected' : '' %>>Default (logo αριστερά)</option>
            <option value="centered" <%= ((config.theme && config.theme.headerLayout) || '') === 'centered' ? 'selected' : '' %>>Centered (logo + τίτλος κεντραρισμένα)</option>
          </select>
        </label>
        <label><span>Θέση Login / Account</span>
          <select name="themeAuthPosition" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="right" <%= ((config.theme && config.theme.authPosition) || 'right') === 'right' ? 'selected' : '' %>>Δεξιά</option>
            <option value="left" <%= ((config.theme && config.theme.authPosition) || '') === 'left' ? 'selected' : '' %>>Αριστερά</option>
          </select>
        </label>
        <label><span>Style κεντρικού menu</span>
          <select name="themeMenuStyle" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="classic" <%= ((config.theme && config.theme.menuStyle) || 'classic') === 'classic' ? 'selected' : '' %>>Classic</option>
            <option value="pills" <%= ((config.theme && config.theme.menuStyle) || '') === 'pills' ? 'selected' : '' %>>Pills</option>
            <option value="compact" <%= ((config.theme && config.theme.menuStyle) || '') === 'compact' ? 'selected' : '' %>>Compact</option>
          </select>
        </label>
        <label><span>Τι εμφανίζεται στο header</span>
          <select name="themeBrandingMode" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="logo_name" <%= ((config.theme && config.theme.brandingMode) || 'logo_name') === 'logo_name' ? 'selected' : '' %>>Logo + Όνομα καταστήματος</option>
            <option value="logo_only" <%= ((config.theme && config.theme.brandingMode) || '') === 'logo_only' ? 'selected' : '' %>>Μόνο logo (χωρίς κείμενο)</option>
            <option value="name_only" <%= ((config.theme && config.theme.brandingMode) || '') === 'name_only' ? 'selected' : '' %>>Μόνο όνομα (χωρίς logo)</option>
          </select>
        </label>
        <label><span>Τρόπος εμφάνισης logo</span>
          <select name="themeLogoDisplayMode" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="contain" <%= ((config.theme && config.theme.logoDisplayMode) || 'contain') === 'contain' ? 'selected' : '' %>>Contain — ολόκληρο το logo ορατό (συνιστάται)</option>
            <option value="cover" <%= ((config.theme && config.theme.logoDisplayMode) || '') === 'cover' ? 'selected' : '' %>>Cover — γεμίζει το πλαίσιο (μπορεί να κόψει)</option>
            <option value="clean_badge" <%= ((config.theme && config.theme.logoDisplayMode) || '') === 'clean_badge' ? 'selected' : '' %>>Clean badge — με λευκό φόντο badge</option>
            <option value="transparent_blend" <%= ((config.theme && config.theme.logoDisplayMode) || '') === 'transparent_blend' ? 'selected' : '' %>>Transparent blend — για PNG με διαφανές φόντο</option>
          </select>
        </label>
        <label><span>Φόντο πλαισίου logo</span>
          <select id="themeLogoBgMode" name="themeLogoBgMode" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="none" <%= ((config.theme && config.theme.logoBgMode) || '') === 'none' ? 'selected' : '' %>>Χωρίς φόντο</option>
            <option value="dark_badge" <%= ((config.theme && config.theme.logoBgMode) || '') === 'dark_badge' ? 'selected' : '' %>>Σκούρο badge</option>
            <option value="light_badge" <%= ((config.theme && config.theme.logoBgMode) || '') === 'light_badge' ? 'selected' : '' %>>Ανοιχτό badge</option>
            <option value="auto" <%= ((config.theme && config.theme.logoBgMode) || 'auto') === 'auto' ? 'selected' : '' %>>Auto (βάσει theme χρώματος)</option>
          </select>
        </label>
        <label><span>Εσωτερικό κενό logo (padding, px)</span>
          <input type="number" min="0" max="24" name="themeLogoPadding" value="<%= Number((config.theme && config.theme.logoPadding) || 6) %>" <%= permissions.canEditSettings ? '' : 'readonly' %> />
          <small class="helper">Χώρος γύρω από το logo μέσα στο πλαίσιο (0–24px).</small>
        </label>
        <label><span>Γωνίες πλαισίου logo (radius, px)</span>
          <input type="number" min="0" max="36" name="themeLogoRadius" value="<%= Number((config.theme && config.theme.logoRadius) || 10) %>" <%= permissions.canEditSettings ? '' : 'readonly' %> />
          <small class="helper">Στρογγυλότητα του πλαισίου γύρω από το logo (0 = τετράγωνο, 36 = κύκλος).</small>
        </label>
        <label><span>Σκιά logo</span>
          <select name="themeLogoShadow" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="none" <%= ((config.theme && config.theme.logoShadow) || '') === 'none' ? 'selected' : '' %>>Χωρίς σκιά</option>
            <option value="soft" <%= ((config.theme && config.theme.logoShadow) || 'soft') === 'soft' ? 'selected' : '' %>>Ήπια σκιά (συνιστάται)</option>
            <option value="floating" <%= ((config.theme && config.theme.logoShadow) || '') === 'floating' ? 'selected' : '' %>>Floating — έντονη σκιά (ιδανικό για διαφανή PNG)</option>
          </select>
        </label>
        <label><span>Μέγιστο ύψος logo στο header (px)</span>
          <input id="themeLogoMaxHeight" type="number" min="56" max="120" name="themeLogoMaxHeight" value="<%= config.theme.logoMaxHeight %>" <%= permissions.canEditSettings ? '' : 'readonly' %> />
          <small class="helper">Ύψος σε pixels (56–120px). <% if (config.theme && config.theme.presetId === 'eukolakis_classic_diy') { %>Για Eukolakis Classic συνιστάται 80–100px.<% } else { %>Τιμές 64–96px δουλεύουν καλά για τα περισσότερα logo.<% } %></small>
        </label>

        <fieldset style="border:1px solid #e5e7eb;padding:10px;border-radius:10px;margin-top:10px;">
          <legend><strong>Header & logo (Eukolakis Classic)</strong></legend>
          <p class="helper">Preview labels: Homepage header / Product page header / Checkout header.</p>
          <label><span>Homepage header — Foreground logo</span><select name="themeHeaderFgHomepage"><% ['hidden','badge-left','badge-right','centered-small','normal'].forEach(function(m){ %><option value="<%= m %>" <%= (config.theme.headerFgHomepage || 'hidden')===m ? 'selected':'' %>><%= m %></option><% }) %></select></label>
          <label><span>Homepage header — Hero/background logo</span><select name="themeHeaderHeroHomepage"><% ['off','centered-background','full-width-background'].forEach(function(m){ %><option value="<%= m %>" <%= (config.theme.headerHeroHomepage || 'centered-background')===m ? 'selected':'' %>><%= m %></option><% }) %></select></label>
          <label><span>Product page header — Foreground logo</span><select name="themeHeaderFgProduct"><% ['hidden','badge-left','badge-right','centered-small','normal'].forEach(function(m){ %><option value="<%= m %>" <%= (config.theme.headerFgProduct || 'badge-right')===m ? 'selected':'' %>><%= m %></option><% }) %></select></label>
          <label><span>Product page header — Hero/background logo</span><select name="themeHeaderHeroProduct"><% ['off','centered-background','full-width-background'].forEach(function(m){ %><option value="<%= m %>" <%= (config.theme.headerHeroProduct || 'centered-background')===m ? 'selected':'' %>><%= m %></option><% }) %></select></label>
          <label><span>Checkout header — Foreground logo</span><select name="themeHeaderFgCheckout"><% ['hidden','badge-left','badge-right','centered-small','normal'].forEach(function(m){ %><option value="<%= m %>" <%= (config.theme.headerFgCheckout || 'badge-left')===m ? 'selected':'' %>><%= m %></option><% }) %></select></label>
          <label><span>Checkout header — Hero/background logo</span><select name="themeHeaderHeroCheckout"><% ['off','centered-background','full-width-background'].forEach(function(m){ %><option value="<%= m %>" <%= (config.theme.headerHeroCheckout || 'off')===m ? 'selected':'' %>><%= m %></option><% }) %></select></label>
        </fieldset>
        <% if (config.logoPath) { %>
        <% const liveLogoBgMode = (config.theme && config.theme.logoBgMode) || 'auto'; %>
        <% const liveLogoPreviewBgClass = liveLogoBgMode === 'dark_badge' ? 'is-dark' : (liveLogoBgMode === 'light_badge' ? 'is-light' : 'is-auto'); %>
        <% const liveBrandingMode = (config.theme && config.theme.brandingMode) || 'logo_name'; %>
        <% const liveIsClassic = config.theme && config.theme.presetId === 'eukolakis_classic_diy'; %>
        <% const liveRawHeight = config.theme.logoMaxHeight; %>
        <% const livePreviewLogoHeight = Math.max(56, Math.min(120, liveRawHeight || (liveIsClassic ? 96 : 88))); %>
        <div class="branding-live-preview">
          <div class="title">Live preview (logo size + shadow)</div>
          <div class="logo-preview-frame <%= liveLogoPreviewBgClass %>" style="padding:<%= Number((config.theme && config.theme.logoPadding) || 6) %>px;border-radius:<%= Number((config.theme && config.theme.logoRadius) || 10) %>px;box-shadow:<%= ((config.theme && config.theme.logoShadow) || 'soft') === 'floating' ? '0 16px 28px rgba(15,23,42,.22)' : (((config.theme && config.theme.logoShadow) || 'soft') === 'none' ? 'none' : '0 4px 12px rgba(15,23,42,.12)') %>;">
            <img src="<%= config.logoPath %>" alt="Logo live preview" style="max-height:<%= livePreviewLogoHeight %>px;filter:<%= ((config.theme && config.theme.logoShadow) || 'soft') === 'floating' ? 'drop-shadow(0 12px 18px rgba(15,23,42,.28))' : (((config.theme && config.theme.logoShadow) || 'soft') === 'none' ? 'none' : 'drop-shadow(0 6px 10px rgba(15,23,42,.22))') %>;" />
          </div>
        </div>
        <% } %>
        <div style="margin-top:10px;padding:10px;border:1px solid #e2e8f0;border-radius:10px;background:#f8fafc;">
          <h4 style="margin:0 0 8px;font-size:.82rem;color:#374151;font-weight:700;">Κάρτες Προϊόντων</h4>
          <p class="helper" style="margin-bottom:8px;">Εμφάνιση thumbnail και εφέ hover για τις κάρτες προϊόντων στο κατάστημα.</p>
          <label><span>Αναλογία εικόνας (aspect ratio)</span>
            <select name="themeProductThumbAspect" <%= permissions.canEditSettings ? '' : 'disabled' %>>
              <option value="4:3" <%= ((config.theme && config.theme.productThumbAspect) || '4:3') === '4:3' ? 'selected' : '' %>>4:3 — οριζόντια (συνιστάται)</option>
              <option value="1:1" <%= ((config.theme && config.theme.productThumbAspect) || '') === '1:1' ? 'selected' : '' %>>1:1 — τετράγωνο</option>
              <option value="3:4" <%= ((config.theme && config.theme.productThumbAspect) || '') === '3:4' ? 'selected' : '' %>>3:4 — κατακόρυφο</option>
            </select>
          </label>
          <label><span>Εφαρμογή εικόνας (fit)</span>
            <select name="themeProductThumbFit" <%= permissions.canEditSettings ? '' : 'disabled' %>>
              <option value="cover" <%= ((config.theme && config.theme.productThumbFit) || 'cover') === 'cover' ? 'selected' : '' %>>Cover — γεμίζει τον χώρο (συνιστάται)</option>
              <option value="contain" <%= ((config.theme && config.theme.productThumbFit) || '') === 'contain' ? 'selected' : '' %>>Contain — εμφανίζει ολόκληρη την εικόνα</option>
            </select>
          </label>
          <label><span>Φόντο εικόνας (hex χρώμα)</span>
            <input type="text" name="themeProductThumbBg" value="<%= ((config.theme && config.theme.productThumbBg) || '#111111') %>" placeholder="#111111" <%= permissions.canEditSettings ? '' : 'readonly' %> />
