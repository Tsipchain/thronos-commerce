<!DOCTYPE html>
<html lang="<%= lang %>">
  <head>
    <meta charset="UTF-8" />
    <title><%= t('admin.tabTheme').split('&')[0].trim() %> – <%= config.storeName %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css" />
    <style>
      :root {
        --primary-color: <%= config.primaryColor %>;
        --accent-color: <%= config.accentColor %>;
        --font-family: <%= config.fontFamily %>;
        --menu-bg: <%= (config.theme && config.theme.menuBg) || '#111' %>;
        --menu-text: <%= (config.theme && config.theme.menuText) || '#fff' %>;
        --menu-active-bg: <%= (config.theme && config.theme.menuActiveBg) || '#f06292' %>;
        --menu-active-text: <%= (config.theme && config.theme.menuActiveText) || '#fff' %>;
        --button-radius: <%= (config.theme && config.theme.buttonRadius) || '4px' %>;
      }

      /* ── Full-Ops banner ── */
      .fullops-banner {
        background: #fff3cd;
        border: 1px solid #ffc107;
        border-radius: 6px;
        padding: 14px 18px;
        margin-bottom: 20px;
        font-size: 0.95rem;
        line-height: 1.5;
        color: #5a4200;
      }

      /* ── Products table & modal ── */
      .products-table { width: 100%; border-collapse: collapse; margin-bottom: 12px; }
      .products-table th, .products-table td {
        text-align: left; padding: 8px 10px;
        border-bottom: 1px solid #e0e0e0; font-size: 0.88rem;
      }
      .products-table th { background: #f5f5f5; font-weight: 600; }
      .products-table .thumb { width: 48px; height: 48px; object-fit: cover; border-radius: 4px; }
      .products-table .no-img { width: 48px; height: 48px; background: #eee; border-radius: 4px; display: inline-block; }
      .btn-sm { padding: 4px 10px; font-size: 0.8rem; border-radius: 4px; cursor: pointer;
                border: 1px solid #ccc; background: #fff; }
      .btn-sm.edit { border-color: var(--accent-color); color: var(--accent-color); }
      .btn-sm.del  { border-color: #e57373; color: #e57373; }
      .btn-sm:disabled { opacity: 0.4; cursor: not-allowed; }

      /* modal overlay */
      .modal-overlay {
        display: none; position: fixed; inset: 0;
        background: rgba(0,0,0,.45); z-index: 900;
        align-items: center; justify-content: center;
      }
      .modal-overlay.open { display: flex; }
      .modal-box {
        background: #fff; border-radius: 8px; padding: 28px 28px 20px;
        width: min(520px, 95vw); max-height: 90vh; overflow-y: auto;
        box-shadow: 0 8px 32px rgba(0,0,0,.18);
      }
      .modal-box h3 { margin-top: 0; }
      .modal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
      .modal-grid .full { grid-column: 1 / -1; }
      .modal-grid label { display: flex; flex-direction: column; gap: 4px; font-size: 0.86rem; }
      .modal-grid input, .modal-grid textarea, .modal-grid select {
        padding: 6px 8px; border: 1px solid #ccc; border-radius: 4px; font-size: 0.9rem;
      }
      .modal-actions { display: flex; gap: 10px; margin-top: 16px; justify-content: flex-end; }

      /* helper text */
      .helper { font-size: 0.82rem; color: #666; margin: 0 0 12px; }

      /* password row for product save */
      .save-row { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-top: 10px; }
      .save-row input[type=password] { flex: 1 1 180px; }

      /* ── Shipping & Payment table ── */
      .sp-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
      .sp-table th, .sp-table td {
        padding: 8px 10px; text-align: left;
        border-bottom: 1px solid #e0e0e0; font-size: 0.87rem;
      }
      .sp-table th { background: #f5f5f5; font-weight: 600; white-space: nowrap; }
      .sp-table input[type=text],
      .sp-table input[type=number] {
        width: 100%; box-sizing: border-box;
        padding: 5px 7px; border: 1px solid #ccc; border-radius: 4px; font-size: 0.87rem;
      }
      .sp-table input:read-only { background: #f9f9f9; color: #888; cursor: not-allowed; }
      .sp-badge {
        display: inline-block; background: #e8f4fd; color: #1a73b8;
        border-radius: 3px; padding: 1px 6px; font-size: 0.76rem; font-family: monospace;
      }

      /* ── Color picker pairs ── */
      .color-field { display: flex; gap: 6px; align-items: center; }
      .color-field input[type=text]  { flex: 1; }
      .color-field input[type=color] {
        width: 36px; height: 34px; padding: 2px;
        border: 1px solid #ccc; border-radius: 4px; cursor: pointer; background: #fff;
        flex-shrink: 0;
      }
      .color-field input[type=color]:disabled { opacity: 0.4; cursor: not-allowed; }

      /* ── Logo upload inline ── */
      .logo-upload-row { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; margin-top: 4px; }
      .logo-upload-row input[type=file] { flex: 1 1 160px; font-size: 0.82rem; }
      .btn-xs { padding: 5px 12px; font-size: 0.8rem; background: #eee;
                border: 1px solid #ccc; border-radius: 4px; cursor: pointer; white-space: nowrap; }
      #logo-upload-status { font-size: 0.8rem; color: #555; margin-top: 4px; }
      .logo-preview-frame { display:inline-flex; align-items:center; justify-content:center; min-width:120px; min-height:60px; margin-top:6px; }
      .logo-preview-frame.is-dark { background:#111827; }
      .logo-preview-frame.is-light { background:#f8fafc; border:1px solid #e5e7eb; }
      .logo-preview-frame.is-auto { background:linear-gradient(135deg,#0f172a,#1f2937); }
      .logo-preview-frame img { max-width: 220px; object-fit: contain; }

      /* ── Notifications section ── */
      .notif-section { margin-top: 22px; padding-top: 16px; border-top: 1px dashed #ddd; }
      .notif-section h3 { margin: 0 0 4px; }
      .checkbox-label { display: flex !important; flex-direction: row !important;
                        align-items: center; gap: 8px; cursor: pointer; }
      .checkbox-label input[type=checkbox] { width: auto; margin: 0; }
      .admin-shell { display:grid; grid-template-columns: 250px 1fr; gap:16px; }
      .admin-sidebar { border:1px solid #e5e7eb; border-radius:10px; padding:10px; background:#fff; position:sticky; top:10px; height:fit-content; }
      .admin-sidebar a { display:block; padding:8px 10px; border-radius:8px; text-decoration:none; color:#111827; font-size:.86rem; }
      .admin-sidebar a.active { background:#eef2ff; color:#3730a3; font-weight:700; }
      .section-panel { display:none; }
      .section-panel.active { display:block; }
      .sidebar-toggle{display:none;margin-bottom:10px;}
      @media (max-width: 900px){ .admin-shell{grid-template-columns:1fr;} .sidebar-toggle{display:inline-block;} .admin-sidebar{display:none;} .admin-shell.show-sidebar .admin-sidebar{display:block;} }
      .cat-preview { width: 120px; height: 74px; object-fit: cover; border-radius: 8px; border: 1px solid #e5e7eb; background: #f8fafc; }
      .cat-upload-btn { display:inline-flex; align-items:center; justify-content:center; padding:6px 10px; border-radius:6px; border:1px solid #d1d5db; background:#fff; font-size:.78rem; cursor:pointer; font-weight:600; }
      .cat-remove-btn { background:#fff1f2; border-color:#fecdd3; color:#be123c; }
      .cat-inline-actions { display:flex; align-items:center; gap:6px; flex-wrap:wrap; }
      .cat-image-wrap { position: relative; display: inline-block; }
      .cat-hover-actions {
        position:absolute; inset:auto 6px 6px 6px; display:flex; gap:6px; opacity:0;
        transition:opacity .15s ease-in-out;
      }
      .cat-image-wrap:hover .cat-hover-actions { opacity:1; }
      .cat-helper-row { font-size:.76rem; color:#6b7280; margin-top:4px; }
      .cat-upload-status { font-size:.82rem; margin:10px 0 14px; padding:8px 10px; border-radius:8px; background:#f8fafc; border:1px solid #e2e8f0; color:#334155; display:none; }
      .cat-meta { font-size:.76rem; color:#6b7280; margin-top:4px; line-height:1.3; }
    </style>
  </head>
  <body>
    <header>
      <h1><%= t('admin.headerTitle') %></h1>
      <p class="subtitle">
        <%= t('admin.store') %>: <strong><%= tenant.id %></strong>
        &nbsp;·&nbsp;
        <%= t('admin.package') %>: <strong><%= tenant.supportTier %></strong>
        &nbsp;·&nbsp;
        <a href="<%= withTenantLink('/admin') %>" style="font-size:0.85rem"><%= t('admin.settingsLink') %></a>
        &nbsp;|&nbsp;
        <a href="<%= withTenantLink('/admin/orders') %>" style="font-size:0.85rem"><%= t('admin.ordersLink') %></a>
        &nbsp;|&nbsp;
        <a href="<%= withTenantLink('/') %>" style="font-size:0.85rem"><%= t('admin.storefrontLink') %></a>
      </p>
      <div style="margin-top:8px;display:flex;gap:8px;flex-wrap:wrap;">
        <a href="<%= withTenantLink('/admin') %>" class="button" style="font-size:.82rem;">💾 Αποθήκευση αλλαγών</a>
        <a href="<%= withTenantLink('/') %>" class="button" style="font-size:.82rem;background:#111827;">👁️ Προβολή καταστήματος</a>
        <% if (isPreviewMode) { %>
          <span style="font-size:.8rem;background:#fff7ed;border:1px solid #fed7aa;color:#9a3412;padding:6px 10px;border-radius:6px;">Preview tenant: <strong><%= tenant.id %></strong></span>
        <% } %>
      </div>
    </header>

    <main class="admin-layout">

      <%# ── Full-Ops banner ── %>
      <% if (tenant.supportTier === 'FULL_OPS_START') { %>
      <div class="fullops-banner">
        <strong><%= t('admin.fullOpsBanner') %></strong><br>
        <%= t('admin.fullOpsText') %>
      </div>
      <% } %>

      <%# ── Flash messages ── %>
      <% if (message) { %><p class="admin-msg success"><%= message %></p><% } %>
      <% if (error)   { %><p class="admin-msg error"><%= error %></p><% } %>

      <%# ── Subscription status widget ── %>
      <% if (subscription) { %>
      <div style="background:<%= subscription.isExpired ? '#fef2f2' : subscription.isExpiringSoon ? '#fffbeb' : '#f0fdf4' %>;border:1px solid <%= subscription.isExpired ? '#fca5a5' : subscription.isExpiringSoon ? '#fde68a' : '#bbf7d0' %>;border-radius:10px;padding:14px 18px;margin-bottom:18px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
        <div>
          <span style="font-weight:700;font-size:.9rem;color:<%= subscription.isExpired ? '#dc2626' : subscription.isExpiringSoon ? '#d97706' : '#15803d' %>;">
            <% if (subscription.isExpired) { %>⚠️ Η συνδρομή σας έχει λήξει
            <% } else if (subscription.isExpiringSoon) { %>⏳ Η συνδρομή λήγει σύντομα (<%= subscription.daysLeft %> μέρες)
            <% } else if (subscription.daysLeft !== null) { %>✓ Ενεργή συνδρομή — <%= subscription.daysLeft %> μέρες απομένουν
            <% } else { %>✓ Ενεργή συνδρομή (διαχειριζόμενη)<% } %>
          </span>
          <span style="display:block;font-size:.78rem;color:#6b7280;margin-top:2px;">
            Πακέτο: <strong><%= subscription.plan %></strong>
            <% if (subscription.expiryStr) { %> · Λήξη: <strong><%= subscription.expiryStr %></strong><% } %>
          </span>
        </div>
        <% if (subscription.isExpired || subscription.isExpiringSoon) { %>
        <div>
          <form method="POST" action="<%= withTenantLink('/admin/subscribe/renew') %>" style="display:inline-flex;gap:8px;align-items:center;">
            <input type="password" name="password" placeholder="Κωδικός admin" style="padding:6px 10px;border:1px solid #d1d5db;border-radius:5px;font-size:.82rem;" required />
            <button type="submit" style="padding:7px 16px;background:#4338ca;color:#fff;border:none;border-radius:5px;font-size:.82rem;font-weight:600;cursor:pointer;white-space:nowrap;">💳 Ανανέωση</button>
          </form>
        </div>
        <% } %>
      </div>
      <% } %>

      <button class="button sidebar-toggle" type="button" onclick="document.querySelector('.admin-shell').classList.toggle('show-sidebar')">☰ Μενού</button>
      <div class="admin-shell">
      <aside class="admin-sidebar">
        <a href="#tab-dashboard">📊 Dashboard</a>
        <a href="#tab-theme">🎨 Branding</a>
        <a href="#tab-homepage">🏠 Homepage</a>
        <a href="#tab-categories">🗂️ Categories</a>
        <a href="#tab-products">📦 Products</a>
        <a href="#tab-upload">🖼️ Media</a>
        <a href="<%= withTenantLink('/admin/orders') %>">🧾 Orders</a>
        <a href="<%= withTenantLink('/admin/payments') %>">💳 Payments</a>
        <a href="#tab-notifications">🔔 Notifications</a>
        <a href="#tab-support">⚙️ Advanced</a>
        <a href="<%= withTenantLink('/') %>">👁️ Preview Store</a>
      </aside>
      <div class="admin-main">
      <section id="tab-dashboard" class="admin-block section-panel">
        <h2>Dashboard</h2>
        <p class="helper">Καλώς ήρθατε! Επιλέξτε ενότητα από το sidebar για να κάνετε αλλαγές στο κατάστημά σας.</p>
        <div style="margin-top:12px;padding:10px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;">
          <strong>Payments status</strong>
          <p class="helper" style="margin:6px 0;">Stripe configured: <strong><%= config.stripePublishableKey ? 'yes' : 'no' %></strong></p>
          <a class="button" href="<%= withTenantLink('/admin/payments') %>" style="text-decoration:none;">Open Payments</a>
        </div>
      </section>
      <div style="display:flex;justify-content:flex-end;margin:8px 0 14px;">
        <label style="font-size:.84rem;display:flex;align-items:center;gap:8px;">
          <strong><%= lang === 'el' ? 'Γλώσσα περιεχομένου' : 'Content language' %>:</strong>
          <select onchange="window.location.href=this.value" style="padding:5px 8px;border:1px solid #d1d5db;border-radius:6px;">
            <% (contentLangs || ['el','en']).forEach(function(cl) { %>
              <option value="<%= withTenantLink('/admin', { contentLang: cl, lang }) %>" <%= contentLang === cl ? 'selected' : '' %>><%= cl === 'el' ? 'Ελληνικά' : 'English' %></option>
            <% }) %>
          </select>
        </label>
      </div>


      <%# ══════════════════════════════════════════════════════════ %>
      <%#   TAB 1 – THEME / SETTINGS                                %>
      <%# ══════════════════════════════════════════════════════════ %>
      <form id="tab-theme" class="admin-block section-panel" method="POST" action="<%= withTenantLink('/admin/settings') %>">
        <h2>Store identity & εμφάνιση</h2>
        <p class="helper"><%= t('admin.themeHelper') %></p>

        <label><span><%= t('admin.storeName') %></span>
          <input type="text" name="storeName_el" value="<%= resolveField(rawConfig.storeName, 'el') %>" placeholder="Ελληνικά"
                 <%= permissions.canEditSettings ? '' : 'readonly' %> />
          <input type="text" name="storeName_en" value="<%= resolveField(rawConfig.storeName, 'en') %>" placeholder="English"
                 <%= permissions.canEditSettings ? '' : 'readonly' %> />
          <small class="helper">Το όνομα που βλέπει ο πελάτης στο storefront.</small>
        </label>

        <label><span><%= t('admin.primaryColor') %></span>
          <div class="color-field">
            <input type="text" name="primaryColor" id="txt-primaryColor"
                   value="<%= config.primaryColor %>" placeholder="#222222"
                   <%= permissions.canEditSettings ? '' : 'readonly' %> />
            <input type="color" id="cp-primaryColor" value="<%= config.primaryColor || '#222222' %>"
                   title="Επιλογή χρώματος" <%= permissions.canEditSettings ? '' : 'disabled' %> />
          </div>
        </label>

        <label><span><%= t('admin.accentColor') %></span>
          <div class="color-field">
            <input type="text" name="accentColor" id="txt-accentColor"
                   value="<%= config.accentColor %>" placeholder="#00ff88"
                   <%= permissions.canEditSettings ? '' : 'readonly' %> />
            <input type="color" id="cp-accentColor" value="<%= config.accentColor || '#00ff88' %>"
                   title="Επιλογή χρώματος" <%= permissions.canEditSettings ? '' : 'disabled' %> />
          </div>
        </label>

        <label><span><%= t('admin.fontFamily') %></span>
          <select name="fontFamily" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
              <%= config.fontFamily.includes('system-ui') ? 'selected' : '' %>>System UI (προεπιλογή)</option>
            <option value="'Roboto', Arial, sans-serif"
              <%= config.fontFamily.includes('Roboto') ? 'selected' : '' %>>Roboto</option>
            <option value="'Segoe UI', system-ui, sans-serif"
              <%= config.fontFamily.includes('Segoe UI') && !config.fontFamily.includes('system-ui, -apple') ? 'selected' : '' %>>Segoe UI</option>
          </select>
        </label>

        <label><span><%= t('admin.heroTextLabel') %></span>
          <textarea name="heroText_el" rows="2" placeholder="Ελληνικά"
                    <%= permissions.canEditSettings ? '' : 'readonly' %>><%= resolveField(rawConfig.heroText, 'el') %></textarea>
          <textarea name="heroText_en" rows="2" placeholder="English"
                    <%= permissions.canEditSettings ? '' : 'readonly' %>><%= resolveField(rawConfig.heroText, 'en') %></textarea>
        </label>

        <label><span><%= t('admin.web3DomainLabel') %></span>
          <input type="text" name="web3Domain" value="<%= config.web3Domain %>"
                 placeholder="π.χ. mystore.thr" <%= permissions.canEditSettings ? '' : 'readonly' %> />
        </label>

        <label><span><%= t('admin.logoPath') %></span>
          <input type="text" name="logoPath" id="logoPath-input" value="<%= config.logoPath %>"
                 placeholder="/logo.svg" readonly />
          <small class="helper">Το πεδίο ενημερώνεται αυτόματα από το upload λογότυπου.</small>
        </label>
        <% if (config.logoPath) { %>
          <% const logoBgMode = (config.theme && config.theme.logoBgMode) || 'auto'; %>
          <% const logoPreviewBgClass = logoBgMode === 'dark_badge' ? 'is-dark' : (logoBgMode === 'light_badge' ? 'is-light' : 'is-auto'); %>
          <div style="margin:-8px 0 10px;">
            <div class="logo-preview-frame <%= logoPreviewBgClass %>" style="padding:<%= Number((config.theme && config.theme.logoPadding) || 6) %>px;border-radius:<%= Number((config.theme && config.theme.logoRadius) || 10) %>px;">
              <img src="<%= config.logoPath %>" alt="Logo preview" style="max-height:<%= Number((config.theme && config.theme.logoMaxHeight) || 52) %>px;" />
            </div>
          </div>
        <% } %>
        <% if (permissions.canUploadMedia) { %>
        <div style="margin:-4px 0 14px;">
          <p class="helper" style="margin-bottom:5px;"><%= t('admin.uploadLogoHelper') %></p>
          <div class="logo-upload-row">
            <input type="file" id="logo-file" accept="image/*" />
            <input type="password" id="logo-pass" placeholder="<%= t('admin.logoPassPlaceholder') %>" style="width:130px;" />
            <button type="button" class="btn-xs" id="logo-upload-btn"><%= t('admin.uploadLogoBtn') %></button>
          </div>
          <p id="logo-upload-status"></p>
        </div>
        <% } %>

        <h3><%= t('admin.menuColors') %></h3>
        <p class="helper"><%= t('admin.menuColorsHelper') %></p>

        <label><span><%= t('admin.menuBg') %></span>
          <div class="color-field">
            <input type="text" name="themeMenuBg" id="txt-themeMenuBg"
                   value="<%= (config.theme && config.theme.menuBg) || '#111111' %>"
                   <%= permissions.canEditSettings ? '' : 'readonly' %> />
            <input type="color" id="cp-themeMenuBg"
                   value="<%= (config.theme && config.theme.menuBg) || '#111111' %>"
                   title="Επιλογή χρώματος" <%= permissions.canEditSettings ? '' : 'disabled' %> />
          </div>
        </label>

        <label><span><%= t('admin.menuText') %></span>
          <div class="color-field">
            <input type="text" name="themeMenuText" id="txt-themeMenuText"
                   value="<%= (config.theme && config.theme.menuText) || '#ffffff' %>"
                   <%= permissions.canEditSettings ? '' : 'readonly' %> />
            <input type="color" id="cp-themeMenuText"
                   value="<%= (config.theme && config.theme.menuText) || '#ffffff' %>"
                   title="Επιλογή χρώματος" <%= permissions.canEditSettings ? '' : 'disabled' %> />
          </div>
        </label>

        <label><span><%= t('admin.menuActiveBg') %></span>
          <div class="color-field">
            <input type="text" name="themeMenuActiveBg" id="txt-themeMenuActiveBg"
                   value="<%= (config.theme && config.theme.menuActiveBg) || '#f06292' %>"
                   <%= permissions.canEditSettings ? '' : 'readonly' %> />
            <input type="color" id="cp-themeMenuActiveBg"
                   value="<%= (config.theme && config.theme.menuActiveBg) || '#f06292' %>"
                   title="Επιλογή χρώματος" <%= permissions.canEditSettings ? '' : 'disabled' %> />
          </div>
        </label>

        <label><span><%= t('admin.menuActiveText') %></span>
          <div class="color-field">
            <input type="text" name="themeMenuActiveText" id="txt-themeMenuActiveText"
                   value="<%= (config.theme && config.theme.menuActiveText) || '#ffffff' %>"
                   <%= permissions.canEditSettings ? '' : 'readonly' %> />
            <input type="color" id="cp-themeMenuActiveText"
                   value="<%= (config.theme && config.theme.menuActiveText) || '#ffffff' %>"
                   title="Επιλογή χρώματος" <%= permissions.canEditSettings ? '' : 'disabled' %> />
          </div>
        </label>

        <label><span><%= t('admin.buttonRadius') %></span>
          <input type="text" name="themeButtonRadius"
                 value="<%= (config.theme && config.theme.buttonRadius) || '4px' %>"
                 placeholder="4px" <%= permissions.canEditSettings ? '' : 'readonly' %> />
        </label>
        <details style="margin:10px 0 14px;">
          <summary style="cursor:pointer;font-weight:700;">Advanced theme settings</summary>
          <p class="helper">Εσωτερικές ρυθμίσεις εμφάνισης. Συνήθως δεν χρειάζονται συχνές αλλαγές.</p>
        <label><span>Διάταξη Header</span>
          <select name="themeHeaderLayout" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="default" <%= ((config.theme && config.theme.headerLayout) || 'default') === 'default' ? 'selected' : '' %>>Default</option>
            <option value="centered" <%= ((config.theme && config.theme.headerLayout) || '') === 'centered' ? 'selected' : '' %>>Centered logo + τίτλος</option>
          </select>
        </label>
        <label><span>Branding mode</span>
          <select name="themeBrandingMode" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="logo_name" <%= ((config.theme && config.theme.brandingMode) || 'logo_name') === 'logo_name' ? 'selected' : '' %>>Logo + Name</option>
            <option value="logo_only" <%= ((config.theme && config.theme.brandingMode) || '') === 'logo_only' ? 'selected' : '' %>>Logo only</option>
            <option value="name_only" <%= ((config.theme && config.theme.brandingMode) || '') === 'name_only' ? 'selected' : '' %>>Name only</option>
          </select>
        </label>
        <label><span>Logo display mode</span>
          <select name="themeLogoDisplayMode" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="contain" <%= ((config.theme && config.theme.logoDisplayMode) || 'contain') === 'contain' ? 'selected' : '' %>>Contain</option>
            <option value="cover" <%= ((config.theme && config.theme.logoDisplayMode) || '') === 'cover' ? 'selected' : '' %>>Cover</option>
            <option value="clean_badge" <%= ((config.theme && config.theme.logoDisplayMode) || '') === 'clean_badge' ? 'selected' : '' %>>Clean badge</option>
            <option value="transparent_blend" <%= ((config.theme && config.theme.logoDisplayMode) || '') === 'transparent_blend' ? 'selected' : '' %>>Transparent blend</option>
          </select>
        </label>
        <label><span>Logo background mode</span>
          <select name="themeLogoBgMode" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="none" <%= ((config.theme && config.theme.logoBgMode) || '') === 'none' ? 'selected' : '' %>>None</option>
            <option value="dark_badge" <%= ((config.theme && config.theme.logoBgMode) || '') === 'dark_badge' ? 'selected' : '' %>>Dark badge</option>
            <option value="light_badge" <%= ((config.theme && config.theme.logoBgMode) || '') === 'light_badge' ? 'selected' : '' %>>Light badge</option>
            <option value="auto" <%= ((config.theme && config.theme.logoBgMode) || 'auto') === 'auto' ? 'selected' : '' %>>Auto</option>
          </select>
        </label>
        <label><span>Logo padding (px)</span>
          <input type="number" min="0" max="24" name="themeLogoPadding" value="<%= Number((config.theme && config.theme.logoPadding) || 6) %>" <%= permissions.canEditSettings ? '' : 'readonly' %> />
        </label>
        <label><span>Logo radius (px)</span>
          <input type="number" min="0" max="36" name="themeLogoRadius" value="<%= Number((config.theme && config.theme.logoRadius) || 10) %>" <%= permissions.canEditSettings ? '' : 'readonly' %> />
        </label>
        <label><span>Logo shadow</span>
          <select name="themeLogoShadow" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="none" <%= ((config.theme && config.theme.logoShadow) || '') === 'none' ? 'selected' : '' %>>None</option>
            <option value="soft" <%= ((config.theme && config.theme.logoShadow) || 'soft') === 'soft' ? 'selected' : '' %>>Soft</option>
            <option value="floating" <%= ((config.theme && config.theme.logoShadow) || '') === 'floating' ? 'selected' : '' %>>Floating</option>
          </select>
        </label>
        <label><span>Logo max height (px)</span>
          <input type="number" min="28" max="140" name="themeLogoMaxHeight" value="<%= Number((config.theme && config.theme.logoMaxHeight) || 52) %>" <%= permissions.canEditSettings ? '' : 'readonly' %> />
        </label>
        <label><span>Hero Style</span>
          <select name="themeHeroStyle" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="soft" <%= ((config.theme && config.theme.heroStyle) || 'soft') === 'soft' ? 'selected' : '' %>>Soft</option>
            <option value="strong" <%= ((config.theme && config.theme.heroStyle) || '') === 'strong' ? 'selected' : '' %>>Strong / Branded</option>
          </select>
        </label>
        <label><span>Category Menu Style</span>
          <select name="themeCategoryMenuStyle" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="text" <%= ((config.theme && config.theme.categoryMenuStyle) || '') === 'text' ? 'selected' : '' %>>Text only</option>
            <option value="image" <%= ((config.theme && config.theme.categoryMenuStyle) || '') === 'image' ? 'selected' : '' %>>Image only</option>
            <option value="image_label" <%= ((config.theme && config.theme.categoryMenuStyle) || 'image_label') === 'image_label' ? 'selected' : '' %>>Image + Label</option>
          </select>
        </label>
        <label><span>Card Style</span>
          <select name="themeCardStyle" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="soft" <%= ((config.theme && config.theme.cardStyle) || 'soft') === 'soft' ? 'selected' : '' %>>Soft</option>
            <option value="bold" <%= ((config.theme && config.theme.cardStyle) || '') === 'bold' ? 'selected' : '' %>>Bold</option>
          </select>
        </label>
        <label><span>Section Spacing</span>
          <select name="themeSectionSpacing" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="normal" <%= ((config.theme && config.theme.sectionSpacing) || 'normal') === 'normal' ? 'selected' : '' %>>Normal</option>
            <option value="relaxed" <%= ((config.theme && config.theme.sectionSpacing) || '') === 'relaxed' ? 'selected' : '' %>>Relaxed</option>
          </select>
        </label>
        <label class="checkbox-label">
          <input type="checkbox" name="themeBannerVisible" <%= ((config.theme && config.theme.bannerVisible) !== false) ? 'checked' : '' %> <%= permissions.canEditSettings ? '' : 'disabled' %> />
          <span>Εμφάνιση banner/hero</span>
        </label>
        <label><span>Preview Badge Style</span>
          <select name="themePreviewBadgeStyle" <%= permissions.canEditSettings ? '' : 'disabled' %>>
            <option value="soft" <%= ((config.theme && config.theme.previewBadgeStyle) || 'soft') === 'soft' ? 'selected' : '' %>>Soft</option>
            <option value="contrast" <%= ((config.theme && config.theme.previewBadgeStyle) || '') === 'contrast' ? 'selected' : '' %>>High contrast</option>
          </select>
        </label>
        <label class="checkbox-label">
          <input type="checkbox" name="themeCursorEffect" <%= (config.theme && config.theme.cursorEffect) ? 'checked' : '' %> <%= permissions.canEditSettings ? '' : 'disabled' %> />
          <span>DIY cursor effect (μόνο desktop)</span>
        </label>
        <% if (tenant.id === 'eukolakis') { %>
        <label><span>Cursor image URL (desktop only)</span>
          <input type="text" name="themeCursorImage" value="<%= (config.theme && config.theme.cursorImage) || '' %>" placeholder="/tenants/eukolakis/media/cursor/wrench.png" <%= permissions.canEditSettings ? '' : 'readonly' %> />
          <small class="helper">Αν μείνει κενό, γίνεται fallback σε crosshair.</small>
        </label>
        <% } %>
        </details>

        <label><span><%= t('admin.adminPass') %></span>
          <input type="password" name="password"
                 <%= permissions.canEditSettings ? '' : 'disabled' %> />
        </label>

        <button type="submit" class="button" <%= permissions.canEditSettings ? '' : 'disabled' %>>
          <%= t('admin.saveSettings') %>
        </button>
        <% if (!permissions.canEditSettings) { %>
          <p class="helper" style="margin-top:8px;"><%= t('admin.fullOpsManagedNote') %></p>
        <% } %>
      </form>

      <form id="tab-homepage" class="admin-block section-panel" method="POST" action="<%= withTenantLink('/admin/settings') %>">
        <h2>Homepage</h2>
        <p class="helper">Ρυθμίστε την αρχική σελίδα σαν branded landing-store για kits, ανταλλακτικά και εργαλεία.</p>
        <label><span>Hero title (EL/EN)</span>
          <input type="text" name="heroTitle_el" value="<%= resolveField(rawConfig.heroTitle, 'el') %>" placeholder="Ελληνικά" />
          <input type="text" name="heroTitle_en" value="<%= resolveField(rawConfig.heroTitle, 'en') %>" placeholder="English" />
        </label>
        <label><span>Hero subtitle (EL/EN)</span>
          <textarea name="heroSubtitle_el" rows="2" placeholder="Ελληνικά"><%= resolveField(rawConfig.heroSubtitle, 'el') %></textarea>
          <textarea name="heroSubtitle_en" rows="2" placeholder="English"><%= resolveField(rawConfig.heroSubtitle, 'en') %></textarea>
        </label>
        <label><span>Hero image / banner URL</span>
          <input type="text" name="homepageHeroImage" value="<%= (rawConfig.homepage && rawConfig.homepage.heroImage) || '' %>" placeholder="/tenants/eukolakis/media/banner.png" />
        </label>
        <% const hpPrimary = (rawConfig.homepage && (rawConfig.homepage.featuredPrimary || rawConfig.homepage.featuredIds)) || []; %>
        <% const hpKitProducts = (rawProducts || []).filter(function(p){ return p.type === 'KIT'; }); %>
        <% const hpKitIds = hpKitProducts.map(function(p){ return p.id; }); %>
        <% const hpP1Missing = hpPrimary[0] && !hpKitIds.includes(hpPrimary[0]); %>
        <% const hpP2Missing = hpPrimary[1] && !hpKitIds.includes(hpPrimary[1]); %>
        <label><span>Primary Product #1</span>
          <select name="homepageFeaturedPrimary1" id="homepageFeaturedPrimary1">
            <option value="">-- Select KIT --</option>
            <% hpKitProducts.forEach(function(p){ %>
              <option value="<%= p.id %>" <%= hpPrimary[0] === p.id ? 'selected' : '' %>><%= p.id %> — <%= resolveField(p.name, 'el') || resolveField(p.name, 'en') || p.id %></option>
            <% }) %>
          </select>
          <small class="helper">Εμφανίζεται στο πρώτο μεγάλο card της homepage.</small>
          <% if (hpP1Missing) { %><small style="color:#b91c1c;font-weight:700;">Το τρέχον ID δεν βρέθηκε. Pick a KIT now.</small><% } %>
        </label>
        <label><span>Primary Product #2</span>
          <select name="homepageFeaturedPrimary2" id="homepageFeaturedPrimary2">
            <option value="">-- Select KIT --</option>
            <% hpKitProducts.forEach(function(p){ %>
              <option value="<%= p.id %>" <%= hpPrimary[1] === p.id ? 'selected' : '' %>><%= p.id %> — <%= resolveField(p.name, 'el') || resolveField(p.name, 'en') || p.id %></option>
            <% }) %>
          </select>
          <small class="helper">Εμφανίζεται στο δεύτερο μεγάλο card της homepage.</small>
          <% if (hpP2Missing) { %><small style="color:#b91c1c;font-weight:700;">Το τρέχον ID δεν βρέθηκε. Pick a KIT now.</small><% } %>
          <% if (hpP1Missing || hpP2Missing) { %><button type="button" class="button" style="margin-top:8px;" onclick="window.location.hash='#tab-products'">Pick a KIT now</button><% } %>
        </label>
        <label><span>Secondary Feature Block</span>
          <input type="text" name="homepageFeaturedSecondaryId" value="<%= (rawConfig.homepage && rawConfig.homepage.featuredSecondaryId) || '' %>" placeholder="eukolaki-spare-pack" />
          <small class="helper">Μικρότερο block εξερεύνησης κάτω από τα κύρια kits.</small>
        </label>
        <label><span>Secondary block title (EL/EN)</span>
          <input type="text" name="homepageSecondaryTitle_el" value="<%= resolveField(rawConfig.homepage && rawConfig.homepage.secondaryCard && rawConfig.homepage.secondaryCard.title, 'el') %>" placeholder="Ελληνικά" />
          <input type="text" name="homepageSecondaryTitle_en" value="<%= resolveField(rawConfig.homepage && rawConfig.homepage.secondaryCard && rawConfig.homepage.secondaryCard.title, 'en') %>" placeholder="English" />
        </label>
        <label><span>Secondary block text (EL/EN)</span>
          <input type="text" name="homepageSecondaryText_el" value="<%= resolveField(rawConfig.homepage && rawConfig.homepage.secondaryCard && rawConfig.homepage.secondaryCard.text, 'el') %>" placeholder="Ελληνικά" />
          <input type="text" name="homepageSecondaryText_en" value="<%= resolveField(rawConfig.homepage && rawConfig.homepage.secondaryCard && rawConfig.homepage.secondaryCard.text, 'en') %>" placeholder="English" />
        </label>
        <label><span>Secondary block link</span>
          <input type="text" name="homepageSecondaryLink" value="<%= (rawConfig.homepage && rawConfig.homepage.secondaryCard && rawConfig.homepage.secondaryCard.link) || '' %>" placeholder="/?category=spare-parts" />
        </label>
        <label class="checkbox-label">
          <input type="checkbox" name="homepageShowSubscriptionsCard" <%= (rawConfig.homepage && rawConfig.homepage.showSubscriptionsCard) ? 'checked' : '' %> />
          <span>Εμφάνιση κάρτας "Συνδρομές / Videos"</span>
        </label>
        <input type="password" name="password" placeholder="Κωδικός διαχειριστή" />
        <button type="submit" class="button">Αποθήκευση homepage</button>
      </form>


      <%# ══════════════════════════════════════════════════════════ %>
      <%#   TAB 2 – CATEGORIES                                      %>
      <%# ══════════════════════════════════════════════════════════ %>
      <section id="tab-categories" class="admin-block section-panel">
        <h2><%= t('admin.categoriesTitle') %></h2>
        <p class="helper"><%= t('admin.categoriesHelper') %></p>
        <p class="cat-helper-row">Αντικατάσταση εικόνας: πατήστε «Ανέβασμα/Αλλαγή» και διαλέξτε αρχείο. Δεν χρειάζεται επικόλληση path.</p>
        <label style="display:inline-flex;align-items:center;gap:8px;font-size:.82rem;margin-bottom:10px;">
          Κωδικός επαναπιστοποίησης (μόνο αν ζητηθεί):
          <input id="category-reauth-password" type="password" placeholder="προαιρετικό" style="padding:6px 8px;border:1px solid #d1d5db;border-radius:6px;min-width:220px;" />
        </label>
        <div id="cat-upload-status" class="cat-upload-status"></div>

        <table class="admin-table">
          <thead>
            <tr>
              <th><%= t('admin.catColId') %></th>
              <th>Εικόνα</th>
              <th><%= t('admin.catColName') %></th>
              <th><%= t('admin.catColSlug') %></th>
              <th>Main Nav</th>
              <th>Order</th>
              <th><%= t('admin.catColParent') %></th>
              <th><%= t('admin.catColAction') %></th>
            </tr>
          </thead>
          <tbody>
            <% categories.forEach(function(cat){ %>
              <tr>
                <% const rawCat = rawCategories.find(rc=>rc.id===cat.id); %>
                <td><code><%= cat.id %></code></td>
                <td>
                  <% if (rawCat?.image) { %>
                    <div class="cat-image-wrap">
                      <img src="<%= rawCat.image %>" alt="<%= cat.name %>" class="cat-preview" />
                      <div class="cat-hover-actions">
                        <label class="cat-upload-btn" style="padding:4px 8px;font-size:.72rem;">
                          <input type="file" accept="image/*" onchange="uploadCategoryImage('<%= cat.id %>', this)" style="display:none;" />
                          Αλλαγή
                        </label>
                        <button type="button" class="cat-upload-btn cat-remove-btn" style="padding:4px 8px;font-size:.72rem;" onclick="removeCategoryImage('<%= cat.id %>')">Αφαίρεση</button>
                      </div>
                    </div>
                  <% } else { %><span style="color:#9ca3af;">—</span><% } %>
                </td>
                <td>
                  <div><strong>EL:</strong> <%= resolveField(rawCat?.name, 'el') || cat.name %></div>
                  <div style="color:#6b7280;"><strong>EN:</strong> <%= resolveField(rawCat?.name, 'en') || '—' %></div>
                  <div class="cat-meta">
                    <div><strong>EL desc:</strong> <%= resolveField(rawCat?.shortDescription, 'el') || '—' %></div>
                    <div><strong>EN desc:</strong> <%= resolveField(rawCat?.shortDescription, 'en') || '—' %></div>
                  </div>
                </td>
                <td><%= cat.slug %></td>
                <td><%= rawCat && rawCat.showInMainNav === false ? 'No' : 'Yes' %></td>
                <td><%= (rawCat && rawCat.navOrder !== undefined) ? rawCat.navOrder : '—' %></td>
                <td><%= cat.parentId ? cat.parentId : '–' %></td>
                <td>
                  <div class="cat-inline-actions">
                    <label class="cat-upload-btn">
                      <input type="file" accept="image/*" onchange="uploadCategoryImage('<%= cat.id %>', this)" style="display:none;" />
                      <%= rawCat?.image ? 'Αλλαγή εικόνας' : 'Ανέβασμα εικόνας' %>
                    </label>
                    <button type="button" class="cat-upload-btn cat-remove-btn" onclick="removeCategoryImage('<%= cat.id %>')" <%= rawCat?.image ? '' : 'disabled' %>>Αφαίρεση</button>
                  </div>
                  <form method="POST" action="<%= withTenantLink('/admin/categories/delete') %>" class="inline-form">
                    <input type="hidden" name="categoryId" value="<%= cat.id %>" />
                    <input type="password" name="password" placeholder="Κωδικός (μόνο αν ζητηθεί)"
                           <%= permissions.canEditCategories ? '' : 'disabled' %> />
                    <button type="submit" class="button danger"
                            <%= permissions.canEditCategories ? '' : 'disabled' %>><%= t('admin.catDelete') %></button>
                  </form>
                </td>
              </tr>
            <% }) %>
            <% if (categories.length === 0) { %>
              <tr><td colspan="8" style="color:#888;font-style:italic;"><%= t('admin.catNone') %></td></tr>
            <% } %>
          </tbody>
        </table>

        <% if (permissions.canEditCategories) { %>
        <form method="POST" action="<%= withTenantLink('/admin/categories/add') %>" class="admin-subform">
          <h3><%= t('admin.catAddTitle') %></h3>
          <p class="helper"><%= t('admin.catAddHelper') %></p>
          <input type="text" name="id" placeholder="Κωδικός (π.χ. bags)" required />
          <input type="text" name="name_el" placeholder="Όνομα (Ελληνικά)" required />
          <input type="text" name="name_en" placeholder="Name (English)" />
          <input type="text" name="shortDescription_el" placeholder="Σύντομη περιγραφή (Ελληνικά)" />
          <input type="text" name="shortDescription_en" placeholder="Short description (English)" />
          <label class="checkbox-label"><input type="checkbox" name="showInMainNav" checked /><span>Εμφάνιση στο main navigation strip</span></label>
          <input type="number" name="navOrder" placeholder="Σειρά στο main nav (π.χ. 1,2,3)" />
          <input type="text" name="slug" placeholder="Slug (π.χ. tsantes)" required />
          <select name="parentId">
            <option value=""><%= t('admin.catNoParent') %></option>
            <% categories.forEach(function(cat){ %>
              <option value="<%= cat.id %>"><%= cat.name %> (<%= cat.id %>)</option>
            <% }) %>
          </select>
          <input type="password" name="password" placeholder="Κωδικός διαχειριστή (μόνο αν ζητηθεί)" required />
          <button type="submit" class="button"><%= t('admin.catAddBtn') %></button>
        </form>

        <form method="POST" action="<%= withTenantLink('/admin/categories/update') %>" class="admin-subform">
          <h3><%= t('admin.catUpdateTitle') %></h3>
          <select name="categoryId">
            <% categories.forEach(function(cat){ %>
              <option value="<%= cat.id %>"><%= cat.name %> (<%= cat.id %>)</option>
            <% }) %>
          </select>
          <input type="text" name="name_el" placeholder="Νέο όνομα (Ελληνικά)" required />
          <input type="text" name="name_en" placeholder="New name (English)" />
          <input type="text" name="shortDescription_el" placeholder="Σύντομη περιγραφή (Ελληνικά)" />
          <input type="text" name="shortDescription_en" placeholder="Short description (English)" />
          <label class="checkbox-label"><input type="checkbox" name="showInMainNav" checked /><span>Εμφάνιση στο main navigation strip</span></label>
          <input type="number" name="navOrder" placeholder="Σειρά στο main nav (π.χ. 1,2,3)" />
          <input type="text" name="slug" placeholder="Νέο slug" required />
          <select name="parentId">
            <option value=""><%= t('admin.catNoParent') %></option>
            <% categories.forEach(function(cat){ %>
              <option value="<%= cat.id %>"><%= cat.name %> (<%= cat.id %>)</option>
            <% }) %>
          </select>
          <input type="password" name="password" placeholder="Κωδικός διαχειριστή (μόνο αν ζητηθεί)" required />
          <button type="submit" class="button"><%= t('admin.catUpdateBtn') %></button>
        </form>
        <% } else { %>
          <p class="helper"><%= t('admin.catManagedNote') %></p>
        <% } %>
      </section>

      <%# ══════════════════════════════════════════════════════════ %>
      <%#   TAB 3 – PRODUCTS (table + modal editor)                 %>
      <%# ══════════════════════════════════════════════════════════ %>
      <section id="tab-products" class="admin-block section-panel">
        <h2><%= t('admin.productsTitle') %></h2>
        <p class="helper">
          <%= t('admin.productsHelper') %>
          <% if (!permissions.canEditProducts) { %>
            <br><em><%= t('admin.productsManagedNote') %></em>
          <% } %>
        </p>

        <% if (permissions.canEditProducts) { %>
          <button class="button" id="btn-add-product" type="button"><%= t('admin.addProduct') %></button>
          <button class="button" id="btn-view-all-products" type="button" style="background:#1f2937;">All</button>
          <button class="button" id="btn-view-parts-products" type="button" style="background:#0f766e;">Spare parts</button>
          <details style="margin-top:10px;">
            <summary style="cursor:pointer;font-weight:700;">Quick add spare part</summary>
            <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px;margin-top:8px;">
              <input type="text" id="quick-part-id" placeholder="id (e.g. part-bolt-m8)" />
              <input type="text" id="quick-part-name" placeholder="Όνομα ανταλλακτικού" />
              <input type="number" id="quick-part-price" placeholder="Τιμή" min="0" step="0.01" />
              <input type="number" id="quick-part-stock" placeholder="Stock" min="0" step="1" />
              <input type="text" id="quick-part-image" placeholder="Image URL (auto από upload)" readonly />
              <div style="display:flex;gap:8px;">
                <label class="cat-upload-btn" style="cursor:pointer;">Upload<input type="file" id="quick-part-file" accept="image/*" style="display:none;" /></label>
                <button class="button" type="button" id="btn-quick-part-add">Add part</button>
              </div>
              <input type="password" id="quick-part-password" placeholder="Password (μόνο αν λήξει session)" style="display:none;" />
              <img id="quick-part-preview" alt="" style="display:none;width:58px;height:58px;object-fit:cover;border-radius:8px;border:1px solid #e5e7eb;" />
            </div>
          </details>
        <% } %>

        <table class="products-table" id="products-table">
          <thead>
            <tr>
              <th></th>
              <th><%= t('admin.colName') %></th>
              <th><%= t('admin.colPrice') %></th>
              <th><%= t('admin.colSku') %></th>
              <th><%= t('admin.colCategory') %></th>
              <% if (permissions.canEditProducts) { %><th><%= t('admin.colActions') %></th><% } %>
            </tr>
          </thead>
          <tbody id="products-tbody">
            <%# Rendered by JS below %>
          </tbody>
        </table>

        <%# Hidden form that submits the serialized JSON array to the backend %>
        <form id="products-save-form" method="POST" action="<%= withTenantLink('/admin/products') %>">
          <input type="hidden" name="productsJson" id="products-json-input" />
          <% if (permissions.canEditProducts) { %>
          <div class="save-row">
            <label style="flex:1 1 auto;font-size:0.86rem;">
              <%= t('admin.savePassLabel') %>
            </label>
            <input type="password" name="password" placeholder="<%= t('admin.adminPass') %>" />
            <button type="submit" class="button"><%= t('admin.saveAll') %></button>
          </div>
          <% } %>
        </form>
      </section>


      <%# ══════════════════════════════════════════════════════════ %>
      <%#   TAB 4 – IMAGE UPLOAD                                    %>
      <%# ══════════════════════════════════════════════════════════ %>
      <section id="tab-upload" class="admin-block section-panel">
        <h2><%= t('admin.imagesTitle') %></h2>
        <p class="helper"><%= t('admin.imagesHelper') %></p>
        <form id="upload-form" enctype="multipart/form-data">
          <input type="file" name="image" accept="image/*"
                 <%= permissions.canUploadMedia ? '' : 'disabled' %> required />
          <input type="password" name="password" placeholder="Κωδικός διαχειριστή (μόνο αν ζητηθεί)"
                 <%= permissions.canUploadMedia ? '' : 'disabled' %> />
          <button class="button" type="submit"
                  <%= permissions.canUploadMedia ? '' : 'disabled' %>><%= t('admin.uploadBtn') %></button>
        </form>
        <p id="upload-result"></p>
        <% if (!permissions.canUploadMedia) { %>
          <p class="helper"><%= t('admin.imagesManagedNote') %></p>
        <% } %>

        <%# ── Favicon ── %>
        <hr style="margin:28px 0 22px;border:none;border-top:1px solid #e5e7eb;" />
        <h3 style="margin-bottom:6px;"><%= t('admin.faviconTitle') %></h3>
        <p class="helper"><%= t('admin.faviconHelper') %></p>

        <% if (hasFavicon) { %>
          <div style="display:flex;align-items:center;gap:16px;margin-bottom:14px;">
            <img src="/favicon.ico?v=<%= Date.now() %>" alt="favicon"
                 style="width:48px;height:48px;object-fit:contain;border:1px solid #e5e7eb;border-radius:6px;padding:4px;background:#f9fafb;" />
            <div>
              <p style="margin:0 0 6px;font-size:0.85rem;color:#374151;font-weight:500;">Τρέχον favicon</p>
              <form method="POST" action="<%= withTenantLink('/admin/favicon/delete') %>" style="display:inline;">
                <input type="hidden" name="password" id="fav-del-pw" value="" />
                <button class="button" type="button" style="font-size:0.8rem;padding:4px 10px;background:#fee2e2;color:#b91c1c;border:1px solid #fca5a5;"
                        onclick="deleteFavicon(this)"><%= t('admin.faviconDelete') %></button>
              </form>
            </div>
          </div>
        <% } else { %>
          <p style="color:#9ca3af;font-size:0.85rem;margin-bottom:14px;"><%= t('admin.faviconNone') %></p>
        <% } %>

        <form method="POST" action="<%= withTenantLink('/admin/favicon') %>" enctype="multipart/form-data" style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
          <input type="file" name="favicon" accept="image/png,image/jpeg,image/x-icon,image/svg+xml" required />
          <input type="password" name="password" placeholder="<%= t('admin.passwordPlaceholder') %>" required style="width:180px;" />
          <button class="button" type="submit"><%= t('admin.faviconUploadBtn') %></button>
        </form>
        <p style="font-size:0.78rem;color:#9ca3af;margin-top:6px;">PNG / ICO / SVG · max 512 KB</p>
      </section>

      <%# ══════════════════════════════════════════════════════════ %>
      <%#   TAB 5 – SHIPPING & PAYMENT                              %>
      <%# ══════════════════════════════════════════════════════════ %>
      <section id="tab-shipping" class="admin-block section-panel">
        <h2><%= t('admin.shippingTitle') %></h2>
        <p class="helper"><%= t('admin.shippingHelper') %></p>

        <% if (!permissions.canEditSettings) { %>
          <p class="helper"><%= t('admin.shippingManagedNote') %></p>
        <% } %>

        <form method="POST" action="<%= withTenantLink('/admin/shipping-payment') %>">

          <%# ── Shipping options ── %>
          <h3><%= t('admin.shippingOptionsTitle') %></h3>
          <% if ((config.shippingOptions || []).length === 0) { %>
            <p class="helper" style="color:#888;"><%= t('admin.shippingNone') %></p>
          <% } else { %>
          <table class="sp-table">
            <thead>
              <tr>
                <th><%= t('admin.shipColId') %></th>
                <th><%= t('admin.shipColLabel') %></th>
                <th><%= t('admin.shipColBase') %></th>
                <th><%= t('admin.shipColCodFee') %></th>
                <th><%= t('admin.shipColAllowed') %></th>
              </tr>
            </thead>
            <tbody>
              <% (config.shippingOptions || []).forEach(function(opt, i) { %>
              <tr>
                <td><span class="sp-badge"><%= opt.id %></span></td>
                <td>
                  <input type="text" name="ship_label_<%= i %>"
                         value="<%= opt.label || '' %>"
                         <%= permissions.canEditSettings ? 'required' : 'readonly' %> />
                </td>
                <td>
                  <input type="number" name="ship_base_<%= i %>"
                         value="<%= opt.base !== undefined ? opt.base : 0 %>"
                         min="0" step="0.01"
                         <%= permissions.canEditSettings ? '' : 'readonly' %> />
                </td>
                <td>
                  <input type="number" name="ship_codFee_<%= i %>"
                         value="<%= opt.codFee !== undefined ? opt.codFee : 0 %>"
                         min="0" step="0.01"
                         <%= permissions.canEditSettings ? '' : 'readonly' %> />
                </td>
                <td>
                  <% (opt.allowedPaymentMethods || []).forEach(function(pm) { %>
                    <span class="sp-badge"><%= pm %></span>
                  <% }) %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <% } %>
          <p class="helper" style="margin-top:6px;"><%= t('admin.shipCostHelper') %></p>

          <%# ── Payment options ── %>
          <h3><%= t('admin.paymentOptionsTitle') %></h3>
          <% if ((config.paymentOptions || []).length === 0) { %>
            <p class="helper" style="color:#888;"><%= t('admin.paymentNone') %></p>
          <% } else { %>
          <table class="sp-table">
            <thead>
              <tr>
                <th><%= t('admin.payColId') %></th>
                <th><%= t('admin.payColLabel') %></th>
                <th><%= t('admin.payColType') %></th>
              </tr>
            </thead>
            <tbody>
              <% (config.paymentOptions || []).forEach(function(opt, i) { %>
              <tr>
                <td><span class="sp-badge"><%= opt.id %></span></td>
                <td>
                  <input type="text" name="pay_label_<%= i %>"
                         value="<%= opt.label || '' %>"
                         <%= permissions.canEditSettings ? 'required' : 'readonly' %> />
                </td>
                <td><span class="sp-badge"><%= opt.type || '–' %></span></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <% } %>
          <% if (permissions.canEditSettings) { %>
          <div class="save-row">
            <label style="flex:1 1 auto;font-size:0.86rem;"><%= t('admin.adminPass') %>:</label>
            <input type="password" name="password" placeholder="<%= t('admin.adminPass') %>" />
            <button type="submit" class="button"><%= t('admin.shippingSave') %></button>
          </div>
          <% } %>

        </form>
      </section>

      <%# ══════════════════════════════════════════════════════════ %>
      <%#   TAB 7 – NOTIFICATIONS                                   %>
      <%# ══════════════════════════════════════════════════════════ %>
      <form id="tab-notifications" class="admin-block section-panel" method="POST" action="<%= withTenantLink('/admin/notifications') %>">
        <h2><%= t('admin.notificationsTitle') %></h2>
        <p class="helper">Ρύθμιση παραληπτών email και webhook για ειδοποιήσεις παραγγελιών.</p>
        <label><span><%= t('admin.notifEmailLabel') %> <small style="color:#999">(<%= t('admin.notifEmailHint') %>)</small></span>
          <textarea name="notificationEmails" rows="3"
                    placeholder="owner@myshop.gr&#10;backup@myshop.gr"
                    <%= permissions.canEditSettings ? '' : 'readonly' %>><%= (config.notificationEmails || []).join('\n') %></textarea>
        </label>
        <label class="checkbox-label">
          <input type="checkbox" name="notificationCcCustomer"
                 <%= (config.notificationCcCustomer) ? 'checked' : '' %>
                 <%= permissions.canEditSettings ? '' : 'disabled' %> />
          <span><%= t('admin.notifCcCustomer') %></span>
        </label>
        <label><span><%= t('admin.notifFromName') %></span>
          <input type="text" name="notificationFromName"
                 value="<%= config.notificationFromName || '' %>"
                 placeholder="π.χ. FashionMM Store"
                 <%= permissions.canEditSettings ? '' : 'readonly' %> />
        </label>
        <label><span><%= t('admin.webhookUrl') %></span>
          <input type="text" name="notificationWebhookUrl"
                 value="<%= config.notificationWebhookUrl || '' %>"
                 placeholder="https://myhook.example.com/orders"
                 <%= permissions.canEditSettings ? '' : 'readonly' %> />
        </label>
        <label><span><%= t('admin.webhookSecret') %> <small style="color:#999">(<%= t('admin.webhookSecretHint') %>)</small></span>
          <input type="text" name="notificationWebhookSecret"
                 value="<%= config.notificationWebhookSecret || '' %>"
                 placeholder="mysecret123"
                 <%= permissions.canEditSettings ? '' : 'readonly' %> />
        </label>
        <% if (permissions.canEditSettings) { %>
        <div class="save-row">
          <label style="flex:1 1 auto;font-size:0.86rem;"><%= t('admin.adminPass') %>:</label>
          <input type="password" name="password" placeholder="<%= t('admin.adminPass') %>" />
          <button type="submit" class="button">Αποθήκευση ειδοποιήσεων</button>
        </div>
        <% } %>
      </form>


      <%# ══════════════════════════════════════════════════════════ %>
      <%#   TAB 8 – INVENTORY                                       %>
      <%# ══════════════════════════════════════════════════════════ %>
      <section id="tab-inventory" class="admin-block section-panel">
        <h2><%= t('admin.inventoryTitle') %></h2>
        <p class="helper"><%= t('admin.inventoryHelper') %></p>

        <%# ── Stock table ── %>
        <h3><%= t('admin.inventoryStockTitle') %></h3>
        <table class="sp-table" id="inv-stock-table">
          <thead>
            <tr>
              <th><%= t('admin.invColProduct') %></th>
              <th><%= t('admin.invColSku') %></th>
              <th><%= t('admin.invColStock') %></th>
              <th><%= t('admin.invColStatus') %></th>
              <th><%= t('admin.invColViews') %></th>
              <th><%= t('admin.invColOrders') %></th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach(function(p) { %>
              <% const s = p.stock !== undefined ? p.stock : '–'; %>
              <% const sNum = typeof s === 'number' ? s : parseInt(s); %>
              <% const statusClass = s === '–' ? '' : sNum === 0 ? 'stock-out' : sNum < 3 ? 'stock-low' : 'stock-ok'; %>
              <tr>
                <td>
                  <% if (p.imageUrl) { %><img src="<%= p.imageUrl %>" style="width:28px;height:28px;object-fit:cover;border-radius:3px;vertical-align:middle;margin-right:6px;" /><% } %>
                  <%= p.name %>
                  <% if (p.featured) { %><span style="color:#f59e0b;font-size:.75rem;margin-left:4px;">⭐</span><% } %>
                </td>
                <td style="color:#888;font-size:.82rem;"><%= p.sku || '–' %></td>
                <td style="font-weight:600;"><%= s %></td>
                <td>
                  <% if (s !== '–') { %>
                    <% if (sNum === 0) { %>
                      <span class="sp-badge" style="background:#fee2e2;color:#991b1b;"><%= t('admin.invStatusOut') %></span>
                    <% } else if (sNum < 3) { %>
                      <span class="sp-badge" style="background:#fef3c7;color:#92400e;"><%= t('admin.invStatusLow') %></span>
                    <% } else { %>
                      <span class="sp-badge" style="background:#d1fae5;color:#065f46;"><%= t('admin.invStatusOk') %></span>
                    <% } %>
                  <% } else { %>–<% } %>
                </td>
                <td style="font-size:.85rem;"><%= analytics.pageViews[p.id] || 0 %></td>
                <td style="font-size:.85rem;font-weight:600;"><%= orderCounts[p.id] || 0 %></td>
              </tr>
            <% }) %>
            <% if (!products.length) { %>
              <tr><td colspan="6" style="color:#aaa;text-align:center;padding:20px;"><%= t('admin.noProductsYet') %></td></tr>
            <% } %>
          </tbody>
        </table>

        <%# ── Orders by product bar chart ── %>
        <% const chartProducts = products.filter(function(p){ return (orderCounts[p.id]||0) > 0; }); %>
        <% if (chartProducts.length > 0) { %>
        <h3 style="margin-top:24px;"><%= t('admin.chartOrdersTitle') %></h3>
        <% const maxOrders = Math.max.apply(null, chartProducts.map(function(p){ return orderCounts[p.id]||0; })); %>
        <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:20px;">
          <% chartProducts.sort(function(a,b){ return (orderCounts[b.id]||0)-(orderCounts[a.id]||0); }).forEach(function(p) { %>
            <div style="display:flex;align-items:center;gap:10px;font-size:.84rem;">
              <span style="width:160px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= p.name %></span>
              <div style="flex:1;background:#f0f2fa;border-radius:4px;overflow:hidden;height:18px;">
                <div style="width:<%= Math.round((orderCounts[p.id]||0)/maxOrders*100) %>%;background:var(--accent-color,#5b6af5);height:100%;border-radius:4px;"></div>
              </div>
              <span style="width:28px;text-align:right;font-weight:700;"><%= orderCounts[p.id]||0 %></span>
            </div>
          <% }); %>
        </div>
        <% } %>

        <%# ── Top cities ── %>
        <% const cityEntries = Object.entries(cityCounts).sort(function(a,b){ return b[1]-a[1]; }).slice(0,10); %>
        <% if (cityEntries.length > 0) { %>
        <h3 style="margin-top:24px;"><%= t('admin.chartCitiesTitle') %></h3>
        <% const maxCityOrders = cityEntries[0][1]; %>
        <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:20px;">
          <% cityEntries.forEach(function(entry) { %>
            <div style="display:flex;align-items:center;gap:10px;font-size:.84rem;">
              <span style="width:140px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">📍 <%= entry[0] %></span>
              <div style="flex:1;background:#f0f2fa;border-radius:4px;overflow:hidden;height:18px;">
                <div style="width:<%= Math.round(entry[1]/maxCityOrders*100) %>%;background:#10b981;height:100%;border-radius:4px;"></div>
              </div>
              <span style="width:28px;text-align:right;font-weight:700;"><%= entry[1] %></span>
            </div>
          <% }); %>
        </div>
        <% } %>

        <%# ── Manual stock adjustment ── %>
        <% if (permissions.canEditProducts) { %>
        <h3 style="margin-top:24px;"><%= t('admin.invAdjustTitle') %></h3>
        <form method="POST" action="<%= withTenantLink('/admin/stock/adjust') %>" class="admin-subform" style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;">
          <label style="flex:1;min-width:140px;">
            <%= t('admin.invAdjustProduct') %>
            <select name="productId" style="margin-top:4px;">
              <% products.forEach(function(p) { %>
                <option value="<%= p.id %>"><%= p.name %> (<%= p.stock !== undefined ? p.stock : '–' %>)</option>
              <% }) %>
            </select>
          </label>
          <label style="flex:0 0 90px;">
            <%= t('admin.invAdjustQty') %>
            <input type="number" name="newStock" min="0" step="1" value="0" style="margin-top:4px;" />
          </label>
          <label style="flex:1;min-width:140px;">
            <%= t('admin.invAdjustReason') %>
            <input type="text" name="reason" placeholder="π.χ. αναπλήρωση" style="margin-top:4px;" />
          </label>
          <label style="flex:0 0 160px;">
            <%= t('admin.adminPass') %>
            <input type="password" name="password" style="margin-top:4px;" />
          </label>
          <button class="button" type="submit" style="align-self:flex-end;"><%= t('admin.invAdjustBtn') %></button>
        </form>
        <% } %>

        <%# ── Stock movement log ── %>
        <h3 style="margin-top:24px;"><%= t('admin.invLogTitle') %></h3>
        <% if (stockLog.length === 0) { %>
          <p class="helper" style="color:#aaa;"><%= t('admin.invLogEmpty') %></p>
        <% } else { %>
        <table class="sp-table" style="font-size:.83rem;">
          <thead>
            <tr>
              <th><%= t('admin.invLogDate') %></th>
              <th><%= t('admin.invLogProduct') %></th>
              <th><%= t('admin.invLogDelta') %></th>
              <th><%= t('admin.invLogReason') %></th>
              <th><%= t('admin.invLogOrder') %></th>
            </tr>
          </thead>
          <tbody>
            <% stockLog.forEach(function(e) { %>
            <tr>
              <td style="white-space:nowrap;color:#666;"><%= new Date(e.createdAt).toLocaleDateString(lang) %></td>
              <td><%= e.productName || e.productId %></td>
              <td style="font-weight:700;color:<%= e.delta < 0 ? '#dc2626' : '#16a34a' %>">
                <%= e.delta > 0 ? '+' + e.delta : e.delta %>
              </td>
              <td><%= e.reason %></td>
              <td style="font-size:.78rem;color:#aaa;font-family:monospace;"><%= e.orderId || '–' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </section>


      <%# ══════════════════════════════════════════════════════════ %>
      <%#   TAB 9 – SUPPORT / TICKETS                               %>
      <%# ══════════════════════════════════════════════════════════ %>
      <section id="tab-support" class="admin-block section-panel">
        <h2>💬 <%= t('admin.supportTitle') %></h2>
        <p class="helper"><%= t('admin.supportHelper') %></p>

        <div style="margin:0 0 20px;padding:14px;border:1px solid #e5e7eb;border-radius:10px;background:#f8fafc;">
          <h3 style="margin:0 0 8px;">Backups & Export</h3>
          <% if (exportAccess) { %>
            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px;">
              <a class="button" href="<%= withTenantLink('/admin/export/products.json') %>">Export products.json</a>
              <a class="button" href="<%= withTenantLink('/admin/export/products.csv') %>" style="background:#1f2937;">Export products.csv</a>
              <a class="button" href="<%= withTenantLink('/admin/export/categories.json') %>" style="background:#334155;">Export categories.json</a>
              <a class="button" href="<%= withTenantLink('/admin/export/config.json') %>" style="background:#475569;">Export config.json</a>
            </div>
          <% } else { %>
            <p style="margin:0 0 10px;color:#92400e;">Export available on paid plans. Contact support / upgrade.</p>
          <% } %>
          <div style="max-height:210px;overflow:auto;border:1px solid #e5e7eb;background:#fff;border-radius:8px;padding:8px;">
            <% if (backups && backups.length) { %>
              <% backups.forEach(function(b) { %>
                <div style="display:flex;justify-content:space-between;gap:10px;align-items:center;padding:6px 0;border-bottom:1px solid #f1f5f9;">
                  <div style="font-size:.82rem;">
                    <strong><%= b.filename %></strong><br />
                    <span style="color:#64748b;"><%= b.type %> · <%= Math.max(1, Math.round(Number(b.size || 0) / 1024)) %>KB · <%= new Date(b.modifiedAt).toLocaleString('el-GR') %></span>
                  </div>
                  <div style="display:flex;gap:6px;">
                    <a class="button" style="padding:4px 10px;font-size:.75rem;" href="<%= withTenantLink('/admin/backups/' + b.filename) %>">Download</a>
                    <form method="POST" action="<%= withTenantLink('/admin/backups/restore') %>" onsubmit="return confirm('Restore backup <%= b.filename %>;')" style="display:flex;gap:6px;align-items:center;">
                      <input type="hidden" name="filename" value="<%= b.filename %>" />
                      <input type="password" name="password" placeholder="password" style="padding:4px 6px;font-size:.74rem;width:110px;" />
                      <button class="button" type="submit" style="padding:4px 8px;font-size:.75rem;background:#0f766e;">Restore</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <p style="margin:0;font-size:.82rem;color:#64748b;">No backups yet. Save products/categories/settings to generate backups.</p>
            <% } %>
          </div>
          <form method="POST" action="<%= withTenantLink('/admin/backups/create-now') %>" style="display:flex;gap:8px;align-items:center;margin-top:10px;flex-wrap:wrap;">
            <input type="password" name="password" placeholder="Admin password" style="padding:6px 8px;" />
            <button class="button" type="submit">Create backup now</button>
          </form>
          <form method="POST" action="<%= withTenantLink('/admin/import/products') %>" enctype="multipart/form-data" style="display:flex;gap:8px;align-items:center;margin-top:10px;flex-wrap:wrap;">
            <input type="file" name="file" accept=".csv,.xlsx" required />
            <input type="password" name="password" placeholder="Admin password" style="padding:6px 8px;" />
            <button class="button" type="submit" style="background:#0f766e;">Import products from Excel/CSV</button>
          </form>
        </div>

        <%# ── Ticket list ── %>
        <% if (tickets && tickets.length) { %>
          <h3 style="font-size:.9rem;margin-bottom:10px;"><%= t('admin.supportHistory') %></h3>
          <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:28px;">
            <% tickets.forEach(function(tk) { %>
              <div style="border:1px solid #e5e7eb;border-radius:8px;padding:14px 16px;background:#fafafa;">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:6px;">
                  <strong style="font-size:.9rem;"><%= tk.subject %></strong>
                  <span style="font-size:.74rem;padding:2px 10px;border-radius:20px;font-weight:600;background:<%= tk.status === 'resolved' ? '#d1fae5' : tk.status === 'replied' ? '#dbeafe' : '#fef3c7' %>;color:<%= tk.status === 'resolved' ? '#065f46' : tk.status === 'replied' ? '#1e40af' : '#92400e' %>;">
                    <%= tk.status === 'resolved' ? '✓ Επιλύθηκε' : tk.status === 'replied' ? '💬 Απάντηση' : '⏳ Εκκρεμεί' %>
                  </span>
                </div>
                <p style="font-size:.82rem;color:#374151;margin:6px 0 4px;white-space:pre-wrap;"><%= tk.body %></p>
                <span style="font-size:.74rem;color:#9ca3af;"><%= new Date(tk.createdAt).toLocaleString('el-GR') %> · <%= tk.category %></span>
                <% if (tk.replies && tk.replies.length) { %>
                  <% tk.replies.forEach(function(r) { %>
                    <div style="margin-top:10px;padding:10px 12px;background:#eff6ff;border-left:3px solid #3b82f6;border-radius:4px;">
                      <strong style="font-size:.8rem;color:#1d4ed8;">Support</strong>
                      <p style="font-size:.82rem;margin:4px 0 0;white-space:pre-wrap;color:#1e3a8a;"><%= r.text %></p>
                      <span style="font-size:.72rem;color:#93c5fd;"><%= new Date(r.createdAt).toLocaleString('el-GR') %></span>
                    </div>
                  <% }) %>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } %>

        <%# ── New ticket form ── %>
        <h3 style="font-size:.9rem;margin-bottom:10px;"><%= t('admin.supportNewTicket') %></h3>
        <form method="POST" action="<%= withTenantLink('/admin/tickets/new') %>" style="display:flex;flex-direction:column;gap:12px;max-width:600px;">
          <label style="font-size:.86rem;display:flex;flex-direction:column;gap:4px;">
            <%= t('admin.supportCategory') %>
            <select name="category" style="padding:8px 10px;border:1px solid #d1d5db;border-radius:5px;font-size:.86rem;">
              <option value="product_change">🛍 Αλλαγή προϊόντων / περιεχομένου</option>
              <option value="design_change">🎨 Αλλαγή σχεδιασμού / theme</option>
              <option value="billing">💳 Τιμολόγηση / συνδρομή</option>
              <option value="technical">🔧 Τεχνικό πρόβλημα</option>
              <option value="general">💬 Γενική ερώτηση</option>
            </select>
          </label>
          <label style="font-size:.86rem;display:flex;flex-direction:column;gap:4px;">
            <%= t('admin.supportSubject') %>
            <input type="text" name="subject" required placeholder="π.χ. Θέλω να προσθέσω 3 νέα προϊόντα" style="padding:8px 10px;border:1px solid #d1d5db;border-radius:5px;font-size:.86rem;" />
          </label>
          <label style="font-size:.86rem;display:flex;flex-direction:column;gap:4px;">
            <%= t('admin.supportMessage') %>
            <textarea name="message" required rows="5" placeholder="Περιγράψτε αναλυτικά τι χρειάζεστε. Αν έχετε εικόνες, στείλτε τες και στο support@thronoschain.org." style="padding:8px 10px;border:1px solid #d1d5db;border-radius:5px;font-size:.86rem;resize:vertical;"></textarea>
          </label>
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
            <input type="password" name="password" placeholder="<%= t('admin.adminPass') %>" style="flex:0 0 180px;padding:8px 10px;border:1px solid #d1d5db;border-radius:5px;font-size:.86rem;" />
            <button type="submit" class="button" style="white-space:nowrap;">📨 <%= t('admin.supportSend') %></button>
          </div>
        </form>
        <p style="margin-top:14px;font-size:.78rem;color:#9ca3af;">
          Μπορείτε επίσης να επικοινωνήσετε απευθείας: <a href="mailto:support@thronoschain.org" style="color:#4338ca;">support@thronoschain.org</a>
        </p>
      </section>
      </div>
      </div>
    </main>


