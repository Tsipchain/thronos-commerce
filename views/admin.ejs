    <script>
      // ── i18n strings for JS ────────────────────────────────────
      const i18nJs = {
        noProducts:    '<%- t("admin.noProductsYet") %>',
        newProduct:    '<%- t("admin.modalNewProduct") %>',
        editPrefix:    '<%- t("admin.modalEditPrefix") %>',
        editBtn:       '<%- t("admin.editProduct") %>',
        deleteBtn:     '<%- t("admin.deleteProduct") %>',
        nameRequired:  '<%- t("admin.jsNameIdRequired") %>',
        uploading:     '<%- t("admin.jsUploading") %>',
        uploadOk:      '<%- t("admin.jsUploadComplete") %>',
        uploadErr:     '<%- t("admin.jsUploadError") %>',
        logoOk:        '<%- t("admin.jsLogoUploaded") %>',
        selectFile:    '<%- t("admin.jsSelectFile") %>',
        enterPass:     '<%- t("admin.jsEnterPassword") %>'
      };

      // ── Products data (server-rendered) ────────────────────────
      let products = JSON.parse(<%- productsJsonEscaped %>);
      const canEdit = <%= permissions.canEditProducts ? 'true' : 'false' %>;
      const isEukolakisClassicPreset = <%= config.theme && config.theme.presetId === 'eukolakis_classic_diy' ? 'true' : 'false' %>;
      let productFilter = 'all';
      let pendingKitCreate = null;

      // ── Render table ────────────────────────────────────────────
      function renderTable() {
        const tbody = document.getElementById('products-tbody');
        const visibleProducts = products.filter(function(p) {
          if (productFilter === 'parts') return ['spare-parts', 'tools'].includes(String(p.categoryId || ''));
          return true;
        });
        if (!visibleProducts.length) {
          tbody.innerHTML = '<tr><td colspan="' + (canEdit ? 6 : 5) + '" style="color:#888;font-style:italic;">' + i18nJs.noProducts + '</td></tr>';
          return;
        }
        tbody.innerHTML = visibleProducts.map((p) => {
          const i = products.findIndex(function(pr) { return pr.id === p.id; });
          const pName = (p.name && typeof p.name === 'object') ? (p.name.el || p.name.en || '') : (p.name || '');
          const img = p.imageUrl
            ? '<img class="thumb" src="' + escHtml(p.imageUrl) + '" alt="" loading="lazy">'
            : '<span class="no-img"></span>';
          const editBtn = canEdit
            ? '<button class="btn-sm edit" type="button" onclick="openEdit(' + i + ')">' + i18nJs.editBtn + '</button> ' +
              '<button class="btn-sm del" type="button" onclick="deleteProduct(' + i + ')">' + i18nJs.deleteBtn + '</button>' +
              (p.type === 'KIT'
                ? ' <button class="btn-sm" type="button" onclick="openKitBuilder(' + i + ')">Edit KIT wizard</button>'
                : ' <button class="btn-sm" type="button" onclick="makeProductKit(' + i + ')">Make this a KIT</button>')
            : '';
          return '<tr>' +
            '<td>' + img + '</td>' +
            '<td>' + escHtml(pName) + '</td>' +
            '<td>' + (p.price !== undefined ? Number(p.price).toFixed(2) : '–') + '</td>' +
            '<td>' + escHtml(p.sku || '') + '</td>' +
            '<td>' + escHtml(p.categoryId || '') + (p.active === false ? ' <small style="color:#b91c1c;">(hidden)</small>' : '') + '</td>' +
            (canEdit ? '<td>' + editBtn + '</td>' : '') +
            '</tr>';
        }).join('');
      }

      function escHtml(s) {
        return String(s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }
      async function parseJsonSafe(response) {
        const raw = await response.text();
        try {
          return JSON.parse(raw);
        } catch (_err) {
          return { ok: false, error: 'Server returned non-JSON response.', raw };
        }
      }

      // ── Modal logic ─────────────────────────────────────────────
      let editingIdx = -1; // -1 = new product

      const modal       = document.getElementById('product-modal');
      const fNameEl     = document.getElementById('f-name-el');
      const fNameEn     = document.getElementById('f-name-en');
      const fId         = document.getElementById('f-id');
      const fSku        = document.getElementById('f-sku');
      const fType       = document.getElementById('f-type');
      const fPrice      = document.getElementById('f-price');
      const fStock      = document.getElementById('f-stock');
      const fFeatured   = document.getElementById('f-featured');
      const fActive     = document.getElementById('f-active');
      const fCat        = document.getElementById('f-category');
      const fImg        = document.getElementById('f-imageUrl');
      const fImgPreview = document.getElementById('f-image-preview');
      const fImgFile    = document.getElementById('f-image-file');
      const fImgUploadBtn = document.getElementById('f-image-upload-btn');
      const fImgStatus  = document.getElementById('f-image-upload-status');
      const fDescEl     = document.getElementById('f-description-el');
      const fDescEn     = document.getElementById('f-description-en');
      const fSeoTitle   = document.getElementById('f-seoTitle');
      const fSeoDesc    = document.getElementById('f-seoDescription');
      const fGallery    = document.getElementById('f-gallery');
      const fGalleryList = document.getElementById('f-gallery-list');
      const fGalleryNewUrl = document.getElementById('f-gallery-new-url');
      const fGalleryNewFile = document.getElementById('f-gallery-new-file');
      const fGalleryAddBtn = document.getElementById('f-gallery-add-btn');
      const fGalleryUploadBtn = document.getElementById('f-gallery-upload-btn');
      const fGalleryStatus = document.getElementById('f-gallery-status');
      const mTitle      = document.getElementById('modal-title');

      // ── Digital content fields (may be null if tier doesn't support) ──
      const fHasDigital    = document.getElementById('f-hasDigitalContent');
      const fContentDesc   = document.getElementById('f-contentDescription');
      const fManualUrl     = document.getElementById('f-manualUrl');
      const fVideoUrl      = document.getElementById('f-videoUrl');
      function readLocalizedField(elInput, enInput) {
        const elVal = (elInput.value || '').trim();
        const enVal = (enInput.value || '').trim();
        if (elVal && enVal) return { el: elVal, en: enVal };
        if (elVal) return elVal;
        if (enVal) return { en: enVal };
        return '';
      }
      function getLocalizedForEdit(value, langCode) {
        if (value && typeof value === 'object' && !Array.isArray(value)) return value[langCode] || '';
        return langCode === 'el' ? (value || '') : '';
      }

      async function uploadManual(input) {
        const file = input.files[0];
        if (!file) return;
        const statusEl = document.getElementById('manual-upload-status');
        const pw = document.querySelector('input[name="password"]') ||
                   { value: prompt('Κωδικός διαχειριστή για ανέβασμα:') };
        statusEl.textContent = 'Ανέβασμα...';
        const fd = new FormData();
        fd.append('manual', file);
        fd.append('password', pw.value || '');
        try {
          const res = await fetch('<%= withTenantLink("/admin/upload-manual") %>', { method: 'POST', body: fd });
          const j = await res.json();
          if (j.ok) {
            if (fManualUrl) fManualUrl.value = j.url;
            statusEl.style.color = '#059669';
            statusEl.textContent = '✓ Ανέβηκε: ' + j.url;
          } else {
            statusEl.style.color = '#dc2626';
            statusEl.textContent = j.error || 'Σφάλμα ανεβάσματος.';
          }
        } catch(e) {
          statusEl.style.color = '#dc2626';
          statusEl.textContent = 'Σφάλμα δικτύου.';
        }
        input.value = '';
      }

      // ── Specs dynamic rows ───────────────────────────────────────
      function renderSpecRows(specs) {
        const container = document.getElementById('specs-rows');
        container.innerHTML = '';
        (specs || []).forEach(function(s) { addSpecRow(s.k, s.v); });
      }

      function addSpecRow(k, v) {
        const container = document.getElementById('specs-rows');
        const row = document.createElement('div');
        row.style.cssText = 'display:flex;gap:6px;margin-bottom:6px;';
        row.innerHTML =
          '<input type="text" placeholder="Χαρακτηριστικό" value="' + (k || '').replace(/"/g,'&quot;') + '" class="spec-k" style="flex:1;padding:5px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:.84rem;" />' +
          '<input type="text" placeholder="Τιμή" value="' + (v || '').replace(/"/g,'&quot;') + '" class="spec-v" style="flex:1;padding:5px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:.84rem;" />' +
          '<button type="button" onclick="this.closest(\'div\').remove()" style="background:#fee2e2;color:#dc2626;border:none;border-radius:4px;padding:4px 8px;cursor:pointer;">×</button>';
        container.appendChild(row);
      }

      function readSpecRows() {
        const rows = document.querySelectorAll('#specs-rows > div');
        const result = [];
        rows.forEach(function(row) {
          const k = (row.querySelector('.spec-k').value || '').trim();
          const v = (row.querySelector('.spec-v').value || '').trim();
          if (k && v) result.push({ k, v });
        });
        return result;
      }

      // ── Variant dynamic rows ─────────────────────────────────────
      function renderVariantRows(variants) {
        const container = document.getElementById('variants-rows');
        container.innerHTML = '';
        (variants || []).forEach(function(v) { addVariantRow(v); });
      }

      function addVariantRow(v) {
        v = v || {};
        const container = document.getElementById('variants-rows');
        const row = document.createElement('div');
        row.className = 'variant-row';
        row.dataset.vid = v.id || ('v-' + Date.now().toString(36));
        row.style.cssText = 'background:#f9fafb;border:1px solid #e5e7eb;border-radius:6px;padding:10px 12px;margin-bottom:8px;display:grid;grid-template-columns:1fr 120px 90px 80px;gap:6px;';
        row.innerHTML =
          '<input class="v-label" type="text" placeholder="<%= t("admin.variantLabel") %>" value="' + escHtml(v.label || '') + '" style="padding:5px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:.84rem;" />' +
          '<input class="v-sku" type="text" placeholder="Variant SKU" value="' + escHtml(v.sku || '') + '" style="padding:5px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:.84rem;" />' +
          '<input class="v-price" type="number" step="0.01" min="0" placeholder="<%= t("admin.variantPrice") %>" value="' + (v.price !== undefined ? v.price : '') + '" style="padding:5px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:.84rem;" />' +
          '<input class="v-stock" type="number" min="0" placeholder="<%= t("admin.variantStock") %>" value="' + (v.stock !== undefined ? v.stock : '') + '" style="padding:5px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:.84rem;" />' +
          '<button type="button" onclick="this.closest(\'.variant-row\').remove()" style="grid-column:4;background:#fee2e2;color:#dc2626;border:none;border-radius:4px;padding:4px 6px;cursor:pointer;font-size:.9rem;">×</button>' +
          '<div style="grid-column:1/5;display:flex;gap:8px;align-items:flex-start;flex-wrap:wrap;border:1px dashed #cbd5e1;border-radius:8px;padding:8px;">' +
            '<img class="v-image-preview" src="' + escHtml(v.imageUrl || '') + '" alt="" style="' + (v.imageUrl ? '' : 'display:none;') + 'width:56px;height:56px;border-radius:8px;object-fit:cover;border:1px solid #d1d5db;" />' +
            '<div style="flex:1;min-width:240px;">' +
              '<div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;margin-bottom:6px;">' +
                '<input class="v-image" type="text" placeholder="Variant image URL" value="' + escHtml(v.imageUrl || '') + '" style="flex:1;min-width:220px;padding:5px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:.82rem;" />' +
                '<a class="v-image-open" href="' + escHtml(v.imageUrl || '') + '" target="_blank" rel="noopener noreferrer" style="font-size:.76rem;color:#0f766e;white-space:nowrap;' + (v.imageUrl ? '' : 'display:none;') + '">Open image in new tab</a>' +
              '</div>' +
              '<div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">' +
                '<input class="v-image-file" type="file" accept="image/png,image/webp,image/jpeg" />' +
                '<button type="button" class="btn-xs" onclick="uploadVariantImage(this)">Upload image</button>' +
              '</div>' +
              '<small class="v-image-feedback" style="display:block;margin-top:5px;font-size:.76rem;color:#334155;">' + (v.imageUrl ? 'Image preview ready.' : 'Add/upload an image to preview it here.') + '</small>' +
              '<input class="v-video" type="text" placeholder="URL βίντεο" value="' + escHtml(v.videoUrl || '') + '" style="width:100%;padding:5px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:.82rem;margin-top:6px;" />' +
              '<video class="v-video-preview" controls muted playsinline style="' + (v.videoUrl ? '' : 'display:none;') + 'margin-top:6px;max-width:220px;max-height:132px;border-radius:8px;border:1px solid #cbd5e1;background:#0f172a;"></video>' +
              '<small class="v-video-feedback" style="display:block;margin-top:5px;font-size:.76rem;color:#334155;">' + (v.videoUrl ? 'Video preview ready.' : 'Add/upload a video URL to preview it here.') + '</small>' +
              '<div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;margin-top:6px;">' +
                '<input class="v-video-file" type="file" accept="video/mp4,video/webm" />' +
                '<button type="button" class="btn-xs" onclick="uploadVariantVideo(this)">Upload video</button>' +
              '</div>' +
              '<small class="v-upload-status" style="display:block;margin-top:5px;font-size:.76rem;color:#64748b;"></small>' +
            '</div>' +
          '</div>' +
          '<textarea class="v-desc" rows="2" placeholder="<%= t("admin.variantDesc") %>" style="grid-column:1/5;padding:5px 8px;border:1px solid #d1d5db;border-radius:4px;font-size:.82rem;resize:vertical;">' + escHtml(v.contentDescription || '') + '</textarea>';
        container.appendChild(row);
        bindVariantUrlPreview(row);
      }

      function readVariantRows() {
        const rows = document.querySelectorAll('#variants-rows .variant-row');
        const result = [];
        rows.forEach(function(row) {
          const label = (row.querySelector('.v-label').value || '').trim();
          if (!label) return;
          const existingId = row.dataset.vid;
          const id = existingId || label.toLowerCase().replace(/[^a-z0-9\u0370-\u03ff]+/g, '-').replace(/^-+|-+$/g, '') || ('v' + Date.now());
          const price = parseFloat(row.querySelector('.v-price').value);
          const stock = parseInt(row.querySelector('.v-stock').value, 10);
          const sku = (row.querySelector('.v-sku').value || '').trim() || undefined;
          const imageUrl = (row.querySelector('.v-image').value || '').trim() || undefined;
          const videoUrl = (row.querySelector('.v-video').value || '').trim() || undefined;
          const contentDescription = (row.querySelector('.v-desc').value || '').trim() || undefined;
          result.push({
            id,
            label,
            sku,
            price:  isNaN(price) ? 0 : price,
            stock:  isNaN(stock) ? 0 : stock,
            imageUrl,
            videoUrl,
            videoDescription: contentDescription,
            contentDescription
          });
        });
        return result;
      }

      let galleryImages = [];
      function setGalleryStatus(message, tone) {
        if (!fGalleryStatus) return;
        fGalleryStatus.textContent = message || '';
        fGalleryStatus.style.color = tone === 'error' ? '#b91c1c' : (tone === 'success' ? '#166534' : '#64748b');
      }
      function syncGalleryField() {
        if (!fGallery) return;
        fGallery.value = galleryImages.join('\n');
      }
      function renderGalleryRows() {
        if (!fGalleryList) return;
        if (!galleryImages.length) {
          fGalleryList.innerHTML = '<small style="color:#64748b;">No extra gallery images yet.</small>';
          syncGalleryField();
          return;
        }
        fGalleryList.innerHTML = galleryImages.map(function(url, idx) {
          return '<div style="display:grid;grid-template-columns:46px 1fr auto;gap:8px;align-items:center;border:1px solid #e5e7eb;border-radius:8px;padding:6px;">' +
            '<img src="' + escHtml(url) + '" alt="" style="width:46px;height:46px;object-fit:cover;border-radius:6px;border:1px solid #d1d5db;" onerror="this.style.opacity=.35;" />' +
            '<input type="text" value="' + escHtml(url) + '" onchange="updateGalleryImage(' + idx + ', this.value)" style="padding:6px 8px;border:1px solid #d1d5db;border-radius:6px;font-size:.82rem;" />' +
            '<div style="display:flex;gap:4px;">' +
              '<button type="button" class="btn-xs" onclick="moveGalleryImage(' + idx + ', -1)" ' + (idx === 0 ? 'disabled' : '') + '>↑</button>' +
              '<button type="button" class="btn-xs" onclick="moveGalleryImage(' + idx + ', 1)" ' + (idx === galleryImages.length - 1 ? 'disabled' : '') + '>↓</button>' +
              '<button type="button" class="btn-xs" style="background:#fee2e2;color:#b91c1c;" onclick="removeGalleryImage(' + idx + ')">Remove</button>' +
            '</div>' +
          '</div>';
        }).join('');
        syncGalleryField();
      }
      function normalizeGalleryInput(url) {
        return String(url || '').trim();
      }
      window.updateGalleryImage = function(idx, value) {
        const next = normalizeGalleryInput(value);
        if (!next) return;
        galleryImages[idx] = next;
        galleryImages = galleryImages.filter(function(url, i, arr) { return url && arr.indexOf(url) === i; });
        renderGalleryRows();
      };
      window.moveGalleryImage = function(idx, dir) {
        const target = idx + dir;
        if (target < 0 || target >= galleryImages.length) return;
        const tmp = galleryImages[idx];
        galleryImages[idx] = galleryImages[target];
        galleryImages[target] = tmp;
        renderGalleryRows();
      };
      window.removeGalleryImage = function(idx) {
        galleryImages.splice(idx, 1);
        renderGalleryRows();
      };
      function setGalleryImages(list) {
        galleryImages = (Array.isArray(list) ? list : [])
          .map(normalizeGalleryInput)
          .filter(function(url, idx, arr) { return url && arr.indexOf(url) === idx; });
        renderGalleryRows();
      }
      function addGalleryImage(url) {
        const clean = normalizeGalleryInput(url);
        if (!clean) return;
        if (galleryImages.includes(clean)) {
          setGalleryStatus('Image already exists in gallery list.', 'error');
          return;
        }
        galleryImages.push(clean);
        renderGalleryRows();
        setGalleryStatus('Gallery image added.', 'success');
      }

      function clearDigitalFields() {
        if (fHasDigital)  fHasDigital.checked = false;
        if (fContentDesc) fContentDesc.value  = '';
        if (fManualUrl)   fManualUrl.value    = '';
        if (fVideoUrl)    fVideoUrl.value     = '';
      }

      function fillDigitalFields(p) {
        if (fHasDigital)  fHasDigital.checked = !!p.hasDigitalContent;
        if (fContentDesc) fContentDesc.value  = p.contentDescription || '';
        if (fManualUrl)   fManualUrl.value    = p.manualUrl  || '';
        if (fVideoUrl)    fVideoUrl.value     = p.videoUrl   || '';
      }

      function readDigitalFields() {
        return {
          hasDigitalContent: fHasDigital  ? fHasDigital.checked || undefined : undefined,
          contentDescription: fContentDesc ? fContentDesc.value.trim() || undefined : undefined,
          manualUrl:  fManualUrl ? fManualUrl.value.trim()  || undefined : undefined,
          videoUrl:   fVideoUrl  ? fVideoUrl.value.trim()   || undefined : undefined
        };
      }

      async function uploadProductImage(file, password) {
        const fd = new FormData();
        fd.append('imageFile', file);
        fd.append('categoryId', (fCat && fCat.value) ? fCat.value : '');
        fd.append('password', password || '');
        const response = await fetch('<%= withTenantLink("/admin/products/image-upload") %>', { method: 'POST', body: fd });
        const json = await parseJsonSafe(response);
        return { status: response.status, body: json };
      }

      async function handleModalImageUpload() {
        const file = fImgFile && fImgFile.files && fImgFile.files[0];
        if (!file) return;
        if (fImgStatus) {
          fImgStatus.style.color = '#475569';
          fImgStatus.textContent = 'Uploading...';
        }
        let result = await uploadProductImage(file, '');
        if (result.status === 401) {
          const password = prompt('Session έληξε. Δώσε admin password για upload:') || '';
          if (!password) {
            if (fImgStatus) {
              fImgStatus.style.color = '#dc2626';
              fImgStatus.textContent = 'Απαιτείται κωδικός.';
            }
            fImgFile.value = '';
            return;
          }
          result = await uploadProductImage(file, password);
        }
        if (!result.body || !result.body.ok) {
          if (fImgStatus) {
            fImgStatus.style.color = '#dc2626';
            fImgStatus.textContent = (result.body && result.body.error) || 'Upload failed.';
          }
          fImgFile.value = '';
          return;
        }
        fImg.value = result.body.url || '';
        if (fImgPreview && fImg.value) {
          fImgPreview.src = fImg.value;
          fImgPreview.style.display = 'block';
        }
        if (fImgStatus) {
          fImgStatus.style.color = '#059669';
          fImgStatus.textContent = '✓ Uploaded';
        }
        fImgFile.value = '';
      }

      async function handleGalleryImageUpload() {
        const file = fGalleryNewFile && fGalleryNewFile.files && fGalleryNewFile.files[0];
        if (!file) return;
        setGalleryStatus('Uploading gallery image...', 'neutral');
        let result = await uploadProductImage(file, '');
        if (result.status === 401) {
          const password = prompt('Session έληξε. Δώσε admin password για upload:') || '';
          if (!password) {
            setGalleryStatus('Απαιτείται κωδικός.', 'error');
            fGalleryNewFile.value = '';
            return;
          }
          result = await uploadProductImage(file, password);
        }
        if (!result.body || !result.body.ok) {
          setGalleryStatus((result.body && result.body.error) || 'Gallery image upload failed.', 'error');
          fGalleryNewFile.value = '';
          return;
        }
        addGalleryImage(result.body.url || '');
        fGalleryNewFile.value = '';
      }

      function ensureVariantRowId(row) {
        if (!row) return '';
        let id = (row.dataset.vid || '').trim();
        if (!id) {
          const label = (row.querySelector('.v-label') && row.querySelector('.v-label').value || '').trim();
          id = (label || ('v-' + Date.now())).toLowerCase().replace(/[^a-z0-9\u0370-\u03ff_-]+/g, '-').replace(/^-+|-+$/g, '') || ('v-' + Date.now().toString(36));
          row.dataset.vid = id;
        }
        return id;
      }

      async function uploadVariantAsset(buttonEl, type) {
        const row = buttonEl && buttonEl.closest('.variant-row');
        if (!row) return;
        const variantId = ensureVariantRowId(row);
        const variantSkuInput = ((row.querySelector('.v-sku') && row.querySelector('.v-sku').value) || '').trim();
        const variantSku = variantSkuInput || variantId;
        const productId = (fId && fId.value || '').trim();
        if (!productId) return alert('Συμπλήρωσε πρώτα Product ID.');
        const fileInput = row.querySelector(type === 'image' ? '.v-image-file' : '.v-video-file');
        const file = fileInput && fileInput.files && fileInput.files[0];
        if (!file) return alert(type === 'image' ? 'Select variant image first.' : 'Select variant video first.');
        const status = row.querySelector('.v-upload-status');
        if (status) status.textContent = 'Uploading...';
        const fd = new FormData();
        fd.append('productId', productId);
        fd.append('variantSku', variantSku);
        fd.append('variantId', variantId);
        fd.append(type === 'image' ? 'variantImage' : 'variantVideo', file);
        fd.append('password', '');
        const endpointBase = type === 'image' ? '<%= withTenantLink("/admin/variants/image-upload") %>' : '<%= withTenantLink("/admin/variants/video-upload") %>';
        const endpoint = endpointBase + '?productId=' + encodeURIComponent(productId) + '&variantSku=' + encodeURIComponent(variantSku);
        let r = await fetch(endpoint, { method: 'POST', body: fd });
        let j = await parseJsonSafe(r);
        if (r.status === 401) {
          const pw = prompt('Session έληξε. Δώσε admin password για upload:') || '';
          if (!pw) return;
          fd.set('password', pw);
          r = await fetch(endpoint, { method: 'POST', body: fd });
          j = await parseJsonSafe(r);
        }
        if (!j.ok) {
          if (status) status.textContent = j.error || 'Upload failed.';
          return alert(j.error || 'Upload failed.');
        }
        if (type === 'image') {
          const urlEl = row.querySelector('.v-image');
          if (urlEl) urlEl.value = j.url || '';
          updateVariantImagePreview(row, j.url || '', { bustCache: true, loadingMessage: 'Loading preview…' });
          if (status) status.textContent = '✓ Uploaded';
        } else {
          const urlEl = row.querySelector('.v-video');
          if (urlEl) urlEl.value = j.url || '';
          updateVariantVideoPreview(row, j.url || '', { bustCache: true, loadingMessage: 'Loading video preview…' });
          if (status) status.textContent = '✓ Uploaded (video)';
          return;
        }
        if (status && (!row.querySelector('.v-image-preview') || !row.querySelector('.v-image-preview').src)) status.textContent = '✓ Uploaded';
      }
      window.uploadVariantImage = function(buttonEl) { uploadVariantAsset(buttonEl, 'image'); };
      window.uploadVariantVideo = function(buttonEl) { uploadVariantAsset(buttonEl, 'video'); };

      function setVariantImageFeedback(row, message, tone) {
        const feedbackEl = row && row.querySelector('.v-image-feedback');
        if (!feedbackEl) return;
        feedbackEl.textContent = message || '';
        feedbackEl.style.color = tone === 'error' ? '#b91c1c' : (tone === 'success' ? '#166534' : '#334155');
      }

      function syncVariantImageLink(row, url) {
        const linkEl = row && row.querySelector('.v-image-open');
        if (!linkEl) return;
        if (url) {
          linkEl.href = url;
          linkEl.style.display = '';
        } else {
          linkEl.removeAttribute('href');
          linkEl.style.display = 'none';
        }
      }
      function setVariantVideoFeedback(row, message, tone) {
        const feedbackEl = row && row.querySelector('.v-video-feedback');
        if (!feedbackEl) return;
        feedbackEl.textContent = message || '';
        feedbackEl.style.color = tone === 'error' ? '#b91c1c' : (tone === 'success' ? '#166534' : '#334155');
      }
      function updateVariantVideoPreview(row, rawUrl, options) {
        const preview = row && row.querySelector('.v-video-preview');
        if (!preview) return;
        const opts = options || {};
        const baseUrl = (rawUrl || '').trim();
        if (!baseUrl) {
          preview.style.display = 'none';
          preview.removeAttribute('src');
          setVariantVideoFeedback(row, 'Add/upload a video URL to preview it here.', 'neutral');
          return;
        }
        const srcUrl = opts.bustCache ? (baseUrl + (baseUrl.includes('?') ? '&' : '?') + 'v=' + Date.now()) : baseUrl;
        if (opts.loadingMessage) setVariantVideoFeedback(row, opts.loadingMessage, 'neutral');
        preview.onerror = function() {
          preview.style.display = 'none';
          setVariantVideoFeedback(row, 'Could not load video preview. URL was kept.', 'error');
        };
        preview.onloadeddata = function() {
          preview.style.display = 'block';
          setVariantVideoFeedback(row, 'Video preview ready.', 'success');
        };
        preview.src = srcUrl;
      }

      function updateVariantImagePreview(row, rawUrl, options) {
        const preview = row && row.querySelector('.v-image-preview');
        const status = row && row.querySelector('.v-upload-status');
        const opts = options || {};
        if (!preview) return;
        const baseUrl = (rawUrl || '').trim();
        syncVariantImageLink(row, baseUrl);
        if (!baseUrl) {
          preview.style.display = 'none';
          preview.removeAttribute('src');
          setVariantImageFeedback(row, 'Add/upload an image to preview it here.', 'neutral');
          return;
        }
        const srcUrl = opts.bustCache ? (baseUrl + (baseUrl.includes('?') ? '&' : '?') + 't=' + Date.now()) : baseUrl;
        if (opts.loadingMessage) setVariantImageFeedback(row, opts.loadingMessage, 'neutral');
        preview.onload = function() {
          preview.style.display = 'block';
          setVariantImageFeedback(row, 'Image preview ready.', 'success');
          if (status && status.textContent && status.textContent.includes('δεν φορτώνει')) status.textContent = '';
        };
        preview.onerror = function() {
          preview.style.display = 'block';
          preview.onload = null;
          preview.onerror = null;
          preview.src = 'data:image/svg+xml;utf8,' + encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" width="56" height="56"><rect width="100%" height="100%" fill="#fee2e2"/><text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" font-size="10" fill="#991b1b">404</text></svg>');
          setVariantImageFeedback(row, '404/invalid path', 'error');
          if (status) status.textContent = 'Η εικόνα δεν φορτώνει (404/invalid path).';
        };
        preview.src = srcUrl;
      }

      function bindVariantUrlPreview(row) {
        const input = row && row.querySelector('.v-image');
        const videoInput = row && row.querySelector('.v-video');
        const videoPreview = row && row.querySelector('.v-video-preview');
        if (!input) return;
        const refresh = function() {
          const url = (input.value || '').trim();
          updateVariantImagePreview(row, url, { bustCache: true });
        };
        input.addEventListener('change', refresh);
        input.addEventListener('blur', refresh);
        refresh();
        const refreshVideo = function() {
          const vurl = (videoInput && videoInput.value || '').trim();
          if (!videoPreview) return;
          updateVariantVideoPreview(row, vurl);
        };
        if (videoInput) {
          videoInput.addEventListener('change', refreshVideo);
          videoInput.addEventListener('blur', refreshVideo);
          refreshVideo();
        }
      }


      function openAdd() {
        editingIdx = -1;
        mTitle.textContent = i18nJs.newProduct;
        fNameEl.value = ''; fNameEn.value = ''; fId.value = ''; fSku.value = '';
        if (fType) fType.value = 'NORMAL';
        fPrice.value = ''; fStock.value = '1'; fFeatured.checked = false;
        if (fActive) fActive.checked = true;
        fCat.value = ''; fImg.value = ''; fDescEl.value = ''; fDescEn.value = '';
        if (fImgPreview) { fImgPreview.style.display = 'none'; fImgPreview.src = ''; }
        if (fImgStatus) { fImgStatus.textContent = ''; fImgStatus.style.color = '#64748b'; }
        fSeoTitle.value = ''; fSeoDesc.value = ''; fGallery.value = '';
        if (fGalleryNewUrl) fGalleryNewUrl.value = '';
        if (fGalleryNewFile) fGalleryNewFile.value = '';
        setGalleryStatus('', 'neutral');
        setGalleryImages([]);
        renderSpecRows([]);
        renderVariantRows([]);
        clearDigitalFields();
        modal.classList.add('open');
        fNameEl.focus();
      }

      function openEdit(i) {
        editingIdx = i;
        const p = products[i];
        mTitle.textContent = i18nJs.editPrefix + (typeof p.name === 'string' ? p.name : (p.name && (p.name.el || p.name.en)) || '');
        fNameEl.value     = getLocalizedForEdit(p.name, 'el');
        fNameEn.value     = getLocalizedForEdit(p.name, 'en');
        fId.value         = p.id || '';
        fSku.value        = p.sku || '';
        if (fType) fType.value = p.type || 'NORMAL';
        fPrice.value      = p.price !== undefined ? p.price : '';
        fStock.value      = p.stock !== undefined ? p.stock : '';
        fFeatured.checked = !!p.featured;
        if (fActive) fActive.checked = p.active !== false;
        fCat.value        = p.categoryId || '';
        fImg.value        = p.imageUrl || '';
        if (fImgPreview) {
          if (fImg.value) { fImgPreview.src = fImg.value; fImgPreview.style.display = 'block'; }
          else { fImgPreview.style.display = 'none'; fImgPreview.src = ''; }
        }
        if (fImgStatus) { fImgStatus.textContent = ''; fImgStatus.style.color = '#64748b'; }
        fDescEl.value     = getLocalizedForEdit(p.description, 'el');
        fDescEn.value     = getLocalizedForEdit(p.description, 'en');
        fSeoTitle.value   = p.seoTitle || '';
        fSeoDesc.value    = p.seoDescription || '';
        if (fGalleryNewUrl) fGalleryNewUrl.value = '';
        if (fGalleryNewFile) fGalleryNewFile.value = '';
        setGalleryStatus('', 'neutral');
        setGalleryImages(Array.isArray(p.galleryImages) ? p.galleryImages : (Array.isArray(p.gallery) ? p.gallery : []));
        renderSpecRows(Array.isArray(p.specs) ? p.specs : []);
        renderVariantRows(Array.isArray(p.variants) ? p.variants : []);
        fillDigitalFields(p);
        modal.classList.add('open');
        fNameEl.focus();
      }

      function closeModal() { modal.classList.remove('open'); }

      document.getElementById('modal-cancel').addEventListener('click', closeModal);
      modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });

      document.getElementById('modal-save').addEventListener('click', function() {
        const nameObj = readLocalizedField(fNameEl, fNameEn);
        const name = typeof nameObj === 'string' ? nameObj.trim() : (nameObj.el || nameObj.en || '').trim();
        const id   = fId.value.trim();
        if (!name || !id) {
          alert(i18nJs.nameRequired);
          return;
        }
        const galleryRaw    = galleryImages.slice();
        const specsRows     = readSpecRows();
        const variantRows   = readVariantRows();
        const digitalFields = readDigitalFields();
        const editedFields = {
          id,
          name:           nameObj,
          sku:            fSku.value.trim() || undefined,
          type:           (fType && fType.value) ? fType.value : undefined,
          price:          parseFloat(fPrice.value) || 0,
          stock:          parseInt(fStock.value, 10) || 0,
          featured:       fFeatured.checked || undefined,
          active:         fActive && !fActive.checked ? false : undefined,
          categoryId:     fCat.value || undefined,
          imageUrl:       fImg.value.trim() || undefined,
          description:    readLocalizedField(fDescEl, fDescEn) || undefined,
          seoTitle:       fSeoTitle.value.trim() || undefined,
          seoDescription: fSeoDesc.value.trim() || undefined,
          galleryImages:  galleryRaw.length  ? galleryRaw  : undefined,
          gallery:        galleryRaw.length  ? galleryRaw  : undefined,
          specs:          specsRows.length   ? specsRows   : undefined,
          variants:       variantRows.length ? variantRows : undefined,
          ...digitalFields
        };
        Object.keys(editedFields).forEach(k => editedFields[k] === undefined && delete editedFields[k]);
        if (editedFields.type === 'KIT' && !editedFields.kitPayMode && isEukolakisClassicPreset) {
          editedFields.kitPayMode = 'parts_only';
        }

        if (editingIdx === -1) {
          products.push(editedFields);
        } else {
          const base = products[editingIdx] || {};
          products[editingIdx] = { ...base, ...editedFields };
        }
        closeModal();
        renderTable();
      });

      function deleteProduct(i) {
        const p = products[i] || {};
        const pName = (p.name && typeof p.name === 'object') ? (p.name.el || p.name.en || i) : (p.name || i);
        if (!confirm(i18nJs.editPrefix.replace(': ','') + ' "' + pName + '" ;')) return;
        products.splice(i, 1);
        renderTable();
      }

      // ── Add button ──────────────────────────────────────────────
      const btnAdd = document.getElementById('btn-add-product');
      if (btnAdd) btnAdd.addEventListener('click', openAdd);
      const btnViewAll = document.getElementById('btn-view-all-products');
      const btnViewParts = document.getElementById('btn-view-parts-products');
      if (btnViewAll) btnViewAll.addEventListener('click', function() { productFilter = 'all'; renderTable(); });
      if (btnViewParts) btnViewParts.addEventListener('click', function() { productFilter = 'parts'; renderTable(); });
      if (fImgUploadBtn) fImgUploadBtn.addEventListener('click', handleModalImageUpload);
      if (fImg) fImg.addEventListener('input', function() {
        if (!fImgPreview) return;
        if (fImg.value.trim()) { fImgPreview.src = fImg.value.trim(); fImgPreview.style.display = 'block'; }
        else { fImgPreview.style.display = 'none'; fImgPreview.src = ''; }
      });
      if (fGalleryAddBtn) fGalleryAddBtn.addEventListener('click', function() {
        if (!fGalleryNewUrl) return;
        addGalleryImage(fGalleryNewUrl.value);
        fGalleryNewUrl.value = '';
      });
      if (fGalleryUploadBtn) fGalleryUploadBtn.addEventListener('click', handleGalleryImageUpload);

      async function uploadQuickPartImage(file, password) {
        const fd = new FormData();
        fd.append('partFile', file);
        fd.append('password', password || '');
        const response = await fetch('<%= withTenantLink("/admin/parts/image-upload") %>', { method: 'POST', body: fd });
        const json = await response.json();
        return { status: response.status, body: json };
      }
      async function handleQuickPartUpload() {
        const fileInput = document.getElementById('quick-part-file');
        const file = fileInput && fileInput.files && fileInput.files[0];
        if (!file) return;
        const preview = document.getElementById('quick-part-preview');
        const initial = await uploadQuickPartImage(file, '');
        let uploadUrl = '';
        if (initial.status === 401) {
          const pwField = document.getElementById('quick-part-password');
          if (pwField) pwField.style.display = 'block';
          const pw = (pwField && pwField.value) || prompt('Session έληξε. Δώσε admin password για upload:') || '';
          if (!pw) return alert('Απαιτείται password για upload εικόνας.');
          const retried = await uploadQuickPartImage(file, pw);
          if (!retried.body || !retried.body.ok) return alert((retried.body && retried.body.error) || 'Upload error');
          uploadUrl = retried.body.url || '';
        } else {
          if (!initial.body || !initial.body.ok) return alert((initial.body && initial.body.error) || 'Upload error');
          uploadUrl = initial.body.url || '';
        }
        document.getElementById('quick-part-image').value = uploadUrl;
        if (preview && uploadUrl) {
          preview.src = uploadUrl;
          preview.style.display = 'block';
        }
      }
      const quickPartFileInput = document.getElementById('quick-part-file');
      if (quickPartFileInput) quickPartFileInput.addEventListener('change', handleQuickPartUpload);
      const quickPartAddBtn = document.getElementById('btn-quick-part-add');
      if (quickPartAddBtn) quickPartAddBtn.addEventListener('click', async function() {
        const id = (document.getElementById('quick-part-id').value || '').trim();
        const name = (document.getElementById('quick-part-name').value || '').trim();
        if (!id || !name) return alert('id και όνομα είναι υποχρεωτικά');
        if (products.some(function(p){ return p.id === id; })) return alert('Υπάρχει ήδη προϊόν με αυτό το id');
        const fileInput = document.getElementById('quick-part-file');
        const file = fileInput && fileInput.files && fileInput.files[0];
        if (file && !document.getElementById('quick-part-image').value) await handleQuickPartUpload();
        const uploadedImageUrl = (document.getElementById('quick-part-image').value || '').trim();
        products.push({
          id,
          type: 'PART',
          name: { el: name, en: name },
          categoryId: 'spare-parts',
          price: parseFloat(document.getElementById('quick-part-price').value) || 0,
          stock: parseInt(document.getElementById('quick-part-stock').value, 10) || 0,
          imageUrl: uploadedImageUrl || undefined
        });
        if (pendingKitCreate && pendingKitCreate.productIdx >= 0 && pendingKitCreate.groupIdx >= 0) {
          const kp = products[pendingKitCreate.productIdx];
          const kg = kp && Array.isArray(kp.kitOptions) ? kp.kitOptions[pendingKitCreate.groupIdx] : null;
          if (kg) {
            kg.choices = Array.isArray(kg.choices) ? kg.choices : [];
            kg.choices.push({
              id: (id + '-' + Date.now()).toLowerCase(),
              linkedProductId: id,
              label: name,
              description: '',
              image: uploadedImageUrl || '',
              useLinkedPriceDelta: true,
              priceDelta: parseFloat(document.getElementById('quick-part-price').value) || 0
            });
            kitBuilderIdx = pendingKitCreate.productIdx;
            kitBuilderGroupIdx = pendingKitCreate.groupIdx;
            pendingKitCreate = null;
            openKitBuilderModal();
            renderKitBuilder();
          }
        }
        document.getElementById('quick-part-id').value = '';
        document.getElementById('quick-part-name').value = '';
        document.getElementById('quick-part-price').value = '';
        document.getElementById('quick-part-stock').value = '';
        document.getElementById('quick-part-image').value = '';
        if (fileInput) fileInput.value = '';
        const preview = document.getElementById('quick-part-preview');
        if (preview) { preview.src = ''; preview.style.display = 'none'; }
        renderTable();
      });

      let kitBuilderIdx = -1;
      let kitBuilderGroupIdx = -1;
      const kitBuilderModal = document.getElementById('kit-builder-modal');
      function openKitBuilderModal() {
        kitBuilderModal.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
      function closeKitBuilderModal() {
        kitBuilderModal.classList.remove('open');
        document.body.style.overflow = '';
      }
      function renderKitBuilder() {
        if (kitBuilderIdx < 0 || !products[kitBuilderIdx]) return;
        const product = products[kitBuilderIdx];
        product.kitOptions = Array.isArray(product.kitOptions) ? product.kitOptions : [];
        product.kitOptions.sort(function(a, b) { return (Number(a.order) || 0) - (Number(b.order) || 0); });
        document.getElementById('kit-builder-title').textContent = (product.name && (product.name.el || product.name.en)) || product.id;
        const groupList = document.getElementById('kit-groups-list');
        groupList.innerHTML = product.kitOptions.map(function(g, idx) {
          const selected = idx === kitBuilderGroupIdx ? 'background:#eef2ff;' : '';
          return '<div style="border:1px solid #e5e7eb;border-radius:6px;padding:6px;margin-bottom:6px;' + selected + '">' +
            '<strong>' + escHtml(g.label || g.id) + '</strong> <small>(' + escHtml(g.inputType || 'radio') + (g.required ? ', required' : '') + ')</small>' +
            '<div style="margin-top:4px;"><button type="button" onclick="selectKitGroup(' + idx + ')">Edit</button> <button type="button" onclick="removeKitGroup(' + idx + ')">Remove</button></div></div>';
        }).join('');
        const preview = document.getElementById('kit-builder-preview');
        preview.innerHTML = product.kitOptions.map(function(g){
          const labels = Array.isArray(g.choices) ? g.choices.map(function(c){ return escHtml(c.label || c.id); }) : [];
          return '<div style="margin:0 0 6px;padding:7px 9px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;min-width:240px;max-width:100%;word-break:break-word;">' +
            '<strong>' + escHtml(g.label || g.id) + '</strong>' +
            '<div style="margin-top:4px;display:flex;flex-wrap:wrap;gap:4px;">' +
            (labels.length ? labels.map(function(lbl){ return '<span style="display:inline-flex;padding:2px 7px;border-radius:999px;background:#e0f2fe;color:#0c4a6e;font-size:.74rem;">' + lbl + '</span>'; }).join('') : '<span style="font-size:.78rem;color:#64748b;">—</span>') +
            '</div></div>';
        }).join('') || '<em>No groups yet.</em>';
        renderKitChoices();
      }
      function renderKitChoices() {
        const product = products[kitBuilderIdx];
        const box = document.getElementById('kit-choices-list');
        if (!product || kitBuilderGroupIdx < 0 || !product.kitOptions[kitBuilderGroupIdx]) { box.innerHTML = '<em>Select group.</em>'; return; }
        const group = product.kitOptions[kitBuilderGroupIdx];
        group.choices = Array.isArray(group.choices) ? group.choices : [];
        box.innerHTML = group.choices.map(function(c, idx){
          const linked = c.linkedProductId ? products.find(function(p){ return p.id === c.linkedProductId; }) : null;
          const linkedName = linked ? ((linked.name && (linked.name.el || linked.name.en)) || linked.id) : '';
          const linkedVariants = linked && Array.isArray(linked.variants) ? linked.variants : [];
          const fixedVariantId = (c.linkedVariantId || '').trim();
          const fixedVariant = fixedVariantId ? linkedVariants.find(function(v){ return v.id === fixedVariantId; }) : null;
          const linkedPrice = fixedVariant ? (Number(fixedVariant.price) || 0).toFixed(2) : (linked ? (Number(linked.price) || 0).toFixed(2) : '0.00');
          const thumb = c.image || (fixedVariant && fixedVariant.imageUrl) || (linked && linked.imageUrl) || '';
          const variantSelect = linkedVariants.length
            ? ('<div style="margin-top:6px;"><label style="font-size:.74rem;color:#475569;display:block;">Variant (optional)</label>' +
                '<select onchange="setKitChoiceVariant(' + idx + ', this.value)" style="width:100%;max-width:240px;padding:4px;border:1px solid #cbd5e1;border-radius:6px;">' +
                '<option value="">Customer chooses</option>' +
                linkedVariants.map(function(v){
                  const vLabel = (v.label && (v.label.el || v.label.en)) || v.label || v.id;
                  return '<option value="' + escHtml(v.id) + '"' + (v.id === fixedVariantId ? ' selected' : '') + '>' + escHtml(vLabel) + ' (' + (Number(v.price) || 0).toFixed(2) + '€)</option>';
                }).join('') +
                '</select></div>')
            : '';
          return '<div style="border:1px solid #e5e7eb;border-radius:6px;padding:8px;margin-bottom:6px;background:#fff;word-break:break-word;">' +
            (thumb ? '<img src="' + escHtml(thumb) + '" style="width:44px;height:44px;object-fit:cover;border-radius:6px;vertical-align:middle;margin-right:6px;" />' : '<span style="display:inline-flex;width:44px;height:44px;border-radius:6px;background:#f1f5f9;align-items:center;justify-content:center;margin-right:6px;">🧩</span>') +
            '<strong>' + escHtml(c.label || c.id) + '</strong> <small>' + escHtml(c.linkedProductId || '') + '</small>' +
            (linked ? '<div style="font-size:.78rem;color:#334155;">' + escHtml(linkedName) + ' · ' + linkedPrice + '€</div>' : '') +
            variantSelect +
            '<div>Δ: ' + (Number(c.priceDelta)||0).toFixed(2) + '€ ' + (c.useLinkedPriceDelta ? '(linked)' : '') + '</div>' +
            '<button type="button" onclick="removeKitChoice(' + idx + ')">Remove</button></div>';
        }).join('') || '<em>No choices yet.</em>';
      }
      window.selectKitGroup = function(idx) { kitBuilderGroupIdx = idx; renderKitBuilder(); };
      window.removeKitGroup = function(idx) { products[kitBuilderIdx].kitOptions.splice(idx, 1); if (kitBuilderGroupIdx === idx) kitBuilderGroupIdx = -1; renderKitBuilder(); };
      window.removeKitChoice = function(idx) { products[kitBuilderIdx].kitOptions[kitBuilderGroupIdx].choices.splice(idx, 1); renderKitBuilder(); };
      window.setKitChoiceVariant = function(idx, value) {
        const product = products[kitBuilderIdx];
        const group = product && product.kitOptions && product.kitOptions[kitBuilderGroupIdx];
        if (!group || !group.choices || !group.choices[idx]) return;
        group.choices[idx].linkedVariantId = (value || '').trim();
        renderKitBuilder();
      };
      window.openKitBuilder = function(i) {
        if (!products[i] || products[i].type !== 'KIT') return;
        kitBuilderIdx = i;
        kitBuilderGroupIdx = -1;
        openKitBuilderModal();
        renderKitBuilder();
      };
      window.makeProductKit = function(i) {
        const existing = products[i];
        if (!existing) return;
        const next = { ...existing, type: 'KIT', price: 0 };
        if (!next.kitOptions) next.kitOptions = [];
        if (!next.kitPayMode && isEukolakisClassicPreset) next.kitPayMode = 'parts_only';
        products[i] = next;
        renderTable();
      };
      function suggestGroupTypeById(groupId) {
        const normalized = String(groupId || '').toLowerCase();
        if (!isEukolakisClassicPreset) return 'radio';
        if (normalized.includes('spare') || normalized.includes('part') || normalized.includes('tool') || normalized.includes('ανταλλακ')) return 'checkbox';
        return 'radio';
      }
      const kgIdInput = document.getElementById('kg-id');
      const kgTypeInput = document.getElementById('kg-type');
      if (kgIdInput && kgTypeInput) {
        kgIdInput.addEventListener('input', function() {
          kgTypeInput.value = suggestGroupTypeById(kgIdInput.value);
        });
      }
      const kgAddBtn = document.getElementById('kg-add');
      if (kgAddBtn) kgAddBtn.addEventListener('click', function() {
        const product = products[kitBuilderIdx];
        if (!product) return;
        const gid = (document.getElementById('kg-id').value || '').trim();
        if (!gid) return alert('Group id required');
        product.kitOptions = Array.isArray(product.kitOptions) ? product.kitOptions : [];
        product.kitOptions.push({
          id: gid,
          label: (document.getElementById('kg-label').value || gid).trim(),
          required: document.getElementById('kg-required').checked,
          inputType: (document.getElementById('kg-type').value === 'checkbox' ? 'checkbox' : suggestGroupTypeById(gid)),
          order: parseInt(document.getElementById('kg-order').value, 10) || 0,
          choices: document.getElementById('kg-required').checked ? [] : [{
            id: 'skip',
            label: 'Δεν το χρειάζομαι / Το έχω ήδη',
            description: '',
            image: '',
            linkedProductId: '',
            priceDelta: 0
          }]
        });
        kitBuilderGroupIdx = product.kitOptions.length - 1;
        renderKitBuilder();
      });
      document.getElementById('kit-builder-close').addEventListener('click', function() { closeKitBuilderModal(); renderTable(); });
      kitBuilderModal.addEventListener('click', function(e) { if (e.target === kitBuilderModal) closeKitBuilderModal(); });
      document.getElementById('kit-choice-search-btn').addEventListener('click', async function() {
        if (kitBuilderIdx < 0 || kitBuilderGroupIdx < 0) return alert('Select group first');
        const q = (document.getElementById('kit-choice-search-q').value || '').trim();
        const url = '<%= withTenantLink("/admin/products/search") %>?q=' + encodeURIComponent(q);
        const r = await fetch(url);
        const items = await r.json();
        const box = document.getElementById('kit-choice-search-results');
        box.innerHTML = items.map(function(item, idx) {
          const variantRows = Array.isArray(item.variants) && item.variants.length
            ? ('<div style="margin-top:4px;padding-top:4px;border-top:1px dashed #cbd5e1;">' + item.variants.map(function(v, vIdx){
                return '<div style="display:flex;gap:6px;align-items:center;margin-top:4px;">' +
                  (v.imageUrl ? '<img src="' + escHtml(v.imageUrl) + '" style="width:28px;height:28px;object-fit:cover;border-radius:6px;" />' : '<span style="display:inline-flex;width:28px;height:28px;background:#e2e8f0;border-radius:6px;"></span>') +
                  '<small style="flex:1;">' + escHtml(v.label || v.id) + ' · ' + (Number(v.price) || 0).toFixed(2) + '€</small>' +
                  '<button type="button" onclick="addLinkedVariantChoice(' + idx + ',' + vIdx + ')">Use variant</button></div>';
              }).join('') + '</div>')
            : '';
          return '<div style="display:flex;gap:6px;align-items:center;padding:4px 0;border-bottom:1px solid #e5e7eb;">' +
            (item.imageUrl ? '<img src="' + escHtml(item.imageUrl) + '" style="width:40px;height:40px;object-fit:cover;border-radius:6px;" />' : '') +
            '<div style="flex:1;"><strong>' + escHtml(item.name) + '</strong><br><small>' + escHtml(item.id) + ' · ' + item.price.toFixed(2) + '€ · stock ' + item.stock + '</small>' + variantRows + '</div>' +
            '<button type="button" onclick="addLinkedChoice(' + idx + ')">Use base</button></div>';
        }).join('');
        window.__kitSearchItems = items;
      });
      const createPartBtn = document.getElementById('kit-create-part-btn');
      if (createPartBtn) createPartBtn.addEventListener('click', function() {
        const q = (document.getElementById('kit-choice-search-q').value || '').trim();
        pendingKitCreate = { productIdx: kitBuilderIdx, groupIdx: kitBuilderGroupIdx };
        window.location.hash = '#tab-products';
        const quickName = document.getElementById('quick-part-name');
        const quickId = document.getElementById('quick-part-id');
        const quickPrice = document.getElementById('quick-part-price');
        if (quickName) quickName.value = q;
        if (quickId && q) quickId.value = q.toLowerCase().replace(/[^a-z0-9\u0370-\u03ff]+/g, '-').replace(/^-+|-+$/g, '');
        if (quickPrice) quickPrice.value = '';
        const details = document.querySelector('#tab-products details');
        if (details) details.open = true;
      });
      window.addLinkedChoice = function(idx) {
        const item = (window.__kitSearchItems || [])[idx];
        if (!item) return;
        const product = products[kitBuilderIdx];
        const group = product && product.kitOptions && product.kitOptions[kitBuilderGroupIdx];
        if (!group) return;
        group.choices = Array.isArray(group.choices) ? group.choices : [];
        const cId = (item.id + '-' + Date.now()).toLowerCase();
        const useLinkedPriceDelta = confirm('Use linked product price as delta?');
        const customLabel = prompt('Choice label override (optional):', item.name || '') || '';
        const customDesc = prompt('Choice description override (optional):', '') || '';
        const customDelta = prompt('priceDelta (leave empty to auto/default):', useLinkedPriceDelta ? String(item.price) : '0');
        group.choices.push({
          id: cId,
          linkedProductId: item.id,
          linkedVariantId: '',
          label: customLabel.trim(),
          description: customDesc.trim(),
          image: item.imageUrl || '',
          useLinkedPriceDelta,
          priceDelta: customDelta === '' ? (useLinkedPriceDelta ? item.price : 0) : (parseFloat(customDelta) || 0)
        });
        renderKitBuilder();
      };
      window.addLinkedVariantChoice = function(idx, variantIdx) {
        const item = (window.__kitSearchItems || [])[idx];
        const variant = item && Array.isArray(item.variants) ? item.variants[variantIdx] : null;
        if (!item || !variant) return;
        const product = products[kitBuilderIdx];
        const group = product && product.kitOptions && product.kitOptions[kitBuilderGroupIdx];
        if (!group) return;
        group.choices = Array.isArray(group.choices) ? group.choices : [];
        const cId = (item.id + '-' + variant.id + '-' + Date.now()).toLowerCase();
        group.choices.push({
          id: cId,
          linkedProductId: item.id,
          linkedVariantId: variant.id,
          label: (item.name || item.id) + ' - ' + (variant.label || variant.id),
          description: '',
          image: variant.imageUrl || item.imageUrl || '',
          useLinkedPriceDelta: true,
          priceDelta: Number(variant.price) || 0
        });
        renderKitBuilder();
      };

      // ── Serialize before submit ─────────────────────────────────
      const saveForm = document.getElementById('products-save-form');
      if (saveForm) {
        saveForm.addEventListener('submit', function() {
          document.getElementById('products-json-input').value = JSON.stringify(products);
        });
      }

      // ── Initial render ──────────────────────────────────────────
      renderTable();


      // ── Image upload ────────────────────────────────────────────
      const uploadForm   = document.getElementById('upload-form');
      const uploadResult = document.getElementById('upload-result');

      if (uploadForm) {
        uploadForm.addEventListener('submit', async function(e) {
          e.preventDefault();
          uploadResult.textContent = i18nJs.uploading;
          const formData = new FormData(uploadForm);
          const response = await fetch('<%= withTenantLink("/admin/upload-image") %>', { method: 'POST', body: formData });
          const json = await response.json();
          if (json.ok) {
            uploadResult.innerHTML = i18nJs.uploadOk + '<code>' + json.url + '</code>';
          } else {
            uploadResult.textContent = json.error || i18nJs.uploadErr;
          }
        });
      }

      const homepageBannerFile = document.getElementById('homepage-banner-file');
      const homepageBannerBtn = document.getElementById('homepage-banner-upload-btn');
      const homepageBannerStatus = document.getElementById('homepage-banner-status');
      const homepageHeroInput = document.getElementById('homepageHeroImage');
      const homepageHeroPreview = document.getElementById('homepage-hero-preview');
      if (homepageBannerBtn) {
        homepageBannerBtn.addEventListener('click', async function() {
          const file = homepageBannerFile && homepageBannerFile.files && homepageBannerFile.files[0];
          if (!file) return alert('<%= lang === "el" ? "Επίλεξε πρώτα αρχείο εικόνας για το banner." : "Select a banner image first." %>');
          if (homepageBannerStatus) homepageBannerStatus.textContent = '<%= lang === "el" ? "Γίνεται ανέβασμα..." : "Uploading..." %>';
          const fd = new FormData();
          fd.append('bannerFile', file);
          const inlinePw = (document.querySelector('#tab-homepage input[name=\"password\"]') || { value: '' }).value || '';
          const pw = inlinePw || prompt('<%= lang === "el" ? "Κωδικός admin για ανέβασμα banner:" : "Admin password for banner upload:" %>') || '';
          fd.append('password', pw);
          const r = await fetch('<%= withTenantLink("/admin/homepage/banner-upload") %>', { method: 'POST', body: fd });
          const j = await r.json();
          if (!j.ok) {
            if (homepageBannerStatus) homepageBannerStatus.textContent = j.error || '<%= lang === "el" ? "Σφάλμα ανεβάσματος." : "Upload failed." %>';
            alert(j.error || '<%= lang === "el" ? "Σφάλμα ανεβάσματος." : "Upload failed." %>');
            return;
          }
          if (homepageHeroInput) homepageHeroInput.value = j.url || '';
          if (homepageHeroPreview && j.url) {
            homepageHeroPreview.src = j.url;
            homepageHeroPreview.style.display = 'block';
          }
          if (homepageBannerStatus) homepageBannerStatus.textContent = '<%= lang === "el" ? "✓ Ανέβηκε επιτυχώς" : "✓ Uploaded" %>';
        });
      }

      async function uploadCategoryImage(categoryId, input) {
        const file = input.files && input.files[0];
        if (!file) return;
        const statusEl = document.getElementById('cat-upload-status');
        const pwEl = document.getElementById('category-reauth-password');
        const fd = new FormData();
        fd.append('categoryId', categoryId);
        fd.append('image', file);
        fd.append('password', (pwEl && pwEl.value) || '');
        if (statusEl) {
          statusEl.style.display = 'block';
          statusEl.textContent = 'Γίνεται upload εικόνας κατηγορίας...';
        }
        const r = await fetch('<%= withTenantLink("/admin/categories/image-upload") %>', { method: 'POST', body: fd });
        const j = await r.json();
        if (!j.ok) {
          if (statusEl) statusEl.textContent = j.error || 'Σφάλμα upload';
          alert(j.error || 'Σφάλμα upload');
          return;
        }
        if (statusEl) statusEl.textContent = 'Η εικόνα κατηγορίας αποθηκεύτηκε.';
        window.location.reload();
      }

      async function removeCategoryImage(categoryId) {
        if (!confirm('Να αφαιρεθεί η εικόνα κατηγορίας;')) return;
        const statusEl = document.getElementById('cat-upload-status');
        const pwEl = document.getElementById('category-reauth-password');
        const body = new URLSearchParams();
        body.set('categoryId', categoryId);
        body.set('password', (pwEl && pwEl.value) || '');
        if (statusEl) {
          statusEl.style.display = 'block';
          statusEl.textContent = 'Αφαιρείται η εικόνα κατηγορίας...';
        }
        const r = await fetch('<%= withTenantLink("/admin/categories/image-remove") %>', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: body.toString() });
        const j = await r.json();
        if (!j.ok) {
          if (statusEl) statusEl.textContent = j.error || 'Σφάλμα διαγραφής';
          alert(j.error || 'Σφάλμα διαγραφής');
          return;
        }
        if (statusEl) statusEl.textContent = 'Η εικόνα κατηγορίας αφαιρέθηκε.';
        window.location.reload();
      }

      // ── Color pickers ─────────────────────────────────────────────
      function bindColorPair(textId, pickerId) {
        const txt  = document.getElementById(textId);
        const pick = document.getElementById(pickerId);
        if (!txt || !pick) return;
        pick.addEventListener('input', () => { txt.value = pick.value; });
        txt.addEventListener('input', () => {
          if (/^#[0-9a-f]{6}$/i.test(txt.value)) pick.value = txt.value;
        });
      }
      bindColorPair('txt-primaryColor',       'cp-primaryColor');
      bindColorPair('txt-accentColor',        'cp-accentColor');
      bindColorPair('txt-themeMenuBg',        'cp-themeMenuBg');
      bindColorPair('txt-themeMenuText',      'cp-themeMenuText');
      bindColorPair('txt-themeMenuActiveBg',  'cp-themeMenuActiveBg');
      bindColorPair('txt-themeMenuActiveText','cp-themeMenuActiveText');
      const adminActionTimeoutMs = Number(<%- JSON.stringify(Number(adminActionTimeoutMs || 0)) %>) || (30 * 60 * 1000);
      let reauthDeadlineTs = Date.now() + (Number(<%- JSON.stringify(Number(adminReauthRemainingMs || 0)) %>) || 0);
      document.querySelectorAll('form.js-settings-save-form').forEach((formEl) => {
        formEl.addEventListener('submit', function(ev) {
          const passInput = formEl.querySelector('input[name="password"]');
          const hasTypedPassword = !!(passInput && String(passInput.value || '').trim());
          if (hasTypedPassword) {
            reauthDeadlineTs = Date.now() + adminActionTimeoutMs;
            return;
          }
          if (Date.now() <= reauthDeadlineTs) return;
          ev.preventDefault();
          const pw = prompt('Έληξε το admin save session (30 λεπτά). Βάλε ξανά κωδικό για αποθήκευση:');
          if (!pw) return alert('Δεν έγινε αποθήκευση χωρίς επαναπιστοποίηση.');
          if (passInput) passInput.value = pw;
          reauthDeadlineTs = Date.now() + adminActionTimeoutMs;
          formEl.submit();
        });
      });
      function showSectionFromHash() {
        const hash = window.location.hash || '#tab-dashboard';
        document.querySelectorAll('.section-panel').forEach((el) => el.classList.remove('active'));
        const activePanel = document.querySelector(hash);
        if (activePanel) activePanel.classList.add('active');
        document.querySelectorAll('.admin-sidebar a').forEach((a) => {
          const href = a.getAttribute('href') || '';
          a.classList.toggle('active', href === hash);
        });
      }
      window.addEventListener('hashchange', showSectionFromHash);
      showSectionFromHash();
      document.querySelectorAll('.admin-sidebar a[href^="#"]').forEach((a) => {
        a.addEventListener('click', () => {
          if (window.innerWidth <= 900) document.querySelector('.admin-shell').classList.remove('show-sidebar');
        });
      });

      // ── Logo upload (fills logoPath-input on success) ─────────────
      const logoUploadBtn    = document.getElementById('logo-upload-btn');
      const logoUploadStatus = document.getElementById('logo-upload-status');
      if (logoUploadBtn) {
        logoUploadBtn.addEventListener('click', async () => {
          const file = document.getElementById('logo-file').files[0];
          const pass = document.getElementById('logo-pass').value;
          if (!file) { logoUploadStatus.textContent = i18nJs.selectFile; return; }
          if (!pass) { logoUploadStatus.textContent = i18nJs.enterPass; return; }
          logoUploadStatus.textContent = i18nJs.uploading;
          const fd = new FormData();
          fd.append('image', file);
          fd.append('password', pass);
          const r = await fetch('<%= withTenantLink("/admin/upload-image") %>', { method: 'POST', body: fd });
          const j = await parseJsonSafe(r);
          if (j.ok) {
            document.getElementById('logoPath-input').value = j.url;
            const logoBgModeSelect = document.getElementById('themeLogoBgMode');
            const logoMaxHeightInput = document.getElementById('themeLogoMaxHeight');
            const activeThemeKey = '<%= (config.theme && config.theme.presetId) || "" %>';
            if (logoBgModeSelect && activeThemeKey !== 'eukolakis_classic_diy' && (logoBgModeSelect.value === 'auto' || !logoBgModeSelect.value)) {
              logoBgModeSelect.value = 'light_badge';
            }
            if (logoMaxHeightInput && activeThemeKey !== 'eukolakis_classic_diy') {
              const current = Number(logoMaxHeightInput.value) || 0;
              if (current < 88) logoMaxHeightInput.value = '88';
            }
            logoUploadStatus.innerHTML = i18nJs.logoOk + '<code>' + j.url + '</code>';
          } else {
            logoUploadStatus.textContent = j.error || i18nJs.uploadErr;
          }
        });
      }

      const cursorUploadBtn = document.getElementById('cursor-upload-btn');
      if (cursorUploadBtn) {
        cursorUploadBtn.addEventListener('click', async () => {
          const fileEl = document.getElementById('cursor-file');
          const file = fileEl && fileEl.files && fileEl.files[0];
          const statusEl = document.getElementById('cursor-upload-status');
          const urlInput = document.getElementById('themeCursorImage-input');
          const previewEl = document.getElementById('cursor-preview');
          const passEl = document.querySelector('#tab-theme input[name="password"]');
          if (!file) { if (statusEl) statusEl.textContent = 'Επίλεξε αρχείο εικόνας.'; return; }
          if (statusEl) statusEl.textContent = 'Ανέβασμα cursor...';
          const fd = new FormData();
          fd.append('cursorFile', file);
          fd.append('password', (passEl && passEl.value) || '');
          const r = await fetch('<%= withTenantLink("/admin/theme/cursor-upload") %>', { method: 'POST', body: fd });
          const j = await r.json();
          if (!j.ok) {
            if (statusEl) statusEl.textContent = j.error || 'Upload error';
            return;
          }
          if (urlInput) urlInput.value = j.url;
          if (previewEl) { previewEl.src = j.url; previewEl.style.display = 'inline-block'; }
          if (statusEl) statusEl.textContent = '✓ Ανέβηκε: ' + j.url;
        });
      }
      const cursorPreviewBtn = document.getElementById('cursor-preview-btn');
      if (cursorPreviewBtn) {
        cursorPreviewBtn.addEventListener('click', () => {
          const urlInput = document.getElementById('themeCursorImage-input');
          const url = (urlInput && urlInput.value || '').trim();
          if (!url || !/^\//.test(url)) return alert('Cursor preview requires a root-relative URL (starts with /).');
          const cursorRule = 'url("' + url.replace(/"/g, '\\"') + '") 16 16, auto';
          document.documentElement.style.cursor = cursorRule;
          document.body.style.cursor = cursorRule;
          document.querySelectorAll('a,button,input,textarea,select,label,.button,.btn-xs').forEach((el) => { el.style.cursor = cursorRule; });
          setTimeout(() => {
            document.documentElement.style.cursor = '';
            document.body.style.cursor = '';
            document.querySelectorAll('a,button,input,textarea,select,label,.button,.btn-xs').forEach((el) => { el.style.cursor = ''; });
          }, 2500);
        });
      }

      (function initHomepageBlockBuilder() {
        const builder = document.getElementById('homepage-block-builder');
        const input = document.getElementById('homepageBlockOrderInput');
        if (!builder || !input) return;
        const normalizeAndSync = () => {
          const keys = Array.from(builder.querySelectorAll('.hb-row'))
            .map((row) => String(row.getAttribute('data-key') || '').trim())
            .filter(Boolean);
          input.value = keys.join(',');
        };
        const currentOrder = String(input.value || '')
          .split(',')
          .map((v) => v.trim().toLowerCase())
          .filter(Boolean);
        if (currentOrder.length) {
          const rowMap = {};
          builder.querySelectorAll('.hb-row').forEach((row) => { rowMap[String(row.getAttribute('data-key') || '').toLowerCase()] = row; });
          currentOrder.forEach((key) => {
            if (rowMap[key]) builder.appendChild(rowMap[key]);
          });
        }
        builder.addEventListener('click', (e) => {
          const row = e.target.closest('.hb-row');
          if (!row) return;
          if (e.target.classList.contains('hb-up')) {
            const prev = row.previousElementSibling;
            if (prev) builder.insertBefore(row, prev);
            normalizeAndSync();
          }
          if (e.target.classList.contains('hb-down')) {
            const next = row.nextElementSibling;
            if (next) builder.insertBefore(next, row);
            normalizeAndSync();
          }
        });
        normalizeAndSync();
      })();

      // ── Favicon delete (prompt for password inline) ──
      function deleteFavicon(btn) {
        const pw = prompt('Root admin κωδικός για διαγραφή favicon:');
        if (!pw) return;
        const form = btn.closest('form');
        form.querySelector('#fav-del-pw').value = pw;
        form.submit();
      }
    </script>
  </body>
</html>
