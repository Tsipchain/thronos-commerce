<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Tenant not found</title>
    <style>
      body { font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; margin: 0; background:#f8fafc; color:#0f172a; }
      .wrap { max-width: 760px; margin: 6vh auto; background: #fff; border:1px solid #e2e8f0; border-radius: 12px; padding: 24px; box-shadow: 0 8px 28px rgba(15,23,42,.06); }
      h1 { margin: 0 0 10px; font-size: 1.35rem; }
      p { margin: 8px 0; line-height: 1.45; }
      code { background:#f1f5f9; border:1px solid #e2e8f0; border-radius:6px; padding:2px 6px; }
      a { color:#0f766e; }
    </style>
  </head>
  <body>
    <main class="wrap">
      <h1>Tenant domain not recognized</h1>
      <p>The host <code><%= host || 'unknown' %></code> is not mapped to an active tenant storefront.</p>
      <p>If this is your custom domain, please check DNS / SSL status in Root Admin tenant settings.</p>
      <p>Need help? Contact <a href="mailto:<%= supportEmail %>"><%= supportEmail %></a>.</p>
    </main>
  </body>
</html>
