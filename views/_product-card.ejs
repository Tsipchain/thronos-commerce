<% const isEukolakisTenant = (typeof tenantId !== 'undefined' && tenantId === 'eukolakis'); %>
<% const productSkuValue = String(product.sku || '').trim().toLowerCase(); %>
<% const productTagsValue = Array.isArray(product.tags) ? product.tags.map(function(tag){ return String(tag || '').trim().toLowerCase(); }).filter(Boolean).join(',') : ''; %>
<article class="product-card hover-<%= (config && config.theme && config.theme.productCardHoverEffect) || 'lift' %> <%= config && config.theme && config.theme.cardStyle === 'bold' ? 'bold' : '' %> <%= isEukolakisTenant && product.type === 'KIT' ? 'kit-clickable' : '' %>" data-product-id="<%= product.id %>" data-product-price="<%= Number(product.price) || 0 %>" data-product-sku="<%= productSkuValue %>" data-product-tags="<%= productTagsValue %>" <%= isEukolakisTenant && product.type === 'KIT' ? 'data-kit-product-id="' + product.id + '"' : '' %> <%= product.type !== 'KIT' ? ('data-product-open-url=\"' + withTenantLink('/product/' + product.id, lang !== 'el' ? { lang } : {}) + '\"') : '' %>>
  <% if (product.imageUrl) { %>
    <div class="product-thumb">
      <img src="<%= product.imageUrl %>" alt="<%= product.name %>" loading="lazy" />
      <% if (product.featured) { %><span class="featured-badge">⭐ <%= t('storefront.featured') %></span><% } %>
    </div>
  <% } else if (product.featured) { %>
    <div class="product-thumb placeholder" style="background:#fffbeb;min-height:60px;">
      <span class="featured-badge" style="position:relative;top:0;left:0;display:inline-block;margin:10px;">⭐ <%= t('storefront.featured') %></span>
    </div>
  <% } else { %>
    <div class="product-thumb placeholder" aria-hidden="true"><span style="font-size:22px;">🖼️</span></div>
  <% } %>
  <div class="product-card-body">
    <h2><%= product.name %></h2>
    <% if (product.type === 'KIT') { %>
      <p style="margin:0 0 8px;font-size:.72rem;font-weight:700;letter-spacing:.04em;color:#0f766e;">DIY KIT CONFIGURATOR</p>
    <% } %>
    <% if (product.description) { %><p><%= product.description %></p><% } %>
    <p class="price">
      <%= Number(product.price).toFixed(2) %> €
      <% if (product.stock !== undefined) { %>
        <% if (product.stock === 0) { %>
          <span class="stock-pill out"><%= t('checkout.stockOut') %></span>
        <% } else if (product.stock < 3) { %>
          <span class="stock-pill low"><%= t('checkout.stockLow') %> (<%= product.stock %>)</span>
        <% } else { %>
          <span class="stock-pill ok"><%= t('checkout.inStock') %></span>
        <% } %>
      <% } %>
    </p>
    <% const deliveryEstimateLabel = product.deliveryEstimate || (Number(product.stock) === 0 ? (lang === 'el' ? 'Παράδοση 4-7 ημέρες' : 'Delivery in 4-7 days') : (lang === 'el' ? 'Παράδοση 1-3 ημέρες' : 'Delivery in 1-3 days')); %>
    <p style="margin:0 0 10px;font-size:.76rem;color:#64748b;">🚚 <%= deliveryEstimateLabel %></p>
    <div class="card-actions">
      <% if (isEukolakisTenant && product.type === 'KIT') { %>
        <a class="btn-cart" href="#" data-kit-launch="<%= product.id %>" style="text-decoration:none;display:inline-block;"><%= lang === 'el' ? 'Ξεκίνα Roll Kit' : 'Start Roll Kit' %></a>
      <% } else if (product.type === 'KIT') { %>
        <a class="button" data-exposure-link href="<%= withTenantLink('/product/' + product.id, lang !== 'el' ? { lang } : {}) %>"><%= t('storefront.viewProduct') %></a>
        <a class="btn-cart" href="<%= withTenantLink('/product/' + product.id, lang !== 'el' ? { lang } : {}) %>" data-kit-launch="<%= product.id %>" style="text-decoration:none;display:inline-block;"><%= lang === 'el' ? 'Διαμόρφωση Kit' : 'Configure Kit' %></a>
      <% } else if (product.stock !== 0) { %>
        <a class="button" data-exposure-link href="<%= withTenantLink('/product/' + product.id, lang !== 'el' ? { lang } : {}) %>"><%= t('storefront.viewProduct') %></a>
        <button class="btn-cart" type="button"
          onclick="window.thrcAddToCart && window.thrcAddToCart({id:'<%= product.id %>',name:'<%= product.name.replace(/'/g,"\\'") %>',price:<%= Number(product.price) || 0 %>,imageUrl:'<%= (product.imageUrl||'').replace(/'/g,"\\'") %>'})">
          <%= t('storefront.addToCart') %>
        </button>
      <% } else { %>
        <a class="button" data-exposure-link href="<%= withTenantLink('/product/' + product.id, lang !== 'el' ? { lang } : {}) %>"><%= t('storefront.viewProduct') %></a>
        <button class="btn-cart" type="button" disabled><%= t('checkout.stockOut') %></button>
      <% } %>
    </div>
  </div>
</article>
